constexpr compare_three_way_result_t<I1, I2>
operator<=>(const reverse_iterator<I1>& x, const reverse_iterator<I2>& y) {
    return y.base() <=> x.base();
}

template<class I1, class I2>
[[nodiscard]] constexpr auto
operator-(const reverse_iterator<I1>& x, const reverse_iterator<I2>& y)
    -> decltype(y.base() - x.base()) {
    return y.base() - x.base();
}

