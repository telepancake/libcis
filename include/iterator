// [counted.iter] — counted_iterator
//===----------------------------------------------------------------------===//

namespace detail {
    template<class Iter, class = void>
    struct counted_iter_concept {};
    template<class Iter>
        requires requires { typename Iter::iterator_concept; }
    struct counted_iter_concept<Iter> {
        using iterator_concept = typename Iter::iterator_concept;
    };

    template<class Iter, class = void>
    struct counted_iter_category {};
    template<class Iter>
        requires requires { typename Iter::iterator_category; }
    struct counted_iter_category<Iter> {
        using iterator_category = typename Iter::iterator_category;
    };

    template<class Iter, class = void>
    struct counted_iter_value_type {};
    template<indirectly_readable Iter>
    struct counted_iter_value_type<Iter> {
        using value_type = iter_value_t<Iter>;
    };
} // namespace detail

template<input_or_output_iterator Iter>
class counted_iterator
    : public detail::counted_iter_concept<Iter>,
      public detail::counted_iter_category<Iter>,
      public detail::counted_iter_value_type<Iter> {
public:
    using iterator_type   = Iter;
    using difference_type = iter_difference_t<Iter>;

    constexpr counted_iterator()
        requires default_initializable<Iter>
    = default;

    constexpr counted_iterator(Iter it, iter_difference_t<Iter> n)
        : current_(move(it)), count_(n) {}

    template<class I2>
        requires convertible_to<const I2&, Iter>
    constexpr counted_iterator(const counted_iterator<I2>& other)
        : current_(other.current_), count_(other.count_) {}

    template<class I2>
        requires assignable_from<Iter&, const I2&>
    constexpr counted_iterator& operator=(const counted_iterator<I2>& other) {
        current_ = other.current_;
        count_   = other.count_;
        return *this;
    }

    [[nodiscard]] constexpr const Iter& base() const& noexcept { return current_; }
    [[nodiscard]] constexpr Iter        base() &&            { return move(current_); }
    [[nodiscard]] constexpr iter_difference_t<Iter> count() const noexcept { return count_; }

    [[nodiscard]] constexpr decltype(auto) operator*() {
        return *current_;
    }
    [[nodiscard]] constexpr decltype(auto) operator*() const
        requires detail::dereferenceable<const Iter>
    {
        return *current_;
    }

    constexpr auto operator->() const noexcept
        requires contiguous_iterator<Iter>
    {
        return to_address(current_);
    }

    constexpr counted_iterator& operator++() {
        ++current_;
        --count_;
        return *this;
    }
    constexpr decltype(auto) operator++(int) {
        --count_;
        return current_++;
    }
    constexpr counted_iterator operator++(int)
        requires forward_iterator<Iter>
    {
        counted_iterator tmp = *this;
        ++*this;
        return tmp;
    }

    constexpr counted_iterator& operator--()
        requires bidirectional_iterator<Iter>
    {
        --current_;
        ++count_;
        return *this;
    }
    constexpr counted_iterator operator--(int)
        requires bidirectional_iterator<Iter>
    {
        counted_iterator tmp = *this;
        --*this;
        return tmp;
    }

    [[nodiscard]] constexpr counted_iterator operator+(difference_type n) const
        requires random_access_iterator<Iter>
    {
        return counted_iterator(current_ + n, count_ - n);
    }
    [[nodiscard]] friend constexpr counted_iterator
    operator+(difference_type n, const counted_iterator& x)
        requires random_access_iterator<Iter>
    {
        return x + n;
    }
    constexpr counted_iterator& operator+=(difference_type n)
        requires random_access_iterator<Iter>
    {
        current_ += n;
        count_   -= n;
        return *this;
    }
    [[nodiscard]] constexpr counted_iterator operator-(difference_type n) const
        requires random_access_iterator<Iter>
    {
        return counted_iterator(current_ - n, count_ + n);
    }
    constexpr counted_iterator& operator-=(difference_type n)
        requires random_access_iterator<Iter>
    {
        current_ -= n;
        count_   += n;
        return *this;
    }
    [[nodiscard]] constexpr decltype(auto) operator[](difference_type n) const
        requires random_access_iterator<Iter>
    {
        return current_[n];
    }

    template<common_with<Iter> I2>
    [[nodiscard]] friend constexpr iter_difference_t<I2>
    operator-(const counted_iterator& lhs, const counted_iterator<I2>& rhs) {
        // note: rhs.count() (public) -- gcc-10 does not let a hidden friend of
        // counted_iterator<Iter> see counted_iterator<I2>'s privates
        return rhs.count() - lhs.count_;
    }
    [[nodiscard]] friend constexpr difference_type
    operator-(const counted_iterator& lhs, default_sentinel_t) {
        return -lhs.count_;
    }
    [[nodiscard]] friend constexpr difference_type
    operator-(default_sentinel_t, const counted_iterator& rhs) {
        return rhs.count_;
    }

    template<common_with<Iter> I2>
    friend constexpr bool
    operator==(const counted_iterator& lhs, const counted_iterator<I2>& rhs) {
        return lhs.count_ == rhs.count();
    }
    friend constexpr bool
    operator==(const counted_iterator& lhs, default_sentinel_t) {
        return lhs.count_ == 0;
    }

    template<common_with<Iter> I2>
    friend constexpr strong_ordering
    operator<=>(const counted_iterator& lhs, const counted_iterator<I2>& rhs) {
        return rhs.count() <=> lhs.count_;
    }

    // gcc-10: a hidden friend with a trailing requires-clause is not found by
    // ADL inside dependent requires-expressions; use an enable_if template
    // parameter instead.
    template<class I2 = Iter, enable_if_t<input_iterator<I2>, int> = 0>
    [[nodiscard]] friend constexpr decltype(auto)
    iter_move(const counted_iterator& i)
        noexcept(noexcept(ranges::iter_move(i.current_)))
    {
        return ranges::iter_move(i.current_);
    }

    template<indirectly_swappable<Iter> I2>
    friend constexpr void
    iter_swap(const counted_iterator& x,
              const counted_iterator<I2>& y)
        noexcept(noexcept(ranges::iter_swap(x.current_, y.current_)))
    {
        ranges::iter_swap(x.current_, y.current_);
    }

private:
    Iter current_ = Iter();
    difference_type count_ = 0;

    template<input_or_output_iterator OtherIter>
    friend class counted_iterator;
};

// iterator_traits specialisation for counted_iterator<Iter>: only when
// iterator_traits<Iter> is itself a specialisation (matches libc++'s
// same_as<_ITER_TRAITS<_Iter>, iterator_traits<_Iter>> constraint)
template<input_iterator Iter>
    requires same_as<detail::iter_traits_t<Iter>, iterator_traits<Iter>>
struct iterator_traits<counted_iterator<Iter>> : iterator_traits<Iter> {
    using pointer = conditional_t<contiguous_iterator<Iter>,
                                  add_pointer_t<iter_reference_t<Iter>>,
                                  void>;
};

//===----------------------------------------------------------------------===//
// [common.iter] — common_iterator
// Ported from libc++ __iterator/common_iterator.h.  Uses std::variant.
// <variant> is included here (mid-file, outside namespace std) rather than at
// the top: <variant> pulls in <functional>, which needs iterator_traits.
//===----------------------------------------------------------------------===//

} // namespace std
#include <variant>
namespace std {

namespace detail {
    template<class Iter>
    concept can_use_postfix_proxy =
        constructible_from<iter_value_t<Iter>, iter_reference_t<Iter>> &&
        move_constructible<iter_value_t<Iter>>;

    // gcc-10: hidden friends of common_iterator<A> are not granted access to
    // the privates of a different specialisation common_iterator<B> by the
    // template friend class declaration; route the access through this
    // accessor, which every specialisation befriends.
    struct common_iterator_access {
        template<class CI>
        static constexpr auto& hold(CI& c) noexcept { return c.hold_; }
        template<class CI>
        static constexpr const auto& hold(const CI& c) noexcept { return c.hold_; }
    };
} // namespace detail

template<input_or_output_iterator Iter, sentinel_for<Iter> Sent>
    requires(!same_as<Iter, Sent> && copyable<Iter>)
class common_iterator {
    struct proxy {
        constexpr const iter_value_t<Iter>* operator->() const noexcept {
            return std::addressof(value_);
        }
        iter_value_t<Iter> value_;
    };

    struct postfix_proxy {
        constexpr const iter_value_t<Iter>& operator*() const noexcept {
            return value_;
        }
        iter_value_t<Iter> value_;
    };

    // index 0 = iterator, index 1 = sentinel
    variant<Iter, Sent> hold_;

    template<input_or_output_iterator OI, sentinel_for<OI> OS>
        requires(!same_as<OI, OS> && copyable<OI>)
    friend class common_iterator;

    friend struct detail::common_iterator_access;

public:
    common_iterator()
        requires default_initializable<Iter>
    = default;

    constexpr common_iterator(Iter i) : hold_(in_place_type<Iter>, std::move(i)) {}
    constexpr common_iterator(Sent s) : hold_(in_place_type<Sent>, std::move(s)) {}

    template<class I2, class S2>
        requires convertible_to<const I2&, Iter> && convertible_to<const S2&, Sent>
    constexpr common_iterator(const common_iterator<I2, S2>& other)
        : hold_([&]() -> variant<Iter, Sent> {
              if (other.hold_.index() == 0)
                  return variant<Iter, Sent>{in_place_index<0>, std::get<0>(other.hold_)};
              return variant<Iter, Sent>{in_place_index<1>, std::get<1>(other.hold_)};
          }()) {}

    template<class I2, class S2>
        requires convertible_to<const I2&, Iter> && convertible_to<const S2&, Sent> &&
                 assignable_from<Iter&, const I2&> && assignable_from<Sent&, const S2&>
    constexpr common_iterator& operator=(const common_iterator<I2, S2>& other) {
        auto idx       = hold_.index();
        auto other_idx = other.hold_.index();
        if (idx == 0 && other_idx == 0)
            std::get<0>(hold_) = std::get<0>(other.hold_);
        else if (idx == 1 && other_idx == 1)
            std::get<1>(hold_) = std::get<1>(other.hold_);
        else if (other_idx == 1)
            hold_.template emplace<1>(std::get<1>(other.hold_));
        else
            hold_.template emplace<0>(std::get<0>(other.hold_));
        return *this;
    }

    [[nodiscard]] constexpr decltype(auto) operator*() {
        return *std::get<Iter>(hold_);
    }
    [[nodiscard]] constexpr decltype(auto) operator*() const
        requires detail::dereferenceable<const Iter>
    {
        return *std::get<Iter>(hold_);
    }

    template<class I2 = Iter>
    [[nodiscard]] constexpr auto operator->() const
        requires indirectly_readable<const I2> &&
                 (requires(const I2& i) { i.operator->(); } ||
                  is_reference_v<iter_reference_t<I2>> ||
                  constructible_from<iter_value_t<I2>, iter_reference_t<I2>>)
    {
        if constexpr (is_pointer_v<Iter> || requires(const Iter& i) { i.operator->(); }) {
            return std::get<Iter>(hold_);
        } else if constexpr (is_reference_v<iter_reference_t<Iter>>) {
            auto&& tmp = *std::get<Iter>(hold_);
            return std::addressof(tmp);
        } else {
            return proxy{*std::get<Iter>(hold_)};
        }
    }

    constexpr common_iterator& operator++() {
        ++std::get<Iter>(hold_);
        return *this;
    }

    constexpr decltype(auto) operator++(int) {
        if constexpr (forward_iterator<Iter>) {
            auto tmp = *this;
            ++*this;
            return tmp;
        } else if constexpr (requires(Iter& i) {
                                 { *i++ } -> detail::referenceable_type;
                             } || !detail::can_use_postfix_proxy<Iter>) {
            return std::get<Iter>(hold_)++;
        } else {
            auto p = postfix_proxy{**this};
            ++*this;
            return p;
        }
    }

    template<class I2, sentinel_for<Iter> S2>
        requires sentinel_for<Sent, I2>
    [[nodiscard]] friend constexpr bool
    operator==(const common_iterator& x, const common_iterator<I2, S2>& y) {
        const auto& yh = detail::common_iterator_access::hold(y);
        auto x_index = x.hold_.index();
        auto y_index = yh.index();

        if (x_index == y_index)
            return true;

        if (x_index == 0)
            return std::get<Iter>(x.hold_) == std::get<S2>(yh);

        return std::get<Sent>(x.hold_) == std::get<I2>(yh);
    }

    template<class I2, sentinel_for<Iter> S2>
        requires sentinel_for<Sent, I2> && equality_comparable_with<Iter, I2>
    [[nodiscard]] friend constexpr bool
    operator==(const common_iterator& x, const common_iterator<I2, S2>& y) {
        const auto& yh = detail::common_iterator_access::hold(y);
        auto x_index = x.hold_.index();
        auto y_index = yh.index();

        if (x_index == 1 && y_index == 1)
            return true;

        if (x_index == 0 && y_index == 0)
            return std::get<Iter>(x.hold_) == std::get<I2>(yh);

        if (x_index == 0)
            return std::get<Iter>(x.hold_) == std::get<S2>(yh);

        return std::get<Sent>(x.hold_) == std::get<I2>(yh);
    }

    template<sized_sentinel_for<Iter> I2, sized_sentinel_for<Iter> S2>
        requires sized_sentinel_for<Sent, I2>
    [[nodiscard]] friend constexpr iter_difference_t<I2>
    operator-(const common_iterator& x, const common_iterator<I2, S2>& y) {
        const auto& yh = detail::common_iterator_access::hold(y);
        auto x_index = x.hold_.index();
        auto y_index = yh.index();

        if (x_index == 1 && y_index == 1)
            return 0;

        if (x_index == 0 && y_index == 0)
            return std::get<Iter>(x.hold_) - std::get<I2>(yh);

        if (x_index == 0)
            return std::get<Iter>(x.hold_) - std::get<S2>(yh);

        return std::get<Sent>(x.hold_) - std::get<I2>(yh);
    }

    template<class I2 = Iter, enable_if_t<input_iterator<I2>, int> = 0>
    [[nodiscard]] friend constexpr decltype(auto)
    iter_move(const common_iterator& i)
        noexcept(noexcept(ranges::iter_move(std::declval<const Iter&>())))
    {
        return ranges::iter_move(std::get<Iter>(i.hold_));
    }

    template<indirectly_swappable<Iter> I2, class S2>
    friend constexpr void
    iter_swap(const common_iterator& x, const common_iterator<I2, S2>& y)
        noexcept(noexcept(ranges::iter_swap(std::declval<const Iter&>(),
                                            std::declval<const I2&>())))
    {
        ranges::iter_swap(std::get<Iter>(x.hold_),
                          std::get<I2>(detail::common_iterator_access::hold(y)));
    }
};

template<class Iter, class Sent>
struct incrementable_traits<common_iterator<Iter, Sent>> {
    using difference_type = iter_difference_t<Iter>;
};

// A concept, not a plain && in a type argument: constraint conjunction
// short-circuits (the derived_from conjunct is never substituted when the
// category does not exist).  Mirrors libc++ __denotes_forward_iter.
namespace detail {
    template<class Iter>
    concept common_iter_denotes_forward = requires {
        typename iterator_traits<Iter>::iterator_category;
    } && derived_from<typename iterator_traits<Iter>::iterator_category, forward_iterator_tag>;

    template<class Iter, class Sent>
    concept common_iter_has_ptr_op =
        requires(const common_iterator<Iter, Sent>& a) { a.operator->(); };

    template<class, class>
    struct common_iter_arrow_type_or_void {
        using type = void;
    };

    template<class Iter, class Sent>
        requires common_iter_has_ptr_op<Iter, Sent>
    struct common_iter_arrow_type_or_void<Iter, Sent> {
        using type = decltype(std::declval<const common_iterator<Iter, Sent>&>().operator->());
    };
} // namespace detail

template<input_iterator Iter, class Sent>
struct iterator_traits<common_iterator<Iter, Sent>> {
    using iterator_concept  = conditional_t<forward_iterator<Iter>,
                                            forward_iterator_tag, input_iterator_tag>;
    using iterator_category = conditional_t<detail::common_iter_denotes_forward<Iter>,
                                            forward_iterator_tag, input_iterator_tag>;
    using pointer           = typename detail::common_iter_arrow_type_or_void<Iter, Sent>::type;
    using value_type        = iter_value_t<Iter>;
    using difference_type   = iter_difference_t<Iter>;
    using reference         = iter_reference_t<Iter>;
};

//===----------------------------------------------------------------------===//
// [iterator.range] — begin / end / cbegin / cend / rbegin / rend / crbegin /
//                    crend / size / ssize / empty / data
//===----------------------------------------------------------------------===//

// begin/end — array
template<class T, size_t N>
[[nodiscard]] constexpr T* begin(T (&array)[N]) noexcept { return array; }
template<class T, size_t N>
[[nodiscard]] constexpr T* end(T (&array)[N]) noexcept { return array + N; }

// begin/end — container
template<class C>
[[nodiscard]] constexpr auto begin(C& c) -> decltype(c.begin()) { return c.begin(); }
template<class C>
[[nodiscard]] constexpr auto begin(const C& c) -> decltype(c.begin()) { return c.begin(); }
template<class C>
[[nodiscard]] constexpr auto end(C& c) -> decltype(c.end()) { return c.end(); }
template<class C>
[[nodiscard]] constexpr auto end(const C& c) -> decltype(c.end()) { return c.end(); }

// cbegin / cend (qualified std::begin/std::end -- must not be ADL-hijacked)
template<class C>
[[nodiscard]] constexpr auto cbegin(const C& c)
    noexcept(noexcept(std::begin(c))) -> decltype(std::begin(c)) {
    return std::begin(c);
}
template<class C>
[[nodiscard]] constexpr auto cend(const C& c)
    noexcept(noexcept(std::end(c))) -> decltype(std::end(c)) {
    return std::end(c);
}

// rbegin / rend — array
template<class T, size_t N>
[[nodiscard]] constexpr reverse_iterator<T*> rbegin(T (&array)[N]) {
    return reverse_iterator<T*>(array + N);
}
template<class T, size_t N>
[[nodiscard]] constexpr reverse_iterator<T*> rend(T (&array)[N]) {
    return reverse_iterator<T*>(array);
}

// rbegin / rend — initializer_list
template<class E>
[[nodiscard]] constexpr reverse_iterator<const E*>
rbegin(initializer_list<E> il) {
    return reverse_iterator<const E*>(il.end());
}
template<class E>
[[nodiscard]] constexpr reverse_iterator<const E*>
rend(initializer_list<E> il) {
    return reverse_iterator<const E*>(il.begin());
}

// rbegin / rend — container
template<class C>
[[nodiscard]] constexpr auto rbegin(C& c) -> decltype(c.rbegin()) { return c.rbegin(); }
template<class C>
[[nodiscard]] constexpr auto rbegin(const C& c) -> decltype(c.rbegin()) { return c.rbegin(); }
template<class C>
[[nodiscard]] constexpr auto rend(C& c) -> decltype(c.rend()) { return c.rend(); }
template<class C>
[[nodiscard]] constexpr auto rend(const C& c) -> decltype(c.rend()) { return c.rend(); }

// crbegin / crend (qualified std::rbegin/std::rend -- must not be ADL-hijacked)
template<class C>
[[nodiscard]] constexpr auto crbegin(const C& c)
    -> decltype(std::rbegin(c)) {
    return std::rbegin(c);
}
template<class C>
[[nodiscard]] constexpr auto crend(const C& c)
    -> decltype(std::rend(c)) {
    return std::rend(c);
}

// size / ssize
template<class C>
[[nodiscard]] constexpr auto size(const C& c)
    noexcept(noexcept(c.size())) -> decltype(c.size()) {
    return c.size();
}
template<class T, size_t N>
[[nodiscard]] constexpr size_t size(const T (&)[N]) noexcept { return N; }

template<class C>
[[nodiscard]] constexpr auto ssize(const C& c)
    noexcept(noexcept(static_cast<common_type_t<ptrdiff_t,
                                                make_signed_t<decltype(c.size())>>>(c.size())))
    -> common_type_t<ptrdiff_t, make_signed_t<decltype(c.size())>> {
    return static_cast<common_type_t<ptrdiff_t, make_signed_t<decltype(c.size())>>>(c.size());
}

template<class T, ptrdiff_t N>
[[nodiscard]] constexpr ptrdiff_t ssize(const T (&)[N]) noexcept { return N; }

// empty
template<class C>
[[nodiscard]] constexpr auto empty(const C& c)
    noexcept(noexcept(c.empty())) -> decltype(c.empty()) {
    return c.empty();
}
template<class T, size_t N>
[[nodiscard]] constexpr bool empty(const T (&)[N]) noexcept { return false; }
template<class E>
[[nodiscard]] constexpr bool empty(initializer_list<E> il) noexcept {
    return il.size() == 0;
}

// data
template<class C>
[[nodiscard]] constexpr auto data(C& c)
    noexcept(noexcept(c.data())) -> decltype(c.data()) {
    return c.data();
}
template<class C>
[[nodiscard]] constexpr auto data(const C& c)
    noexcept(noexcept(c.data())) -> decltype(c.data()) {
    return c.data();
}
template<class T, size_t N>
[[nodiscard]] constexpr T* data(T (&array)[N]) noexcept { return array; }
template<class E>
[[nodiscard]] constexpr const E* data(initializer_list<E> il) noexcept {
    return il.begin();
}

//===----------------------------------------------------------------------===//
// [stream.iterators] — istream_iterator / ostream_iterator /
// istreambuf_iterator / ostreambuf_iterator
// (from __iterator/istream_iterator.h, ostream_iterator.h,
//  istreambuf_iterator.h, ostreambuf_iterator.h)
// Only the <iosfwd> declarations are needed here: every stream operation is
// inside a member template instantiated at the point of use.
//===----------------------------------------------------------------------===//

template<class T, class CharT = char, class Traits = char_traits<CharT>,
         class Distance = ptrdiff_t>
class istream_iterator {
public:
    using iterator_category = input_iterator_tag;
    using value_type        = T;
    using difference_type   = Distance;
    using pointer           = const T*;
    using reference         = const T&;
    using char_type         = CharT;
    using traits_type       = Traits;
    using istream_type      = basic_istream<CharT, Traits>;

private:
    istream_type* in_stream;
    T value;

public:
    constexpr istream_iterator() : in_stream(nullptr), value() {}
    constexpr istream_iterator(default_sentinel_t) : istream_iterator() {}
    istream_iterator(istream_type& s) : in_stream(std::addressof(s)) {
        if (!(*in_stream >> value))
            in_stream = nullptr;
    }

    const T& operator*() const { return value; }
    const T* operator->() const { return std::addressof(operator*()); }
    istream_iterator& operator++() {
        if (!(*in_stream >> value))
            in_stream = nullptr;
        return *this;
    }
    istream_iterator operator++(int) {
        istream_iterator t(*this);
        ++(*this);
        return t;
    }

    template<class U, class CharU, class TraitsU, class DistanceU>
    friend bool operator==(const istream_iterator<U, CharU, TraitsU, DistanceU>& x,
                           const istream_iterator<U, CharU, TraitsU, DistanceU>& y);

    friend bool operator==(const istream_iterator& i, default_sentinel_t) {
        return i.in_stream == nullptr;
    }
};

template<class T, class CharT, class Traits, class Distance>
inline bool operator==(const istream_iterator<T, CharT, Traits, Distance>& x,
                       const istream_iterator<T, CharT, Traits, Distance>& y) {
    return x.in_stream == y.in_stream;
}

template<class T, class CharT = char, class Traits = char_traits<CharT>>
class ostream_iterator {
public:
    using iterator_category = output_iterator_tag;
    using value_type        = void;
    using difference_type   = ptrdiff_t;   // void before C++20 (P0896)
    using pointer           = void;
    using reference         = void;
    using char_type         = CharT;
    using traits_type       = Traits;
    using ostream_type      = basic_ostream<CharT, Traits>;

private:
    ostream_type* out_stream;
    const char_type* delim;

public:
    ostream_iterator(ostream_type& s) noexcept
        : out_stream(std::addressof(s)), delim(nullptr) {}
    ostream_iterator(ostream_type& s, const CharT* delimiter) noexcept
        : out_stream(std::addressof(s)), delim(delimiter) {}
    ostream_iterator& operator=(const T& v) {
        *out_stream << v;
        if (delim)
            *out_stream << delim;
        return *this;
    }

    ostream_iterator& operator*() { return *this; }
    ostream_iterator& operator++() { return *this; }
    ostream_iterator& operator++(int) { return *this; }
};

// default Traits argument already on the <iosfwd> declaration
template<class CharT, class Traits>
class istreambuf_iterator {
public:
    using iterator_category = input_iterator_tag;
    using value_type        = CharT;
    using difference_type   = typename Traits::off_type;
    using pointer           = CharT*;
    using reference         = CharT;
    using char_type         = CharT;
    using traits_type       = Traits;
    using int_type          = typename Traits::int_type;
    using streambuf_type    = basic_streambuf<CharT, Traits>;
    using istream_type      = basic_istream<CharT, Traits>;

private:
    mutable streambuf_type* sbuf;

    class proxy_type {
        char_type keep;
        streambuf_type* sbuf;
        explicit proxy_type(char_type c, streambuf_type* s) : keep(c), sbuf(s) {}
        friend class istreambuf_iterator;

    public:
        char_type operator*() const { return keep; }
    };

    bool test_for_eof() const {
        if (sbuf && traits_type::eq_int_type(sbuf->sgetc(), traits_type::eof()))
            sbuf = nullptr;
        return sbuf == nullptr;
    }

public:
    constexpr istreambuf_iterator() noexcept : sbuf(nullptr) {}
    constexpr istreambuf_iterator(default_sentinel_t) noexcept
        : istreambuf_iterator() {}
    istreambuf_iterator(istream_type& s) noexcept : sbuf(s.rdbuf()) {}
    istreambuf_iterator(streambuf_type* s) noexcept : sbuf(s) {}
    istreambuf_iterator(const proxy_type& p) noexcept : sbuf(p.sbuf) {}

    char_type operator*() const { return static_cast<char_type>(sbuf->sgetc()); }
    istreambuf_iterator& operator++() {
        sbuf->sbumpc();
        return *this;
    }
    proxy_type operator++(int) { return proxy_type(sbuf->sbumpc(), sbuf); }

    bool equal(const istreambuf_iterator& b) const {
        return test_for_eof() == b.test_for_eof();
    }

    friend bool operator==(const istreambuf_iterator& i, default_sentinel_t) {
        return i.test_for_eof();
    }
};

template<class CharT, class Traits>
inline bool operator==(const istreambuf_iterator<CharT, Traits>& a,
                       const istreambuf_iterator<CharT, Traits>& b) {
    return a.equal(b);
}

// default Traits argument already on the <iosfwd> declaration
template<class CharT, class Traits>
class ostreambuf_iterator {
public:
    using iterator_category = output_iterator_tag;
    using value_type        = void;
    using difference_type   = ptrdiff_t;   // void before C++20 (P0896)
    using pointer           = void;
    using reference         = void;
    using char_type         = CharT;
    using traits_type       = Traits;
    using streambuf_type    = basic_streambuf<CharT, Traits>;
    using ostream_type      = basic_ostream<CharT, Traits>;

private:
    streambuf_type* sbuf;

public:
    ostreambuf_iterator(ostream_type& s) noexcept : sbuf(s.rdbuf()) {}
    ostreambuf_iterator(streambuf_type* s) noexcept : sbuf(s) {}
    ostreambuf_iterator& operator=(CharT c) {
        if (sbuf && traits_type::eq_int_type(sbuf->sputc(c), traits_type::eof()))
            sbuf = nullptr;
        return *this;
    }
    ostreambuf_iterator& operator*() { return *this; }
    ostreambuf_iterator& operator++() { return *this; }
    ostreambuf_iterator& operator++(int) { return *this; }
    [[nodiscard]] bool failed() const noexcept { return sbuf == nullptr; }
};

} // namespace std
