// <iterator> -- C++20 iterator library.
// Mechanically ported from libc++ include/iterator + include/__iterator/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Provides: deprecated-but-still-present std::iterator base class
//   ([depr.iterator.basic]), ranges::advance/next/prev ([range.iter.ops]).
// Omitted: ranges::distance (lives in <ranges>: its range overload needs the
//   range concepts).
// common_iterator uses std::variant (<variant> is included here).
#pragma once

#include <type_traits>
#include <concepts>
#include <utility>
#include <cstddef>
#include <initializer_list>
#include <bits/pointer.h>
#include <bits/identity.h>
#include <iosfwd>   // basic_istream/basic_ostream/basic_streambuf/char_traits
                    // forward declarations for the stream iterators

namespace std {

//===----------------------------------------------------------------------===//
// Internal concept helpers (from __concepts/referenceable.h,
// __concepts/primary_template.h)
//===----------------------------------------------------------------------===//
namespace detail {

template<class T>
concept referenceable_type = requires { typename type_identity<T&>; };

// class_or_enum already in concepts; redefine locally if needed
// (already defined in <concepts> but in detail:: here for iterator use)
template<class T>
concept iter_class_or_enum = is_class_v<T> || is_union_v<T> || is_enum_v<T>;

} // namespace detail

//===----------------------------------------------------------------------===//
// [iterator.tags] — iterator category tags
// (from __iterator/iterator_traits.h)
//===----------------------------------------------------------------------===//

struct input_iterator_tag {};
struct output_iterator_tag {};
struct forward_iterator_tag       : public input_iterator_tag {};
struct bidirectional_iterator_tag : public forward_iterator_tag {};
struct random_access_iterator_tag : public bidirectional_iterator_tag {};
struct contiguous_iterator_tag    : public random_access_iterator_tag {};

//===----------------------------------------------------------------------===//
// [incrementable.traits] — incrementable_traits, iter_difference_t
// (from __iterator/incrementable_traits.h)
//===----------------------------------------------------------------------===//

// Forward-declare iterator_traits (needed by iter_difference_t)
template<class Iter>
struct iterator_traits;

// primary_template concept: an iterator_traits specialisation IS the primary
// iff it declares __primary_template = itself.
namespace detail {
    template<class T>
    concept primary_template = requires {
        typename T::primary_template;
        requires is_same_v<typename T::primary_template, T>;
    };
} // namespace detail

template<class>
struct incrementable_traits {};

template<class T>
    requires is_object_v<T>
struct incrementable_traits<T*> {
    using difference_type = ptrdiff_t;
};

template<class I>
struct incrementable_traits<const I> : incrementable_traits<I> {};

namespace detail {
    template<class T>
    concept has_member_difference_type = requires { typename T::difference_type; };

    // Guard against void* and similar: only attempt subtraction for
    // non-void-pointer types (gcc-10 hard-errors on void* arithmetic even
    // inside a requires expression).
    template<class T>
    concept not_void_ptr =
        !(is_pointer_v<T> && is_void_v<remove_pointer_t<T>>);

    template<class T>
    concept has_integral_minus =
        not_void_ptr<T> &&
        requires(const T& x, const T& y) {
            { x - y } -> integral;
        };
} // namespace detail

template<detail::has_member_difference_type T>
struct incrementable_traits<T> {
    using difference_type = typename T::difference_type;
};

template<detail::has_integral_minus T>
    requires(!detail::has_member_difference_type<T>)
struct incrementable_traits<T> {
    using difference_type = make_signed_t<decltype(declval<T>() - declval<T>())>;
};

template<class I>
using iter_difference_t =
    typename conditional_t<detail::primary_template<iterator_traits<remove_cvref_t<I>>>,
                           incrementable_traits<remove_cvref_t<I>>,
                           iterator_traits<remove_cvref_t<I>>>::difference_type;

//===----------------------------------------------------------------------===//
// [readable.traits] — indirectly_readable_traits, iter_value_t
// (from __iterator/readable_traits.h)
//===----------------------------------------------------------------------===//

namespace detail {
    template<class T>
    struct cond_value_type {};
    template<class T>
        requires is_object_v<T>
    struct cond_value_type<T> { using value_type = remove_cv_t<T>; };

    template<class T>
    concept has_member_value_type = requires { typename T::value_type; };
    template<class T>
    concept has_member_element_type = requires { typename T::element_type; };
} // namespace detail

template<class>
struct indirectly_readable_traits {};

template<class I>
    requires is_array_v<I>
struct indirectly_readable_traits<I> {
    using value_type = remove_cv_t<remove_extent_t<I>>;
};

template<class I>
struct indirectly_readable_traits<const I> : indirectly_readable_traits<I> {};

template<class T>
struct indirectly_readable_traits<T*> : detail::cond_value_type<T> {};

template<detail::has_member_value_type T>
struct indirectly_readable_traits<T> : detail::cond_value_type<typename T::value_type> {};

template<detail::has_member_element_type T>
struct indirectly_readable_traits<T> : detail::cond_value_type<typename T::element_type> {};

// Both members present — ambiguous: no value_type unless they match
template<detail::has_member_value_type T>
    requires detail::has_member_element_type<T>
struct indirectly_readable_traits<T> {};

template<detail::has_member_value_type T>
    requires detail::has_member_element_type<T> &&
             same_as<remove_cv_t<typename T::element_type>,
                     remove_cv_t<typename T::value_type>>
struct indirectly_readable_traits<T>
    : detail::cond_value_type<typename T::value_type> {};

//===----------------------------------------------------------------------===//
// [iterator.traits] — iterator_traits, iter_reference_t
// (from __iterator/iterator_traits.h)
//===----------------------------------------------------------------------===//

// dereferenceable concept (exposition-only)
namespace detail {
    template<class T>
    concept dereferenceable = requires(T& t) {
        { *t } -> referenceable_type;
    };
} // namespace detail

template<detail::dereferenceable T>
using iter_reference_t = decltype(*declval<T&>());

// ---- iterator_traits helpers ----

namespace iter_traits_detail {

    template<class I>
    concept cpp17_iterator = requires(I i) {
        { *i } -> detail::referenceable_type;
        { ++i } -> same_as<I&>;
        { *i++ } -> detail::referenceable_type;
    } && copyable<I>;

    template<class I>
    concept cpp17_input_iterator =
        cpp17_iterator<I> && equality_comparable<I> && requires(I i) {
            typename incrementable_traits<I>::difference_type;
            typename indirectly_readable_traits<I>::value_type;
            typename common_reference_t<iter_reference_t<I>&&,
                                        typename indirectly_readable_traits<I>::value_type&>;
            typename common_reference_t<decltype(*i++)&&,
                                        typename indirectly_readable_traits<I>::value_type&>;
            requires signed_integral<typename incrementable_traits<I>::difference_type>;
        };

    template<class I>
    concept cpp17_forward_iterator =
        cpp17_input_iterator<I> &&
        constructible_from<I> &&
        is_reference_v<iter_reference_t<I>> &&
        same_as<remove_cvref_t<iter_reference_t<I>>,
                typename indirectly_readable_traits<I>::value_type> &&
        requires(I i) {
            { i++ } -> convertible_to<const I&>;
            { *i++ } -> same_as<iter_reference_t<I>>;
        };

    template<class I>
    concept cpp17_bidirectional_iterator =
        cpp17_forward_iterator<I> && requires(I i) {
            { --i } -> same_as<I&>;
            { i-- } -> convertible_to<const I&>;
            { *i-- } -> same_as<iter_reference_t<I>>;
        };

    template<class I>
    concept cpp17_random_access_iterator =
        cpp17_bidirectional_iterator<I> && totally_ordered<I> &&
        requires(I i, typename incrementable_traits<I>::difference_type n) {
            { i += n } -> same_as<I&>;
            { i -= n } -> same_as<I&>;
            { i + n }  -> same_as<I>;
            { n + i }  -> same_as<I>;
            { i - n }  -> same_as<I>;
            { i - i }  -> same_as<decltype(n)>;
            { i[n] }   -> convertible_to<iter_reference_t<I>>;
        };

} // namespace iter_traits_detail

namespace detail {
    template<class I>
    concept specifies_members = requires {
        typename I::value_type;
        typename I::difference_type;
        typename I::reference;
        typename I::iterator_category;
    };

    template<class I>
    concept has_member_reference = requires { typename I::reference; };
    template<class I>
    concept has_member_pointer = requires { typename I::pointer; };
    template<class I>
    concept has_member_iterator_category = requires { typename I::iterator_category; };

    template<class I>
    concept cpp17_iterator_missing_members =
        !specifies_members<I> && iter_traits_detail::cpp17_iterator<I>;

    template<class I>
    concept cpp17_input_iterator_missing_members =
        cpp17_iterator_missing_members<I> && iter_traits_detail::cpp17_input_iterator<I>;

    // pointer member or arrow operator
    template<class I>
    struct iter_traits_pointer_or_void { using type = void; };

    template<has_member_pointer I>
    struct iter_traits_pointer_or_void<I> { using type = typename I::pointer; };

    template<class I>
        requires requires(I& i) { i.operator->(); } && (!has_member_pointer<I>)
    struct iter_traits_pointer_or_void<I> {
        using type = decltype(declval<I&>().operator->());
    };

    // reference member
    template<class I>
    struct iter_traits_reference { using type = iter_reference_t<I>; };
    template<has_member_reference I>
    struct iter_traits_reference<I> { using type = typename I::reference; };

    // iterator_category deduction
    template<class I> struct deduce_category { using type = input_iterator_tag; };
    template<iter_traits_detail::cpp17_random_access_iterator I>
    struct deduce_category<I> { using type = random_access_iterator_tag; };
    template<iter_traits_detail::cpp17_bidirectional_iterator I>
    struct deduce_category<I> { using type = bidirectional_iterator_tag; };
    template<iter_traits_detail::cpp17_forward_iterator I>
    struct deduce_category<I> { using type = forward_iterator_tag; };

    template<class I> struct iter_traits_category : deduce_category<I> {};
    template<has_member_iterator_category I>
    struct iter_traits_category<I> { using type = typename I::iterator_category; };

    // difference_type deduction
    template<class I> struct iter_traits_difference { using type = void; };
    template<class I>
        requires requires { typename incrementable_traits<I>::difference_type; }
    struct iter_traits_difference<I> {
        using type = typename incrementable_traits<I>::difference_type;
    };

    // detected_or: if Expr<T> is valid, use it; else Default
    template<class Default, template<class> class Expr, class T, class = void>
    struct detected_or_impl { using type = Default; };
    template<class Default, template<class> class Expr, class T>
    struct detected_or_impl<Default, Expr, T, void_t<Expr<T>>> { using type = Expr<T>; };

    template<class Default, template<class> class Expr, class T>
    using detected_or_t = typename detected_or_impl<Default, Expr, T>::type;

    template<class T> using pointer_member_t = typename T::pointer;

    // __iterator_traits (internal)
    template<class I>
    struct iterator_traits_impl {};

    template<specifies_members I>
    struct iterator_traits_impl<I> {
        using iterator_category = typename I::iterator_category;
        using value_type        = typename I::value_type;
        using difference_type   = typename I::difference_type;
        using pointer           = detected_or_t<void, pointer_member_t, I>;
        using reference         = typename I::reference;
    };

    template<cpp17_input_iterator_missing_members I>
    struct iterator_traits_impl<I> {
        using iterator_category = typename iter_traits_category<I>::type;
        using value_type        = typename indirectly_readable_traits<I>::value_type;
        using difference_type   = typename incrementable_traits<I>::difference_type;
        using pointer           = typename iter_traits_pointer_or_void<I>::type;
        using reference         = typename iter_traits_reference<I>::type;
    };

    template<cpp17_iterator_missing_members I>
    struct iterator_traits_impl<I> {
        using iterator_category = output_iterator_tag;
        using value_type        = void;
        using difference_type   = typename iter_traits_difference<I>::type;
        using pointer           = void;
        using reference         = void;
    };
} // namespace detail

// Primary template
template<class I>
struct iterator_traits : detail::iterator_traits_impl<I> {
    using primary_template = iterator_traits;
};

// Pointer specialisation
template<class T>
    requires is_object_v<T>
struct iterator_traits<T*> {
    using difference_type   = ptrdiff_t;
    using value_type        = remove_cv_t<T>;
    using pointer           = T*;
    using reference         = T&;
    using iterator_category = random_access_iterator_tag;
    using iterator_concept  = contiguous_iterator_tag;
};

// iter_value_t: from readable_traits or iterator_traits
template<class I>
using iter_value_t =
    typename conditional_t<detail::primary_template<iterator_traits<remove_cvref_t<I>>>,
                           indirectly_readable_traits<remove_cvref_t<I>>,
                           iterator_traits<remove_cvref_t<I>>>::value_type;

//===----------------------------------------------------------------------===//
// ranges::iter_move CPO
// (from __iterator/iter_move.h)
//===----------------------------------------------------------------------===//

namespace ranges {
namespace iter_move_detail {

void iter_move(); // poison pill (declared, not deleted: gcc-10 mishandles a
                  // deleted non-template overload during dependent ADL --
                  // matches libstdc++-10's form)

template<class T>
concept unqualified_iter_move =
    detail::iter_class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) { iter_move(std::forward<T>(t)); };

template<class T>
concept move_deref =
    !unqualified_iter_move<T> &&
    requires(T&& t) {
        *t;
        requires is_lvalue_reference_v<decltype(*t)>;
    };

template<class T>
concept just_deref =
    !unqualified_iter_move<T> && !move_deref<T> &&
    requires(T&& t) {
        *t;
        requires(!is_lvalue_reference_v<decltype(*t)>);
    };

struct iter_move_fn {
    template<class I>
        requires unqualified_iter_move<I>
    [[nodiscard]] constexpr decltype(auto) operator()(I&& i) const
        noexcept(noexcept(iter_move(std::forward<I>(i)))) {
        return iter_move(std::forward<I>(i));
    }

    template<class I>
        requires move_deref<I>
    [[nodiscard]] constexpr auto operator()(I&& i) const
        noexcept(noexcept(std::move(*std::forward<I>(i))))
        -> decltype(std::move(*std::forward<I>(i))) {
        return std::move(*std::forward<I>(i));
    }

    template<class I>
        requires just_deref<I>
    [[nodiscard]] constexpr auto operator()(I&& i) const
        noexcept(noexcept(*std::forward<I>(i)))
        -> decltype(*std::forward<I>(i)) {
        return *std::forward<I>(i);
    }
};

} // namespace iter_move_detail

inline namespace cpo {
    inline constexpr auto iter_move = iter_move_detail::iter_move_fn{};
} // namespace cpo

} // namespace ranges

// iter_rvalue_reference_t
template<detail::dereferenceable T>
    requires requires(T& t) {
        { ranges::iter_move(t) } -> detail::referenceable_type;
    }
using iter_rvalue_reference_t = decltype(ranges::iter_move(std::declval<T&>()));

//===----------------------------------------------------------------------===//
// [iterator.concept.readable] — indirectly_readable, iter_common_reference_t
//===----------------------------------------------------------------------===//

// projected helper types (forward-declared here, defined after projected)
namespace detail {
    template<class T>
    concept specialization_of_projected = requires {
        typename T::projected_iterator;
        typename T::projected_projection;
    } && primary_template<T>;
} // namespace detail

namespace detail {
    template<class In>
    concept indirectly_readable_impl =
        requires(const In i) {
            typename iter_value_t<In>;
            typename iter_reference_t<In>;
            typename iter_rvalue_reference_t<In>;
            { *i } -> same_as<iter_reference_t<In>>;
            { ranges::iter_move(i) } -> same_as<iter_rvalue_reference_t<In>>;
        } &&
        common_reference_with<iter_reference_t<In>&&, iter_value_t<In>&> &&
        common_reference_with<iter_reference_t<In>&&, iter_rvalue_reference_t<In>&&> &&
        common_reference_with<iter_rvalue_reference_t<In>&&, const iter_value_t<In>&>;
} // namespace detail

template<class In>
concept indirectly_readable = detail::indirectly_readable_impl<remove_cvref_t<In>>;

// indirect_value_t helper (from __iterator/concepts.h: __indirect_value_t).
// For a non-projected iterator: iter_value_t<T>&.
// For a std::projected specialization: the projection applied to the
// underlying iterator's indirect-value (recursively). This matches P2538R1
// and is what the indirect-callable concepts must use as the "value" argument.
namespace detail {
    template<class T>
    struct indirect_value_t_impl { using type = iter_value_t<T>&; };

    template<specialization_of_projected T>
    struct indirect_value_t_impl<T> {
        using type = invoke_result_t<typename T::projected_projection&,
                                     typename indirect_value_t_impl<typename T::projected_iterator>::type>;
    };
} // namespace detail

template<indirectly_readable T>
using indirect_value_t = typename detail::indirect_value_t_impl<remove_cvref_t<T>>::type;

template<indirectly_readable T>
using iter_common_reference_t = common_reference_t<iter_reference_t<T>,
                                                    indirect_value_t<T>>;

//===----------------------------------------------------------------------===//
// [iterator.concept.writable] — indirectly_writable
//===----------------------------------------------------------------------===//

template<class Out, class T>
concept indirectly_writable = requires(Out&& o, T&& t) {
    *o = std::forward<T>(t);
    *std::forward<Out>(o) = std::forward<T>(t);
    const_cast<const iter_reference_t<Out>&&>(*o) = std::forward<T>(t);
    const_cast<const iter_reference_t<Out>&&>(*std::forward<Out>(o)) = std::forward<T>(t);
};

//===----------------------------------------------------------------------===//
// [iterator.concept.winc] — weakly_incrementable, incrementable
//===----------------------------------------------------------------------===//

namespace detail {
    template<class T>
    concept integer_like = integral<T> && !same_as<T, bool>;
    template<class T>
    concept signed_integer_like = signed_integral<T>;
} // namespace detail

template<class I>
concept weakly_incrementable =
    movable<I> && requires(I i) {
        typename iter_difference_t<I>;
        requires detail::signed_integer_like<iter_difference_t<I>>;
        { ++i } -> same_as<I&>;
        i++;
    };

template<class I>
concept incrementable =
    regular<I> && weakly_incrementable<I> && requires(I i) {
        { i++ } -> same_as<I>;
    };

//===----------------------------------------------------------------------===//
// [iterator.concept.iterator] — input_or_output_iterator
//===----------------------------------------------------------------------===//

template<class I>
concept input_or_output_iterator =
    requires(I i) { { *i } -> detail::referenceable_type; } &&
    weakly_incrementable<I>;

//===----------------------------------------------------------------------===//
// [iterator.concept.sentinel] — sentinel_for, disable_sized_sentinel_for,
//                               sized_sentinel_for
//===----------------------------------------------------------------------===//

template<class S, class I>
concept sentinel_for =
    semiregular<S> &&
    input_or_output_iterator<I> &&
    detail::weakly_equality_comparable_with<S, I>;

template<class, class>
inline constexpr bool disable_sized_sentinel_for = false;

template<class S, class I>
concept sized_sentinel_for =
    sentinel_for<S, I> &&
    !disable_sized_sentinel_for<remove_cv_t<S>, remove_cv_t<I>> &&
    requires(const I& i, const S& s) {
        { s - i } -> same_as<iter_difference_t<I>>;
        { i - s } -> same_as<iter_difference_t<I>>;
    };

//===----------------------------------------------------------------------===//
// ITER_CONCEPT mechanism (for deducing iterator_concept from traits)
//===----------------------------------------------------------------------===//

namespace detail {
    // Choose which cache to use: prefer iterator_traits<I> over I itself
    // if iterator_traits<I> is a specialisation (not primary).
    template<class Iter>
    using iter_traits_t = conditional_t<primary_template<iterator_traits<Iter>>,
                                        Iter,
                                        iterator_traits<Iter>>;

    // Step 1: look for iterator_concept member
    template<class Iter, class = void>
    struct iter_concept_impl1 {};
    template<class Iter>
    struct iter_concept_impl1<Iter, void_t<typename iter_traits_t<Iter>::iterator_concept>> {
        using type = typename iter_traits_t<Iter>::iterator_concept;
    };

    // Step 2: look for iterator_category member
    template<class Iter, class = void>
    struct iter_concept_impl2 {};
    template<class Iter>
    struct iter_concept_impl2<Iter, void_t<typename iter_traits_t<Iter>::iterator_category>> {
        using type = typename iter_traits_t<Iter>::iterator_category;
    };

    // Step 3: if primary template, fall back to random_access_iterator_tag
    template<class Iter, class = void>
    struct iter_concept_impl3 {};
    template<class Iter>
        requires primary_template<iterator_traits<Iter>>
    struct iter_concept_impl3<Iter> { using type = random_access_iterator_tag; };

    // Pick the first that works
    template<class Iter, class = void>
    struct iter_concept_picker : iter_concept_impl2<Iter> {};
    template<class Iter>
    struct iter_concept_picker<Iter, void_t<typename iter_concept_impl1<Iter>::type>>
        : iter_concept_impl1<Iter> {};

    template<class Iter, class = void>
    struct iter_concept_selector : iter_concept_impl3<Iter> {};
    template<class Iter>
    struct iter_concept_selector<Iter, void_t<typename iter_concept_picker<Iter>::type>>
        : iter_concept_picker<Iter> {};

    template<class Iter>
    using iter_concept_t = typename iter_concept_selector<Iter>::type;
} // namespace detail

//===----------------------------------------------------------------------===//
// [iterator.concept.input] — input_iterator
//===----------------------------------------------------------------------===//

template<class I>
concept input_iterator =
    input_or_output_iterator<I> &&
    indirectly_readable<I> &&
    requires { typename detail::iter_concept_t<I>; } &&
    derived_from<detail::iter_concept_t<I>, input_iterator_tag>;

//===----------------------------------------------------------------------===//
// [iterator.concept.output] — output_iterator
//===----------------------------------------------------------------------===//

template<class I, class T>
concept output_iterator =
    input_or_output_iterator<I> &&
    indirectly_writable<I, T> &&
    requires(I it, T&& t) {
        *it++ = std::forward<T>(t);
    };

//===----------------------------------------------------------------------===//
// [iterator.concept.forward] — forward_iterator
//===----------------------------------------------------------------------===//

template<class I>
concept forward_iterator =
    input_iterator<I> &&
    derived_from<detail::iter_concept_t<I>, forward_iterator_tag> &&
    incrementable<I> &&
    sentinel_for<I, I>;

//===----------------------------------------------------------------------===//
// [iterator.concept.bidir] — bidirectional_iterator
//===----------------------------------------------------------------------===//

template<class I>
concept bidirectional_iterator =
    forward_iterator<I> &&
    derived_from<detail::iter_concept_t<I>, bidirectional_iterator_tag> &&
    requires(I i) {
        { --i } -> same_as<I&>;
        { i-- } -> same_as<I>;
    };

//===----------------------------------------------------------------------===//
// [iterator.concept.random.access] — random_access_iterator
//===----------------------------------------------------------------------===//

template<class I>
concept random_access_iterator =
    bidirectional_iterator<I> &&
    derived_from<detail::iter_concept_t<I>, random_access_iterator_tag> &&
    totally_ordered<I> &&
    sized_sentinel_for<I, I> &&
    requires(I i, const I j, const iter_difference_t<I> n) {
        { i += n } -> same_as<I&>;
        { j + n }  -> same_as<I>;
        { n + j }  -> same_as<I>;
        { i -= n } -> same_as<I&>;
        { j - n }  -> same_as<I>;
        { j[n] }   -> same_as<iter_reference_t<I>>;
    };

//===----------------------------------------------------------------------===//
// [iterator.concept.contiguous] — contiguous_iterator
//===----------------------------------------------------------------------===//

template<class I>
concept contiguous_iterator =
    random_access_iterator<I> &&
    derived_from<detail::iter_concept_t<I>, contiguous_iterator_tag> &&
    is_lvalue_reference_v<iter_reference_t<I>> &&
    same_as<iter_value_t<I>, remove_cvref_t<iter_reference_t<I>>> &&
    requires(const I& i) {
        { to_address(i) } -> same_as<add_pointer_t<iter_reference_t<I>>>;
    };

//===----------------------------------------------------------------------===//
// ranges::iter_swap CPO (from __iterator/iter_swap.h)
//===----------------------------------------------------------------------===//

namespace ranges {
namespace iter_swap_detail {

template<class I1, class I2>
void iter_swap(I1, I2) = delete; // poison pill

template<class T1, class T2>
concept unqualified_iter_swap =
    (detail::iter_class_or_enum<remove_cvref_t<T1>> ||
     detail::iter_class_or_enum<remove_cvref_t<T2>>) &&
    requires(T1&& x, T2&& y) { iter_swap(std::forward<T1>(x), std::forward<T2>(y)); };

template<class T1, class T2>
concept readable_swappable =
    indirectly_readable<T1> && indirectly_readable<T2> &&
    swappable_with<iter_reference_t<T1>, iter_reference_t<T2>>;

} // namespace iter_swap_detail
} // namespace ranges

// indirectly_movable_storable (needed for iter_swap third overload)
template<class In, class Out>
concept indirectly_movable =
    indirectly_readable<In> &&
    indirectly_writable<Out, iter_rvalue_reference_t<In>>;

template<class In, class Out>
concept indirectly_movable_storable =
    indirectly_movable<In, Out> &&
    indirectly_writable<Out, iter_value_t<In>> &&
    movable<iter_value_t<In>> &&
    constructible_from<iter_value_t<In>, iter_rvalue_reference_t<In>> &&
    assignable_from<iter_value_t<In>&, iter_rvalue_reference_t<In>>;

namespace ranges {
namespace iter_swap_detail {

struct iter_swap_fn {
    template<class T1, class T2>
        requires unqualified_iter_swap<T1, T2>
    constexpr void operator()(T1&& x, T2&& y) const
        noexcept(noexcept(iter_swap(std::forward<T1>(x), std::forward<T2>(y)))) {
        (void)iter_swap(std::forward<T1>(x), std::forward<T2>(y));
    }

    template<class T1, class T2>
        requires(!unqualified_iter_swap<T1, T2>) && readable_swappable<T1, T2>
    constexpr void operator()(T1&& x, T2&& y) const
        noexcept(noexcept(ranges::swap(*std::forward<T1>(x), *std::forward<T2>(y)))) {
        ranges::swap(*std::forward<T1>(x), *std::forward<T2>(y));
    }

    template<class T1, class T2>
        requires(!unqualified_iter_swap<T1, T2>) &&
                (!readable_swappable<T1, T2>) &&
                indirectly_movable_storable<T1, T2> &&
                indirectly_movable_storable<T2, T1>
    constexpr void operator()(T1&& x, T2&& y) const
        noexcept(noexcept(iter_value_t<T2>(ranges::iter_move(y))) &&
                 noexcept(*y = ranges::iter_move(x)) &&
                 noexcept(*std::forward<T1>(x) = std::declval<iter_value_t<T2>>())) {
        iter_value_t<T2> old(ranges::iter_move(y));
        *y = ranges::iter_move(x);
        *std::forward<T1>(x) = std::move(old);
    }
};

} // namespace iter_swap_detail

inline namespace cpo {
    inline constexpr auto iter_swap = iter_swap_detail::iter_swap_fn{};
} // namespace cpo

} // namespace ranges

//===----------------------------------------------------------------------===//
// indirectly_swappable (from __iterator/iter_swap.h)
//===----------------------------------------------------------------------===//

template<class I1, class I2 = I1>
concept indirectly_swappable =
    indirectly_readable<I1> && indirectly_readable<I2> &&
    requires(const I1 i1, const I2 i2) {
        ranges::iter_swap(i1, i1);
        ranges::iter_swap(i2, i2);
        ranges::iter_swap(i1, i2);
        ranges::iter_swap(i2, i1);
    };

//===----------------------------------------------------------------------===//
// indirectly_copyable, indirectly_copyable_storable
//===----------------------------------------------------------------------===//

template<class In, class Out>
concept indirectly_copyable =
    indirectly_readable<In> &&
    indirectly_writable<Out, iter_reference_t<In>>;

template<class In, class Out>
concept indirectly_copyable_storable =
    indirectly_copyable<In, Out> &&
    indirectly_writable<Out, iter_value_t<In>&> &&
    indirectly_writable<Out, const iter_value_t<In>&> &&
    indirectly_writable<Out, iter_value_t<In>&&> &&
    indirectly_writable<Out, const iter_value_t<In>&&> &&
    copyable<iter_value_t<In>> &&
    constructible_from<iter_value_t<In>, iter_reference_t<In>> &&
    assignable_from<iter_value_t<In>&, iter_reference_t<In>>;

//===----------------------------------------------------------------------===//
// ranges comparison functors (needed for projected / sortable / mergeable)
//===----------------------------------------------------------------------===//

namespace ranges {

struct equal_to {
    template<class T, class U>
        requires equality_comparable_with<T, U>
    [[nodiscard]] constexpr bool operator()(T&& t, U&& u) const
        noexcept(noexcept(bool(std::forward<T>(t) == std::forward<U>(u)))) {
        return std::forward<T>(t) == std::forward<U>(u);
    }
    using is_transparent = void;
};

struct not_equal_to {
    template<class T, class U>
        requires equality_comparable_with<T, U>
    [[nodiscard]] constexpr bool operator()(T&& t, U&& u) const
        noexcept(noexcept(bool(!(std::forward<T>(t) == std::forward<U>(u))))) {
        return !(std::forward<T>(t) == std::forward<U>(u));
    }
    using is_transparent = void;
};

struct less {
    template<class T, class U>
        requires totally_ordered_with<T, U>
    [[nodiscard]] constexpr bool operator()(T&& t, U&& u) const
        noexcept(noexcept(bool(std::forward<T>(t) < std::forward<U>(u)))) {
        return std::forward<T>(t) < std::forward<U>(u);
    }
    using is_transparent = void;
};

struct greater {
    template<class T, class U>
        requires totally_ordered_with<T, U>
    [[nodiscard]] constexpr bool operator()(T&& t, U&& u) const
        noexcept(noexcept(bool(std::forward<U>(u) < std::forward<T>(t)))) {
        return std::forward<U>(u) < std::forward<T>(t);
    }
    using is_transparent = void;
};

struct less_equal {
    template<class T, class U>
        requires totally_ordered_with<T, U>
    [[nodiscard]] constexpr bool operator()(T&& t, U&& u) const
        noexcept(noexcept(bool(!(std::forward<U>(u) < std::forward<T>(t))))) {
        return !(std::forward<U>(u) < std::forward<T>(t));
    }
    using is_transparent = void;
};

struct greater_equal {
    template<class T, class U>
        requires totally_ordered_with<T, U>
    [[nodiscard]] constexpr bool operator()(T&& t, U&& u) const
        noexcept(noexcept(bool(!(std::forward<T>(t) < std::forward<U>(u))))) {
        return !(std::forward<T>(t) < std::forward<U>(u));
    }
    using is_transparent = void;
};

} // namespace ranges

