// [range.access] — ranges::begin and ranges::iterator_t
// (moved here from <ranges>: the C++20 insert_iterator stores a
//  ranges::iterator_t<Container>; the remaining range-access CPOs stay in
//  <ranges>)
//===----------------------------------------------------------------------===//

namespace ranges {

// enable_borrowed_range (specialised by views and by span/string_view etc.)
template<class>
inline constexpr bool enable_borrowed_range = false;

namespace access_detail {
    template<class T>
    concept can_borrow =
        is_lvalue_reference_v<T> ||
        enable_borrowed_range<remove_cvref_t<T>>;

    template<class T>
    concept class_or_enum = is_class_v<T> || is_union_v<T> || is_enum_v<T>;
} // namespace access_detail

// ---- ranges::begin ----
namespace begin_detail {
void begin() = delete; // poison pill

template<class T>
concept member_begin =
    access_detail::can_borrow<T> &&
    requires(T&& t) {
        // _LIBCPP_AUTO_CAST: decay-copy the iterator so member begin() returning
        // a reference (e.g. int*&) is checked/returned as a prvalue (int*).
        { static_cast<decay_t<decltype((t.begin()))>>(t.begin()) } -> input_or_output_iterator;
    };

template<class T>
concept adl_begin =
    !member_begin<T> &&
    access_detail::can_borrow<T> &&
    access_detail::class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) {
        { static_cast<decay_t<decltype((begin(t)))>>(begin(t)) } -> input_or_output_iterator;
    };

struct begin_fn {
    // raw array (lvalue)
    template<class T, size_t N>
    [[nodiscard]] constexpr T* operator()(T (&arr)[N]) const noexcept {
        return arr + 0;
    }
    // member .begin()
    template<class T>
        requires member_begin<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(static_cast<decay_t<decltype((t.begin()))>>(t.begin()))) {
        return static_cast<decay_t<decltype((t.begin()))>>(t.begin());
    }
    // ADL begin(t)
    template<class T>
        requires adl_begin<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(static_cast<decay_t<decltype((begin(t)))>>(begin(t)))) {
        return static_cast<decay_t<decltype((begin(t)))>>(begin(t));
    }
};
} // namespace begin_detail

inline namespace cpo {
    inline constexpr auto begin = begin_detail::begin_fn{};
} // namespace cpo

// iterator_t
template<class R>
using iterator_t = decltype(ranges::begin(declval<R&>()));

} // namespace ranges

