};

//===----------------------------------------------------------------------===//
// [iterator.operations] — advance, distance, next, prev
// (std:: versions only; ranges:: versions omitted — live in <ranges>)
//===----------------------------------------------------------------------===//

namespace detail {
    // has_bidirectional_iterator_category
    template<class T, class = void>
    struct has_bidi_cat : false_type {};
    template<class T>
    struct has_bidi_cat<T, void_t<typename iterator_traits<T>::iterator_category>>
        : is_convertible<typename iterator_traits<T>::iterator_category,
                         bidirectional_iterator_tag> {};

    // has_random_access_iterator_category
    template<class T, class = void>
    struct has_ra_cat : false_type {};
    template<class T>
    struct has_ra_cat<T, void_t<typename iterator_traits<T>::iterator_category>>
        : is_convertible<typename iterator_traits<T>::iterator_category,
                         random_access_iterator_tag> {};

    inline void advance_impl(auto& i,
                             typename iterator_traits<remove_reference_t<decltype(i)>>::difference_type n,
                             input_iterator_tag) {
        for (; n > 0; --n) ++i;
    }
    inline void advance_impl(auto& i,
                             typename iterator_traits<remove_reference_t<decltype(i)>>::difference_type n,
                             bidirectional_iterator_tag) {
        if (n >= 0)
            for (; n > 0; --n) ++i;
        else
            for (; n < 0; ++n) --i;
    }
    inline void advance_impl(auto& i,
                             typename iterator_traits<remove_reference_t<decltype(i)>>::difference_type n,
                             random_access_iterator_tag) {
        i += n;
    }
} // namespace detail

template<class InputIter>
constexpr void advance(InputIter& i,
                       typename iterator_traits<InputIter>::difference_type n) {
    using Cat = typename iterator_traits<InputIter>::iterator_category;
    if constexpr (is_convertible_v<Cat, random_access_iterator_tag>) {
        i += n;
    } else if constexpr (is_convertible_v<Cat, bidirectional_iterator_tag>) {
        if (n >= 0)
            for (; n > 0; --n) ++i;
        else
            for (; n < 0; ++n) --i;
    } else {
        for (; n > 0; --n) ++i;
    }
}

template<class InputIter>
[[nodiscard]] constexpr typename iterator_traits<InputIter>::difference_type
distance(InputIter first, InputIter last) {
    if constexpr (detail::has_ra_cat<InputIter>::value) {
        return last - first;
    } else {
        typename iterator_traits<InputIter>::difference_type r(0);
        for (; first != last; ++first) ++r;
        return r;
    }
}

namespace detail {
    // has_input_iterator_category
    template<class T, class = void>
    struct has_input_cat : false_type {};
    template<class T>
    struct has_input_cat<T, void_t<typename iterator_traits<T>::iterator_category>>
        : is_convertible<typename iterator_traits<T>::iterator_category,
                         input_iterator_tag> {};
} // namespace detail

template<class InputIter,
         enable_if_t<detail::has_input_cat<InputIter>::value, int> = 0>
[[nodiscard]] constexpr InputIter
next(InputIter x,
     typename iterator_traits<InputIter>::difference_type n = 1) {
    std::advance(x, n);
    return x;
}

// Note: like libc++, prev(it, n) is constrained on *input* iterator only;
// advance with negative n on a non-bidirectional iterator is a no-op.
template<class InputIter,
         enable_if_t<detail::has_input_cat<InputIter>::value, int> = 0>
[[nodiscard]] constexpr InputIter
prev(InputIter x,
     typename iterator_traits<InputIter>::difference_type n) {
    std::advance(x, -n);
    return x;
}

template<class InputIter,
         enable_if_t<detail::has_input_cat<InputIter>::value, int> = 0>
[[nodiscard]] constexpr InputIter
prev(InputIter it) {
    static_assert(detail::has_bidi_cat<InputIter>::value,
                  "Attempt to prev(it) with a non-bidirectional iterator");
    return std::prev(std::move(it), 1);
}

//===----------------------------------------------------------------------===//
// [range.iter.ops] — ranges::advance, ranges::next, ranges::prev
// (moved here from <ranges>; ranges::distance stays in <ranges> because its
//  range overload needs the range concepts)
//===----------------------------------------------------------------------===//

namespace ranges {

// ranges::advance
namespace advance_detail {
struct advance_fn {
private:
    template<class I>
    static constexpr void advance_forward(I& i, iter_difference_t<I> n) {
        while (n > 0) { --n; ++i; }
    }
    template<class I>
    static constexpr void advance_backward(I& i, iter_difference_t<I> n) {
        while (n < 0) { ++n; --i; }
    }

public:
    template<input_or_output_iterator I>
    constexpr void operator()(I& i, iter_difference_t<I> n) const {
        if constexpr (random_access_iterator<I>) {
            i += n;
        } else if constexpr (bidirectional_iterator<I>) {
            advance_forward(i, n);
            advance_backward(i, n);
        } else {
            advance_forward(i, n);
        }
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    constexpr void operator()(I& i, S bound) const {
        if constexpr (assignable_from<I&, S>) {
            i = std::move(bound);
        } else if constexpr (sized_sentinel_for<S, I>) {
            (*this)(i, bound - i);
        } else {
            while (i != bound) ++i;
        }
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    constexpr iter_difference_t<I> operator()(I& i, iter_difference_t<I> n, S bound) const {
        if constexpr (sized_sentinel_for<S, I>) {
            // magnitude_geq(a, b): |a| >= |b|, assuming the same sign
            auto magnitude_geq = [](auto a, auto b) {
                return a == 0 ? b == 0 : a > 0 ? a >= b : a <= b;
            };
            if (const auto m = bound - i; magnitude_geq(n, m)) {
                (*this)(i, bound);
                return n - m;
            }
            (*this)(i, n);
            return 0;
        } else {
            while (n > 0 && i != bound) { ++i; --n; }
            if constexpr (bidirectional_iterator<I> && same_as<I, S>) {
                while (n < 0 && i != bound) { --i; ++n; }
            }
            return n;
        }
    }
};
} // namespace advance_detail

inline namespace cpo {
    inline constexpr auto advance = advance_detail::advance_fn{};
} // namespace cpo

// ranges::next
namespace next_detail {
struct next_fn {
    template<input_or_output_iterator I>
    [[nodiscard]] constexpr I operator()(I i) const {
        ++i;
        return i;
    }
    template<input_or_output_iterator I>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n) const {
        ranges::advance(i, n);
        return i;
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    [[nodiscard]] constexpr I operator()(I i, S bound) const {
        ranges::advance(i, bound);
        return i;
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n, S bound) const {
        ranges::advance(i, n, bound);
        return i;
    }
};
} // namespace next_detail

inline namespace cpo {
    inline constexpr auto next = next_detail::next_fn{};
} // namespace cpo

// ranges::prev
namespace prev_detail {
struct prev_fn {
    template<bidirectional_iterator I>
    [[nodiscard]] constexpr I operator()(I i) const {
        --i;
        return i;
    }
    template<bidirectional_iterator I>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n) const {
        ranges::advance(i, -n);
        return i;
    }
    template<bidirectional_iterator I>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n, I bound) const {
        ranges::advance(i, -n, bound);
        return i;
    }
};
} // namespace prev_detail

inline namespace cpo {
    inline constexpr auto prev = prev_detail::prev_fn{};
} // namespace cpo

} // namespace ranges

//===----------------------------------------------------------------------===//
// [reverse.iter] — reverse_iterator
//===----------------------------------------------------------------------===//

template<class Iter>
class reverse_iterator {
public:
    using iterator_type     = Iter;
    using iterator_category =
        conditional_t<is_convertible_v<typename iterator_traits<Iter>::iterator_category,
                                       random_access_iterator_tag>,
                      random_access_iterator_tag,
                      typename iterator_traits<Iter>::iterator_category>;
    using iterator_concept  =
        conditional_t<random_access_iterator<Iter>,
                      random_access_iterator_tag,
                      bidirectional_iterator_tag>;
    using value_type        = iter_value_t<Iter>;
    using difference_type   = iter_difference_t<Iter>;
    using pointer           = typename iterator_traits<Iter>::pointer;
    using reference         = iter_reference_t<Iter>;

    constexpr reverse_iterator() : current() {}
    constexpr explicit reverse_iterator(Iter x) : current(x) {}

    template<class U>
        requires(!is_same_v<U, Iter> && is_convertible_v<const U&, Iter>)
    constexpr reverse_iterator(const reverse_iterator<U>& u) : current(u.base()) {}

    template<class U>
        requires(!is_same_v<U, Iter> &&
                 is_convertible_v<const U&, Iter> &&
                 is_assignable_v<Iter&, const U&>)
    constexpr reverse_iterator& operator=(const reverse_iterator<U>& u) {
        current = u.base();
        return *this;
    }

    [[nodiscard]] constexpr Iter base() const { return current; }

    [[nodiscard]] constexpr reference operator*() const {
        Iter tmp = current;
        return *--tmp;
    }

    constexpr pointer operator->() const
        requires is_pointer_v<Iter> || requires(const Iter i) { i.operator->(); }
    {
        Iter tmp = current;
        --tmp;
        if constexpr (is_pointer_v<Iter>) return tmp;
        else return tmp.operator->();
    }

    constexpr reverse_iterator& operator++() { --current; return *this; }
    constexpr reverse_iterator  operator++(int) {
        reverse_iterator tmp(*this);
        --current;
        return tmp;
    }
    constexpr reverse_iterator& operator--() { ++current; return *this; }
    constexpr reverse_iterator  operator--(int) {
        reverse_iterator tmp(*this);
        ++current;
        return tmp;
    }

    [[nodiscard]] constexpr reverse_iterator operator+(difference_type n) const {
        return reverse_iterator(current - n);
    }
    constexpr reverse_iterator& operator+=(difference_type n) {
        current -= n;
        return *this;
    }
    [[nodiscard]] constexpr reverse_iterator operator-(difference_type n) const {
        return reverse_iterator(current + n);
    }
    constexpr reverse_iterator& operator-=(difference_type n) {
        current += n;
        return *this;
    }
    [[nodiscard]] constexpr reference operator[](difference_type n) const {
        return *(*this + n);
    }

    // iter_move / iter_swap friend functions
    [[nodiscard]] friend constexpr iter_rvalue_reference_t<Iter>
    iter_move(const reverse_iterator& i)
        noexcept(is_nothrow_copy_constructible_v<Iter> &&
                 noexcept(ranges::iter_move(--declval<Iter&>()))) {
        auto tmp = i.base();
        return ranges::iter_move(--tmp);
    }

    template<indirectly_swappable<Iter> Iter2>
    friend constexpr void
    iter_swap(const reverse_iterator& x, const reverse_iterator<Iter2>& y)
        noexcept(is_nothrow_copy_constructible_v<Iter> &&
                 is_nothrow_copy_constructible_v<Iter2> &&
                 noexcept(ranges::iter_swap(--declval<Iter&>(),
                                             --declval<Iter2&>()))) {
        auto xtmp = x.base();
        auto ytmp = y.base();
        ranges::iter_swap(--xtmp, --ytmp);
    }

protected:
    Iter current;
};

// reverse_iterator comparison operators
template<class I1, class I2>
constexpr bool operator==(const reverse_iterator<I1>& x,
                          const reverse_iterator<I2>& y)
    requires requires { { x.base() == y.base() } -> convertible_to<bool>; }
{
    return x.base() == y.base();
}

template<class I1, class I2>
constexpr bool operator!=(const reverse_iterator<I1>& x,
                          const reverse_iterator<I2>& y)
    requires requires { { x.base() != y.base() } -> convertible_to<bool>; }
{
    return x.base() != y.base();
}

template<class I1, class I2>
constexpr bool operator<(const reverse_iterator<I1>& x,
                         const reverse_iterator<I2>& y)
    requires requires { { x.base() > y.base() } -> convertible_to<bool>; }
{
    return x.base() > y.base();
}

template<class I1, class I2>
constexpr bool operator>(const reverse_iterator<I1>& x,
                         const reverse_iterator<I2>& y)
    requires requires { { x.base() < y.base() } -> convertible_to<bool>; }
{
    return x.base() < y.base();
}

template<class I1, class I2>
constexpr bool operator<=(const reverse_iterator<I1>& x,
                          const reverse_iterator<I2>& y)
    requires requires { { x.base() >= y.base() } -> convertible_to<bool>; }
{
    return x.base() >= y.base();
}

template<class I1, class I2>
constexpr bool operator>=(const reverse_iterator<I1>& x,
                          const reverse_iterator<I2>& y)
    requires requires { { x.base() <= y.base() } -> convertible_to<bool>; }
{
    return x.base() <= y.base();
}

