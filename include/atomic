//===----------------------------------------------------------------------===//
// atomic_ref base template
//===----------------------------------------------------------------------===//

template<class T>
struct atomic_ref_base {
    static_assert(is_trivially_copyable_v<T>,
        "std::atomic_ref<T> requires T to be trivially copyable");

    using value_type = T;

    // minimum alignment for lock-free: next power-of-2 size up to 16 bytes
    static constexpr size_t min_alignment =
        (sizeof(T) & (sizeof(T) - 1)) || (sizeof(T) > 16) ? 0 : sizeof(T);
    static constexpr size_t required_alignment =
        alignof(T) > min_alignment ? alignof(T) : min_alignment;

    static constexpr bool is_always_lock_free =
        __atomic_always_lock_free(sizeof(T), static_cast<T*>(nullptr));

    [[nodiscard]] bool is_lock_free() const noexcept {
        return is_always_lock_free || __atomic_is_lock_free(sizeof(T), ptr);
    }

    void store(T desired, memory_order order = memory_order::seq_cst) const noexcept {
        __atomic_store(ptr, &desired, to_gcc_order(order));
    }
    T operator=(T desired) const noexcept { store(desired); return desired; }

    [[nodiscard]] T load(memory_order order = memory_order::seq_cst) const noexcept {
        T ret;
        __atomic_load(ptr, &ret, to_gcc_order(order));
        return ret;
    }
    operator T() const noexcept { return load(); }

    T exchange(T desired, memory_order order = memory_order::seq_cst) const noexcept {
        T ret;
        __atomic_exchange(ptr, &desired, &ret, to_gcc_order(order));
        return ret;
    }

    bool compare_exchange_weak(T& expected, T desired,
                               memory_order success, memory_order failure) const noexcept {
        return __atomic_compare_exchange(ptr, &expected, &desired, true,
                                         to_gcc_order(success),
                                         to_gcc_failure_order(failure));
    }
    bool compare_exchange_weak(T& expected, T desired,
                               memory_order order = memory_order::seq_cst) const noexcept {
        return __atomic_compare_exchange(ptr, &expected, &desired, true,
                                         to_gcc_order(order),
                                         to_gcc_failure_order(order));
    }
    bool compare_exchange_strong(T& expected, T desired,
                                 memory_order success, memory_order failure) const noexcept {
        return __atomic_compare_exchange(ptr, &expected, &desired, false,
                                         to_gcc_order(success),
                                         to_gcc_failure_order(failure));
    }
    bool compare_exchange_strong(T& expected, T desired,
                                 memory_order order = memory_order::seq_cst) const noexcept {
        return __atomic_compare_exchange(ptr, &expected, &desired, false,
                                         to_gcc_order(order),
                                         to_gcc_failure_order(order));
    }

    // C++20 wait/notify (spin-based)
    void wait(T old, memory_order order = memory_order::seq_cst) const noexcept {
        atomic_spin_wait(ptr, old, to_gcc_order(order));
    }
    void notify_one() const noexcept { /* no-op */ }
    void notify_all() const noexcept { /* no-op */ }

protected:
    T* ptr;
    explicit atomic_ref_base(T& obj) noexcept : ptr(&obj) {}
};

//===----------------------------------------------------------------------===//
// atomic_ref generic
//===----------------------------------------------------------------------===//

template<class T>
struct atomic_ref : atomic_ref_base<T> {
    using base = atomic_ref_base<T>;

    explicit atomic_ref(T& obj) noexcept : base(obj) {}
    atomic_ref(const atomic_ref&) noexcept = default;
    atomic_ref& operator=(const atomic_ref&) = delete;

    T operator=(T desired) const noexcept { return base::operator=(desired); }
};

//===----------------------------------------------------------------------===//
// atomic_ref<Integral>
//===----------------------------------------------------------------------===//

template<class T>
    requires (is_integral_v<T> && !is_same_v<T, bool>)
struct atomic_ref<T> : atomic_ref_base<T> {
    using base = atomic_ref_base<T>;
    using difference_type = T;

    explicit atomic_ref(T& obj) noexcept : base(obj) {}
    atomic_ref(const atomic_ref&) noexcept = default;
    atomic_ref& operator=(const atomic_ref&) = delete;

    T operator=(T desired) const noexcept { return base::operator=(desired); }

    T fetch_add(T op, memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_fetch_add(this->ptr, op, to_gcc_order(order));
    }
    T fetch_sub(T op, memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_fetch_sub(this->ptr, op, to_gcc_order(order));
    }
    T fetch_and(T op, memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_fetch_and(this->ptr, op, to_gcc_order(order));
    }
    T fetch_or(T op, memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_fetch_or(this->ptr, op, to_gcc_order(order));
    }
    T fetch_xor(T op, memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_fetch_xor(this->ptr, op, to_gcc_order(order));
    }

    T operator++(int) const noexcept { return fetch_add(T(1)); }
    T operator--(int) const noexcept { return fetch_sub(T(1)); }
    T operator++() const noexcept    { return fetch_add(T(1)) + T(1); }
    T operator--() const noexcept    { return fetch_sub(T(1)) - T(1); }
    T operator+=(T op) const noexcept { return fetch_add(op) + op; }
    T operator-=(T op) const noexcept { return fetch_sub(op) - op; }
    T operator&=(T op) const noexcept { return fetch_and(op) & op; }
    T operator|=(T op) const noexcept { return fetch_or(op)  | op; }
    T operator^=(T op) const noexcept { return fetch_xor(op) ^ op; }
};

//===----------------------------------------------------------------------===//
// atomic_ref<float/double/long double>
//===----------------------------------------------------------------------===//

template<class T>
    requires is_floating_point_v<T>
struct atomic_ref<T> : atomic_ref_base<T> {
    using base = atomic_ref_base<T>;
    using difference_type = T;

    explicit atomic_ref(T& obj) noexcept : base(obj) {}
    atomic_ref(const atomic_ref&) noexcept = default;
    atomic_ref& operator=(const atomic_ref&) = delete;

    T operator=(T desired) const noexcept { return base::operator=(desired); }

    T fetch_add(T op, memory_order order = memory_order_seq_cst) const noexcept {
        T old = this->load(memory_order_relaxed);
        T desired = old + op;
        while (!this->compare_exchange_weak(old, desired, order, memory_order_relaxed))
            desired = old + op;
        return old;
    }
    T fetch_sub(T op, memory_order order = memory_order_seq_cst) const noexcept {
        T old = this->load(memory_order_relaxed);
        T desired = old - op;
        while (!this->compare_exchange_weak(old, desired, order, memory_order_relaxed))
            desired = old - op;
        return old;
    }
    T operator+=(T op) const noexcept { return fetch_add(op) + op; }
    T operator-=(T op) const noexcept { return fetch_sub(op) - op; }
};

//===----------------------------------------------------------------------===//
// atomic_ref<T*>
//===----------------------------------------------------------------------===//

template<class T>
struct atomic_ref<T*> : atomic_ref_base<T*> {
    using base = atomic_ref_base<T*>;
    using difference_type = ptrdiff_t;

    explicit atomic_ref(T*& ptr) noexcept : base(ptr) {}
    atomic_ref(const atomic_ref&) noexcept = default;
    atomic_ref& operator=(const atomic_ref&) = delete;

    T* operator=(T* desired) const noexcept { return base::operator=(desired); }

    T* fetch_add(ptrdiff_t op, memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_fetch_add(this->ptr, op * ptrdiff_t(sizeof(T)),
                                  to_gcc_order(order));
    }
    T* fetch_sub(ptrdiff_t op, memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_fetch_sub(this->ptr, op * ptrdiff_t(sizeof(T)),
                                  to_gcc_order(order));
    }
    T* operator++(int) const noexcept { return fetch_add(1); }
    T* operator--(int) const noexcept { return fetch_sub(1); }
    T* operator++() const noexcept    { return fetch_add(1) + 1; }
    T* operator--() const noexcept    { return fetch_sub(1) - 1; }
    T* operator+=(ptrdiff_t op) const noexcept { return fetch_add(op) + op; }
    T* operator-=(ptrdiff_t op) const noexcept { return fetch_sub(op) - op; }
};

