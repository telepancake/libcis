// <atomic> -- atomic types and operations.
// Mechanically ported from libc++ include/atomic + include/__atomic/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Implementation strategy:
//   - Uses GCC __atomic_* builtins throughout.
//   - memory_order is a C++20 scoped enum backed by the same underlying type
//     as the legacy unscoped enum (to match GCC __ATOMIC_* integer values).
//   - wait() is a spin-loop (pausing with __builtin_ia32_pause() on x86).
//     notify_one() / notify_all() are no-ops (correct but not efficient).
//     No futex or OS blocking is used.
#pragma once

#include <type_traits>
#include <cstddef>
#include <cstdint>
#include <cstring>

// sched_yield: keep the prototype at default visibility (the io/locale headers
// later push hidden visibility, and a libc prototype first seen there would
// become unresolvable). Used by the spin-wait to avoid starving other threads.
#pragma GCC visibility push(default)
#include <sched.h>
#pragma GCC visibility pop

//===----------------------------------------------------------------------===//
// libatomic generic runtime fallback
//===----------------------------------------------------------------------===//
// For objects that are not lock-free (oversized / oddly-sized user types), GCC's
// typed __atomic_load/store/exchange/compare_exchange builtins lower to calls
// into libatomic's generic, size-taking entry points
// (__atomic_load(size_t,const volatile void*,void*,int), etc.). The libcis test
// harness links -nodefaultlibs without -latomic, so we provide those generic
// symbols ourselves with a striped spin-lock table (libatomic's own strategy).
//
// They are declared with asm() labels so the C++ identifiers do NOT shadow the
// typed __atomic_* builtins used throughout this header, and marked weak so a
// real libatomic (if ever linked) takes precedence. Definitions in a header
// included by many TUs are fine: weak definitions merge at link time.
namespace libcis_atomic_detail {
struct atomic_spinlock {
    volatile int flag = 0;
    void lock() noexcept {
        while (__atomic_exchange_n(&flag, 1, __ATOMIC_ACQUIRE))
            while (__atomic_load_n(&flag, __ATOMIC_RELAXED)) { }
    }
    void unlock() noexcept { __atomic_store_n(&flag, 0, __ATOMIC_RELEASE); }
};
inline atomic_spinlock& lock_for(const volatile void* p) noexcept {
    static atomic_spinlock table[64];
    return table[(reinterpret_cast<unsigned long>(p) >> 3) & 63u];
}
extern "C" {
void libcis_generic_atomic_load(std::size_t n, const volatile void* src, void* dst, int) asm("__atomic_load");
void libcis_generic_atomic_store(std::size_t n, volatile void* dst, void* src, int) asm("__atomic_store");
void libcis_generic_atomic_exchange(std::size_t n, volatile void* p, void* val, void* ret, int) asm("__atomic_exchange");
bool libcis_generic_atomic_cas(std::size_t n, volatile void* p, void* expected, void* desired, int, int) asm("__atomic_compare_exchange");
bool libcis_generic_atomic_is_lock_free(std::size_t n, const volatile void* p) asm("__atomic_is_lock_free");

__attribute__((weak)) void libcis_generic_atomic_load(std::size_t n, const volatile void* src, void* dst, int) {
    auto& l = lock_for(src); l.lock();
    std::memcpy(dst, const_cast<const void*>(src), n);
    l.unlock();
}
__attribute__((weak)) void libcis_generic_atomic_store(std::size_t n, volatile void* dst, void* src, int) {
    auto& l = lock_for(dst); l.lock();
    std::memcpy(const_cast<void*>(dst), src, n);
    l.unlock();
}
__attribute__((weak)) void libcis_generic_atomic_exchange(std::size_t n, volatile void* p, void* val, void* ret, int) {
    auto& l = lock_for(p); l.lock();
    std::memcpy(ret, const_cast<void*>(p), n);
    std::memcpy(const_cast<void*>(p), val, n);
    l.unlock();
}
__attribute__((weak)) bool libcis_generic_atomic_cas(std::size_t n, volatile void* p, void* expected, void* desired, int, int) {
    auto& l = lock_for(p); l.lock();
    bool ok = std::memcmp(const_cast<void*>(p), expected, n) == 0;
    if (ok) std::memcpy(const_cast<void*>(p), desired, n);
    else    std::memcpy(expected, const_cast<void*>(p), n);
    l.unlock();
    return ok;
}
// A generic object reaching this runtime entry is, by definition, not handled by
// an inline lock-free instruction, so it is never lock-free.
__attribute__((weak)) bool libcis_generic_atomic_is_lock_free(std::size_t, const volatile void*) {
    return false;
}
} // extern "C"
} // namespace libcis_atomic_detail

namespace std {

//===----------------------------------------------------------------------===//
// memory_order (C++20 scoped enum)
//===----------------------------------------------------------------------===//

// Use the underlying type of an unscoped enum to match __ATOMIC_* values.
enum legacy_memory_order_impl {
    mo_relaxed, mo_consume, mo_acquire, mo_release, mo_acq_rel, mo_seq_cst
};

using memory_order_underlying_t = __underlying_type(legacy_memory_order_impl);

enum class memory_order : memory_order_underlying_t {
    relaxed = mo_relaxed,
    consume = mo_consume,
    acquire = mo_acquire,
    release = mo_release,
    acq_rel = mo_acq_rel,
    seq_cst = mo_seq_cst
};

inline constexpr auto memory_order_relaxed = memory_order::relaxed;
inline constexpr auto memory_order_consume = memory_order::consume;
inline constexpr auto memory_order_acquire = memory_order::acquire;
inline constexpr auto memory_order_release = memory_order::release;
inline constexpr auto memory_order_acq_rel = memory_order::acq_rel;
inline constexpr auto memory_order_seq_cst = memory_order::seq_cst;

//===----------------------------------------------------------------------===//
// to_gcc_order helpers (internal)
//===----------------------------------------------------------------------===//

inline constexpr int to_gcc_order(memory_order order) noexcept {
    return order == memory_order_relaxed ? __ATOMIC_RELAXED
         : order == memory_order_acquire ? __ATOMIC_ACQUIRE
         : order == memory_order_release ? __ATOMIC_RELEASE
         : order == memory_order_seq_cst ? __ATOMIC_SEQ_CST
         : order == memory_order_acq_rel ? __ATOMIC_ACQ_REL
                                         : __ATOMIC_CONSUME;
}

// For CAS failure order: release -> relaxed, acq_rel -> acquire
inline constexpr int to_gcc_failure_order(memory_order order) noexcept {
    return order == memory_order_relaxed ? __ATOMIC_RELAXED
         : order == memory_order_acquire ? __ATOMIC_ACQUIRE
         : order == memory_order_release ? __ATOMIC_RELAXED
         : order == memory_order_seq_cst ? __ATOMIC_SEQ_CST
         : order == memory_order_acq_rel ? __ATOMIC_ACQUIRE
                                         : __ATOMIC_CONSUME;
}

//===----------------------------------------------------------------------===//
// kill_dependency
//===----------------------------------------------------------------------===//

template<class T>
inline T kill_dependency(T y) noexcept { return y; }

//===----------------------------------------------------------------------===//
// Fences
//===----------------------------------------------------------------------===//

inline void atomic_thread_fence(memory_order order) noexcept {
    __atomic_thread_fence(to_gcc_order(order));
}

inline void atomic_signal_fence(memory_order order) noexcept {
    __atomic_signal_fence(to_gcc_order(order));
}

//===----------------------------------------------------------------------===//
// spin-wait helper (used by wait())
// Spins reloading until the value differs from old.
// notify_one / notify_all are no-ops (correct but not OS-efficient).
//===----------------------------------------------------------------------===//

// Portable spin pause: use ia32 PAUSE on x86/x86_64, otherwise __asm__ nop.
inline void spin_pause() noexcept {
#if defined(__i386__) || defined(__x86_64__)
    __builtin_ia32_pause();
#else
    __asm__ volatile("" ::: "memory");
#endif
}

// Spin-wait loop: reload *ptr until the loaded value != old.
// This is a correct (but not OS-efficient) C++20 wait() implementation.
// A production implementation would use futex(2) or WaitOnAddress().
// Accepts const volatile pointers by stripping cv to avoid deduction conflicts.
template<class T>
inline void atomic_spin_wait(const volatile T* ptr, T old, int gcc_order) noexcept {
    // Cast away volatile for __atomic_load — GCC's builtin accepts volatile.
    const T* p = const_cast<const T*>(ptr);
    T cur;
    for (int spins = 0;;) {
        __atomic_load(p, &cur, gcc_order);
        if (!(cur == old)) return;
        ++spins;
        if (spins < 16)
            spin_pause();
        else if (spins < 64)
            for (int i = 0; i < 8; ++i) spin_pause();
        else
            ::sched_yield(); // give other threads (e.g. the notifier) a chance
    }
}

template<class T>
inline void atomic_spin_wait(const T* ptr, T old, int gcc_order) noexcept {
    atomic_spin_wait(static_cast<const volatile T*>(ptr), old, gcc_order);
}

//===----------------------------------------------------------------------===//
// atomic storage alignment
//===----------------------------------------------------------------------===//
// Like libc++'s _Atomic(T)/__cxx_atomic_base_impl, atomic storage is over-aligned
// to its lock-free size so the hardware instruction can be used. A struct such as
// {int,int} has alignof 4 but sizeof 8; __atomic_always_lock_free(8,0) reports
// lock-free, so the storage must be 8-aligned for __atomic_is_lock_free(8,&s) to
// agree. We round sizeof(T) up to the next power of two (capped at 16) and take
// the max with alignof(T), but only when that size is itself always lock-free.
template<class T>
inline constexpr size_t atomic_required_alignment() {
    size_t a = alignof(T);
    size_t s = sizeof(T);
    for (size_t cand = 1; cand <= 16; cand <<= 1) {
        if (cand >= s) {
            if (cand > a && __atomic_always_lock_free(cand, static_cast<T*>(nullptr)))
                a = cand;
            break;
        }
    }
    return a;
}

//===----------------------------------------------------------------------===//
// atomic_base -- primary (non-integral, non-pointer) template
//===----------------------------------------------------------------------===//

template<class T, bool IsIntegral = (is_integral_v<T> && !is_same_v<T, bool>)>
struct atomic_base {
    static_assert(is_trivially_copyable_v<T>,
        "std::atomic<T> requires T to be trivially copyable");

    using value_type = T;

    // The storage: over-aligned to its lock-free size so GCC can do lock-free ops.
    alignas(atomic_required_alignment<T>()) T storage;

    static constexpr bool is_always_lock_free =
        __atomic_always_lock_free(sizeof(T), static_cast<T*>(nullptr));

    [[nodiscard]] bool is_lock_free() const volatile noexcept {
        return is_always_lock_free
            || __atomic_is_lock_free(sizeof(T), const_cast<const T*>(&storage));
    }
    [[nodiscard]] bool is_lock_free() const noexcept {
        return is_always_lock_free
            || __atomic_is_lock_free(sizeof(T), &storage);
    }

    void store(T desired, memory_order order = memory_order_seq_cst) volatile noexcept {
        __atomic_store(&storage, &desired, to_gcc_order(order));
    }
    void store(T desired, memory_order order = memory_order_seq_cst) noexcept {
        __atomic_store(&storage, &desired, to_gcc_order(order));
    }

    [[nodiscard]] T load(memory_order order = memory_order_seq_cst) const volatile noexcept {
        T ret;
        __atomic_load(&storage, &ret, to_gcc_order(order));
        return ret;
    }
    [[nodiscard]] T load(memory_order order = memory_order_seq_cst) const noexcept {
        T ret;
        __atomic_load(&storage, &ret, to_gcc_order(order));
        return ret;
    }

    operator T() const volatile noexcept { return load(); }
    operator T() const noexcept { return load(); }

    T exchange(T desired, memory_order order = memory_order_seq_cst) volatile noexcept {
        T ret;
        __atomic_exchange(&storage, &desired, &ret, to_gcc_order(order));
        return ret;
    }
    T exchange(T desired, memory_order order = memory_order_seq_cst) noexcept {
        T ret;
        __atomic_exchange(&storage, &desired, &ret, to_gcc_order(order));
        return ret;
    }

    bool compare_exchange_weak(T& expected, T desired,
                               memory_order success, memory_order failure) volatile noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, true,
                                         to_gcc_order(success),
                                         to_gcc_failure_order(failure));
    }
    bool compare_exchange_weak(T& expected, T desired,
                               memory_order success, memory_order failure) noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, true,
                                         to_gcc_order(success),
                                         to_gcc_failure_order(failure));
    }
    bool compare_exchange_weak(T& expected, T desired,
                               memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, true,
                                         to_gcc_order(order),
                                         to_gcc_failure_order(order));
    }
    bool compare_exchange_weak(T& expected, T desired,
                               memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, true,
                                         to_gcc_order(order),
                                         to_gcc_failure_order(order));
    }

    bool compare_exchange_strong(T& expected, T desired,
                                 memory_order success, memory_order failure) volatile noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, false,
                                         to_gcc_order(success),
                                         to_gcc_failure_order(failure));
    }
    bool compare_exchange_strong(T& expected, T desired,
                                 memory_order success, memory_order failure) noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, false,
                                         to_gcc_order(success),
                                         to_gcc_failure_order(failure));
    }
    bool compare_exchange_strong(T& expected, T desired,
                                 memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, false,
                                         to_gcc_order(order),
                                         to_gcc_failure_order(order));
    }
    bool compare_exchange_strong(T& expected, T desired,
                                 memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_compare_exchange(&storage, &expected, &desired, false,
                                         to_gcc_order(order),
                                         to_gcc_failure_order(order));
    }

    // C++20 wait/notify (spin-based wait; notify is no-op)
    void wait(T old, memory_order order = memory_order_seq_cst) const volatile noexcept {
        atomic_spin_wait(&storage, old, to_gcc_order(order));
    }
    void wait(T old, memory_order order = memory_order_seq_cst) const noexcept {
        atomic_spin_wait(&storage, old, to_gcc_order(order));
    }
    void notify_one() volatile noexcept { /* no-op: spin-based */ }
    void notify_one() noexcept          { /* no-op: spin-based */ }
    void notify_all() volatile noexcept { /* no-op: spin-based */ }
    void notify_all() noexcept          { /* no-op: spin-based */ }

    constexpr atomic_base() noexcept : storage() {}
    constexpr atomic_base(T v) noexcept : storage(v) {}
    atomic_base(const atomic_base&) = delete;
    atomic_base& operator=(const atomic_base&) = delete;
    atomic_base& operator=(const atomic_base&) volatile = delete;
};

//===----------------------------------------------------------------------===//
// atomic_base -- integral specialization (adds fetch_add/sub/and/or/xor, ++)
//===----------------------------------------------------------------------===//

template<class T>
struct atomic_base<T, true> : atomic_base<T, false> {
    using base = atomic_base<T, false>;
    using difference_type = T;

    constexpr atomic_base() noexcept = default;
    constexpr atomic_base(T v) noexcept : base(v) {}

    T fetch_add(T op, memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_fetch_add(&this->storage, op, to_gcc_order(order));
    }
    T fetch_add(T op, memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_fetch_add(&this->storage, op, to_gcc_order(order));
    }
    T fetch_sub(T op, memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_fetch_sub(&this->storage, op, to_gcc_order(order));
    }
    T fetch_sub(T op, memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_fetch_sub(&this->storage, op, to_gcc_order(order));
    }
    T fetch_and(T op, memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_fetch_and(&this->storage, op, to_gcc_order(order));
    }
    T fetch_and(T op, memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_fetch_and(&this->storage, op, to_gcc_order(order));
    }
    T fetch_or(T op, memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_fetch_or(&this->storage, op, to_gcc_order(order));
    }
    T fetch_or(T op, memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_fetch_or(&this->storage, op, to_gcc_order(order));
    }
    T fetch_xor(T op, memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_fetch_xor(&this->storage, op, to_gcc_order(order));
    }
    T fetch_xor(T op, memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_fetch_xor(&this->storage, op, to_gcc_order(order));
    }

    T operator++(int) volatile noexcept { return fetch_add(T(1)); }
    T operator++(int) noexcept          { return fetch_add(T(1)); }
    T operator--(int) volatile noexcept { return fetch_sub(T(1)); }
    T operator--(int) noexcept          { return fetch_sub(T(1)); }
    T operator++() volatile noexcept    { return fetch_add(T(1)) + T(1); }
    T operator++() noexcept             { return fetch_add(T(1)) + T(1); }
    T operator--() volatile noexcept    { return fetch_sub(T(1)) - T(1); }
    T operator--() noexcept             { return fetch_sub(T(1)) - T(1); }
    T operator+=(T op) volatile noexcept { return fetch_add(op) + op; }
    T operator+=(T op) noexcept          { return fetch_add(op) + op; }
    T operator-=(T op) volatile noexcept { return fetch_sub(op) - op; }
    T operator-=(T op) noexcept          { return fetch_sub(op) - op; }
    T operator&=(T op) volatile noexcept { return fetch_and(op) & op; }
    T operator&=(T op) noexcept          { return fetch_and(op) & op; }
    T operator|=(T op) volatile noexcept { return fetch_or(op)  | op; }
    T operator|=(T op) noexcept          { return fetch_or(op)  | op; }
    T operator^=(T op) volatile noexcept { return fetch_xor(op) ^ op; }
    T operator^=(T op) noexcept          { return fetch_xor(op) ^ op; }
};

//===----------------------------------------------------------------------===//
// atomic<T> primary template
//===----------------------------------------------------------------------===//

template<class T>
struct atomic : atomic_base<T> {
    using base = atomic_base<T>;
    using value_type = T;

    // No explicit noexcept on the PRIMARY template: libc++ (__atomic/atomic.h)
    // leaves it `= default` so it is DEDUCED from T's default ctor -- an atomic
    // of a type whose default ctor can throw is then not nothrow-constructible.
    // (The integral/pointer specializations below keep noexcept; their T always
    // is.)
    constexpr atomic() = default;
    constexpr atomic(T v) noexcept : base(v) {}
    atomic(const atomic&) = delete;

    T operator=(T v) volatile noexcept { base::store(v); return v; }
    T operator=(T v) noexcept          { base::store(v); return v; }
    atomic& operator=(const atomic&)          = delete;
    atomic& operator=(const atomic&) volatile = delete;
};

//===----------------------------------------------------------------------===//
// atomic<T*> -- pointer specialization
//===----------------------------------------------------------------------===//

template<class T>
struct atomic<T*> : atomic_base<T*> {
    using base = atomic_base<T*>;
    using difference_type = ptrdiff_t;

    constexpr atomic() noexcept = default;
    constexpr atomic(T* v) noexcept : base(v) {}
    atomic(const atomic&) = delete;

    T* operator=(T* v) volatile noexcept { base::store(v); return v; }
    T* operator=(T* v) noexcept          { base::store(v); return v; }
    atomic& operator=(const atomic&)          = delete;
    atomic& operator=(const atomic&) volatile = delete;

    T* fetch_add(ptrdiff_t op, memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_fetch_add(&this->storage, op * ptrdiff_t(sizeof(T)),
                                  to_gcc_order(order));
    }
    T* fetch_add(ptrdiff_t op, memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_fetch_add(&this->storage, op * ptrdiff_t(sizeof(T)),
                                  to_gcc_order(order));
    }
    T* fetch_sub(ptrdiff_t op, memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_fetch_sub(&this->storage, op * ptrdiff_t(sizeof(T)),
                                  to_gcc_order(order));
    }
    T* fetch_sub(ptrdiff_t op, memory_order order = memory_order_seq_cst) noexcept {
        return __atomic_fetch_sub(&this->storage, op * ptrdiff_t(sizeof(T)),
                                  to_gcc_order(order));
    }

    T* operator++(int) volatile noexcept { return fetch_add(1); }
    T* operator++(int) noexcept          { return fetch_add(1); }
    T* operator--(int) volatile noexcept { return fetch_sub(1); }
    T* operator--(int) noexcept          { return fetch_sub(1); }
    T* operator++() volatile noexcept    { return fetch_add(1) + 1; }
    T* operator++() noexcept             { return fetch_add(1) + 1; }
    T* operator--() volatile noexcept    { return fetch_sub(1) - 1; }
    T* operator--() noexcept             { return fetch_sub(1) - 1; }
    T* operator+=(ptrdiff_t op) volatile noexcept { return fetch_add(op) + op; }
    T* operator+=(ptrdiff_t op) noexcept          { return fetch_add(op) + op; }
    T* operator-=(ptrdiff_t op) volatile noexcept { return fetch_sub(op) - op; }
    T* operator-=(ptrdiff_t op) noexcept          { return fetch_sub(op) - op; }
};

//===----------------------------------------------------------------------===//
// atomic<float/double/long double> -- floating-point specialization (C++20)
//===----------------------------------------------------------------------===//

template<class T>
    requires is_floating_point_v<T>
struct atomic<T> : atomic_base<T> {
    using base = atomic_base<T>;
    using value_type = T;
    using difference_type = T;

    constexpr atomic() noexcept = default;
    constexpr atomic(T v) noexcept : base(v) {}
    atomic(const atomic&) = delete;

    T operator=(T v) noexcept          { base::store(v); return v; }
    T operator=(T v) volatile noexcept
        requires base::is_always_lock_free
    { base::store(v); return v; }
    atomic& operator=(const atomic&)          = delete;
    atomic& operator=(const atomic&) volatile = delete;

    // fetch_add via CAS loop (no hardware FP atomic on most platforms)
    T fetch_add(T op, memory_order order = memory_order_seq_cst) noexcept {
        T old = this->load(memory_order_relaxed);
        T desired = old + op;
        while (!this->compare_exchange_weak(old, desired, order, memory_order_relaxed))
            desired = old + op;
        return old;
    }
    T fetch_add(T op, memory_order order = memory_order_seq_cst) volatile noexcept
        requires base::is_always_lock_free
    {
        T old = this->load(memory_order_relaxed);
        T desired = old + op;
        while (!this->compare_exchange_weak(old, desired, order, memory_order_relaxed))
            desired = old + op;
        return old;
    }
    T fetch_sub(T op, memory_order order = memory_order_seq_cst) noexcept {
        T old = this->load(memory_order_relaxed);
        T desired = old - op;
        while (!this->compare_exchange_weak(old, desired, order, memory_order_relaxed))
            desired = old - op;
        return old;
    }
    T fetch_sub(T op, memory_order order = memory_order_seq_cst) volatile noexcept
        requires base::is_always_lock_free
    {
        T old = this->load(memory_order_relaxed);
        T desired = old - op;
        while (!this->compare_exchange_weak(old, desired, order, memory_order_relaxed))
            desired = old - op;
        return old;
    }
    T operator+=(T op) noexcept { return fetch_add(op) + op; }
    T operator-=(T op) noexcept { return fetch_sub(op) - op; }
    T operator+=(T op) volatile noexcept requires base::is_always_lock_free
    { return fetch_add(op) + op; }
    T operator-=(T op) volatile noexcept requires base::is_always_lock_free
    { return fetch_sub(op) - op; }
};

//===----------------------------------------------------------------------===//
// atomic_flag
//===----------------------------------------------------------------------===//

struct atomic_flag {
    bool storage;

    constexpr atomic_flag() noexcept : storage(false) {}
    // EXTENSION: allow initializing from bool (used by ATOMIC_FLAG_INIT)
    constexpr atomic_flag(bool b) noexcept : storage(b) {}
    atomic_flag(const atomic_flag&) = delete;
    atomic_flag& operator=(const atomic_flag&)          = delete;
    atomic_flag& operator=(const atomic_flag&) volatile = delete;

    bool test(memory_order order = memory_order_seq_cst) const volatile noexcept {
        return __atomic_load_n(&storage, to_gcc_order(order));
    }
    bool test(memory_order order = memory_order_seq_cst) const noexcept {
        return __atomic_load_n(&storage, to_gcc_order(order));
    }
    bool test_and_set(memory_order order = memory_order_seq_cst) volatile noexcept {
        return __atomic_exchange_n(&storage, true, to_gcc_order(order));
    }
