// <stack> — mechanically ported from libc++ include/stack
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Depends on: <deque>, <compare>, <initializer_list>, <memory>, <utility>, <type_traits>
#pragma once

#include <deque>
#include <compare>
#include <initializer_list>
#include <memory>
#include <utility>
#include <type_traits>

namespace std {

//===----------------------------------------------------------------------===//
// stack<T, Container>
//===----------------------------------------------------------------------===//

template <class T, class Container = deque<T>>
class stack {
public:
    using container_type  = Container;
    using value_type      = typename container_type::value_type;
    using reference       = typename container_type::reference;
    using const_reference = typename container_type::const_reference;
    using size_type       = typename container_type::size_type;

    static_assert(is_same_v<T, value_type>,
        "stack<T, Container>: T must match Container::value_type");

protected:
    container_type c;

public:
    // --- Constructors ---

    stack() noexcept(is_nothrow_default_constructible_v<container_type>) : c() {}

    stack(const stack& s) : c(s.c) {}

    stack(stack&& s) noexcept(is_nothrow_move_constructible_v<container_type>)
        : c(std::move(s.c)) {}

    stack& operator=(const stack& s) {
        c = s.c;
        return *this;
    }

    stack& operator=(stack&& s) noexcept(is_nothrow_move_assignable_v<container_type>) {
        c = std::move(s.c);
        return *this;
    }

    explicit stack(const container_type& cont) : c(cont) {}

    explicit stack(container_type&& cont) : c(std::move(cont)) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    explicit stack(const Alloc& a) : c(a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    stack(const container_type& cont, const Alloc& a) : c(cont, a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    stack(container_type&& cont, const Alloc& a) : c(std::move(cont), a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    stack(const stack& s, const Alloc& a) : c(s.c, a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    stack(stack&& s, const Alloc& a) : c(std::move(s.c), a) {}

    // --- Capacity ---

    [[nodiscard]] bool empty() const { return c.empty(); }
    [[nodiscard]] size_type size() const { return c.size(); }

    // --- Element access ---

    [[nodiscard]] reference top() { return c.back(); }
    [[nodiscard]] const_reference top() const { return c.back(); }

    // --- Modifiers ---

    void push(const value_type& v) { c.push_back(v); }
    void push(value_type&& v) { c.push_back(std::move(v)); }

    template <class... Args>
    decltype(auto) emplace(Args&&... args) {
        return c.emplace_back(std::forward<Args>(args)...);
    }

    void pop() { c.pop_back(); }

    void swap(stack& s) noexcept(is_nothrow_swappable_v<container_type>) {
        using std::swap;
        swap(c, s.c);
    }

    // --- Friend access for comparison operators ---

    template <class T1, class C1>
    friend bool operator==(const stack<T1, C1>& x, const stack<T1, C1>& y);

    template <class T1, class C1>
    friend bool operator<(const stack<T1, C1>& x, const stack<T1, C1>& y);

    template <class T1, three_way_comparable C1>
    friend compare_three_way_result_t<C1>
    operator<=>(const stack<T1, C1>& x, const stack<T1, C1>& y);
};

// --- Deduction guides (C++17) ---

template <class Container>
    requires (!is_same_v<Container, void>)   // disambiguate from ill-formed
stack(Container) -> stack<typename Container::value_type, Container>;

template <class Container, class Alloc>
    requires uses_allocator<Container, Alloc>::value
stack(Container, Alloc) -> stack<typename Container::value_type, Container>;

// --- Comparison operators ---

template <class T, class Container>
inline bool operator==(const stack<T, Container>& x, const stack<T, Container>& y) {
    return x.c == y.c;
}

template <class T, class Container>
inline bool operator<(const stack<T, Container>& x, const stack<T, Container>& y) {
    return x.c < y.c;
}

template <class T, class Container>
inline bool operator!=(const stack<T, Container>& x, const stack<T, Container>& y) {
    return !(x == y);
}

template <class T, class Container>
inline bool operator>(const stack<T, Container>& x, const stack<T, Container>& y) {
    return y < x;
}

template <class T, class Container>
inline bool operator>=(const stack<T, Container>& x, const stack<T, Container>& y) {
    return !(x < y);
}

template <class T, class Container>
inline bool operator<=(const stack<T, Container>& x, const stack<T, Container>& y) {
    return !(y < x);
}

template <class T, three_way_comparable Container>
compare_three_way_result_t<Container>
operator<=>(const stack<T, Container>& x, const stack<T, Container>& y) {
    return x.c <=> y.c;
}

// --- Non-member swap ---

template <class T, class Container>
    requires is_swappable_v<Container>
inline void swap(stack<T, Container>& x, stack<T, Container>& y)
    noexcept(noexcept(x.swap(y))) {
    x.swap(y);
}

// --- uses_allocator ---

template <class T, class Container, class Alloc>
struct uses_allocator<stack<T, Container>, Alloc>
    : public uses_allocator<Container, Alloc> {};

} // namespace std
