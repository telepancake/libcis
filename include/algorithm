// merge (with comparator) — merge two sorted ranges into output
template<class InputIter1, class InputIter2, class OutputIter, class Compare>
constexpr OutputIter
merge(InputIter1 first1, InputIter1 last1,
      InputIter2 first2, InputIter2 last2,
      OutputIter result, Compare comp) {
    for (; first1 != last1; ++result) {
        if (first2 == last2) return copy(first1, last1, result);
        if (comp(*first2, *first1)) {
            *result = *first2; ++first2;
        } else {
            *result = *first1; ++first1;
        }
    }
    return copy(first2, last2, result);
}

// merge (operator<)
template<class InputIter1, class InputIter2, class OutputIter>
constexpr OutputIter
merge(InputIter1 first1, InputIter1 last1,
      InputIter2 first2, InputIter2 last2,
      OutputIter result) {
    return merge(first1, last1, first2, last2, result, less<>{});
}

// inplace_merge helpers
namespace detail {
    template<class Compare>
    struct comp_invert {
        Compare comp;
        template<class T1, class T2>
        bool operator()(const T1& x, const T2& y) const { return comp(y, x); }
    };

    // half_inplace_merge: merge [first1,last1) and [first2,last2) into [result,...),
    // moving from both halves — [first2,last2) already in place after result range
    template<class Iter1, class Iter2, class OutIter, class Compare>
    constexpr void
    half_inplace_merge(Iter1 first1, Iter1 last1,
                       Iter2 first2, Iter2 last2,
                       OutIter result, Compare& comp) {
        for (; first1 != last1; ++result) {
            if (first2 == last2) {
                move(first1, last1, result);
                return;
            }
            if (comp(*first2, *first1)) {
                *result = std::move(*first2); ++first2;
            } else {
                *result = std::move(*first1); ++first1;
            }
        }
        // first2..last2 are already in the right place
    }

    template<class BidiIter, class Compare>
    void
    buffered_inplace_merge(BidiIter first, BidiIter middle, BidiIter last,
                           Compare& comp,
                           typename iterator_traits<BidiIter>::difference_type len1,
                           typename iterator_traits<BidiIter>::difference_type len2,
                           typename iterator_traits<BidiIter>::value_type* buff) {
        using value_type = typename iterator_traits<BidiIter>::value_type;
        if (len1 <= len2) {
            value_type* p = buff;
            for (BidiIter i = first; i != middle; ++i, (void)++p)
                ::new (static_cast<void*>(p)) value_type(std::move(*i));
            half_inplace_merge(buff, p, middle, last, first, comp);
            // destroy temporaries
            for (value_type* q = buff; q != p; ++q) q->~value_type();
        } else {
            value_type* p = buff;
            for (BidiIter i = middle; i != last; ++i, (void)++p)
                ::new (static_cast<void*>(p)) value_type(std::move(*i));
            // reverse-merge: use reverse_iterator + inverted comp
            using RBi = reverse_iterator<BidiIter>;
            using Rv  = reverse_iterator<value_type*>;
            comp_invert<Compare&> inv{comp};
            half_inplace_merge(Rv(p), Rv(buff), RBi(middle), RBi(first),
                               RBi(last), inv);
            for (value_type* q = buff; q != p; ++q) q->~value_type();
        }
    }

    template<class BidiIter, class Compare>
    void
    inplace_merge_impl(BidiIter first, BidiIter middle, BidiIter last,
                       Compare& comp,
                       typename iterator_traits<BidiIter>::difference_type len1,
                       typename iterator_traits<BidiIter>::difference_type len2,
                       typename iterator_traits<BidiIter>::value_type* buff,
                       ptrdiff_t buff_size) {
        using diff_t = typename iterator_traits<BidiIter>::difference_type;
        while (true) {
            if (len2 == 0) return;
            if (len1 <= buff_size || len2 <= buff_size)
                return buffered_inplace_merge(first, middle, last, comp, len1, len2, buff);
            // Shrink left range
            for (; true; ++first, (void)--len1) {
                if (len1 == 0) return;
                if (comp(*middle, *first)) break;
            }
            BidiIter m1, m2;
            diff_t len11, len21;
            if (len1 < len2) {
                len21 = len2 / 2;
                m2 = middle;
                advance(m2, len21);
                m1 = upper_bound(first, middle, *m2, comp);
                len11 = distance(first, m1);
            } else {
                if (len1 == 1) {
                    swap(*first, *middle);
                    return;
                }
                len11 = len1 / 2;
                m1 = first;
                advance(m1, len11);
                m2 = lower_bound(middle, last, *m1, comp);
                len21 = distance(middle, m2);
            }
            diff_t len12 = len1 - len11;
            diff_t len22 = len2 - len21;
            middle = rotate(m1, middle, m2);
            if (len11 + len21 < len12 + len22) {
                inplace_merge_impl(first, m1, middle, comp, len11, len21, buff, buff_size);
                first  = middle;
                middle = m2;
                len1   = len12;
                len2   = len22;
            } else {
                inplace_merge_impl(middle, m2, last, comp, len12, len22, buff, buff_size);
                last   = middle;
                middle = m1;
                len1   = len11;
                len2   = len21;
            }
        }
    }
} // namespace detail

// inplace_merge (with comparator)
template<class BidiIter, class Compare>
void
inplace_merge(BidiIter first, BidiIter middle, BidiIter last, Compare comp) {
    using value_type = typename iterator_traits<BidiIter>::value_type;
    using diff_t     = typename iterator_traits<BidiIter>::difference_type;
    diff_t len1    = distance(first, middle);
    diff_t len2    = distance(middle, last);
    diff_t buf_sz  = min(len1, len2);
    // Allocate temporary buffer (may get fewer bytes than requested)
    value_type* buf = nullptr;
    ptrdiff_t got = 0;
    if (buf_sz > 0) {
        buf = static_cast<value_type*>(::operator new(
                  static_cast<size_t>(buf_sz) * sizeof(value_type),
                  std::nothrow));
        got = buf ? buf_sz : 0;
    }
    detail::inplace_merge_impl(first, middle, last, comp, len1, len2, buf, got);
    ::operator delete(buf);
}

// inplace_merge (operator<)
template<class BidiIter>
void
inplace_merge(BidiIter first, BidiIter middle, BidiIter last) {
