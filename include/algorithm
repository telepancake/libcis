// [alg.sorting] — nth_element
// (from __algorithm/nth_element.h)
//===----------------------------------------------------------------------===//

namespace detail {
    // sort3: sort the three elements pointed to by x, y, z — returns whether any swap occurred
    template<class RandomIter, class Compare>
    constexpr bool
    sort3(RandomIter x, RandomIter y, RandomIter z, Compare& comp) {
        if (!comp(*y, *x)) {
            if (!comp(*z, *y)) return false;
            swap(*y, *z);
            if (comp(*y, *x)) swap(*x, *y);
            return true;
        }
        if (comp(*z, *y)) {
            swap(*x, *z);
            return true;
        }
        swap(*x, *y);
        if (comp(*z, *y)) swap(*y, *z);
        return true;
    }

    template<class RandomIter, class Compare>
    constexpr bool
    nth_element_find_guard(RandomIter& i, RandomIter& j,
                           RandomIter m, Compare& comp) {
        while (true) {
            if (i == --j) return false;
            if (comp(*j, *m)) return true;
        }
    }
} // namespace detail

// nth_element (with comparator)
template<class RandomIter, class Compare>
constexpr void
nth_element(RandomIter first, RandomIter nth, RandomIter last, Compare comp) {
    using diff_t = typename iterator_traits<RandomIter>::difference_type;
    const diff_t limit = 7;
    while (true) {
        if (nth == last) return;
        diff_t len = last - first;
        if (len <= 1) return;
        if (len == 2) {
            if (comp(*--last, *first)) swap(*first, *last);
            return;
        }
        if (len == 3) {
            RandomIter m = first;
            detail::sort3(first, ++m, --last, comp);
            return;
        }
        if (len <= limit) {
            // selection sort
            RandomIter lm1 = last;
            for (--lm1; first != lm1; ++first) {
                RandomIter mn = min_element(first, last, comp);
                if (mn != first) swap(*first, *mn);
            }
            return;
        }
        RandomIter m = first + len / 2;
        RandomIter lm1 = last;
        unsigned n_swaps = detail::sort3(first, m, --lm1, comp) ? 1u : 0u;
        RandomIter i = first;
        RandomIter j = lm1;
        if (!comp(*i, *m)) {
            if (detail::nth_element_find_guard(i, j, m, comp)) {
                swap(*i, *j);
                ++n_swaps;
            } else {
                ++i;
                j = last;
                if (!comp(*first, *--j)) {
                    while (true) {
                        if (i == j) return;
                        if (comp(*first, *i)) {
                            swap(*i, *j);
                            ++n_swaps;
                            ++i;
                            break;
                        }
                        ++i;
                    }
                }
                if (i == j) return;
                while (true) {
                    while (!comp(*first, *i)) ++i;
                    do { --j; } while (comp(*first, *j));
                    if (i >= j) break;
                    swap(*i, *j);
                    ++n_swaps;
                    ++i;
                }
                if (nth < i) return;
                first = i;
                continue;
            }
        }
        ++i;
        if (i < j) {
            while (true) {
                while (comp(*i, *m)) ++i;
                do { --j; } while (!comp(*j, *m));
                if (i >= j) break;
                swap(*i, *j);
                ++n_swaps;
                if (m == i) m = j;
                ++i;
            }
        }
        if (i != m && comp(*m, *i)) {
            swap(*i, *m);
            ++n_swaps;
        }
        if (nth == i) return;
        if (n_swaps == 0) {
            if (nth < i) {
                j = m = first;
                while (true) {
                    if (++j == i) return;
                    if (comp(*j, *m)) break;
                    m = j;
                }
            } else {
                j = m = i;
                while (true) {
                    if (++j == last) return;
                    if (comp(*j, *m)) break;
                    m = j;
                }
            }
        }
        if (nth < i) {
            last = i;
        } else {
            first = ++i;
        }
    }
}

// nth_element (operator<)
template<class RandomIter>
constexpr void
nth_element(RandomIter first, RandomIter nth, RandomIter last) {
    nth_element(first, nth, last, less<>{});
}

