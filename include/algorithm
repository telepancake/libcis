// min (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr const T&
min(const T& a, const T& b, Compare comp) {
    return comp(b, a) ? b : a;
}

// min (operator<)
template<class T>
[[nodiscard]] constexpr const T&
min(const T& a, const T& b) {
    return (b < a) ? b : a;
}

// min (initializer_list, comparator)
template<class T, class Compare>
[[nodiscard]] constexpr T
min(initializer_list<T> t, Compare comp) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (comp(*it, result)) result = *it;
    return result;
}

// min (initializer_list, operator<)
template<class T>
[[nodiscard]] constexpr T
min(initializer_list<T> t) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (*it < result) result = *it;
    return result;
}

// max (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr const T&
max(const T& a, const T& b, Compare comp) {
    return comp(a, b) ? b : a;
}

// max (operator<)
template<class T>
[[nodiscard]] constexpr const T&
max(const T& a, const T& b) {
    return (a < b) ? b : a;
}

// max (initializer_list, comparator)
template<class T, class Compare>
[[nodiscard]] constexpr T
max(initializer_list<T> t, Compare comp) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (comp(result, *it)) result = *it;
    return result;
}

// max (initializer_list, operator<)
template<class T>
[[nodiscard]] constexpr T
max(initializer_list<T> t) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (result < *it) result = *it;
    return result;
}

// minmax_result helper
template<class T>
struct minmax_result {
    T min;
    T max;
};

// minmax (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr pair<const T&, const T&>
minmax(const T& a, const T& b, Compare comp) {
    return comp(b, a) ? pair<const T&, const T&>(b, a)
                      : pair<const T&, const T&>(a, b);
}

// minmax (operator<)
template<class T>
[[nodiscard]] constexpr pair<const T&, const T&>
minmax(const T& a, const T& b) {
    return (b < a) ? pair<const T&, const T&>(b, a)
                   : pair<const T&, const T&>(a, b);
}

// minmax (initializer_list, comparator) — pairwise algorithm from
// libc++ __algorithm/minmax_element.h: at most 3n/2 comparisons, and the
// max is the LAST maximal element (min is the first minimal element).
template<class T, class Compare>
[[nodiscard]] constexpr pair<T, T>
minmax(initializer_list<T> t, Compare comp) {
    const T* first = t.begin();
    const T* last  = t.end();
    pair<const T*, const T*> result(first, first);
    if (first != last && ++first != last) {
        if (comp(*first, *result.first))
            result.first = first;
        else
            result.second = first;
        while (++first != last) {
            const T* i = first;
            if (++first == last) {
                if (comp(*i, *result.first)) result.first = i;
                else if (!comp(*i, *result.second)) result.second = i;
                break;
            }
            if (comp(*first, *i)) {
                if (comp(*first, *result.first)) result.first = first;
                if (!comp(*i, *result.second)) result.second = i;
            } else {
                if (comp(*i, *result.first)) result.first = i;
                if (!comp(*first, *result.second)) result.second = first;
            }
        }
    }
    return {*result.first, *result.second};
}

// minmax (initializer_list, operator<)
template<class T>
[[nodiscard]] constexpr pair<T, T>
minmax(initializer_list<T> t) {
    return std::minmax(t, less<>{});
}

// clamp (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr const T&
clamp(const T& v, const T& lo, const T& hi, Compare comp) {
    return comp(v, lo) ? lo : comp(hi, v) ? hi : v;
}

// clamp (operator<)
template<class T>
[[nodiscard]] constexpr const T&
clamp(const T& v, const T& lo, const T& hi) {
    return (v < lo) ? lo : (hi < v) ? hi : v;
}

