// next_permutation (with comparator)
template<class BidiIter, class Compare>
constexpr bool
next_permutation(BidiIter first, BidiIter last, Compare comp) {
    BidiIter i = last;
    if (first == last || first == --i) return false;
    while (true) {
        BidiIter ip1 = i;
        if (comp(*--i, *ip1)) {
            BidiIter j = last;
            while (!comp(*i, *--j))
                ;
            swap(*i, *j);
            reverse(ip1, last);
            return true;
        }
        if (i == first) {
            reverse(first, last);
            return false;
        }
    }
}

