// [alg.sort] — sort (introsort)
// (from __algorithm/sort.h)
//===----------------------------------------------------------------------===//

namespace detail {
    // insertion_sort — sort [first, last) with insertion sort
    template<class BidiIter, class Compare>
    constexpr void
    insertion_sort(BidiIter first, BidiIter last, Compare& comp) {
        using value_type = typename iterator_traits<BidiIter>::value_type;
        if (first == last) return;
        BidiIter i = first;
        for (++i; i != last; ++i) {
            BidiIter j = i;
            --j;
            if (comp(*i, *j)) {
                value_type t(std::move(*i));
                BidiIter k = j;
                j = i;
                do {
                    *j = std::move(*k);
                    j  = k;
                } while (j != first && comp(t, *--k));
                *j = std::move(t);
            }
        }
    }

    // insertion_sort_unguarded — assumes element before first is a valid guard
    template<class RandomIter, class Compare>
    void
    insertion_sort_unguarded(RandomIter first, RandomIter last, Compare& comp) {
        using value_type = typename iterator_traits<RandomIter>::value_type;
        using diff_t = typename iterator_traits<RandomIter>::difference_type;
        if (first == last) return;
        for (RandomIter i = first + diff_t(1); i != last; ++i) {
            RandomIter j = i - diff_t(1);
            if (comp(*i, *j)) {
                value_type t(std::move(*i));
                RandomIter k = j;
                j = i;
                do {
                    *j = std::move(*k);
                    j  = k;
                } while (comp(t, *--k));
                *j = std::move(t);
            }
        }
    }

    // bit_log2 — floor(log2(n)) for n > 0
    inline unsigned
    bit_log2(unsigned long long n) {
        return (unsigned)(sizeof(unsigned long long) * 8 - 1 -
                          __builtin_clzll(n));
    }

    // introsort — [first, last), depth controls heap-sort fallback
    template<class RandomIter, class Compare>
    void
    introsort(RandomIter first, RandomIter last, Compare& comp,
              typename iterator_traits<RandomIter>::difference_type depth,
              bool leftmost) {
        using diff_t     = typename iterator_traits<RandomIter>::difference_type;
        using value_type = typename iterator_traits<RandomIter>::value_type;
        constexpr diff_t ISORT_LIMIT = 24;

        while (true) {
            diff_t len = last - first;
            if (len < 2) return;
            if (len == 2) {
                if (comp(*--last, *first)) swap(*first, *last);
                return;
            }
            if (len == 3) {
                detail::sort3(first, first + diff_t(1), last - diff_t(1), comp);
                return;
            }
            if (len < ISORT_LIMIT) {
                if (leftmost)
                    detail::insertion_sort(first, last, comp);
                else
                    detail::insertion_sort_unguarded(first, last, comp);
                return;
            }
            if (depth == 0) {
                // Fall back to heap sort
                make_heap(first, last, comp);
                sort_heap(first, last, comp);
                return;
            }
            --depth;

            // Median-of-three pivot selection
            diff_t half = len / 2;
            detail::sort3(first + half, first, last - diff_t(1), comp);
            // Now *first is the median/pivot

            // Partition [first+1, last) around pivot *first
            // equals on left: __partition_with_equals_on_right pattern
            {
                // Put pivot at first; partition [first+1, last)
                value_type pivot(std::move(*first));
                RandomIter i = first + diff_t(1);
                RandomIter j = last;

                // Find first >= pivot from left
                while (i < j && comp(*i, pivot)) ++i;
                // Find last < pivot from right (guarded)
                while (i < j) {
                    --j;
                    if (comp(*j, pivot)) break;
                }

                bool already_partitioned = (i >= j);
                if (!already_partitioned) {
                    swap(*i, *j);
                    ++i;
                }

                // Continue partitioning
                while (i < j) {
                    while (comp(*i, pivot)) ++i;
                    do { --j; } while (!comp(*j, pivot));
                    if (i >= j) break;
                    swap(*i, *j);
                    ++i;
                }

                // Place pivot at its final position (just before i)
                RandomIter pivot_pos = i - diff_t(1);
                *first    = std::move(*pivot_pos);
                *pivot_pos = std::move(pivot);

                // [first, pivot_pos) < *pivot_pos <= [pivot_pos+1, last)
                if (!leftmost && !comp(*(first - diff_t(1)), *pivot_pos)) {
                    // Everything in [first, pivot_pos] is equal to pivot
                    first = pivot_pos + diff_t(1);
                    continue;
                }

                // Recurse on smaller partition, tail-recurse on larger
                introsort(first, pivot_pos, comp, depth, leftmost);
                leftmost = false;
                first    = pivot_pos + diff_t(1);
            }
        }
    }
} // namespace detail

// sort (with comparator)
template<class RandomIter, class Compare>
constexpr void
sort(RandomIter first, RandomIter last, Compare comp) {
    if (first == last) return;
    using diff_t = typename iterator_traits<RandomIter>::difference_type;
    diff_t depth = diff_t(2) * diff_t(detail::bit_log2(
        (unsigned long long)(last - first)));
    detail::introsort(first, last, comp, depth, true);
}

// sort (operator<)
template<class RandomIter>
constexpr void
sort(RandomIter first, RandomIter last) {
    sort(first, last, less<>{});
}

