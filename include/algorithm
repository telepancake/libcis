// [alg.sorting] — partial_sort, partial_sort_copy
// (from __algorithm/partial_sort.h, partial_sort_copy.h)
//===----------------------------------------------------------------------===//

// partial_sort (with comparator) — [first, middle) sorted ascending,
// [middle, last) in unspecified order
template<class RandomIter, class Compare>
constexpr void
partial_sort(RandomIter first, RandomIter middle, RandomIter last, Compare comp) {
    if (first == middle) return;
    make_heap(first, middle, comp);
    typename iterator_traits<RandomIter>::difference_type len = middle - first;
    for (RandomIter i = middle; i != last; ++i) {
        if (comp(*i, *first)) {
            swap(*i, *first);
            detail::sift_down(first, comp, len, 0);
        }
    }
    sort_heap(first, middle, comp);
}

// partial_sort (operator<)
template<class RandomIter>
constexpr void
partial_sort(RandomIter first, RandomIter middle, RandomIter last) {
    partial_sort(first, middle, last, less<>{});
}

// partial_sort_copy (with comparator)
template<class InputIter, class RandomIter, class Compare>
constexpr RandomIter
partial_sort_copy(InputIter first, InputIter last,
                  RandomIter result_first, RandomIter result_last,
                  Compare comp) {
    RandomIter r = result_first;
    if (r != result_last) {
        for (; first != last && r != result_last; ++first, (void)++r)
            *r = *first;
        make_heap(result_first, r, comp);
        typename iterator_traits<RandomIter>::difference_type len = r - result_first;
        for (; first != last; ++first) {
            if (comp(*first, *result_first)) {
                *result_first = *first;
                detail::sift_down(result_first, comp, len, 0);
            }
        }
        sort_heap(result_first, r, comp);
    }
    return r;
}

// partial_sort_copy (operator<)
template<class InputIter, class RandomIter>
constexpr RandomIter
partial_sort_copy(InputIter first, InputIter last,
                  RandomIter result_first, RandomIter result_last) {
    return partial_sort_copy(first, last, result_first, result_last, less<>{});
}

