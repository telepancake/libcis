// [alg.sort] — stable_sort
// (from __algorithm/stable_sort.h)
//===----------------------------------------------------------------------===//

namespace detail {
    // merge_move_assign — like merge but moves from input
    template<class Iter1, class Iter2, class OutIter, class Compare>
    constexpr void
    merge_move_assign(Iter1 first1, Iter1 last1,
                      Iter2 first2, Iter2 last2,
                      OutIter result, Compare& comp) {
        for (; first1 != last1; ++result) {
            if (first2 == last2) {
                for (; first1 != last1; ++first1, (void)++result)
                    *result = std::move(*first1);
                return;
            }
            if (comp(*first2, *first1)) {
                *result = std::move(*first2); ++first2;
            } else {
                *result = std::move(*first1); ++first1;
            }
        }
        for (; first2 != last2; ++first2, (void)++result)
            *result = std::move(*first2);
    }

    // stable_sort_impl — mergesort using buff when available
    template<class RandomIter, class Compare>
    void
    stable_sort_impl(RandomIter first, RandomIter last, Compare& comp,
                     typename iterator_traits<RandomIter>::difference_type len,
                     typename iterator_traits<RandomIter>::value_type* buff,
                     ptrdiff_t buff_size) {
        using value_type = typename iterator_traits<RandomIter>::value_type;
        using diff_t     = typename iterator_traits<RandomIter>::difference_type;
        if (len <= 1) return;
        if (len == 2) {
            if (comp(*--last, *first)) swap(*first, *last);
            return;
        }
        // Threshold for insertion sort (same as libc++: trivially-copyable=>128, else 16)
        const diff_t isort_thresh =
            is_trivially_copy_assignable<value_type>::value ? 128 : 16;
        if (len <= isort_thresh) {
            detail::insertion_sort(first, last, comp);
            return;
        }
        diff_t l2 = len / 2;
        RandomIter m = first + l2;
        if (len <= buff_size) {
            // sort both halves in-place, then merge into buff
            stable_sort_impl(first, m, comp, l2, buff, buff_size);
            stable_sort_impl(m, last, comp, len - l2, buff, buff_size);
            // merge first..m and m..last into buff, then copy back
            value_type* bp = buff;
            for (RandomIter i = first; i != m; ++i, (void)++bp)
                ::new (static_cast<void*>(bp)) value_type(std::move(*i));
            value_type* bend = bp;
            bp = buff;
            merge_move_assign(buff, bend, m, last, first, comp);
            for (value_type* p = buff; p != bend; ++p) p->~value_type();
        } else {
            stable_sort_impl(first, m, comp, l2, buff, buff_size);
            stable_sort_impl(m, last, comp, len - l2, buff, buff_size);
            inplace_merge_impl(first, m, last, comp, l2, len - l2, buff, buff_size);
        }
    }
} // namespace detail

// stable_sort (with comparator)
template<class RandomIter, class Compare>
void
stable_sort(RandomIter first, RandomIter last, Compare comp) {
    using value_type = typename iterator_traits<RandomIter>::value_type;
    using diff_t     = typename iterator_traits<RandomIter>::difference_type;
    diff_t len  = last - first;
    value_type* buf = nullptr;
    ptrdiff_t got = 0;
    if (len > 1) {
        buf = static_cast<value_type*>(::operator new(
                  static_cast<size_t>(len) * sizeof(value_type),
                  std::nothrow));
        got = buf ? len : 0;
    }
    detail::stable_sort_impl(first, last, comp, len, buf, got);
    ::operator delete(buf);
}

// stable_sort (operator<)
template<class RandomIter>
void
stable_sort(RandomIter first, RandomIter last) {
    stable_sort(first, last, less<>{});
}

