// min (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr const T&
min(const T& a, const T& b, Compare comp) {
    return comp(b, a) ? b : a;
}

// min (operator<)
template<class T>
[[nodiscard]] constexpr const T&
min(const T& a, const T& b) {
    return (b < a) ? b : a;
}

// min (initializer_list, comparator)
template<class T, class Compare>
[[nodiscard]] constexpr T
min(initializer_list<T> t, Compare comp) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (comp(*it, result)) result = *it;
    return result;
}

// min (initializer_list, operator<)
template<class T>
[[nodiscard]] constexpr T
min(initializer_list<T> t) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (*it < result) result = *it;
    return result;
}

// max (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr const T&
max(const T& a, const T& b, Compare comp) {
    return comp(a, b) ? b : a;
}

// max (operator<)
template<class T>
[[nodiscard]] constexpr const T&
max(const T& a, const T& b) {
    return (a < b) ? b : a;
}

// max (initializer_list, comparator)
template<class T, class Compare>
[[nodiscard]] constexpr T
max(initializer_list<T> t, Compare comp) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (comp(result, *it)) result = *it;
    return result;
}

// max (initializer_list, operator<)
template<class T>
[[nodiscard]] constexpr T
max(initializer_list<T> t) {
    auto it = t.begin();
    T result = *it;
    for (++it; it != t.end(); ++it)
        if (result < *it) result = *it;
    return result;
}

// minmax_result helper
template<class T>
struct minmax_result {
    T min;
    T max;
};

// minmax (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr pair<const T&, const T&>
minmax(const T& a, const T& b, Compare comp) {
    return comp(b, a) ? pair<const T&, const T&>(b, a)
                      : pair<const T&, const T&>(a, b);
}

// minmax (operator<)
template<class T>
[[nodiscard]] constexpr pair<const T&, const T&>
minmax(const T& a, const T& b) {
    return (b < a) ? pair<const T&, const T&>(b, a)
                   : pair<const T&, const T&>(a, b);
}

// minmax (initializer_list, comparator)
template<class T, class Compare>
[[nodiscard]] constexpr pair<T, T>
minmax(initializer_list<T> t, Compare comp) {
    auto it = t.begin();
    T mn = *it, mx = *it;
    for (++it; it != t.end(); ++it) {
        if (comp(*it, mn)) mn = *it;
        if (comp(mx, *it)) mx = *it;
    }
    return {mn, mx};
}

// minmax (initializer_list, operator<)
template<class T>
[[nodiscard]] constexpr pair<T, T>
minmax(initializer_list<T> t) {
    auto it = t.begin();
    T mn = *it, mx = *it;
    for (++it; it != t.end(); ++it) {
        if (*it < mn) mn = *it;
        if (mx < *it) mx = *it;
    }
    return {mn, mx};
}

// clamp (comparator)
template<class T, class Compare>
[[nodiscard]] constexpr const T&
clamp(const T& v, const T& lo, const T& hi, Compare comp) {
    return comp(v, lo) ? lo : comp(hi, v) ? hi : v;
}

// clamp (operator<)
template<class T>
[[nodiscard]] constexpr const T&
clamp(const T& v, const T& lo, const T& hi) {
    return (v < lo) ? lo : (hi < v) ? hi : v;
}

