        if (first2 == last2) return copy(first1, last1, result);
        if (comp(*first1, *first2)) {
            *result = *first1; ++result; ++first1;
        } else {
            if (comp(*first2, *first1)) {
                *result = *first2; ++result;
            } else {
                ++first1;
            }
            ++first2;
