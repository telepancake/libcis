struct move_backward_fn {
    template<bidirectional_iterator I1, sentinel_for<I1> S1, bidirectional_iterator I2>
        requires indirectly_movable<I1, I2>
    constexpr move_backward_result<I1, I2>
    operator()(I1 first, S1 last, I2 result) const {
        I1 last_it = ranges::next(first, last);
        for (I1 i = last_it; i != first;)
            *--result = ranges::iter_move(--i);
        return {std::move(last_it), std::move(result)};
    }

    template<bidirectional_range R, bidirectional_iterator I>
        requires indirectly_movable<iterator_t<R>, I>
    constexpr move_backward_result<borrowed_iterator_t<R>, I>
    operator()(R&& r, I result) const {
