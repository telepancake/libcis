struct is_permutation_fn {
    template<forward_iterator I1, sentinel_for<I1> S1,
             forward_iterator I2, sentinel_for<I2> S2,
             class Proj1 = identity, class Proj2 = identity,
             indirect_equivalence_relation<projected<I1, Proj1>, projected<I2, Proj2>> Pred = equal_to>
    [[nodiscard]] constexpr bool
    operator()(I1 first1, S1 last1, I2 first2, S2 last2,
               Pred pred = {}, Proj1 proj1 = {}, Proj2 proj2 = {}) const {
        // Skip the common prefix.
        while (first1 != last1 && first2 != last2) {
            if (!std::invoke(pred, std::invoke(proj1, *first1), std::invoke(proj2, *first2)))
                break;
            ++first1;
            ++first2;
        }
        if (first1 == last1)
            return first2 == last2;
        if (first2 == last2)
            return false;
        auto l1 = ranges::distance(first1, last1);
        auto l2 = ranges::distance(first2, last2);
        if (l1 != l2)
            return false;
        I1 last1_it = ranges::next(first1, last1);
        I2 last2_it = ranges::next(first2, last2);
        for (I1 i = first1; i != last1_it; ++i) {
            bool already = false;
            for (I1 j = first1; j != i; ++j)
                if (std::invoke(pred, std::invoke(proj1, *j), std::invoke(proj1, *i))) {
                    already = true;
                    break;
                }
            if (already)
                continue;
            decltype(l1) c2 = 0;
            for (I2 j = first2; j != last2_it; ++j)
                if (std::invoke(pred, std::invoke(proj1, *i), std::invoke(proj2, *j)))
                    ++c2;
            if (c2 == 0)
                return false;
            decltype(l1) c1 = 1;
            for (I1 j = ranges::next(i); j != last1_it; ++j)
                if (std::invoke(pred, std::invoke(proj1, *i), std::invoke(proj1, *j)))
                    ++c1;
            if (c1 != c2)
                return false;
        }
        return true;
    }

    template<forward_range R1, forward_range R2,
             class Proj1 = identity, class Proj2 = identity,
             indirect_equivalence_relation<projected<iterator_t<R1>, Proj1>,
                                           projected<iterator_t<R2>, Proj2>> Pred = equal_to>
    [[nodiscard]] constexpr bool
    operator()(R1&& r1, R2&& r2, Pred pred = {}, Proj1 proj1 = {}, Proj2 proj2 = {}) const {
        return (*this)(ranges::begin(r1), ranges::end(r1),
                       ranges::begin(r2), ranges::end(r2),
                       std::move(pred), std::move(proj1), std::move(proj2));
    }
};

inline constexpr is_permutation_fn is_permutation{};

