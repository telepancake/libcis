//===----------------------------------------------------------------------===//
// shuffle  (from __algorithm/shuffle.h)
// DEVIATION from libc++ layering: libc++ includes uniform_int_distribution
// here, but in libcis <random> includes <vector> which includes <algorithm>,
// so <algorithm> cannot include <random> back. shuffle is a template, so a
// forward declaration suffices: the distribution is only instantiated at the
// point of use, and any caller of shuffle has <random> included for the URBG
// it must pass anyway.
//===----------------------------------------------------------------------===//

namespace std {

template<class IntType> class uniform_int_distribution;

// [alg.random.shuffle] std::shuffle — libc++ __algorithm/shuffle.h:
// Fisher-Yates with uniform_int_distribution re-parameterized per step.
template<class RandomAccessIterator, class UniformRandomBitGenerator>
void shuffle(RandomAccessIterator first, RandomAccessIterator last,
             UniformRandomBitGenerator&& g) {
    typedef typename iterator_traits<RandomAccessIterator>::difference_type difference_type;
    // The artificial dependency on the template parameter delays the
    // completeness check on uniform_int_distribution to the instantiation
    // point (where the caller's <random> include has defined it).
    using D = uniform_int_distribution<
        conditional_t<(sizeof(remove_reference_t<UniformRandomBitGenerator>) > 0), ptrdiff_t, ptrdiff_t>>;
    typedef typename D::param_type P;
    difference_type d = last - first;
    if (d > 1) {
        D uid;
        for (--last, (void)--d; first < last; ++first, (void)--d) {
            difference_type i = uid(g, P(0, d));
            if (i != difference_type(0))
                std::iter_swap(first, first + i);
        }
    }
}

} // namespace std

//===----------------------------------------------------------------------===//
// sample  (from __algorithm/sample.h) — same uniform_int_distribution
// forward-declaration technique as shuffle above.
//===----------------------------------------------------------------------===//

namespace std {

namespace detail {
    // Reservoir sampling: input population iterator, random-access output.
    template<class PopIter, class SampleIter, class Distance, class URBG>
    SampleIter sample_impl(PopIter first, PopIter last, SampleIter out,
                           Distance n, URBG& g, input_iterator_tag) {
        using D = uniform_int_distribution<Distance>;
        Distance k = 0;
        for (; first != last && k < n; ++first, (void)++k)
            out[k] = *first;
        Distance sz = k;
        for (; first != last; ++first, (void)++k) {
            Distance r = D(0, k)(g);
            if (r < sz)
                out[r] = *first;
        }
        return out + std::min(n, k);
    }

    // Selection sampling: forward population iterator, any output.
    template<class PopIter, class SampleIter, class Distance, class URBG>
    SampleIter sample_impl(PopIter first, PopIter last, SampleIter out,
                           Distance n, URBG& g, forward_iterator_tag) {
        using D = uniform_int_distribution<Distance>;
        Distance unsampled_sz = static_cast<Distance>(std::distance(first, last));
        for (n = std::min(n, unsampled_sz); n != 0; ++first) {
            Distance r = D(0, --unsampled_sz)(g);
            if (r < n) {
                *out = *first;
                ++out;
                --n;
            }
        }
        return out;
    }
} // namespace detail

template<class PopIter, class SampleIter, class Distance, class URBG>
SampleIter sample(PopIter first, PopIter last, SampleIter out,
                  Distance n, URBG&& g) {
    using PopCat = typename iterator_traits<PopIter>::iterator_category;
    using Difference = typename iterator_traits<PopIter>::difference_type;
    static_assert(is_convertible_v<PopCat, forward_iterator_tag> ||
                  is_convertible_v<typename iterator_traits<SampleIter>::iterator_category,
                                   random_access_iterator_tag>,
                  "SampleIterator must meet the requirements of RandomAccessIterator");
    using CommonType = common_type_t<Distance, Difference>;
    using Tag = conditional_t<is_convertible_v<PopCat, forward_iterator_tag>,
                              forward_iterator_tag, input_iterator_tag>;
    return detail::sample_impl(first, last, out,
                               static_cast<CommonType>(n), g, Tag{});
}

//===----------------------------------------------------------------------===//
// vector<bool> bit_iterator fast paths for count/fill
// (from libc++ __algorithm/count.h __count_bool and __fill_n_bool;
//  bit_iterator and bit_fill_n live in <vector>, which includes <algorithm>,
//  so only forward declarations appear here — instantiation happens at the
//  caller, where <vector> is complete. bit_count is a friend of bit_iterator.)
//===----------------------------------------------------------------------===//

template<class Cp, bool IsConst>
class bit_iterator;

template<class Cp>
constexpr void bit_fill_n(bit_iterator<Cp, false> first,
                          typename Cp::size_type n, bool val) noexcept;

// count specialization for vector<bool> iterators (friend of bit_iterator)
template<class Cp, bool IsConst>
[[nodiscard]] constexpr typename bit_iterator<Cp, IsConst>::difference_type
count(const bit_iterator<Cp, IsConst>& first, const bit_iterator<Cp, IsConst>& last,
      const bool& value) {
    using difference_type = typename bit_iterator<Cp, IsConst>::difference_type;
    using storage_type    = typename Cp::storage_type;
    const unsigned bpw = Cp::bits_per_word;
    difference_type total =
        (last.seg_ - first.seg_) * difference_type(bpw) +
        difference_type(last.ctz_) - difference_type(first.ctz_);
    typename Cp::size_type n = static_cast<typename Cp::size_type>(total);
    difference_type r = 0;
    auto seg = first.seg_;
    // first partial word
    if (n > 0 && first.ctz_ != 0) {
        unsigned clz_f = bpw - first.ctz_;
        typename Cp::size_type dn = clz_f < n ? clz_f : n;
        storage_type m =
            (static_cast<storage_type>(~storage_type(0)) >> (clz_f - dn)) &
            (static_cast<storage_type>(~storage_type(0)) << first.ctz_);
        r += __builtin_popcountll(static_cast<unsigned long long>(*seg & m));
        n -= dn;
        ++seg;
    }
    // whole words
    for (; n >= bpw; n -= bpw) {
        r += __builtin_popcountll(static_cast<unsigned long long>(*seg));
        ++seg;
    }
    // last partial word
    if (n > 0) {
        storage_type m = static_cast<storage_type>(~storage_type(0)) >> (bpw - n);
        r += __builtin_popcountll(static_cast<unsigned long long>(*seg & m));
    }
    return value ? r : total - r;
}

// fill specialization for vector<bool> iterators (friend of bit_iterator)
template<class Cp>
constexpr void
fill(const bit_iterator<Cp, false>& first, const bit_iterator<Cp, false>& last,
     const bool& value) {
    using storage_type = typename Cp::storage_type;
    const unsigned bpw = Cp::bits_per_word;
    using difference_type = typename bit_iterator<Cp, false>::difference_type;
    typename Cp::size_type n = static_cast<typename Cp::size_type>(
        (last.seg_ - first.seg_) * difference_type(bpw) +
        difference_type(last.ctz_) - difference_type(first.ctz_));
    if (n == 0)
        return;
    auto seg = first.seg_;
    // first partial word
    if (first.ctz_ != 0) {
        unsigned clz_f = bpw - first.ctz_;
        typename Cp::size_type dn = clz_f < n ? clz_f : n;
        storage_type m =
            (static_cast<storage_type>(~storage_type(0)) >> (clz_f - dn)) &
            (static_cast<storage_type>(~storage_type(0)) << first.ctz_);
        if (value) *seg |=  m;
        else       *seg &= ~m;
        n -= dn;
        ++seg;
    }
    // middle whole words
    storage_type fill_val = value ? static_cast<storage_type>(~storage_type(0)) : storage_type(0);
    for (; n >= bpw; n -= bpw) {
        *seg = fill_val;
        ++seg;
    }
    // last partial word
    if (n > 0) {
        storage_type m = static_cast<storage_type>(~storage_type(0)) >> (bpw - n);
        if (value) *seg |=  m;
        else       *seg &= ~m;
    }
}

// fill_n specialization for vector<bool> iterators
template<class Cp, class Size>
constexpr bit_iterator<Cp, false>
fill_n(bit_iterator<Cp, false> first, Size n, const bool& value) {
    auto count = static_cast<typename Cp::size_type>(detail::convert_to_integral(n));
    std::bit_fill_n(first, count, value);
    return first + static_cast<typename bit_iterator<Cp, false>::difference_type>(count);
}

