// is_sorted_until (with comparator)
template<class ForwardIter, class Compare>
[[nodiscard]] constexpr ForwardIter
is_sorted_until(ForwardIter first, ForwardIter last, Compare comp) {
    if (first != last) {
        ForwardIter i = first;
        while (++i != last) {
            if (comp(*i, *first)) return i;
            first = i;
        }
    }
    return last;
}

// is_sorted_until (operator<)
template<class ForwardIter>
[[nodiscard]] constexpr ForwardIter
is_sorted_until(ForwardIter first, ForwardIter last) {
    return is_sorted_until(first, last, less<>{});
}

// is_sorted (with comparator)
