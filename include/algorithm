                 InputIter2 first2, InputIter2 last2,
                 OutputIter result, Compare comp) {
    return detail::set_intersection_impl(
               std::move(first1), std::move(last1),
               std::move(first2), std::move(last2), std::move(result), comp,
               detail::set_intersection_dispatch_tag<InputIter1>{},
               detail::set_intersection_dispatch_tag<InputIter2>{}).out;
}

