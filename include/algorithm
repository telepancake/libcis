// lower_bound (with comparator) — first position where !(comp(*it, value))
template<class ForwardIter, class T, class Compare>
[[nodiscard]] constexpr ForwardIter
lower_bound(ForwardIter first, ForwardIter last, const T& value, Compare comp) {
    auto len = distance(first, last);
    while (len != 0) {
        auto half = len / 2;
        ForwardIter mid = first;
        advance(mid, half);
        if (comp(*mid, value)) {
            first = ++mid;
            len -= half + 1;
        } else {
            len = half;
        }
    }
    return first;
}

// lower_bound (operator<)
template<class ForwardIter, class T>
[[nodiscard]] constexpr ForwardIter
lower_bound(ForwardIter first, ForwardIter last, const T& value) {
    return lower_bound(first, last, value, less<>{});
}

// upper_bound (with comparator) — first position where comp(value, *it)
template<class ForwardIter, class T, class Compare>
[[nodiscard]] constexpr ForwardIter
upper_bound(ForwardIter first, ForwardIter last, const T& value, Compare comp) {
    auto len = distance(first, last);
    while (len != 0) {
        auto half = len / 2;
        ForwardIter mid = first;
        advance(mid, half);
        if (comp(value, *mid)) {
            len = half;
        } else {
            first = ++mid;
            len -= half + 1;
        }
    }
    return first;
}

// upper_bound (operator<)
template<class ForwardIter, class T>
[[nodiscard]] constexpr ForwardIter
upper_bound(ForwardIter first, ForwardIter last, const T& value) {
    return upper_bound(first, last, value, less<>{});
}

// equal_range (with comparator)
template<class ForwardIter, class T, class Compare>
[[nodiscard]] constexpr pair<ForwardIter, ForwardIter>
equal_range(ForwardIter first, ForwardIter last, const T& value, Compare comp) {
    auto len  = distance(first, last);
    ForwardIter end = last;
    while (len != 0) {
        auto half = len / 2;
        ForwardIter mid = first;
        advance(mid, half);
        if (comp(*mid, value)) {
            first = ++mid;
            len -= half + 1;
        } else if (comp(value, *mid)) {
            end = mid;
            len = half;
        } else {
            ForwardIter mp1 = mid;
            return {lower_bound(first, mid, value, comp),
                    upper_bound(++mp1, end, value, comp)};
        }
    }
    return {first, first};
}

// equal_range (operator<)
template<class ForwardIter, class T>
[[nodiscard]] constexpr pair<ForwardIter, ForwardIter>
equal_range(ForwardIter first, ForwardIter last, const T& value) {
    return equal_range(first, last, value, less<>{});
}

// binary_search (with comparator)
template<class ForwardIter, class T, class Compare>
[[nodiscard]] constexpr bool
binary_search(ForwardIter first, ForwardIter last, const T& value, Compare comp) {
    first = lower_bound(first, last, value, comp);
    return first != last && !comp(value, *first);
}

// binary_search (operator<)
template<class ForwardIter, class T>
[[nodiscard]] constexpr bool
binary_search(ForwardIter first, ForwardIter last, const T& value) {
    return binary_search(first, last, value, less<>{});
}

