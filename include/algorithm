//===----------------------------------------------------------------------===//
// detail::convert_to_integral (from __utility/convert_to_integral.h)
// Converts user-defined integer-like count types to a real integral type so
// the *_n algorithm loops use built-in arithmetic/comparisons.
//===----------------------------------------------------------------------===//

namespace detail {
    inline constexpr int                convert_to_integral(int v)                { return v; }
    inline constexpr unsigned           convert_to_integral(unsigned v)           { return v; }
    inline constexpr long               convert_to_integral(long v)               { return v; }
    inline constexpr unsigned long      convert_to_integral(unsigned long v)      { return v; }
    inline constexpr long long          convert_to_integral(long long v)          { return v; }
    inline constexpr unsigned long long convert_to_integral(unsigned long long v) { return v; }
#if defined(__SIZEOF_INT128__)
    inline constexpr __int128_t         convert_to_integral(__int128_t v)         { return v; }
    inline constexpr __uint128_t        convert_to_integral(__uint128_t v)        { return v; }
#endif

    template<class Fp, enable_if_t<is_floating_point_v<Fp>, int> = 0>
    constexpr long long convert_to_integral(Fp v) { return static_cast<long long>(v); }

    template<class T, bool = is_enum_v<T>>
    struct sfinae_underlying_type {
        using type = __underlying_type(T);
        using promoted_type = decltype(((type)1) + 0);
    };
    template<class T>
    struct sfinae_underlying_type<T, false> {};

    template<class T, enable_if_t<is_enum_v<T>, int> = 0>
    constexpr typename sfinae_underlying_type<T>::promoted_type
    convert_to_integral(T v) { return static_cast<typename sfinae_underlying_type<T>::promoted_type>(v); }

    // Fallback for class types convertible to an integral (e.g. the test
    // suite's UserDefinedIntegral): use the promoted result of `v + 0`.
    template<class T, enable_if_t<is_class_v<T>, int> = 0>
    constexpr decltype(declval<T>() + 0) convert_to_integral(T v) { return v + 0; }
} // namespace detail

