// includes (with comparator) — true iff [first2,last2) is a subset of [first1,last1)
template<class InputIter1, class InputIter2, class Compare>
[[nodiscard]] constexpr bool
includes(InputIter1 first1, InputIter1 last1,
         InputIter2 first2, InputIter2 last2,
         Compare comp) {
    for (; first2 != last2; ++first1) {
        if (first1 == last1 || comp(*first2, *first1)) return false;
        if (!comp(*first1, *first2)) ++first2;
    }
    return true;
}

// includes (operator<)
template<class InputIter1, class InputIter2>
[[nodiscard]] constexpr bool
includes(InputIter1 first1, InputIter1 last1,
         InputIter2 first2, InputIter2 last2) {
    return includes(first1, last1, first2, last2, less<>{});
}

// set_union (with comparator)
template<class InputIter1, class InputIter2, class OutputIter, class Compare>
constexpr OutputIter
set_union(InputIter1 first1, InputIter1 last1,
          InputIter2 first2, InputIter2 last2,
          OutputIter result, Compare comp) {
    for (; first1 != last1; ++result) {
        if (first2 == last2) return copy(first1, last1, result);
        if (comp(*first2, *first1)) {
            *result = *first2; ++first2;
        } else {
            if (!comp(*first1, *first2)) ++first2;
            *result = *first1; ++first1;
        }
    }
    return copy(first2, last2, result);
}

// set_union (operator<)
template<class InputIter1, class InputIter2, class OutputIter>
constexpr OutputIter
set_union(InputIter1 first1, InputIter1 last1,
          InputIter2 first2, InputIter2 last2,
          OutputIter result) {
    return set_union(first1, last1, first2, last2, result, less<>{});
}

// set_intersection — ported from libc++ __algorithm/set_intersection.h,
// including the one-sided binary search optimization for forward iterators
// (required for the documented comparison-complexity guarantees).
namespace detail {
    template<class I1, class I2, class O>
    struct set_intersection_result3 {
        I1 in1;
        I2 in2;
        O  out;
    };

    // __lower_bound_bisecting
    template<class Iter, class T, class Comp>
    constexpr Iter
    lower_bound_bisecting(Iter first, const T& value,
                          typename iterator_traits<Iter>::difference_type len,
                          Comp& comp) {
        while (len != 0) {
            auto l2 = len / 2;
            Iter m = first;
            std::advance(m, l2);
            if (comp(*m, value)) {
                first = ++m;
                len -= l2 + 1;
            } else {
                len = l2;
            }
        }
        return first;
    }

    // __lower_bound_onesided (meta binary search)
    template<class Iter, class Sent, class T, class Comp>
    constexpr Iter
    lower_bound_onesided(Iter first, Sent last, const T& value, Comp& comp) {
        // step = 0, ensuring we can always short-circuit when distance is 1 later on
        if (first == last || !comp(*first, value))
            return first;
        using Distance = typename iterator_traits<Iter>::difference_type;
        for (Distance step = 1; first != last; step <<= 1) {
            Iter it = first;
            Distance traveled = 0;
            for (; traveled != step && it != last; ++traveled)
                ++it;
            Distance dist = traveled;
            // once we reach the last range where the needle can be we must
            // start looking inwards, bisecting that range
            if (it == last || !comp(*it, value)) {
                // we've already checked the previous value and it was less; we
                // can save one comparison by skipping bisection
                if (dist == 1)
                    return it;
                return detail::lower_bound_bisecting(first, value, dist, comp);
            }
            // range not found, move forward!
            first = it;
        }
        return first;
    }

    // __set_intersection_add_output_if_equal
    template<class I1, class I2, class O>
    constexpr void
    set_intersection_add_output_if_equal(bool may_be_equal,
                                         I1& first1, I2& first2, O& result,
                                         bool& prev_may_be_equal) {
        if (may_be_equal && prev_may_be_equal) {
            *result = *first1;
            ++result;
            ++first1;
            ++first2;
            prev_may_be_equal = false;
        } else {
            prev_may_be_equal = may_be_equal;
        }
    }

    // forward/forward: one-sided binary search version
    template<class I1, class S1, class I2, class S2, class O, class Comp>
    constexpr set_intersection_result3<I1, I2, O>
    set_intersection_impl(I1 first1, S1 last1, I2 first2, S2 last2, O result,
                          Comp&& comp,
                          forward_iterator_tag, forward_iterator_tag) {
        bool prev_may_be_equal = false;
        while (first2 != last2) {
            I1 first1_next = detail::lower_bound_onesided(first1, last1, *first2, comp);
            std::swap(first1_next, first1);
            // keeping in mind that a==b iff !(a<b) && !(b<a):
            // if we can't advance first1, that means !(*first1 < *first2),
            // therefore may_be_equal==true
            detail::set_intersection_add_output_if_equal(
                first1 == first1_next, first1, first2, result, prev_may_be_equal);
            if (first1 == last1)
                break;
            I2 first2_next = detail::lower_bound_onesided(first2, last2, *first1, comp);
            std::swap(first2_next, first2);
            detail::set_intersection_add_output_if_equal(
                first2 == first2_next, first1, first2, result, prev_may_be_equal);
        }
        while (first1 != last1)
            ++first1;
        while (first2 != last2)
            ++first2;
        return {std::move(first1), std::move(first2), std::move(result)};
    }

    // input iterators: classic single-pass version
    template<class I1, class S1, class I2, class S2, class O, class Comp>
    constexpr set_intersection_result3<I1, I2, O>
    set_intersection_impl(I1 first1, S1 last1, I2 first2, S2 last2, O result,
                          Comp&& comp,
                          input_iterator_tag, input_iterator_tag) {
        while (first1 != last1 && first2 != last2) {
            if (comp(*first1, *first2)) {
                ++first1;
            } else {
                if (!comp(*first2, *first1)) {
                    *result = *first1;
                    ++result;
                    ++first1;
                }
                ++first2;
            }
        }
        while (first1 != last1)
            ++first1;
        while (first2 != last2)
            ++first2;
        return {std::move(first1), std::move(first2), std::move(result)};
    }

    template<class Iter>
    using set_intersection_dispatch_tag =
        conditional_t<is_convertible_v<typename iterator_traits<Iter>::iterator_category,
                                       forward_iterator_tag>,
                      forward_iterator_tag, input_iterator_tag>;
} // namespace detail

// set_intersection (with comparator)
