// [alg.min.max] — min_element, max_element, minmax_element
// (from __algorithm/min_element.h, max_element.h, minmax_element.h)
//===----------------------------------------------------------------------===//

// min_element (comparator)
template<class ForwardIter, class Compare>
[[nodiscard]] constexpr ForwardIter
min_element(ForwardIter first, ForwardIter last, Compare comp) {
    if (first == last) return last;
    ForwardIter result = first;
    for (++first; first != last; ++first)
        if (comp(*first, *result)) result = first;
    return result;
}

// min_element (operator<)
template<class ForwardIter>
[[nodiscard]] constexpr ForwardIter
min_element(ForwardIter first, ForwardIter last) {
    if (first == last) return last;
    ForwardIter result = first;
    for (++first; first != last; ++first)
        if (*first < *result) result = first;
    return result;
}

// max_element (comparator)
template<class ForwardIter, class Compare>
[[nodiscard]] constexpr ForwardIter
max_element(ForwardIter first, ForwardIter last, Compare comp) {
    if (first == last) return last;
    ForwardIter result = first;
    for (++first; first != last; ++first)
        if (comp(*result, *first)) result = first;
    return result;
}

// max_element (operator<)
template<class ForwardIter>
[[nodiscard]] constexpr ForwardIter
max_element(ForwardIter first, ForwardIter last) {
    if (first == last) return last;
    ForwardIter result = first;
    for (++first; first != last; ++first)
        if (*result < *first) result = first;
    return result;
}

// minmax_element (comparator)
template<class ForwardIter, class Compare>
[[nodiscard]] constexpr pair<ForwardIter, ForwardIter>
minmax_element(ForwardIter first, ForwardIter last, Compare comp) {
    pair<ForwardIter, ForwardIter> result(first, first);
    if (first == last || ++first == last)
        return result;
    if (comp(*first, *result.first))
        result.first = first;
    else
        result.second = first;
    while (++first != last) {
        ForwardIter i = first;
        if (++first == last) {
            if (comp(*i, *result.first)) result.first = i;
            else if (!comp(*i, *result.second)) result.second = i;
            break;
        } else {
            if (comp(*first, *i)) {
                if (comp(*first, *result.first)) result.first = first;
                if (!comp(*i, *result.second)) result.second = i;
            } else {
                if (comp(*i, *result.first)) result.first = i;
                if (!comp(*first, *result.second)) result.second = first;
            }
        }
    }
    return result;
}

// minmax_element (operator<)
template<class ForwardIter>
[[nodiscard]] constexpr pair<ForwardIter, ForwardIter>
minmax_element(ForwardIter first, ForwardIter last) {
    return minmax_element(first, last, less<typename iterator_traits<ForwardIter>::value_type>{});
}

