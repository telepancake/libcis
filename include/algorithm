// is_permutation (3-iterator, with predicate)
template<class ForwardIter1, class ForwardIter2, class BinaryPred>
[[nodiscard]] constexpr bool
is_permutation(ForwardIter1 first1, ForwardIter1 last1,
               ForwardIter2 first2, BinaryPred pred) {
    // Skip equal prefix
    for (; first1 != last1; ++first1, (void)++first2)
        if (!pred(*first1, *first2)) break;
    if (first1 == last1) return true;
    using diff_t = typename iterator_traits<ForwardIter1>::difference_type;
    diff_t l1 = distance(first1, last1);
    if (l1 == diff_t(1)) return false;
    ForwardIter2 last2 = first2;
    advance(last2, l1);
    // For each element in [first1, last1), verify same count in [first2, last2)
    for (ForwardIter1 i = first1; i != last1; ++i) {
        // Check if *i already counted
        bool already = false;
        for (ForwardIter1 j = first1; j != i; ++j)
            if (pred(*j, *i)) { already = true; break; }
        if (already) continue;
        diff_t c2 = 0;
        for (ForwardIter2 j = first2; j != last2; ++j)
            if (pred(*i, *j)) ++c2;
        if (c2 == 0) return false;
        diff_t c1 = 1;
        for (ForwardIter1 j = next(i); j != last1; ++j)
            if (pred(*i, *j)) ++c1;
        if (c1 != c2) return false;
    }
    return true;
}

// is_permutation (3-iterator, operator==)
template<class ForwardIter1, class ForwardIter2>
[[nodiscard]] constexpr bool
is_permutation(ForwardIter1 first1, ForwardIter1 last1, ForwardIter2 first2) {
    return is_permutation(first1, last1, first2, equal_to<>{});
}

// is_permutation (4-iterator, with predicate)
template<class ForwardIter1, class ForwardIter2, class BinaryPred>
[[nodiscard]] constexpr bool
is_permutation(ForwardIter1 first1, ForwardIter1 last1,
               ForwardIter2 first2, ForwardIter2 last2,
               BinaryPred pred) {
    // libc++: when both ranges are random-access, a length mismatch returns
    // false with ZERO predicate applications (the tests assert the count).
    if constexpr (is_convertible_v<typename iterator_traits<ForwardIter1>::iterator_category,
                                   random_access_iterator_tag> &&
                  is_convertible_v<typename iterator_traits<ForwardIter2>::iterator_category,
                                   random_access_iterator_tag>) {
        if (last1 - first1 != last2 - first2)
            return false;
    }
    // Skip equal prefix
    while (first1 != last1 && first2 != last2) {
        if (!pred(*first1, *first2)) break;
        ++first1; ++first2;
    }
    if (first1 == last1) return first2 == last2;
    if (first2 == last2) return false;
    auto l1 = distance(first1, last1);
    auto l2 = distance(first2, last2);
    if (l1 != l2) return false;
    // For each element in [first1, last1), verify same count in [first2, last2)
    for (ForwardIter1 i = first1; i != last1; ++i) {
        bool already = false;
        for (ForwardIter1 j = first1; j != i; ++j)
            if (pred(*j, *i)) { already = true; break; }
        if (already) continue;
        decltype(l1) c2 = 0;
        for (ForwardIter2 j = first2; j != last2; ++j)
            if (pred(*i, *j)) ++c2;
        if (c2 == 0) return false;
        decltype(l1) c1 = 1;
        for (ForwardIter1 j = next(i); j != last1; ++j)
            if (pred(*i, *j)) ++c1;
        if (c1 != c2) return false;
    }
    return true;
}

// is_permutation (4-iterator, operator==)
template<class ForwardIter1, class ForwardIter2>
[[nodiscard]] constexpr bool
is_permutation(ForwardIter1 first1, ForwardIter1 last1,
               ForwardIter2 first2, ForwardIter2 last2) {
    return is_permutation(first1, last1, first2, last2, equal_to<>{});
}

