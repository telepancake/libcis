struct is_sorted_fn {
    template<forward_iterator I, sentinel_for<I> S,
             class Proj = identity,
             indirect_strict_weak_order<projected<I, Proj>> Comp = less>
    [[nodiscard]] constexpr bool
    operator()(I first, S last, Comp comp = {}, Proj proj = {}) const {
        if (first == last) return true;
        I nxt = first;
        for (++nxt; nxt != last; ++first, (void)++nxt)
            if (std::invoke(comp, std::invoke(proj, *nxt), std::invoke(proj, *first)))
                return false;
        return true;
    }

    template<forward_range R,
             class Proj = identity,
             indirect_strict_weak_order<projected<iterator_t<R>, Proj>> Comp = less>
    [[nodiscard]] constexpr bool
    operator()(R&& r, Comp comp = {}, Proj proj = {}) const {
        return (*this)(ranges::begin(r), ranges::end(r),
                       std::move(comp), std::move(proj));
    }
};

