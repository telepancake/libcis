struct find_first_of_fn {
    template<input_iterator I1, sentinel_for<I1> S1,
             forward_iterator I2, sentinel_for<I2> S2,
             class Pred = equal_to,
             class Proj1 = identity,
             class Proj2 = identity>
        requires indirect_binary_predicate<Pred, projected<I1, Proj1>, projected<I2, Proj2>>
    [[nodiscard]] constexpr I1
    operator()(I1 first1, S1 last1,
               I2 first2, S2 last2,
               Pred pred = {}, Proj1 proj1 = {}, Proj2 proj2 = {}) const {
        for (; first1 != last1; ++first1)
            for (I2 it = first2; it != last2; ++it)
                if (std::invoke(pred,
                                std::invoke(proj1, *first1),
                                std::invoke(proj2, *it)))
                    return first1;
        return first1;
    }

    template<input_range R1, forward_range R2,
             class Pred = equal_to,
             class Proj1 = identity,
             class Proj2 = identity>
        requires indirect_binary_predicate<Pred,
                    projected<iterator_t<R1>, Proj1>,
                    projected<iterator_t<R2>, Proj2>>
    [[nodiscard]] constexpr borrowed_iterator_t<R1>
    operator()(R1&& r1, R2&& r2,
               Pred pred = {}, Proj1 proj1 = {}, Proj2 proj2 = {}) const {
        return (*this)(ranges::begin(r1), ranges::end(r1),
                       ranges::begin(r2), ranges::end(r2),
                       std::move(pred), std::move(proj1), std::move(proj2));
    }
};

