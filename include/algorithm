struct unique_fn {
    template<permutable I, sentinel_for<I> S,
             class Proj = identity,
             indirect_equivalence_relation<projected<I, Proj>> Comp = equal_to>
    [[nodiscard]] constexpr subrange<I>
    operator()(I first, S last, Comp comp = {}, Proj proj = {}) const {
        // adjacent_find
        I tail = ranges::next(first, last);
        detail::proj_comp<Comp, Proj> pc{comp, proj};
        I ret = std::unique(std::move(first), tail, pc);
        return {std::move(ret), std::move(tail)};
    }

    template<forward_range R,
             class Proj = identity,
             indirect_equivalence_relation<projected<iterator_t<R>, Proj>> Comp = equal_to>
        requires permutable<iterator_t<R>>
    [[nodiscard]] constexpr borrowed_subrange_t<R>
    operator()(R&& r, Comp comp = {}, Proj proj = {}) const {
        return (*this)(ranges::begin(r), ranges::end(r),
                       std::move(comp), std::move(proj));
    }
};

inline constexpr unique_fn unique{};

struct unique_copy_fn {
    template<input_iterator I, sentinel_for<I> S, weakly_incrementable O,
             class Proj = identity,
             indirect_equivalence_relation<projected<I, Proj>> Comp = equal_to>
        requires indirectly_copyable<I, O> &&
                 (forward_iterator<I> ||
                  (input_iterator<O> && same_as<iter_value_t<I>, iter_value_t<O>>) ||
                  indirectly_copyable_storable<I, O>)
    constexpr unique_copy_result<I, O>
    operator()(I first, S last, O result, Comp comp = {}, Proj proj = {}) const {
        if (first == last)
            return {std::move(first), std::move(result)};
        if constexpr (forward_iterator<I>) {
            I i = first;
            *result = *i;
            ++result;
            while (++first != last) {
                if (!std::invoke(comp, std::invoke(proj, *i), std::invoke(proj, *first))) {
                    *result = *first;
                    ++result;
                    i = first;
                }
            }
            return {std::move(first), std::move(result)};
        } else {
            iter_value_t<I> t(*first);
            *result = t;
            ++result;
            while (++first != last) {
                if (!std::invoke(comp, std::invoke(proj, t), std::invoke(proj, *first))) {
                    t = *first;
                    *result = t;
                    ++result;
                }
            }
            return {std::move(first), std::move(result)};
        }
    }

    template<input_range R, weakly_incrementable O,
             class Proj = identity,
             indirect_equivalence_relation<projected<iterator_t<R>, Proj>> Comp = equal_to>
        requires indirectly_copyable<iterator_t<R>, O> &&
                 (forward_iterator<iterator_t<R>> ||
                  (input_iterator<O> && same_as<range_value_t<R>, iter_value_t<O>>) ||
                  indirectly_copyable_storable<iterator_t<R>, O>)
    constexpr unique_copy_result<borrowed_iterator_t<R>, O>
    operator()(R&& r, O result, Comp comp = {}, Proj proj = {}) const {
        return (*this)(ranges::begin(r), ranges::end(r), std::move(result),
                       std::move(comp), std::move(proj));
    }
};

