[[nodiscard]] constexpr bool
is_sorted(ForwardIter first, ForwardIter last, Compare comp) {
    return is_sorted_until(first, last, comp) == last;
}

// is_sorted (operator<)
template<class ForwardIter>
[[nodiscard]] constexpr bool
is_sorted(ForwardIter first, ForwardIter last) {
