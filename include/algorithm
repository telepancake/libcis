template<class BidiIter>
constexpr bool
next_permutation(BidiIter first, BidiIter last) {
    return next_permutation(first, last, less<>{});
}

// prev_permutation (with comparator)
template<class BidiIter, class Compare>
constexpr bool
prev_permutation(BidiIter first, BidiIter last, Compare comp) {
    BidiIter i = last;
    if (first == last || first == --i) return false;
    while (true) {
        BidiIter ip1 = i;
        if (comp(*ip1, *--i)) {
            BidiIter j = last;
            while (!comp(*--j, *i))
                ;
            swap(*i, *j);
            reverse(ip1, last);
            return true;
        }
        if (i == first) {
            reverse(first, last);
            return false;
        }
    }
}

