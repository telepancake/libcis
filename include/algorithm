// is_heap_until (with comparator)
template<class RandomIter, class Compare>
[[nodiscard]] constexpr RandomIter
is_heap_until(RandomIter first, RandomIter last, Compare comp) {
    using diff_t = typename iterator_traits<RandomIter>::difference_type;
    diff_t len = last - first;
    diff_t p   = 0;
    diff_t c   = 1;
    RandomIter pp = first;
    while (c < len) {
        RandomIter cp = first + c;
        if (comp(*pp, *cp)) return cp;
        ++c;
        ++cp;
        if (c == len) return last;
        if (comp(*pp, *cp)) return cp;
        ++p;
        ++pp;
        c = 2 * p + 1;
    }
    return last;
}

// is_heap_until (operator<)
template<class RandomIter>
[[nodiscard]] constexpr RandomIter
is_heap_until(RandomIter first, RandomIter last) {
    return is_heap_until(first, last, less<>{});
}

// is_heap (with comparator)
template<class RandomIter, class Compare>
[[nodiscard]] constexpr bool
is_heap(RandomIter first, RandomIter last, Compare comp) {
    return is_heap_until(first, last, comp) == last;
}

// is_heap (operator<)
template<class RandomIter>
[[nodiscard]] constexpr bool
is_heap(RandomIter first, RandomIter last) {
    return is_heap(first, last, less<>{});
}

// sift_up — moves element at (last-1) up into the heap [first, last)
namespace detail {
    template<class RandomIter, class Compare>
    constexpr void
    sift_up(RandomIter first, RandomIter last, Compare& comp,
            typename iterator_traits<RandomIter>::difference_type len) {
        using value_type = typename iterator_traits<RandomIter>::value_type;
        if (len > 1) {
            len = (len - 2) / 2;
            RandomIter ptr = first + len;
            if (comp(*ptr, *--last)) {
                value_type t(std::move(*last));
                do {
                    *last = std::move(*ptr);
                    last  = ptr;
                    if (len == 0) break;
                    len = (len - 1) / 2;
                    ptr = first + len;
                } while (comp(*ptr, t));
                *last = std::move(t);
            }
        }
    }

    // sift_down — sifts element at position start downward in heap [first, first+n)
    template<class RandomIter, class Compare>
    constexpr void
    sift_down(RandomIter first, Compare& comp,
              typename iterator_traits<RandomIter>::difference_type len,
              typename iterator_traits<RandomIter>::difference_type start) {
        using diff_t     = typename iterator_traits<RandomIter>::difference_type;
        using value_type = typename iterator_traits<RandomIter>::value_type;
        diff_t child = start;
        if (len < 2 || (len - 2) / 2 < child) return;
        child = 2 * child + 1;
        if ((child + 1) < len && comp(first[child], first[child + 1]))
            ++child;
        if (comp(first[child], first[start])) return;
        value_type top(std::move(first[start]));
        do {
            first[start] = std::move(first[child]);
            start = child;
            if ((len - 2) / 2 < child) break;
            child = 2 * child + 1;
            if ((child + 1) < len && comp(first[child], first[child + 1]))
                ++child;
        } while (!comp(first[child], top));
        first[start] = std::move(top);
    }

    // floyd_sift_down — sifts down unconditionally (used by pop_heap)
    // Returns the position of the hole after sifting down to a leaf.
    template<class RandomIter, class Compare>
    constexpr RandomIter
    floyd_sift_down(RandomIter first, Compare& comp,
                    typename iterator_traits<RandomIter>::difference_type len) {
        using diff_t = typename iterator_traits<RandomIter>::difference_type;
        RandomIter hole = first;
        RandomIter child_i = first;
        diff_t child = 0;
        while (true) {
            child_i += diff_t(child + 1);
            child = 2 * child + 1;
            if ((child + 1) < len && comp(*child_i, *(child_i + diff_t(1)))) {
                ++child_i;
                ++child;
            }
            *hole = std::move(*child_i);
            hole  = child_i;
            if (child > (len - 2) / 2) return hole;
        }
    }
} // namespace detail

// push_heap (with comparator) — [first, last-1) is a heap; bubble last-1 up
template<class RandomIter, class Compare>
constexpr void
push_heap(RandomIter first, RandomIter last, Compare comp) {
    typename iterator_traits<RandomIter>::difference_type len = last - first;
    detail::sift_up(first, last, comp, len);
}

// push_heap (operator<)
template<class RandomIter>
constexpr void
push_heap(RandomIter first, RandomIter last) {
    push_heap(first, last, less<>{});
}

// pop_heap (with comparator) — swaps max to last-1, re-heapifies [first, last-1)
template<class RandomIter, class Compare>
constexpr void
pop_heap(RandomIter first, RandomIter last, Compare comp) {
    using value_type = typename iterator_traits<RandomIter>::value_type;
    typename iterator_traits<RandomIter>::difference_type len = last - first;
    if (len > 1) {
        value_type top = std::move(*first);
        RandomIter hole = detail::floyd_sift_down(first, comp, len);
        --last;
        if (hole == last) {
            *hole = std::move(top);
        } else {
            *hole = std::move(*last);
            ++hole;
            *last = std::move(top);
            detail::sift_up(first, hole, comp, hole - first);
        }
    }
}

// pop_heap (operator<)
template<class RandomIter>
constexpr void
pop_heap(RandomIter first, RandomIter last) {
    pop_heap(first, last, less<>{});
}

// make_heap (with comparator) — heapify [first, last) in O(n)
template<class RandomIter, class Compare>
constexpr void
make_heap(RandomIter first, RandomIter last, Compare comp) {
    using diff_t = typename iterator_traits<RandomIter>::difference_type;
    diff_t n = last - first;
    if (n > 1) {
        for (diff_t start = (n - 2) / 2; start >= 0; --start)
            detail::sift_down(first, comp, n, start);
    }
}

// make_heap (operator<)
template<class RandomIter>
constexpr void
make_heap(RandomIter first, RandomIter last) {
    make_heap(first, last, less<>{});
}

// sort_heap (with comparator) — sorts a heap in ascending order
template<class RandomIter, class Compare>
constexpr void
sort_heap(RandomIter first, RandomIter last, Compare comp) {
    for (typename iterator_traits<RandomIter>::difference_type n = last - first;
         n > 1; --last, --n)
        pop_heap(first, last, comp);
}

// sort_heap (operator<)
template<class RandomIter>
constexpr void
sort_heap(RandomIter first, RandomIter last) {
    sort_heap(first, last, less<>{});
}

