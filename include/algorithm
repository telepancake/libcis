struct min_fn {
    template<class T,
             class Proj = identity,
             indirect_strict_weak_order<projected<const T*, Proj>> Comp = less>
    [[nodiscard]] constexpr const T&
    operator()(const T& a, const T& b, Comp comp = {}, Proj proj = {}) const {
        return std::invoke(comp, std::invoke(proj, b), std::invoke(proj, a)) ? b : a;
    }

    template<copyable T,
             class Proj = identity,
             indirect_strict_weak_order<projected<const T*, Proj>> Comp = less>
    [[nodiscard]] constexpr T
    operator()(initializer_list<T> r, Comp comp = {}, Proj proj = {}) const {
        auto it = r.begin();
        T result = *it;
        for (++it; it != r.end(); ++it)
            if (std::invoke(comp, std::invoke(proj, *it), std::invoke(proj, result)))
                result = *it;
        return result;
    }

    template<input_range R,
             class Proj = identity,
             indirect_strict_weak_order<projected<iterator_t<R>, Proj>> Comp = less>
        requires indirectly_copyable_storable<iterator_t<R>, range_value_t<R>*>
    [[nodiscard]] constexpr range_value_t<R>
    operator()(R&& r, Comp comp = {}, Proj proj = {}) const {
        auto first = ranges::begin(r);
        auto last  = ranges::end(r);
        range_value_t<R> result = *first;
        for (++first; first != last; ++first)
            if (std::invoke(comp, std::invoke(proj, *first), std::invoke(proj, result)))
                result = *first;
        return result;
    }
};

