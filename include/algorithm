// [alg.partitions] — is_partitioned, partition, stable_partition,
//   partition_copy, partition_point
// (from __algorithm/is_partitioned.h, partition.h, stable_partition.h,
//  partition_copy.h, partition_point.h)
//===----------------------------------------------------------------------===//

// is_partitioned
template<class InputIter, class Predicate>
[[nodiscard]] constexpr bool
is_partitioned(InputIter first, InputIter last, Predicate pred) {
    for (; first != last; ++first)
        if (!pred(*first)) break;
    if (first == last) return true;
    ++first;
    for (; first != last; ++first)
        if (pred(*first)) return false;
    return true;
}

// partition (forward iterator specialization)
namespace detail {
    template<class ForwardIter, class Predicate>
    constexpr ForwardIter
    partition_forward(ForwardIter first, ForwardIter last, Predicate& pred) {
        while (true) {
            if (first == last) return first;
            if (!pred(*first)) break;
            ++first;
        }
        ForwardIter p = first;
        while (++p != last)
            if (pred(*p)) { swap(*first, *p); ++first; }
        return first;
    }

    template<class BidiIter, class Predicate>
    constexpr BidiIter
    partition_bidirectional(BidiIter first, BidiIter last, Predicate& pred) {
        while (true) {
            while (true) {
                if (first == last) return first;
                if (!pred(*first)) break;
                ++first;
            }
            do {
                if (first == --last) return first;
            } while (!pred(*last));
            swap(*first, *last);
            ++first;
        }
    }
} // namespace detail

// partition (dispatches on iterator category)
template<class ForwardIter, class Predicate>
constexpr ForwardIter
partition(ForwardIter first, ForwardIter last, Predicate pred) {
    if constexpr (is_convertible_v<
                      typename iterator_traits<ForwardIter>::iterator_category,
                      bidirectional_iterator_tag>) {
        return detail::partition_bidirectional(first, last, pred);
    } else {
        return detail::partition_forward(first, last, pred);
    }
}

// stable_partition
namespace detail {
    template<class ForwardIter, class Predicate>
    ForwardIter
    stable_partition_impl(ForwardIter first, ForwardIter last, Predicate& pred,
                          typename iterator_traits<ForwardIter>::difference_type len,
                          typename iterator_traits<ForwardIter>::value_type* buff,
                          ptrdiff_t buff_size) {
        using value_type = typename iterator_traits<ForwardIter>::value_type;
        if (len == 0 || (first == last)) return first;
        if (len == 1) return first;
        if (len == 2) {
            ForwardIter m = first;
            if (pred(*++m)) { swap(*first, *m); return m; }
            return first;
        }
        if (len <= buff_size) {
            // *first is known to be false (pred(*first)==false).
            // Move false-elements to buffer, true-elements to front.
            value_type* p = buff;
            // Move *first (known false) into buffer
            ::new (static_cast<void*>(p)) value_type(std::move(*first));
            ++p;
            ForwardIter i = first;  // i starts at first, loop starts at ++i below
            while (++i != last) {
                if (pred(*i)) {
                    *first = std::move(*i);
                    ++first;  // first = partition point (end of trues so far)
                } else {
                    ::new (static_cast<void*>(p)) value_type(std::move(*i));
                    ++p;
                }
            }
            // first now points to the partition point (first false position)
            // Copy false-elements from buffer back starting at first
            ForwardIter ret = first;  // save partition point
            i = first;
            for (value_type* q = buff; q != p; ++q, ++i) {
                *i = std::move(*q);
                q->~value_type();
            }
            return ret;  // return partition point (first false)
        }
        // Split in half, recurse.
        // *first is known to be false.
        ForwardIter m = first;
        typename iterator_traits<ForwardIter>::difference_type l2 = len / 2;
        advance(m, l2);
        // Recurse on first half [first, m) — *first known false
        ForwardIter ff = stable_partition_impl(first, m, pred, l2, buff, buff_size);
        // For second half [m, last), advance past leading trues before recursing
        ForwardIter m1 = m;
        ForwardIter sf = last;
        typename iterator_traits<ForwardIter>::difference_type len_half = len - l2;
        while (pred(*m1)) {
            if (++m1 == last) goto second_half_done;
            --len_half;
        }
        sf = stable_partition_impl(m1, last, pred, len_half, buff, buff_size);
second_half_done:
        return rotate(ff, m, sf);
    }
} // namespace detail

template<class ForwardIter, class Predicate>
ForwardIter
stable_partition(ForwardIter first, ForwardIter last, Predicate pred) {
    // Find first element not satisfying pred
    while (first != last && pred(*first)) ++first;
    if (first == last) return first;
    using value_type = typename iterator_traits<ForwardIter>::value_type;
    using diff_t     = typename iterator_traits<ForwardIter>::difference_type;
    diff_t len = distance(first, last);
    value_type* buf = nullptr;
    ptrdiff_t got = 0;
    if (len >= 3) {
        buf = static_cast<value_type*>(::operator new(
                  static_cast<size_t>(len) * sizeof(value_type),
                  std::nothrow));
        got = buf ? len : 0;
    }
    ForwardIter result = detail::stable_partition_impl(first, last, pred, len, buf, got);
    ::operator delete(buf);
    return result;
}

// partition_copy
template<class InputIter, class OutputIter1, class OutputIter2, class Predicate>
constexpr pair<OutputIter1, OutputIter2>
partition_copy(InputIter first, InputIter last,
               OutputIter1 out_true, OutputIter2 out_false,
               Predicate pred) {
    for (; first != last; ++first) {
        if (pred(*first)) { *out_true  = *first; ++out_true; }
        else              { *out_false = *first; ++out_false; }
    }
    return {out_true, out_false};
}

// partition_point — binary search for partition boundary
template<class ForwardIter, class Predicate>
constexpr ForwardIter
partition_point(ForwardIter first, ForwardIter last, Predicate pred) {
    auto len = distance(first, last);
    while (len != 0) {
        auto half = len / 2;
        ForwardIter m = first;
        advance(m, half);
        if (pred(*m)) {
            first = ++m;
            len -= half + 1;
        } else {
            len = half;
        }
    }
    return first;
}

