struct adjacent_find_fn {
    template<forward_iterator I, sentinel_for<I> S,
             class Proj = identity,
             indirect_binary_predicate<projected<I, Proj>, projected<I, Proj>> Pred = equal_to>
    [[nodiscard]] constexpr I
    operator()(I first, S last, Pred pred = {}, Proj proj = {}) const {
        if (first == last) return first;
        I nxt = first;
        for (++nxt; nxt != last; ++first, (void)++nxt)
            if (std::invoke(pred,
                            std::invoke(proj, *first),
                            std::invoke(proj, *nxt)))
                return first;
        return nxt;
    }

    template<forward_range R,
             class Proj = identity,
             indirect_binary_predicate<projected<iterator_t<R>, Proj>,
                                       projected<iterator_t<R>, Proj>> Pred = equal_to>
    [[nodiscard]] constexpr borrowed_iterator_t<R>
    operator()(R&& r, Pred pred = {}, Proj proj = {}) const {
        return (*this)(ranges::begin(r), ranges::end(r),
                       std::move(pred), std::move(proj));
    }
};

