// <ctime> -- C time functions and types in namespace std.
// Mechanically ported from libc++ include/ctime.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Includes <time.h> (reachable via the system include path even with
// -nostdinc++) and re-exports the [ctime.syn] types and functions into
// namespace std.  The macros (NULL, CLOCKS_PER_SEC, TIME_UTC) remain in the
// global namespace as provided by <time.h>; the standard only requires them
// there.
#pragma once

// glibc declarations must keep DEFAULT visibility no matter where this
// wrapper is first included from: io headers wrap their bodies in
// `#pragma GCC visibility push(hidden)` (libstdc++-ABI isolation), and a
// libc prototype first seen inside such a region becomes a hidden symbol
// the linker then cannot resolve against libc (e.g. strtod via <sstream>).
#pragma GCC visibility push(default)
#include <time.h>
#pragma GCC visibility pop

namespace std {

using ::clock_t;
using ::size_t;
using ::time_t;
using ::timespec;
using ::tm;

using ::asctime;
using ::clock;
using ::ctime;
using ::difftime;
using ::gmtime;
using ::localtime;
using ::mktime;
using ::strftime;
using ::time;
using ::timespec_get;

} // namespace std
