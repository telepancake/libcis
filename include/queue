// <queue> — mechanically ported from libc++ include/queue
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Contains: queue<T, Container> and priority_queue<T, Container, Compare>
// Depends on: <deque>, <vector>, <algorithm>, <functional>, <compare>,
//             <initializer_list>, <memory>, <utility>, <type_traits>
#pragma once

#include <deque>
#include <vector>
#include <cstdlib>
#include <algorithm>
#include <functional>
#include <compare>
#include <initializer_list>
#include <memory>
#include <utility>
#include <type_traits>

namespace std {

namespace detail {
// libc++ __is_allocator (same pattern as detail::string_is_allocator_v):
// constrains the queue/priority_queue deduction guides.
template <class Alloc>
inline constexpr bool queue_is_allocator_v = requires(Alloc& a) {
    typename Alloc::value_type;
    a.allocate(size_t{});
};
} // namespace detail

//===----------------------------------------------------------------------===//
// queue<T, Container>
//===----------------------------------------------------------------------===//

template <class T, class Container = deque<T>>
class queue {
public:
    using container_type  = Container;
    using value_type      = typename container_type::value_type;
    using reference       = typename container_type::reference;
    using const_reference = typename container_type::const_reference;
    using size_type       = typename container_type::size_type;

    static_assert(is_same_v<T, value_type>,
        "queue<T, Container>: T must match Container::value_type");

protected:
    container_type c;

public:
    // --- Constructors ---

    queue() noexcept(is_nothrow_default_constructible_v<container_type>) : c() {}

    queue(const queue& q) : c(q.c) {}

    queue(queue&& q) noexcept(is_nothrow_move_constructible_v<container_type>)
        : c(std::move(q.c)) {}

    queue& operator=(const queue& q) {
        c = q.c;
        return *this;
    }

    queue& operator=(queue&& q) noexcept(is_nothrow_move_assignable_v<container_type>) {
        c = std::move(q.c);
        return *this;
    }

    explicit queue(const container_type& cont) : c(cont) {}

    explicit queue(container_type&& cont) : c(std::move(cont)) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    explicit queue(const Alloc& a) : c(a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    queue(const container_type& cont, const Alloc& a) : c(cont, a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    queue(container_type&& cont, const Alloc& a) : c(std::move(cont), a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    queue(const queue& q, const Alloc& a) : c(q.c, a) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    queue(queue&& q, const Alloc& a) : c(std::move(q.c), a) {}

    // --- Capacity ---

    [[nodiscard]] bool empty() const { return c.empty(); }
    [[nodiscard]] size_type size() const { return c.size(); }

    // --- Element access ---

    [[nodiscard]] reference front() { return c.front(); }
    [[nodiscard]] const_reference front() const { return c.front(); }
    [[nodiscard]] reference back() { return c.back(); }
    [[nodiscard]] const_reference back() const { return c.back(); }

    // --- Modifiers ---

    void push(const value_type& v) { c.push_back(v); }
    void push(value_type&& v) { c.push_back(std::move(v)); }

    template <class... Args>
    decltype(auto) emplace(Args&&... args) {
        return c.emplace_back(std::forward<Args>(args)...);
    }

    void pop() { c.pop_front(); }

    void swap(queue& q) noexcept(is_nothrow_swappable_v<container_type>) {
        using std::swap;
        swap(c, q.c);
    }

    // --- Friend access for comparison operators ---

    template <class T1, class C1>
    friend bool operator==(const queue<T1, C1>& x, const queue<T1, C1>& y);

    template <class T1, class C1>
    friend bool operator<(const queue<T1, C1>& x, const queue<T1, C1>& y);

    template <class T1, three_way_comparable C1>
    friend compare_three_way_result_t<C1>
    operator<=>(const queue<T1, C1>& x, const queue<T1, C1>& y);
};

// --- Deduction guides (C++17) ---

template <class Container>
queue(Container) -> queue<typename Container::value_type, Container>;

template <class Container, class Alloc>
    requires uses_allocator<Container, Alloc>::value
queue(Container, Alloc) -> queue<typename Container::value_type, Container>;

// --- Comparison operators ---

template <class T, class Container>
inline bool operator==(const queue<T, Container>& x, const queue<T, Container>& y) {
    return x.c == y.c;
}

template <class T, class Container>
inline bool operator<(const queue<T, Container>& x, const queue<T, Container>& y) {
    return x.c < y.c;
}

template <class T, class Container>
inline bool operator!=(const queue<T, Container>& x, const queue<T, Container>& y) {
    return !(x == y);
}

template <class T, class Container>
inline bool operator>(const queue<T, Container>& x, const queue<T, Container>& y) {
    return y < x;
}

template <class T, class Container>
inline bool operator>=(const queue<T, Container>& x, const queue<T, Container>& y) {
    return !(x < y);
}

template <class T, class Container>
inline bool operator<=(const queue<T, Container>& x, const queue<T, Container>& y) {
    return !(y < x);
}

template <class T, three_way_comparable Container>
compare_three_way_result_t<Container>
operator<=>(const queue<T, Container>& x, const queue<T, Container>& y) {
    return x.c <=> y.c;
}

// --- Non-member swap ---

template <class T, class Container>
    requires is_swappable_v<Container>
inline void swap(queue<T, Container>& x, queue<T, Container>& y)
    noexcept(noexcept(x.swap(y))) {
    x.swap(y);
}

// --- uses_allocator ---

template <class T, class Container, class Alloc>
struct uses_allocator<queue<T, Container>, Alloc>
    : public uses_allocator<Container, Alloc> {};

//===----------------------------------------------------------------------===//
// priority_queue<T, Container, Compare>
//===----------------------------------------------------------------------===//

template <class T, class Container = vector<T>, class Compare = less<T>>
class priority_queue {
public:
    using container_type  = Container;
    using value_compare   = Compare;
    using value_type      = typename container_type::value_type;
    using reference       = typename container_type::reference;
    using const_reference = typename container_type::const_reference;
    using size_type       = typename container_type::size_type;

    static_assert(is_same_v<T, value_type>,
        "priority_queue<T, Container, Compare>: T must match Container::value_type");

protected:
    container_type c;
    value_compare  comp;

public:
    // --- Constructors ---

    priority_queue()
        noexcept(is_nothrow_default_constructible_v<container_type> &&
                 is_nothrow_default_constructible_v<value_compare>)
        : c(), comp() {}

    priority_queue(const priority_queue& q) : c(q.c), comp(q.comp) {}

    priority_queue(priority_queue&& q)
        noexcept(is_nothrow_move_constructible_v<container_type> &&
                 is_nothrow_move_constructible_v<value_compare>)
        : c(std::move(q.c)), comp(std::move(q.comp)) {}

    priority_queue& operator=(const priority_queue& q) {
        c    = q.c;
        comp = q.comp;
        return *this;
    }

    priority_queue& operator=(priority_queue&& q)
        noexcept(is_nothrow_move_assignable_v<container_type> &&
                 is_nothrow_move_assignable_v<value_compare>) {
        c    = std::move(q.c);
        comp = std::move(q.comp);
        return *this;
    }

    explicit priority_queue(const value_compare& cmp)
        : c(), comp(cmp) {}

    priority_queue(const value_compare& cmp, const container_type& cont)
        : c(cont), comp(cmp) {
        std::make_heap(c.begin(), c.end(), comp);
    }

    priority_queue(const value_compare& cmp, container_type&& cont)
        : c(std::move(cont)), comp(cmp) {
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class InputIter>
        requires requires { typename iterator_traits<InputIter>::iterator_category; }
    priority_queue(InputIter first, InputIter last,
                   const value_compare& cmp = value_compare())
        : c(first, last), comp(cmp) {
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class InputIter>
        requires requires { typename iterator_traits<InputIter>::iterator_category; }
    priority_queue(InputIter first, InputIter last,
                   const value_compare& cmp, const container_type& cont)
        : c(cont), comp(cmp) {
        c.insert(c.end(), first, last);
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class InputIter>
        requires requires { typename iterator_traits<InputIter>::iterator_category; }
    priority_queue(InputIter first, InputIter last,
                   const value_compare& cmp, container_type&& cont)
        : c(std::move(cont)), comp(cmp) {
        c.insert(c.end(), first, last);
        std::make_heap(c.begin(), c.end(), comp);
    }

    // Allocator-extended constructors

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    explicit priority_queue(const Alloc& a)
        : c(a), comp() {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    priority_queue(const value_compare& cmp, const Alloc& a)
        : c(a), comp(cmp) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    priority_queue(const value_compare& cmp, const container_type& cont, const Alloc& a)
        : c(cont, a), comp(cmp) {
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    priority_queue(const value_compare& cmp, container_type&& cont, const Alloc& a)
        : c(std::move(cont), a), comp(cmp) {
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    priority_queue(const priority_queue& q, const Alloc& a)
        : c(q.c, a), comp(q.comp) {}

    template <class Alloc>
        requires uses_allocator<container_type, Alloc>::value
    priority_queue(priority_queue&& q, const Alloc& a)
        : c(std::move(q.c), a), comp(std::move(q.comp)) {}

    template <class InputIter, class Alloc>
        requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
                  uses_allocator<container_type, Alloc>::value)
    priority_queue(InputIter first, InputIter last, const Alloc& a)
        : c(first, last, a), comp() {
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class InputIter, class Alloc>
        requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
                  uses_allocator<container_type, Alloc>::value)
    priority_queue(InputIter first, InputIter last,
                   const value_compare& cmp, const Alloc& a)
        : c(first, last, a), comp(cmp) {
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class InputIter, class Alloc>
        requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
                  uses_allocator<container_type, Alloc>::value)
    priority_queue(InputIter first, InputIter last,
                   const value_compare& cmp, const container_type& cont, const Alloc& a)
        : c(cont, a), comp(cmp) {
        c.insert(c.end(), first, last);
        std::make_heap(c.begin(), c.end(), comp);
    }

    template <class InputIter, class Alloc>
        requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
                  uses_allocator<container_type, Alloc>::value)
    priority_queue(InputIter first, InputIter last,
                   const value_compare& cmp, container_type&& cont, const Alloc& a)
        : c(std::move(cont), a), comp(cmp) {
        c.insert(c.end(), first, last);
        std::make_heap(c.begin(), c.end(), comp);
    }

    // --- Capacity ---

    [[nodiscard]] bool empty() const { return c.empty(); }
    [[nodiscard]] size_type size() const { return c.size(); }

    // --- Element access ---

    [[nodiscard]] const_reference top() const { return c.front(); }

    // --- Modifiers ---

    void push(const value_type& v) {
        c.push_back(v);
        std::push_heap(c.begin(), c.end(), comp);
    }

    void push(value_type&& v) {
        c.push_back(std::move(v));
        std::push_heap(c.begin(), c.end(), comp);
    }

    template <class... Args>
    void emplace(Args&&... args) {
        c.emplace_back(std::forward<Args>(args)...);
        std::push_heap(c.begin(), c.end(), comp);
    }

    void pop() {
        std::pop_heap(c.begin(), c.end(), comp);
        c.pop_back();
    }

    void swap(priority_queue& q)
        noexcept(is_nothrow_swappable_v<container_type> &&
                 is_nothrow_swappable_v<value_compare>) {
        using std::swap;
        swap(c, q.c);
        swap(comp, q.comp);
    }
};

// --- Deduction guides (C++17) ---

// Constraints follow libc++ exactly: __is_allocator / !__is_allocator guards
// disambiguate the (Compare, Container)/(..., Alloc) guide overload sets.
template <class Compare, class Container>
    requires (!detail::queue_is_allocator_v<Compare> &&
              !detail::queue_is_allocator_v<Container>)
priority_queue(Compare, Container)
    -> priority_queue<typename Container::value_type, Container, Compare>;

template <class InputIter,
          class Compare   = less<typename iterator_traits<InputIter>::value_type>,
          class Container = vector<typename iterator_traits<InputIter>::value_type>>
    requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
              !detail::queue_is_allocator_v<Compare> &&
              !detail::queue_is_allocator_v<Container>)
priority_queue(InputIter, InputIter, Compare = Compare(), Container = Container())
    -> priority_queue<typename iterator_traits<InputIter>::value_type, Container, Compare>;

template <class Compare, class Container, class Alloc>
    requires (!detail::queue_is_allocator_v<Compare> &&
              !detail::queue_is_allocator_v<Container> &&
              uses_allocator<Container, Alloc>::value)
priority_queue(Compare, Container, Alloc)
    -> priority_queue<typename Container::value_type, Container, Compare>;

template <class InputIter, class Alloc>
    requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
              detail::queue_is_allocator_v<Alloc>)
priority_queue(InputIter, InputIter, Alloc)
    -> priority_queue<typename iterator_traits<InputIter>::value_type,
                      vector<typename iterator_traits<InputIter>::value_type, Alloc>,
                      less<typename iterator_traits<InputIter>::value_type>>;

template <class InputIter, class Compare, class Alloc>
    requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
              !detail::queue_is_allocator_v<Compare> &&
              detail::queue_is_allocator_v<Alloc>)
priority_queue(InputIter, InputIter, Compare, Alloc)
    -> priority_queue<typename iterator_traits<InputIter>::value_type,
                      vector<typename iterator_traits<InputIter>::value_type, Alloc>,
                      Compare>;

template <class InputIter, class Compare, class Container, class Alloc>
    requires (requires { typename iterator_traits<InputIter>::iterator_category; } &&
              !detail::queue_is_allocator_v<Compare> &&
              !detail::queue_is_allocator_v<Container> &&
              uses_allocator<Container, Alloc>::value)
priority_queue(InputIter, InputIter, Compare, Container, Alloc)
    -> priority_queue<typename Container::value_type, Container, Compare>;

// --- Non-member swap ---

template <class T, class Container, class Compare>
    requires (is_swappable_v<Container> && is_swappable_v<Compare>)
inline void swap(priority_queue<T, Container, Compare>& x,
                 priority_queue<T, Container, Compare>& y)
    noexcept(noexcept(x.swap(y))) {
    x.swap(y);
}

// --- uses_allocator ---

template <class T, class Container, class Compare, class Alloc>
struct uses_allocator<priority_queue<T, Container, Compare>, Alloc>
    : public uses_allocator<Container, Alloc> {};

} // namespace std
