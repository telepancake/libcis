// <thread> — thread, jthread, this_thread
// Mechanically ported from libc++ include/__thread/{thread,id,this_thread,jthread}.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Threading: POSIX pthread underneath.
//   pthread_create / join failure -> __builtin_trap() (comment: libc++ throws).
// sleep_for: uses nanosleep() from <time.h>.
#pragma once

// This library always provides hosted threading (pthread underneath).  The
// compiler only predefines __STDCPP_THREADS__ when invoked with -pthread; our
// build links -lpthread without it, so define the macro here (as libstdc++'s
// threading headers do) so [thread.req]/macro and user code observe it.
#ifndef __STDCPP_THREADS__
#  define __STDCPP_THREADS__ 1
#endif

// glibc declarations must keep DEFAULT visibility and be seen FIRST: io headers
// (pulled in via <sstream> below) wrap their bodies in
// `#pragma GCC visibility push(hidden)`, and a libc prototype first seen inside
// such a region becomes a hidden symbol the linker cannot resolve against libc
// (e.g. pthread_self via <thread>).  Including these C headers up front, at
// default visibility, pins the prototypes before any hidden region appears.
#pragma GCC visibility push(default)
#include <pthread.h>
#include <sched.h>      // sched_yield
#include <time.h>       // nanosleep, struct timespec
#include <unistd.h>     // sysconf, _SC_NPROCESSORS_ONLN
#pragma GCC visibility pop

#include <type_traits>
#include <utility>
#include <tuple>
#include <iosfwd>       // basic_ostream / basic_ostringstream forward decls
#include <sstream>      // basic_ostringstream + locale for operator<<(id)
#include <functional>   // invoke, is_invocable_v
#include <compare>
#include <chrono>
#include <stop_token>
#include <exception>   // std::terminate

namespace std {

// ============================================================
// thread::id — defined first so this_thread::get_id can be a friend
// ============================================================
namespace this_thread {
    class thread_id_access; // private helper to construct thread::id
}

namespace thread_detail {

// Recursive storage for the decayed callable + bound arguments.  Each member
// is DIRECT-INITIALIZED through a forwarding constructor (mem-initializer):
// crucially, a function reference is converted to a function pointer here in a
// non-functional-cast context, which on gcc-10 does NOT complete an incomplete
// parameter type — whereas `decay_t<F>(f)` / copy-init / tuple-ctor SFINAE all
// would.  This is what makes [thread.thread.constr] robust against ADL with
// incomplete types.  No std::tuple, no is_constructible/is_invocable traits.
template<class... Vs>
struct bound_args;
template<>
struct bound_args<> {
    bound_args() = default;
};
template<class Head, class... Tail>
struct bound_args<Head, Tail...> {
    Head                head;
    bound_args<Tail...> tail;

    template<class UHead, class... UTail>
    explicit bound_args(UHead&& uhead, UTail&&... utail)
        : head(std::forward<UHead>(uhead)),
          tail(std::forward<UTail>(utail)...) {}
};

template<class Fn, class Node, class... Rest, class... Collected>
void invoke_node(Fn&& fn, bound_args<Node, Rest...>& node, Collected&&... acc) {
    invoke_node(std::forward<Fn>(fn), node.tail,
                std::forward<Collected>(acc)..., std::move(node.head));
}
template<class Fn, class... Collected>
void invoke_node(Fn&& fn, bound_args<>&, Collected&&... acc) {
    detail::invoke_impl(std::forward<Fn>(fn), std::forward<Collected>(acc)...);
}

template<class Storage>
void* thread_proxy(void* vp) {
    Storage* p = static_cast<Storage*>(vp);
    struct Guard { Storage* ptr; ~Guard() { delete ptr; } } guard{p};
    invoke_node(std::move(p->head), p->tail);
    return nullptr;
}

} // namespace thread_detail

class thread {
public:
    // ---- nested id type ----
    class id {
        pthread_t id_ = 0;
    public:
        id() noexcept = default;

    private:
        explicit id(pthread_t v) noexcept : id_(v) {}
        friend class thread;
        friend class this_thread::thread_id_access;
        friend struct hash<id>;
        // Namespace-scope comparison operators (NOT hidden friends, so
        // qualified std::operator==(a,b) finds them — see [thread.thread.id]).
        friend bool operator==(thread::id x, thread::id y) noexcept;
        friend strong_ordering operator<=>(thread::id x, thread::id y) noexcept;
        template<class CharT, class Traits>
        friend basic_ostream<CharT, Traits>&
        operator<<(basic_ostream<CharT, Traits>& os, id v);
    };

    using native_handle_type = pthread_t;

    // ---- constructors ----
    thread() noexcept : t_(0) {}

    template<class F, class... Args>
        requires (!is_same_v<remove_cvref_t<F>, thread>)
    explicit thread(F&& f, Args&&... args) {
        // NOTE: we deliberately do NOT static_assert is_constructible /
        // is_invocable here, nor store the bound arguments in a std::tuple:
        // both would instantiate traits / tuple-ctor SFINAE that complete
        // argument types, breaking [thread.thread.constr]'s robustness against
        // ADL with incomplete types.  bound_args aggregate-stores the decayed
        // arguments without any such trait instantiation.
        using Storage = thread_detail::bound_args<decay_t<F>, decay_t<Args>...>;
        auto* p = new Storage(std::forward<F>(f), std::forward<Args>(args)...);

        int ec = pthread_create(&t_, nullptr, &thread_detail::thread_proxy<Storage>, p);
        if (ec == 0) {
            // p ownership transferred to the new thread
        } else {
            delete p;
            __builtin_trap(); // pthread_create failed (libc++ would throw)
        }
    }

    thread(const thread&)            = delete;
    thread& operator=(const thread&) = delete;

    thread(thread&& other) noexcept : t_(other.t_) { other.t_ = 0; }

    thread& operator=(thread&& other) noexcept {
        if (joinable())
            std::terminate(); // [thread.thread.assign] (respects set_terminate)
        t_ = other.t_;
        other.t_ = 0;
        return *this;
    }

    ~thread() {
        if (joinable())
            std::terminate(); // [thread.thread.destr] (respects set_terminate)
    }

    // ---- observers ----
    [[nodiscard]] bool joinable()            const noexcept { return t_ != 0; }
    [[nodiscard]] id   get_id()              const noexcept { return id(t_); }
    [[nodiscard]] native_handle_type native_handle() noexcept { return t_; }
    [[nodiscard]] static unsigned hardware_concurrency() noexcept;

    // ---- modifiers ----
    void swap(thread& other) noexcept { std::swap(t_, other.t_); }

    void join() {
        int ec = pthread_join(t_, nullptr);
        if (ec != 0)
            __builtin_trap(); // pthread_join failed (libc++ would throw)
        t_ = 0;
    }

    void detach() {
        int ec = pthread_detach(t_);
        if (ec != 0)
            __builtin_trap(); // pthread_detach failed (libc++ would throw)
        t_ = 0;
    }

    friend void swap(thread& x, thread& y) noexcept { x.swap(y); }

private:
    pthread_t t_;
};

// ---- namespace-scope comparison operators for thread::id ----
inline bool operator==(thread::id x, thread::id y) noexcept {
    // pthread_t is an integer handle on this target; compare directly.
    // (pthread_equal is not reliably linkable as a non-inline symbol here.)
    return x.id_ == y.id_;
}
inline strong_ordering operator<=>(thread::id x, thread::id y) noexcept {
    if (x == y) return strong_ordering::equal;
    return (x.id_ < y.id_) ? strong_ordering::less : strong_ordering::greater;
}

// ---- hash<thread::id> ----
template<>
struct hash<thread::id> {
    size_t operator()(thread::id v) const noexcept {
        return hash<unsigned long long>()(
            static_cast<unsigned long long>(v.id_));
    }
};

// ---- operator<< for thread::id ----
template<class CharT, class Traits>
basic_ostream<CharT, Traits>&
operator<<(basic_ostream<CharT, Traits>& os, thread::id v) {
    // [thread.thread.id]/2: the representation must be unaffected by stream
    // flags (oct/hex/showbase/width/...).  Render in a classic-imbued temp
    // stream and insert the resulting string (mirrors libc++).
    basic_ostringstream<CharT, Traits> sstr;
    sstr.imbue(locale::classic());
    sstr << static_cast<unsigned long long>(v.id_);
    return os << sstr.str();
}

// ---- out-of-line hardware_concurrency ----
inline unsigned thread::hardware_concurrency() noexcept {
    long n = ::sysconf(_SC_NPROCESSORS_ONLN);
    return (n > 0) ? static_cast<unsigned>(n) : 0u;
}

// ============================================================
// namespace this_thread
// ============================================================
namespace this_thread {

// Helper class that is a friend of thread::id to construct one from pthread_t
class thread_id_access {
public:
    static thread::id make(pthread_t p) noexcept {
        return thread::id(p);
    }
};

inline thread::id get_id() noexcept {
    return thread_id_access::make(pthread_self());
}

inline void yield() noexcept {
    sched_yield();
}

// sleep_for(nanoseconds) — core implementation using nanosleep
inline void sleep_for(const chrono::nanoseconds& ns) {
    if (ns <= chrono::nanoseconds::zero())
        return;
    chrono::seconds sec = chrono::duration_cast<chrono::seconds>(ns);
    chrono::nanoseconds rem = ns - sec;
    struct timespec ts;
    ts.tv_sec  = static_cast<time_t>(sec.count());
    ts.tv_nsec = static_cast<long>(rem.count());
    while (nanosleep(&ts, &ts) == -1) { /* interrupted; continue */ }
}

// sleep_for generic duration
template<class Rep, class Period>
void sleep_for(const chrono::duration<Rep, Period>& d) {
    if (d > chrono::duration<Rep, Period>::zero()) {
        constexpr chrono::duration<long double> max_ns{9223372036.0L};
        chrono::nanoseconds ns;
        if (d < max_ns) {
            ns = chrono::duration_cast<chrono::nanoseconds>(d);
            if (ns < d) ++ns;
        } else {
            ns = chrono::nanoseconds::max();
        }
        sleep_for(ns);
    }
}

// sleep_until — steady_clock specialization
template<class Duration>
void sleep_until(
    const chrono::time_point<chrono::steady_clock, Duration>& tp)
{
    sleep_for(tp - chrono::steady_clock::now());
}

// sleep_until — generic Clock
template<class Clock, class Duration>
void sleep_until(const chrono::time_point<Clock, Duration>& tp) {
    while (Clock::now() < tp)
        sleep_for(chrono::milliseconds(1));
}

} // namespace this_thread

// ============================================================
// jthread
// ============================================================
class jthread {
public:
    using id                 = thread::id;
    using native_handle_type = thread::native_handle_type;

    jthread() noexcept : stop_source_(nostopstate) {}

    template<class Fun, class... Args>
        requires (!is_same_v<remove_cvref_t<Fun>, jthread>)
    explicit jthread(Fun&& fun, Args&&... args)
        : stop_source_(),
          thread_(init_thread(stop_source_,
                              std::forward<Fun>(fun),
                              std::forward<Args>(args)...)) {
        static_assert(is_constructible_v<decay_t<Fun>, Fun>);
        static_assert((is_constructible_v<decay_t<Args>, Args> && ...));
        static_assert(is_invocable_v<decay_t<Fun>, decay_t<Args>...> ||
                      is_invocable_v<decay_t<Fun>, stop_token, decay_t<Args>...>);
    }

    ~jthread() {
        if (joinable()) {
            request_stop();
            join();
        }
    }

    jthread(const jthread&)            = delete;
    jthread(jthread&&) noexcept        = default;
    jthread& operator=(const jthread&) = delete;

    jthread& operator=(jthread&& other) noexcept {
        if (this != &other) {
            if (joinable()) {
                request_stop();
                join();
            }
            stop_source_ = std::move(other.stop_source_);
            thread_      = std::move(other.thread_);
        }
        return *this;
    }

    void swap(jthread& other) noexcept {
        std::swap(stop_source_, other.stop_source_);
        std::swap(thread_, other.thread_);
    }

    [[nodiscard]] bool joinable()    const noexcept { return get_id() != id(); }
    void join()                             { thread_.join(); }
    void detach()                           { thread_.detach(); }
    [[nodiscard]] id get_id()        const noexcept { return thread_.get_id(); }
    [[nodiscard]] native_handle_type native_handle() { return thread_.native_handle(); }

    [[nodiscard]] stop_source get_stop_source() noexcept { return stop_source_; }
    [[nodiscard]] stop_token  get_stop_token()  const noexcept {
        return stop_source_.get_token();
    }
    bool request_stop() noexcept { return stop_source_.request_stop(); }

    [[nodiscard]] static unsigned hardware_concurrency() noexcept {
        return thread::hardware_concurrency();
    }

    friend void swap(jthread& lhs, jthread& rhs) noexcept { lhs.swap(rhs); }

private:
    template<class Fun, class... Args>
    static thread init_thread(const stop_source& ss, Fun&& fun, Args&&... args) {
        if constexpr (is_invocable_v<decay_t<Fun>, stop_token, decay_t<Args>...>) {
            return thread(std::forward<Fun>(fun), ss.get_token(),
                          std::forward<Args>(args)...);
        } else {
            return thread(std::forward<Fun>(fun),
                          std::forward<Args>(args)...);
        }
    }

    stop_source stop_source_;
    thread      thread_;
};

} // namespace std
