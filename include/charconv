// bool overload deleted (as per standard)
to_chars_result to_chars(char*, char*, bool, int = 10) = delete;

// to_chars with base=10 (default)
template<class T>
    requires (is_integral_v<T> && !is_same_v<T, bool>)
inline to_chars_result to_chars(char* first, char* last, T value) {
    using Type = detail::make_32_64_bit_t<T>;
    return detail::to_chars_itoa(first, last, static_cast<Type>(value));
}

// to_chars with explicit base
template<class T>
    requires (is_integral_v<T> && !is_same_v<T, bool>)
inline to_chars_result to_chars(char* first, char* last, T value, int base) {
    using Type = detail::make_32_64_bit_t<T>;
    return detail::to_chars_integral_impl(first, last, static_cast<Type>(value), base);
}

