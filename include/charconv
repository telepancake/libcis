//===----------------------------------------------------------------------===//
// Base-10 output helpers (to_chars_base_10.h — namespace __itoa)
//===----------------------------------------------------------------------===//

inline char* append1(char* p, uint32_t v) noexcept {
    *p = '0' + static_cast<char>(v);
    return p + 1;
}

inline char* append2(char* p, uint32_t v) noexcept {
    p[0] = digits_base_10[v * 2];
    p[1] = digits_base_10[v * 2 + 1];
    return p + 2;
}

inline char* append3(char* p, uint32_t v) noexcept {
    return append2(append1(p, v / 100), v % 100);
}

inline char* append4(char* p, uint32_t v) noexcept {
    return append2(append2(p, v / 100), v % 100);
}

inline char* append5(char* p, uint32_t v) noexcept {
    return append4(append1(p, v / 10000), v % 10000);
}

inline char* append6(char* p, uint32_t v) noexcept {
    return append4(append2(p, v / 10000), v % 10000);
}

inline char* append7(char* p, uint32_t v) noexcept {
    return append6(append1(p, v / 1000000), v % 1000000);
}

inline char* append8(char* p, uint32_t v) noexcept {
    return append6(append2(p, v / 1000000), v % 1000000);
}

inline char* append9(char* p, uint32_t v) noexcept {
    return append8(append1(p, v / 100000000), v % 100000000);
}

template<class T>
inline char* append10(char* p, T v) noexcept {
    return append8(append2(p, static_cast<uint32_t>(v / 100000000)),
                   static_cast<uint32_t>(v % 100000000));
}

inline char* base_10_u32(char* p, uint32_t v) noexcept {
    if (v < 1000000) {
        if (v < 10000) {
            if (v < 100) {
                if (v < 10) return append1(p, v);
                return append2(p, v);
            }
            if (v < 1000) return append3(p, v);
            return append4(p, v);
        }
        if (v < 100000) return append5(p, v);
        return append6(p, v);
    }
    if (v < 100000000) {
        if (v < 10000000) return append7(p, v);
        return append8(p, v);
    }
    if (v < 1000000000) return append9(p, v);
    return append10(p, v);
}

inline char* base_10_u64(char* p, uint64_t v) noexcept {
    if (v <= UINT32_MAX)
        return base_10_u32(p, static_cast<uint32_t>(v));
    if (v >= UINT64_C(10000000000)) {
        p = base_10_u32(p, static_cast<uint32_t>(v / UINT64_C(10000000000)));
        v %= UINT64_C(10000000000);
    }
    return append10(p, v);
}

//===----------------------------------------------------------------------===//
// __traits_base / __traits (traits.h — width estimation + digit reading)
// Port: no __uint128_t specialization for simplicity (we only need 32/64 bit)
//===----------------------------------------------------------------------===//

// mul_overflow: returns true if a*b overflows into r
template<class T, class U>
    requires is_unsigned_v<T>
inline bool mul_overflowed(T a, U b, T& r) {
    return __builtin_mul_overflow(a, static_cast<T>(b), &r);
}

template<class T, class = void>
struct traits_base;

// For types <= 32 bits: use uint32_t arithmetic
template<class T>
struct traits_base<T, enable_if_t<sizeof(T) <= sizeof(uint32_t)>> {
    using type = uint32_t;

    static constexpr int width(T v) noexcept {
        auto t = (32 - __builtin_clz(static_cast<type>(v | 1))) * 1233 >> 12;
        return t - (v < pow10_32[t]) + 1;
    }

    static char* convert(char* p, T v) noexcept {
        return base_10_u32(p, v);
    }

    static constexpr const uint32_t* pow() noexcept { return pow10_32; }
};

// For types == 64 bits: use uint64_t arithmetic
template<class T>
struct traits_base<T, enable_if_t<sizeof(T) == sizeof(uint64_t)>> {
    using type = uint64_t;

    static constexpr int width(T v) noexcept {
        auto t = (64 - __builtin_clzll(static_cast<type>(v | 1))) * 1233 >> 12;
        return t - (v < pow10_64[t]) + 1;
    }

    static char* convert(char* p, T v) noexcept {
        return base_10_u64(p, v);
    }

    static constexpr const uint64_t* pow() noexcept { return pow10_64; }
};

template<class T>
struct traits : traits_base<T> {
    static constexpr int digits = numeric_limits<T>::digits10 + 1;
    using typename traits_base<T>::type;

    template<class It1, class It2, class U>
    static constexpr U inner_product(It1 first1, It1 last1, It2 first2, U init) {
        for (; first1 < last1; ++first1, ++first2)
            init = init + *first1 * *first2;
        return init;
    }

    // Read up to `digits` base-10 characters from [p,ep), filling __a and __b
    // such that the value is a+b, detecting potential overflow via b.
    static constexpr const char* read(const char* p, const char* ep, type& a, type& b) {
        type cprod[digits];
        int j = digits - 1;
        int i = digits;
        do {
            if (*p < '0' || *p > '9') break;
            cprod[--i] = *p++ - '0';
        } while (p != ep && i != 0);

        a = inner_product(cprod + i + 1, cprod + j, traits_base<T>::pow() + 1, cprod[i]);
        if (mul_overflowed(cprod[j], traits_base<T>::pow()[j - i], b))
            --p;
        return p;
    }
};

//===----------------------------------------------------------------------===//
// to_chars integer implementation (to_chars_integral.h)
//===----------------------------------------------------------------------===//

// Forward declaration for the two-overload pair (signed/unsigned)
template<class T>
    requires (!is_signed_v<T>)
to_chars_result to_chars_integral_impl(char* first, char* last, T value, int base);

// Signed: prepend '-', then recurse on unsigned value
template<class T>
    requires is_signed_v<T>
to_chars_result to_chars_integral_impl(char* first, char* last, T value, int base) {
    auto x = to_unsigned_like(value);
    if (value < 0 && first != last) {
        *first++ = '-';
        x = complement(x);
    }
    return to_chars_integral_impl(first, last, x, base);
}

// Count leading zeros for unsigned types — dispatches to the right builtin.
// __builtin_clz takes unsigned int (32-bit); __builtin_clzll takes unsigned
// long long (64-bit).  We must not cast a 64-bit value to unsigned before clz.
template<class T>
    requires is_unsigned_v<T>
constexpr int countl_zero_u(T v) noexcept {
    if constexpr (sizeof(T) <= sizeof(unsigned int))
        return __builtin_clz(static_cast<unsigned int>(v))
               - (numeric_limits<unsigned int>::digits - numeric_limits<T>::digits);
    else
        return __builtin_clzll(static_cast<unsigned long long>(v));
}

// Unsigned base-2 width
template<class T>
    requires is_unsigned_v<T>
constexpr int integral_width_base2(T value) noexcept {
    return numeric_limits<T>::digits - countl_zero_u(T(value | T(1)));
}

// Unsigned base-8 width
template<class T>
    requires is_unsigned_v<T>
constexpr int integral_width_base8(T value) noexcept {
    return (numeric_limits<T>::digits - countl_zero_u(T(value | T(1))) + 2) / 3;
}

// Unsigned base-16 width
template<class T>
    requires is_unsigned_v<T>
constexpr int integral_width_base16(T value) noexcept {
    return (numeric_limits<T>::digits - countl_zero_u(T(value | T(1))) + 3) / 4;
}

// Promote small types to unsigned for the fast base paths
template<class T>
    requires is_unsigned_v<T>
to_chars_result to_chars_base2(char* first, char* last, T value) {
    using W = conditional_t<(sizeof(T) < sizeof(unsigned)), unsigned, T>;
    W v = static_cast<W>(value);
    ptrdiff_t cap = last - first;
    int n = integral_width_base2(value);
    if (n > cap) return {last, errc::value_too_large};

    last = first + n;
    char* p = last;
    // use 4-char LUT chunks while value > 16
    while (v > 16u) {
        unsigned c = v % 16;
        v /= 16;
        p -= 4;
        p[0] = base_2_lut[4*c];   p[1] = base_2_lut[4*c+1];
        p[2] = base_2_lut[4*c+2]; p[3] = base_2_lut[4*c+3];
    }
    do {
        unsigned c = v % 2;
        v /= 2;
        *--p = "01"[c];
    } while (v != 0);
    return {last, errc{}};
}

template<class T>
    requires is_unsigned_v<T>
to_chars_result to_chars_base8(char* first, char* last, T value) {
    using W = conditional_t<(sizeof(T) < sizeof(unsigned)), unsigned, T>;
    W v = static_cast<W>(value);
    ptrdiff_t cap = last - first;
    int n = integral_width_base8(value);
    if (n > cap) return {last, errc::value_too_large};

    last = first + n;
    char* p = last;
    while (v > 64u) {
        unsigned c = v % 64;
        v /= 64;
        p -= 2;
        p[0] = base_8_lut[2*c]; p[1] = base_8_lut[2*c+1];
    }
    do {
        unsigned c = v % 8;
        v /= 8;
        *--p = "01234567"[c];
    } while (v != 0);
    return {last, errc{}};
}

template<class T>
    requires is_unsigned_v<T>
to_chars_result to_chars_base16(char* first, char* last, T value) {
    using W = conditional_t<(sizeof(T) < sizeof(unsigned)), unsigned, T>;
    W v = static_cast<W>(value);
    ptrdiff_t cap = last - first;
    int n = integral_width_base16(value);
    if (n > cap) return {last, errc::value_too_large};

    last = first + n;
    char* p = last;
    while (v > 256u) {
        unsigned c = v % 256;
        v /= 256;
        p -= 2;
        p[0] = base_16_lut[2*c]; p[1] = base_16_lut[2*c+1];
    }
    if (first != last)
        do {
            unsigned c = v % 16;
            v /= 16;
            *--p = "0123456789abcdef"[c];
        } while (v != 0);
    return {last, errc{}};
}

// General base: compute width, then emit digits
template<class T>
    requires is_unsigned_v<T>
int integral_width_generic(T value, unsigned base) {
    unsigned base2 = base * base;
    unsigned base3 = base2 * base;
    unsigned base4 = base2 * base2;
    int r = 0;
    while (true) {
        if (value < base)  return r + 1;
        if (value < base2) return r + 2;
        if (value < base3) return r + 3;
        if (value < base4) return r + 4;
        value /= base4;
        r += 4;
    }
}

// Base-10 itoa (unsigned)
template<class T>
    requires is_unsigned_v<T>
to_chars_result to_chars_itoa(char* first, char* last, T value) {
    using tx = traits<T>;
    ptrdiff_t diff = last - first;
    if (tx::digits <= diff || tx::width(value) <= diff)
        return {tx::convert(first, value), errc{}};
    return {last, errc::value_too_large};
}

// Base-10 itoa (signed) — prepend '-', recurse on unsigned
template<class T>
    requires is_signed_v<T>
to_chars_result to_chars_itoa(char* first, char* last, T value) {
    auto x = to_unsigned_like(value);
    if (value < 0 && first != last) {
        *first++ = '-';
        x = complement(x);
    }
    return to_chars_itoa(first, last, x);
}

// Unsigned general-base to_chars
template<class T>
    requires (!is_signed_v<T>)
to_chars_result to_chars_integral_impl(char* first, char* last, T value, int base) {
    if (base == 10) [[likely]]
        return to_chars_itoa(first, last, value);

    switch (base) {
    case 2:  return to_chars_base2(first, last, value);
    case 8:  return to_chars_base8(first, last, value);
    case 16: return to_chars_base16(first, last, value);
    }

    // Generic base [2,36] not covered above
    ptrdiff_t cap = last - first;
    int n = integral_width_generic(value, static_cast<unsigned>(base));
    if (n > cap) return {last, errc::value_too_large};

    last    = first + n;
    char* p = last;
    do {
        unsigned c = value % base;
        value /= base;
        *--p = "0123456789abcdefghijklmnopqrstuvwxyz"[c];
    } while (value != 0);
    return {last, errc{}};
}

// Promote small types to their 32-bit/64-bit equivalent for base-specific paths
// libc++ uses __make_32_64_or_128_bit_t; we inline the same logic here.
template<class T>
struct make_32_64_bit {
    using type = conditional_t<is_signed_v<T>,
        conditional_t<(sizeof(T) <= 4), int32_t, int64_t>,
        conditional_t<(sizeof(T) <= 4), uint32_t, uint64_t>>;
};
template<class T>
using make_32_64_bit_t = typename make_32_64_bit<T>::type;

//===----------------------------------------------------------------------===//
// from_chars integer helpers (from_chars_integral.h)
//===----------------------------------------------------------------------===//

// Check if c is a valid decimal digit
template<class C>
inline constexpr bool in_pattern_decimal(C c) noexcept {
    return '0' <= c && c <= '9';
}

// Check if c is valid in the given base; returns {ok, digit_value}
struct in_pattern_result {
    bool ok;
    int  val;
    explicit constexpr operator bool() const { return ok; }
};

template<class C>
inline constexpr in_pattern_result in_pattern(C c, int base) noexcept {
    if (base <= 10)
        return {'0' <= c && c < char('0' + base), c - '0'};
    if (in_pattern_decimal(c))
        return {true, c - '0'};
    if ('a' <= c && c < char('a' + base - 10))
        return {true, c - 'a' + 10};
    return {'A' <= c && c < char('A' + base - 10), c - 'A' + 10};
}

// log2f lookup for bases [2..36] (from_chars_integral.h)
inline constexpr float from_chars_log2f_lut[35] = {
    1,         1.5849625, 2,         2.321928,  2.5849626, 2.807355,  3,
    3.169925,  3.321928,  3.4594316, 3.5849626, 3.7004397, 3.807355,  3.9068906,
    4,         4.087463,  4.169925,  4.2479277, 4.321928,  4.3923173, 4.4594316,
    4.523562,  4.5849624, 4.643856,  4.70044,   4.7548876, 4.807355,  4.857981,
    4.9068904, 4.9541965, 5,         5.044394,  5.087463,  5.129283,  5.169925
};

// skip leading zeros, then call f with the first non-zero char
template<class T, class Fn, class... Args>
inline from_chars_result subject_seq_combinator(
    const char* first, const char* last, T& value, Fn f, Args... args)
{
    auto find_non_zero = [](const char* a, const char* b, Args...) {
        for (; a != b; ++a)
            if (*a != '0') break;
        return a;
    };

    const char* p = find_non_zero(first, last, args...);
    if (p == last || !in_pattern(*p, args...)) {
        if (p == first) return {first, errc::invalid_argument};
        value = 0;
        return {p, errc{}};
    }

    auto r = f(p, last, value, args...);
    if (r.ec == errc::result_out_of_range) {
        for (; r.ptr != last; ++r.ptr)
            if (!in_pattern(*r.ptr, args...)) break;
    }
    return r;
}

// Unsigned base-10 from_chars (fast path using traits::read)
template<class T>
    requires is_unsigned_v<T>
inline from_chars_result from_chars_atoi(const char* first, const char* last, T& value) {
    using tx = traits<T>;
    using output_type = typename tx::type;

    return subject_seq_combinator(
        first, last, value,
        [](const char* f, const char* l, T& val, int /*unused*/) -> from_chars_result {
            output_type a, b;
            auto p = tx::read(f, l, a, b);
            if (p == l || !in_pattern_decimal(*p)) {
                output_type m = numeric_limits<T>::max();
                if (m >= a && m - a >= b) {
                    val = static_cast<T>(a + b);
                    return {p, errc{}};
                }
            }
            return {p, errc::result_out_of_range};
        },
        10);
}

// Signed base-10 from_chars — delegate to unsigned via sign_combinator
template<class T>
    requires is_signed_v<T>
inline from_chars_result from_chars_atoi(const char* first, const char* last, T& value);

// sign_combinator: handle '-' prefix then call f for the unsigned parse
template<class T, class Fn, class... Args>
inline from_chars_result sign_combinator(
    const char* first, const char* last, T& value, Fn f, Args... args)
{
    using tl = numeric_limits<T>;
    decltype(to_unsigned_like(value)) x;

    bool neg = (first != last && *first == '-');
    auto r = f(neg ? first + 1 : first, last, x, args...);
    switch (r.ec) {
    case errc::invalid_argument:  return {first, r.ec};
    case errc::result_out_of_range: return r;
    default: break;
    }

    if (neg) {
        if (x <= complement(to_unsigned_like(tl::min()))) {
            value = static_cast<T>(complement(x));
            return r;
        }
    } else {
        if (x <= to_unsigned_like(tl::max())) {
            value = static_cast<T>(x);
            return r;
        }
    }
    return {r.ptr, errc::result_out_of_range};
}

template<class T>
    requires is_signed_v<T>
inline from_chars_result from_chars_atoi(const char* first, const char* last, T& value) {
    using U = make_unsigned_t<T>;
    return sign_combinator(first, last, value, from_chars_atoi<U>);
}

// Unsigned general-base from_chars
template<class T>
    requires is_unsigned_v<T>
inline from_chars_result from_chars_integral(
    const char* first, const char* last, T& value, int base)
{
    if (base == 10) return from_chars_atoi(first, last, value);

    return subject_seq_combinator(
        first, last, value,
        [](const char* p, const char* lastp, T& val, int b) -> from_chars_result {
            using tl = numeric_limits<T>;
            // Estimate safe digit count before overflow check
            auto digs = tl::digits / from_chars_log2f_lut[b - 2];
            T x = static_cast<T>(in_pattern(*p++, b).val);
            T y = 0;

            for (int i = 1; p != lastp; ++i, ++p) {
                if (auto c = in_pattern(*p, b)) {
                    if (static_cast<float>(i) < digs - 1.0f)
                        x = static_cast<T>(x * b + c.val);
                    else {
                        if (!mul_overflowed(x, b, x))
                            ++p;
                        y = static_cast<T>(c.val);
                        break;
                    }
                } else
                    break;
            }

            if (p == lastp || !in_pattern(*p, b)) {
                if (tl::max() - x >= y) {
                    val = static_cast<T>(x + y);
                    return {p, errc{}};
                }
            }
            return {p, errc::result_out_of_range};
        },
        base);
}

// Signed general-base from_chars
template<class T>
    requires is_signed_v<T>
inline from_chars_result from_chars_integral(
    const char* first, const char* last, T& value, int base)
{
    using U = make_unsigned_t<T>;
    return sign_combinator(first, last, value, from_chars_integral<U>, base);
}

