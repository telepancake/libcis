//===----------------------------------------------------------------------===//
// Internal helper: complement (two's complement negation of unsigned)
// (from traits.h — __complement)
//===----------------------------------------------------------------------===//
namespace detail {

template<class T>
    requires is_unsigned_v<T>
constexpr T complement(T x) noexcept {
    return T(~x + 1);
}

template<class T>
constexpr make_unsigned_t<T> to_unsigned_like(T x) noexcept {
    return static_cast<make_unsigned_t<T>>(x);
}

