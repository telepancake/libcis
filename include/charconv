// <charconv> — primitive numerical conversion (integer only).
// Mechanically ported from libc++ include/__charconv/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// KNOWN GAP: Floating-point overloads of to_chars / from_chars are NOT
// implemented.  libc++'s float path (Ryu algorithm, large lookup tables in
// __charconv/to_chars_floating_point.h and from_chars_floating_point.h) is
// very large and would pull in heavy platform-specific machinery.  The integer
// overloads below are complete.  The float overloads are intentionally omitted
// and declared =delete so that any accidental use produces a clear diagnostic.
#pragma once

#include <type_traits>   // is_integral, is_signed, is_unsigned, make_unsigned_t
#include <limits>        // numeric_limits
#include <cstdint>       // uint32_t, uint64_t
#include <cstddef>       // ptrdiff_t
#include <system_error>  // errc

namespace std {

//===----------------------------------------------------------------------===//
// chars_format (chars_format.h)
//===----------------------------------------------------------------------===//

enum class chars_format {
    scientific = 0x1,
    fixed      = 0x2,
    hex        = 0x4,
    general    = fixed | scientific
};

inline constexpr chars_format operator~(chars_format x) {
    return chars_format(~static_cast<int>(x));
}
inline constexpr chars_format operator&(chars_format x, chars_format y) {
    return chars_format(static_cast<int>(x) & static_cast<int>(y));
}
inline constexpr chars_format operator|(chars_format x, chars_format y) {
    return chars_format(static_cast<int>(x) | static_cast<int>(y));
}
inline constexpr chars_format operator^(chars_format x, chars_format y) {
    return chars_format(static_cast<int>(x) ^ static_cast<int>(y));
}
inline constexpr chars_format& operator&=(chars_format& x, chars_format y) {
    x = x & y; return x;
}
inline constexpr chars_format& operator|=(chars_format& x, chars_format y) {
    x = x | y; return x;
}
inline constexpr chars_format& operator^=(chars_format& x, chars_format y) {
    x = x ^ y; return x;
}

