// <span> — mechanically ported from libc++ include/span
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Covers: dynamic_extent, span<T,Extent> (static and dynamic),
//   all constructors, first/last/subspan (static and dynamic),
//   observers, element access, iterators, as_bytes, as_writable_bytes,
//   deduction guides, enable_borrowed_range/enable_view specialisations.
//
// std::reverse_iterator comes from <iterator> (the canonical home).
// <array> previously defined a local reverse_iterator, but that was an ODR
// hazard; it now includes <iterator> directly.
//
// The ranges infrastructure below (begin/end/data/size CPOs, range concepts,
// enable_borrowed_range, enable_view) is provisional: it lives here because
// <ranges> has not yet been ported.  When <ranges> is ported, these
// definitions MUST be moved there (or merged without duplication) per the
// "No duplication of std vocabulary / detail helpers (ODR)" convention.
#pragma once

#include <type_traits>
#include <concepts>
#include <cstddef>
#include <array>
#include <iterator>

namespace std {

//===----------------------------------------------------------------------===//
// dynamic_extent
//===----------------------------------------------------------------------===//

inline constexpr size_t dynamic_extent = static_cast<size_t>(-1);

//===----------------------------------------------------------------------===//
// Forward declaration of span
//===----------------------------------------------------------------------===//

template<class T, size_t Extent = dynamic_extent>
class span;

//===----------------------------------------------------------------------===//
// Helper: is_std_array_v (from libc++ __fwd/array.h)
//===----------------------------------------------------------------------===//

namespace detail {
    template<class T>
    inline constexpr bool is_std_array_v = false;
    template<class T, size_t N>
    inline constexpr bool is_std_array_v<array<T, N>> = true;
} // namespace detail

//===----------------------------------------------------------------------===//
// Minimal ranges namespace for span
// — enable_borrowed_range, enable_view, disable_sized_range
// — to_address helper
// — begin / end / size / data CPOs
// — iterator_t, range_reference_t, range concepts
//===----------------------------------------------------------------------===//

namespace ranges {

template<class>
inline constexpr bool enable_borrowed_range = false;

template<class>
inline constexpr bool enable_view = false;

template<class>
inline constexpr bool disable_sized_range = false;

} // namespace ranges

// to_address (minimal version for raw pointers and smart pointers)
namespace span_detail {
    template<class T>
    constexpr T* to_address(T* p) noexcept {
        static_assert(!is_function_v<T>,
            "to_address: argument must not be a function pointer");
        return p;
    }
    template<class Ptr>
    constexpr auto to_address(const Ptr& p) noexcept {
        if constexpr (requires { Ptr::pointer_traits_to_address(p); })
            return Ptr::pointer_traits_to_address(p);
        else
            return span_detail::to_address(p.operator->());
    }
} // namespace span_detail

namespace ranges {

// class_or_enum — for ADL disambiguation
namespace detail {
    template<class T>
    concept class_or_enum = is_class_v<T> || is_union_v<T> || is_enum_v<T>;

    // can_borrow: lvalue reference or enable_borrowed_range<remove_cvref_t>
    template<class T>
    concept can_borrow =
        is_lvalue_reference_v<T> ||
        enable_borrowed_range<remove_cvref_t<T>>;

    template<class T>
    concept integer_like_type =
        is_integral_v<T> && !is_same_v<bool, remove_cv_t<T>>;
} // namespace detail

// ---- begin CPO ----
namespace begin_cpo {
void begin() = delete; // poison pill

struct begin_fn {
    // raw array
    template<class T, size_t N>
    [[nodiscard]] constexpr T* operator()(T (&arr)[N]) const noexcept {
        return arr;
    }
    // member .begin() — only for can_borrow types
    template<class T>
        requires detail::can_borrow<T> &&
                 requires(T&& t) { t.begin(); }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.begin())) -> decltype(t.begin()) {
        return t.begin();
    }
    // ADL begin(t)
    template<class T>
        requires detail::can_borrow<T> &&
                 detail::class_or_enum<remove_cvref_t<T>> &&
                 (!requires(T&& t) { t.begin(); }) &&
                 requires(T&& t) { begin(t); }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(begin(t))) -> decltype(begin(t)) {
        return begin(t);
    }
};
} // namespace begin_cpo

// ---- end CPO ----
namespace end_cpo {
void end() = delete; // poison pill

struct end_fn {
    // raw array
    template<class T, size_t N>
    [[nodiscard]] constexpr T* operator()(T (&arr)[N]) const noexcept {
        return arr + N;
    }
    // member .end()
    template<class T>
        requires detail::can_borrow<T> &&
                 requires(T&& t) { t.end(); }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.end())) -> decltype(t.end()) {
        return t.end();
    }
    // ADL end(t)
    template<class T>
        requires detail::can_borrow<T> &&
                 detail::class_or_enum<remove_cvref_t<T>> &&
                 (!requires(T&& t) { t.end(); }) &&
                 requires(T&& t) { end(t); }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(end(t))) -> decltype(end(t)) {
        return end(t);
    }
};
} // namespace end_cpo

// ---- size CPO ----
namespace size_cpo {
void size() = delete; // poison pill

struct size_fn {
    // raw array (rvalue)
    template<class T, size_t N>
    [[nodiscard]] constexpr size_t operator()(T (&&)[N]) const noexcept {
        return N;
    }
    // raw array (lvalue)
    template<class T, size_t N>
    [[nodiscard]] constexpr size_t operator()(T (&)[N]) const noexcept {
        return N;
    }
    // member .size()
    template<class T>
        requires (!ranges::disable_sized_range<remove_cvref_t<T>>) &&
                 requires(T&& t) { t.size(); } &&
                 detail::integer_like_type<remove_cvref_t<decltype(declval<T>().size())>>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.size())) -> decltype(t.size()) {
        return t.size();
    }
    // ADL size(t)
    template<class T>
        requires (!ranges::disable_sized_range<remove_cvref_t<T>>) &&
                 detail::class_or_enum<remove_cvref_t<T>> &&
                 (!requires(T&& t) { t.size(); }) &&
                 requires(T&& t) { size(t); } &&
                 detail::integer_like_type<remove_cvref_t<decltype(size(declval<T>()))>>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(size(t))) -> decltype(size(t)) {
        return size(t);
    }
};
} // namespace size_cpo

// ---- data CPO ----
namespace data_cpo {
struct data_fn {
    // member .data() returning pointer-to-object
    template<class T>
        requires detail::can_borrow<T> &&
                 requires(T&& t) {
                     t.data();
                     requires is_pointer_v<decltype(t.data())>;
                     requires is_object_v<remove_pointer_t<decltype(t.data())>>;
                 }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.data())) -> decltype(t.data()) {
        return t.data();
    }
    // fallback: begin() returns a pointer
    template<class T>
        requires detail::can_borrow<T> &&
                 (!requires(T&& t) {
                     t.data();
                     requires is_pointer_v<decltype(t.data())>;
                  }) &&
                 requires(T&& t) {
                     t.begin();
                     requires is_pointer_v<decltype(t.begin())>;
                 }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.begin())) -> decltype(t.begin()) {
        return t.begin();
    }
};
} // namespace data_cpo

inline namespace cpo {
    inline constexpr auto begin = begin_cpo::begin_fn{};
    inline constexpr auto end   = end_cpo::end_fn{};
    inline constexpr auto size  = size_cpo::size_fn{};
    inline constexpr auto data  = data_cpo::data_fn{};
} // namespace cpo

// Type aliases derived from range
template<class R>
using iterator_t = decltype(ranges::begin(declval<R&>()));

template<class R>
using sentinel_t = decltype(ranges::end(declval<R&>()));

template<class R>
using range_reference_t = decltype(*ranges::begin(declval<R&>()));

// Range concepts
template<class T>
concept range = requires(T& t) {
    ranges::begin(t);
    ranges::end(t);
};

template<class T>
concept sized_range = range<T> && requires(T& t) { ranges::size(t); };

template<class T>
concept borrowed_range =
    range<T> &&
    (is_lvalue_reference_v<T> || enable_borrowed_range<remove_cvref_t<T>>);

// contiguous_range: begin() yields a pointer and data() matches
template<class T>
concept contiguous_range =
    range<T> &&
    requires(T& t) {
        { ranges::data(t) } ->
            same_as<add_pointer_t<remove_reference_t<range_reference_t<T>>>>;
    };

} // namespace ranges

//===----------------------------------------------------------------------===//
// Span internal concepts
//===----------------------------------------------------------------------===//

namespace detail {

// is_std_span
template<class T>
inline constexpr bool is_std_span_v = false;
template<class T, size_t N>
inline constexpr bool is_std_span_v<span<T, N>> = true;

// span_array_convertible: is From(*)[] -> To(*)[] valid?
template<class From, class To>
concept span_array_convertible = is_convertible_v<From(*)[], To(*)[]>;

// span_compatible_iterator: a contiguous iterator for element type T
// Requirements: dereferencing yields a reference, to_address gives a pointer,
// and the element type is array-convertible to T.
template<class It, class T>
concept span_compatible_iterator =
    // array convertibility check
    span_array_convertible<remove_reference_t<decltype(*declval<It>())>, T> &&
    // must be dereferenceable
    requires(It it) { *it; } &&
    // to_address must give a pointer to the element type (raw ptr is ok)
    requires(It it) {
        { span_detail::to_address(it) } ->
            same_as<remove_reference_t<decltype(*it)>*>;
    };

// span_compatible_sentinel: can compute last - first (sized), not convertible to size_t
template<class Sent, class It>
concept span_compatible_sentinel =
    requires(It first, Sent last) {
        last - first;
        first - last;
    } &&
    !is_convertible_v<Sent, size_t>;

// span_compatible_range
template<class Range, class ElementType>
concept span_compatible_range =
    !is_std_span_v<remove_cvref_t<Range>> &&
    ranges::contiguous_range<Range> &&
    ranges::sized_range<Range> &&
    (ranges::borrowed_range<Range> || is_const_v<ElementType>) &&
    !is_std_array_v<remove_cvref_t<Range>> &&
    !is_array_v<remove_cvref_t<Range>> &&
    is_convertible_v<
        remove_reference_t<ranges::range_reference_t<Range>>(*)[], ElementType(*)[]>;

} // namespace detail

//===----------------------------------------------------------------------===//
// span<T, Extent> — static-extent specialisation
//===----------------------------------------------------------------------===//

template<class T, size_t Extent>
class span {
public:
    using element_type    = T;
    using value_type      = remove_cv_t<T>;
    using size_type       = size_t;
    using difference_type = ptrdiff_t;
    using pointer         = T*;
    using const_pointer   = const T*;
    using reference       = T&;
    using const_reference = const T&;
    using iterator        = T*;
    using reverse_iterator = std::reverse_iterator<iterator>;

    static constexpr size_type extent = Extent;

    // default constructor — only valid when Extent == 0
    template<size_t Sz = Extent>
        requires(Sz == 0)
    constexpr span() noexcept : data_(nullptr) {}

    constexpr span(const span&) noexcept = default;
    constexpr span& operator=(const span&) noexcept = default;

    // (iterator, count)
    template<class It>
        requires detail::span_compatible_iterator<It, element_type>
    constexpr explicit span(It first, size_type count)
        : data_(span_detail::to_address(first)) {
        (void)count;
    }

    // (iterator, sentinel)
    template<class It, class End>
        requires detail::span_compatible_iterator<It, element_type> &&
                 detail::span_compatible_sentinel<End, It>
    constexpr explicit span(It first, End last)
        : data_(span_detail::to_address(first)) {
        (void)last;
    }

    // C array
    constexpr span(type_identity_t<element_type> (&arr)[Extent]) noexcept
        : data_(arr) {}

    // std::array<OtherElementType, Extent>&
    template<class OtherElementType>
        requires detail::span_array_convertible<OtherElementType, element_type>
    constexpr span(array<OtherElementType, Extent>& arr) noexcept
        : data_(arr.data()) {}

    // const std::array<OtherElementType, Extent>&
    template<class OtherElementType>
        requires detail::span_array_convertible<const OtherElementType, element_type>
    constexpr span(const array<OtherElementType, Extent>& arr) noexcept
        : data_(arr.data()) {}

    // range constructor
    template<class Range>
        requires detail::span_compatible_range<Range, element_type>
    constexpr explicit span(Range&& r)
        : data_(ranges::data(r)) {}

    // converting from span<OtherElementType, Extent> (same extent)
    template<class OtherElementType>
        requires detail::span_array_convertible<OtherElementType, element_type>
    constexpr span(const span<OtherElementType, Extent>& other) noexcept
        : data_(other.data()) {}

    // converting from span<OtherElementType, dynamic_extent> (explicit)
    template<class OtherElementType>
        requires detail::span_array_convertible<OtherElementType, element_type>
    constexpr explicit span(
        const span<OtherElementType, dynamic_extent>& other) noexcept
        : data_(other.data()) {}

    // [span.sub] — static subviews
    template<size_t Count>
    [[nodiscard]] constexpr span<element_type, Count> first() const noexcept {
        static_assert(Count <= Extent,
            "span<T,N>::first<Count>(): Count out of range");
        return span<element_type, Count>{data_, Count};
    }

    template<size_t Count>
    [[nodiscard]] constexpr span<element_type, Count> last() const noexcept {
        static_assert(Count <= Extent,
            "span<T,N>::last<Count>(): Count out of range");
        return span<element_type, Count>{data_ + Extent - Count, Count};
    }

    template<size_t Offset, size_t Count = dynamic_extent>
    [[nodiscard]] constexpr auto subspan() const noexcept
        -> span<element_type, Count != dynamic_extent ? Count : Extent - Offset>
    {
        static_assert(Offset <= Extent,
            "span<T,N>::subspan<Offset,Count>(): Offset out of range");
        static_assert(Count == dynamic_extent || Count <= Extent - Offset,
            "span<T,N>::subspan<Offset,Count>(): Offset+Count out of range");
        using Ret = span<element_type,
                         Count != dynamic_extent ? Count : Extent - Offset>;
        return Ret{data_ + Offset,
                   Count == dynamic_extent ? Extent - Offset : Count};
    }

    // [span.sub] — dynamic subviews
    [[nodiscard]] constexpr span<element_type, dynamic_extent>
    first(size_type count) const noexcept {
        return {data_, count};
    }

    [[nodiscard]] constexpr span<element_type, dynamic_extent>
    last(size_type count) const noexcept {
        return {data_ + Extent - count, count};
    }

    [[nodiscard]] constexpr span<element_type, dynamic_extent>
    subspan(size_type offset, size_type count = dynamic_extent) const noexcept {
        if (count == dynamic_extent)
            return {data_ + offset, Extent - offset};
        return {data_ + offset, count};
    }

    // [span.obs]
    [[nodiscard]] constexpr size_type size() const noexcept { return Extent; }
    [[nodiscard]] constexpr size_type size_bytes() const noexcept {
        return Extent * sizeof(element_type);
    }
    [[nodiscard]] constexpr bool empty() const noexcept { return Extent == 0; }

    // [span.elem]
    [[nodiscard]] constexpr reference operator[](size_type idx) const noexcept {
        return data_[idx];
    }
    [[nodiscard]] constexpr reference front() const noexcept { return data_[0]; }
    [[nodiscard]] constexpr reference back() const noexcept {
        return data_[Extent - 1];
    }
    [[nodiscard]] constexpr pointer data() const noexcept { return data_; }

    // [span.iter]
    [[nodiscard]] constexpr iterator begin() const noexcept { return data_; }
    [[nodiscard]] constexpr iterator end() const noexcept { return data_ + Extent; }
    [[nodiscard]] constexpr reverse_iterator rbegin() const noexcept {
        return reverse_iterator(end());
    }
    [[nodiscard]] constexpr reverse_iterator rend() const noexcept {
        return reverse_iterator(begin());
    }

    // as_bytes helpers
    span<const byte, Extent * sizeof(element_type)>
    as_bytes_impl() const noexcept {
        const byte* p = reinterpret_cast<const byte*>(data_);
        return span<const byte, Extent * sizeof(element_type)>(p, size_bytes());
    }
    span<byte, Extent * sizeof(element_type)>
    as_writable_bytes_impl() const noexcept {
        byte* p = reinterpret_cast<byte*>(data_);
        return span<byte, Extent * sizeof(element_type)>(p, size_bytes());
    }

private:
    pointer data_;
};

//===----------------------------------------------------------------------===//
// span<T, dynamic_extent> — dynamic-extent specialisation
//===----------------------------------------------------------------------===//

template<class T>
class span<T, dynamic_extent> {
public:
    using element_type    = T;
    using value_type      = remove_cv_t<T>;
    using size_type       = size_t;
    using difference_type = ptrdiff_t;
    using pointer         = T*;
    using const_pointer   = const T*;
    using reference       = T&;
    using const_reference = const T&;
    using iterator        = T*;
    using reverse_iterator = std::reverse_iterator<iterator>;

    static constexpr size_type extent = dynamic_extent;

    constexpr span() noexcept : data_(nullptr), size_(0) {}

    constexpr span(const span&) noexcept = default;
    constexpr span& operator=(const span&) noexcept = default;

    // (iterator, count)
    template<class It>
        requires detail::span_compatible_iterator<It, element_type>
    constexpr span(It first, size_type count)
        : data_(span_detail::to_address(first)), size_(count) {}

    // (iterator, sentinel)
    template<class It, class End>
        requires detail::span_compatible_iterator<It, element_type> &&
                 detail::span_compatible_sentinel<End, It>
    constexpr span(It first, End last)
        : data_(span_detail::to_address(first)),
          size_(static_cast<size_type>(last - first)) {}

    // C array
    template<size_t N>
    constexpr span(type_identity_t<element_type> (&arr)[N]) noexcept
        : data_(arr), size_(N) {}

    // std::array<OtherElementType, N>&
    template<class OtherElementType, size_t N>
        requires detail::span_array_convertible<OtherElementType, element_type>
    constexpr span(array<OtherElementType, N>& arr) noexcept
        : data_(arr.data()), size_(N) {}

    // const std::array<OtherElementType, N>&
    template<class OtherElementType, size_t N>
        requires detail::span_array_convertible<const OtherElementType, element_type>
    constexpr span(const array<OtherElementType, N>& arr) noexcept
        : data_(arr.data()), size_(N) {}

    // range constructor
    template<class Range>
        requires detail::span_compatible_range<Range, element_type>
    constexpr span(Range&& r)
        : data_(ranges::data(r)), size_(ranges::size(r)) {}

    // converting from any span
    template<class OtherElementType, size_t OtherExtent>
        requires detail::span_array_convertible<OtherElementType, element_type>
    constexpr span(const span<OtherElementType, OtherExtent>& other) noexcept
        : data_(other.data()), size_(other.size()) {}

    // [span.sub] — static subviews
    template<size_t Count>
    [[nodiscard]] constexpr span<element_type, Count> first() const noexcept {
        return span<element_type, Count>{data_, Count};
    }

    template<size_t Count>
    [[nodiscard]] constexpr span<element_type, Count> last() const noexcept {
        return span<element_type, Count>{data_ + size_ - Count, Count};
    }

    template<size_t Offset, size_t Count = dynamic_extent>
    [[nodiscard]] constexpr span<element_type, Count>
    subspan() const noexcept {
        return span<element_type, Count>{
            data_ + Offset,
            Count == dynamic_extent ? size_ - Offset : Count};
    }

    // [span.sub] — dynamic subviews
    [[nodiscard]] constexpr span<element_type, dynamic_extent>
    first(size_type count) const noexcept {
        return {data_, count};
    }

    [[nodiscard]] constexpr span<element_type, dynamic_extent>
    last(size_type count) const noexcept {
        return {data_ + size_ - count, count};
    }

    [[nodiscard]] constexpr span<element_type, dynamic_extent>
    subspan(size_type offset, size_type count = dynamic_extent) const noexcept {
        if (count == dynamic_extent)
            return {data_ + offset, size_ - offset};
        return {data_ + offset, count};
    }

    // [span.obs]
    [[nodiscard]] constexpr size_type size() const noexcept { return size_; }
    [[nodiscard]] constexpr size_type size_bytes() const noexcept {
        return size_ * sizeof(element_type);
    }
    [[nodiscard]] constexpr bool empty() const noexcept { return size_ == 0; }

    // [span.elem]
    [[nodiscard]] constexpr reference operator[](size_type idx) const noexcept {
        return data_[idx];
    }
    [[nodiscard]] constexpr reference front() const noexcept { return data_[0]; }
    [[nodiscard]] constexpr reference back() const noexcept {
        return data_[size_ - 1];
    }
    [[nodiscard]] constexpr pointer data() const noexcept { return data_; }

    // [span.iter]
    [[nodiscard]] constexpr iterator begin() const noexcept { return data_; }
    [[nodiscard]] constexpr iterator end() const noexcept { return data_ + size_; }
    [[nodiscard]] constexpr reverse_iterator rbegin() const noexcept {
        return reverse_iterator(end());
    }
    [[nodiscard]] constexpr reverse_iterator rend() const noexcept {
        return reverse_iterator(begin());
    }

    // as_bytes helpers
    span<const byte, dynamic_extent> as_bytes_impl() const noexcept {
        const byte* p = reinterpret_cast<const byte*>(data_);
        return span<const byte, dynamic_extent>(p, size_bytes());
    }
    span<byte, dynamic_extent> as_writable_bytes_impl() const noexcept {
        byte* p = reinterpret_cast<byte*>(data_);
        return span<byte, dynamic_extent>(p, size_bytes());
    }

private:
    pointer   data_;
    size_type size_;
};

//===----------------------------------------------------------------------===//
// enable_borrowed_range and enable_view specialisations for span
//===----------------------------------------------------------------------===//

template<class T, size_t Extent>
inline constexpr bool ranges::enable_borrowed_range<span<T, Extent>> = true;

template<class T, size_t Extent>
inline constexpr bool ranges::enable_view<span<T, Extent>> = true;

//===----------------------------------------------------------------------===//
// [span.objectrep] — as_bytes / as_writable_bytes
//===----------------------------------------------------------------------===//

template<class T, size_t Extent>
    requires(!is_volatile_v<T>)
[[nodiscard]] auto as_bytes(span<T, Extent> s) noexcept {
    return s.as_bytes_impl();
}

template<class T, size_t Extent>
    requires(!is_const_v<T> && !is_volatile_v<T>)
[[nodiscard]] auto as_writable_bytes(span<T, Extent> s) noexcept {
    return s.as_writable_bytes_impl();
}

//===----------------------------------------------------------------------===//
// Deduction guides
//===----------------------------------------------------------------------===//

template<class It, class EndOrSize>
span(It, EndOrSize) -> span<remove_reference_t<decltype(*declval<It>())>>;

template<class T, size_t N>
span(T (&)[N]) -> span<T, N>;

template<class T, size_t N>
span(array<T, N>&) -> span<T, N>;

template<class T, size_t N>
span(const array<T, N>&) -> span<const T, N>;

template<class R>
    requires ranges::contiguous_range<R>
span(R&&) -> span<remove_reference_t<ranges::range_reference_t<R>>>;

} // namespace std
