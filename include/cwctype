// <cwctype> -- C wide-character classification functions in namespace std.
// Mechanically ported from libc++ include/cwctype.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
#pragma once

// glibc declarations must keep DEFAULT visibility no matter where this
// wrapper is first included from: io headers wrap their bodies in
// `#pragma GCC visibility push(hidden)` (libstdc++-ABI isolation), and a
// libc prototype first seen inside such a region becomes a hidden symbol
// the linker then cannot resolve against libc (e.g. strtod via <sstream>).
#pragma GCC visibility push(default)
#include <wctype.h>
#pragma GCC visibility pop

namespace std {

using ::wint_t;
using ::wctrans_t;
using ::wctype_t;
using ::iswalnum;
using ::iswalpha;
using ::iswblank;
using ::iswcntrl;
using ::iswdigit;
using ::iswgraph;
using ::iswlower;
using ::iswprint;
using ::iswpunct;
using ::iswspace;
using ::iswupper;
using ::iswxdigit;
using ::iswctype;
using ::wctype;
using ::towlower;
using ::towupper;
using ::towctrans;
using ::wctrans;

} // namespace std
