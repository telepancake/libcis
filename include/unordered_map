// <unordered_map> — ported from libc++ include/unordered_map (release/20.x)
// on top of bits/hash_table.h (libc++ __hash_table).
//
// Note: the node value type is pair<const Key, T> itself (libc++ wraps it in
// the layout-identical __hash_value_type; see bits/hash_table.h header
// comment), so the table iterators are used directly without the
// __hash_map_iterator wrappers.
//
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
#pragma once

#include <memory_resource>
#include <bits/hash_table.h>
#include <functional>
#include <memory>
#include <utility>
#include <tuple>
#include <iterator>
#include <algorithm>
#include <initializer_list>
#include <type_traits>

namespace std {

// ============================================================================
// __unordered_map_hasher / __unordered_map_equal
// Wrap the user's Hash/Pred so the table can hash/compare container values
// (pair<const Key,T>), plain keys, and (C++20) heterogeneous keys.
// libc++ has empty-base-optimized and member variants; [[no_unique_address]]
// gives us both in one.
// ============================================================================

namespace detail {

template<class Key, class Cp, class Hash, class Pred>
class unordered_map_hasher {
    [[no_unique_address]] Hash hash_;

public:
    unordered_map_hasher() noexcept(is_nothrow_default_constructible_v<Hash>) : hash_() {}
    unordered_map_hasher(const Hash& h) noexcept(is_nothrow_copy_constructible_v<Hash>)
        : hash_(h) {}

    const Hash& hash_function() const noexcept { return hash_; }

    size_t operator()(const Cp& x) const { return hash_(x.first); }
    size_t operator()(const Key& x) const { return hash_(x); }
    template<class K2>
    size_t operator()(const K2& x) const { return hash_(x); }

    void swap(unordered_map_hasher& y) noexcept(is_nothrow_swappable_v<Hash>) {
        using std::swap;
        swap(hash_, y.hash_);
    }
};

template<class Key, class Cp, class Hash, class Pred>
inline void swap(unordered_map_hasher<Key, Cp, Hash, Pred>& x,
                 unordered_map_hasher<Key, Cp, Hash, Pred>& y) noexcept(noexcept(x.swap(y))) {
    x.swap(y);
}

template<class Key, class Cp, class Pred, class Hash>
class unordered_map_equal {
    [[no_unique_address]] Pred pred_;

public:
    unordered_map_equal() noexcept(is_nothrow_default_constructible_v<Pred>) : pred_() {}
    unordered_map_equal(const Pred& p) noexcept(is_nothrow_copy_constructible_v<Pred>)
        : pred_(p) {}

    const Pred& key_eq() const noexcept { return pred_; }

    bool operator()(const Cp& x, const Cp& y) const { return pred_(x.first, y.first); }
    bool operator()(const Cp& x, const Key& y) const { return pred_(x.first, y); }
    bool operator()(const Key& x, const Cp& y) const { return pred_(x, y.first); }
    template<class K2>
    bool operator()(const Cp& x, const K2& y) const { return pred_(x.first, y); }
    template<class K2>
    bool operator()(const K2& x, const Cp& y) const { return pred_(x, y.first); }
    template<class K2>
    bool operator()(const Key& x, const K2& y) const { return pred_(x, y); }
    template<class K2>
    bool operator()(const K2& x, const Key& y) const { return pred_(x, y); }

    void swap(unordered_map_equal& y) noexcept(is_nothrow_swappable_v<Pred>) {
        using std::swap;
        swap(pred_, y.pred_);
    }
};

template<class Key, class Cp, class Pred, class Hash>
inline void swap(unordered_map_equal<Key, Cp, Pred, Hash>& x,
                 unordered_map_equal<Key, Cp, Pred, Hash>& y) noexcept(noexcept(x.swap(y))) {
    x.swap(y);
}

// __iter_key_type / __iter_mapped_type / __iter_to_alloc_type
// (unique names; detail::iter_key_type is owned by <map>)
template<class InputIt>
using ht_iter_key_type =
    remove_const_t<typename iterator_traits<InputIt>::value_type::first_type>;
template<class InputIt>
using ht_iter_mapped_type = typename iterator_traits<InputIt>::value_type::second_type;
template<class InputIt>
using ht_iter_to_alloc_type =
    pair<const typename iterator_traits<InputIt>::value_type::first_type,
         typename iterator_traits<InputIt>::value_type::second_type>;

} // namespace detail

template<class Key, class T, class Hash, class Pred, class Alloc>
class unordered_multimap;

// ============================================================================
// unordered_map
// ============================================================================

template<class Key, class T,
         class Hash  = hash<Key>,
         class Pred  = equal_to<Key>,
         class Alloc = allocator<pair<const Key, T>>>
class unordered_map {
public:
    // types
    using key_type        = Key;
    using mapped_type     = T;
    using hasher          = type_identity_t<Hash>;
    using key_equal       = type_identity_t<Pred>;
    using allocator_type  = type_identity_t<Alloc>;
    using value_type      = pair<const key_type, mapped_type>;
    using reference       = value_type&;
    using const_reference = const value_type&;
    static_assert(is_same_v<value_type, typename allocator_type::value_type>,
                  "Allocator::value_type must be same type as value_type");

private:
    using table_hasher = detail::unordered_map_hasher<key_type, value_type, hasher, key_equal>;
    using table_key_equal = detail::unordered_map_equal<key_type, value_type, key_equal, hasher>;

    using table = hash_table<value_type, table_hasher, table_key_equal, allocator_type>;

    table table_;

    using node = typename table::node;
    using node_traits = typename table::node_traits;
    using alloc_traits = allocator_traits<allocator_type>;

    template<class, class, class, class, class>
    friend class unordered_map;
    template<class, class, class, class, class>
    friend class unordered_multimap;

public:
    using pointer         = typename alloc_traits::pointer;
    using const_pointer   = typename alloc_traits::const_pointer;
    using size_type       = typename table::size_type;
    using difference_type = typename table::difference_type;

    using iterator             = typename table::iterator;
    using const_iterator       = typename table::const_iterator;
    using local_iterator       = typename table::local_iterator;
    using const_local_iterator = typename table::const_local_iterator;

    using node_type          = ht_map_node_handle<node, allocator_type>;
    using insert_return_type = ht_insert_return_type<iterator, node_type>;

    // ------------------------------------------------------------------
    // Constructors
    // ------------------------------------------------------------------

    unordered_map() noexcept(is_nothrow_default_constructible_v<table>) {}

    explicit unordered_map(size_type n, const hasher& hf = hasher(),
                           const key_equal& eql = key_equal())
        : table_(hf, eql) {
        table_.rehash_unique(n);
    }

    unordered_map(size_type n, const hasher& hf, const key_equal& eql, const allocator_type& a)
        : table_(hf, eql, a) {
        table_.rehash_unique(n);
    }

    template<class InputIterator>
    unordered_map(InputIterator first, InputIterator last) {
        insert(first, last);
    }

    template<class InputIterator>
    unordered_map(InputIterator first, InputIterator last, size_type n,
                  const hasher& hf = hasher(), const key_equal& eql = key_equal())
        : table_(hf, eql) {
        table_.rehash_unique(n);
        insert(first, last);
    }

    template<class InputIterator>
    unordered_map(InputIterator first, InputIterator last, size_type n,
                  const hasher& hf, const key_equal& eql, const allocator_type& a)
        : table_(hf, eql, a) {
        table_.rehash_unique(n);
        insert(first, last);
    }

    explicit unordered_map(const allocator_type& a) : table_(a) {}

    unordered_map(const unordered_map& u) : table_(u.table_) {
        table_.rehash_unique(u.bucket_count());
        insert(u.begin(), u.end());
    }

    unordered_map(const unordered_map& u, const allocator_type& a) : table_(u.table_, a) {
        table_.rehash_unique(u.bucket_count());
        insert(u.begin(), u.end());
    }

    unordered_map(unordered_map&& u) noexcept(is_nothrow_move_constructible_v<table>)
        : table_(std::move(u.table_)) {}

    unordered_map(unordered_map&& u, const allocator_type& a)
        : table_(std::move(u.table_), a) {
        if (a != u.get_allocator()) {
            iterator i = u.begin();
            while (u.size() != 0)
                table_.emplace_unique(
                    table::kv_types::move_value(u.table_.remove((i++))->get_value()));
        }
    }

    unordered_map(initializer_list<value_type> il) { insert(il.begin(), il.end()); }

    unordered_map(initializer_list<value_type> il, size_type n,
                  const hasher& hf = hasher(), const key_equal& eql = key_equal())
        : table_(hf, eql) {
        table_.rehash_unique(n);
        insert(il.begin(), il.end());
    }

    unordered_map(initializer_list<value_type> il, size_type n,
                  const hasher& hf, const key_equal& eql, const allocator_type& a)
        : table_(hf, eql, a) {
        table_.rehash_unique(n);
        insert(il.begin(), il.end());
    }

    unordered_map(size_type n, const allocator_type& a)
        : unordered_map(n, hasher(), key_equal(), a) {}
    unordered_map(size_type n, const hasher& hf, const allocator_type& a)
        : unordered_map(n, hf, key_equal(), a) {}
    template<class InputIterator>
    unordered_map(InputIterator first, InputIterator last, size_type n, const allocator_type& a)
        : unordered_map(first, last, n, hasher(), key_equal(), a) {}
    template<class InputIterator>
    unordered_map(InputIterator first, InputIterator last, size_type n, const hasher& hf,
                  const allocator_type& a)
        : unordered_map(first, last, n, hf, key_equal(), a) {}
    unordered_map(initializer_list<value_type> il, size_type n, const allocator_type& a)
        : unordered_map(il, n, hasher(), key_equal(), a) {}
    unordered_map(initializer_list<value_type> il, size_type n, const hasher& hf,
                  const allocator_type& a)
        : unordered_map(il, n, hf, key_equal(), a) {}

    ~unordered_map() = default;

    // ------------------------------------------------------------------
    // Assignment
    // ------------------------------------------------------------------

    unordered_map& operator=(const unordered_map& u) {
        table_ = u.table_;
        return *this;
    }

    unordered_map& operator=(unordered_map&& u)
        noexcept(is_nothrow_move_assignable_v<table>) {
        table_ = std::move(u.table_);
        return *this;
    }

    unordered_map& operator=(initializer_list<value_type> il) {
        table_.assign_unique(il.begin(), il.end());
        return *this;
    }

    allocator_type get_allocator() const noexcept {
        return allocator_type(table_.node_alloc());
    }

    // ------------------------------------------------------------------
    // Capacity / iterators
    // ------------------------------------------------------------------

    [[nodiscard]] bool empty() const noexcept { return table_.size() == 0; }
    size_type size() const noexcept { return table_.size(); }
    size_type max_size() const noexcept { return table_.max_size(); }

    iterator begin() noexcept { return table_.begin(); }
    iterator end() noexcept { return table_.end(); }
    const_iterator begin() const noexcept { return table_.begin(); }
    const_iterator end() const noexcept { return table_.end(); }
    const_iterator cbegin() const noexcept { return table_.begin(); }
    const_iterator cend() const noexcept { return table_.end(); }

    // ------------------------------------------------------------------
    // Modifiers
    // ------------------------------------------------------------------

    pair<iterator, bool> insert(const value_type& x) { return table_.insert_unique(x); }

    iterator insert(const_iterator, const value_type& x) { return insert(x).first; }

    template<class InputIterator>
    void insert(InputIterator first, InputIterator last) {
        for (; first != last; ++first)
            table_.insert_unique(*first);
    }

    void insert(initializer_list<value_type> il) { insert(il.begin(), il.end()); }

    pair<iterator, bool> insert(value_type&& x) { return table_.insert_unique(std::move(x)); }

    iterator insert(const_iterator, value_type&& x) {
        return table_.insert_unique(std::move(x)).first;
    }

    template<class P, enable_if_t<is_constructible_v<value_type, P>, int> = 0>
    pair<iterator, bool> insert(P&& x) {
        return table_.insert_unique(std::forward<P>(x));
    }

    template<class P, enable_if_t<is_constructible_v<value_type, P>, int> = 0>
    iterator insert(const_iterator, P&& x) {
        return insert(std::forward<P>(x)).first;
    }

    template<class... Args>
    pair<iterator, bool> emplace(Args&&... args) {
        return table_.emplace_unique(std::forward<Args>(args)...);
    }

    template<class... Args>
    iterator emplace_hint(const_iterator, Args&&... args) {
        return table_.emplace_unique(std::forward<Args>(args)...).first;
    }

    template<class... Args>
    pair<iterator, bool> try_emplace(const key_type& k, Args&&... args) {
        return table_.emplace_unique_key_args(k, piecewise_construct, std::forward_as_tuple(k),
                                              std::forward_as_tuple(std::forward<Args>(args)...));
    }

    template<class... Args>
    pair<iterator, bool> try_emplace(key_type&& k, Args&&... args) {
        return table_.emplace_unique_key_args(
            k, piecewise_construct, std::forward_as_tuple(std::move(k)),
            std::forward_as_tuple(std::forward<Args>(args)...));
    }

    template<class... Args>
    iterator try_emplace(const_iterator, const key_type& k, Args&&... args) {
        return try_emplace(k, std::forward<Args>(args)...).first;
    }

    template<class... Args>
    iterator try_emplace(const_iterator, key_type&& k, Args&&... args) {
        return try_emplace(std::move(k), std::forward<Args>(args)...).first;
    }

    template<class V>
    pair<iterator, bool> insert_or_assign(const key_type& k, V&& v) {
        pair<iterator, bool> res = table_.emplace_unique_key_args(k, k, std::forward<V>(v));
        if (!res.second)
            res.first->second = std::forward<V>(v);
        return res;
    }

    template<class V>
    pair<iterator, bool> insert_or_assign(key_type&& k, V&& v) {
        pair<iterator, bool> res =
            table_.emplace_unique_key_args(k, std::move(k), std::forward<V>(v));
        if (!res.second)
            res.first->second = std::forward<V>(v);
        return res;
    }

    template<class V>
    iterator insert_or_assign(const_iterator, const key_type& k, V&& v) {
        return insert_or_assign(k, std::forward<V>(v)).first;
    }

    template<class V>
    iterator insert_or_assign(const_iterator, key_type&& k, V&& v) {
        return insert_or_assign(std::move(k), std::forward<V>(v)).first;
    }

    iterator erase(const_iterator p) { return table_.erase(p); }
    iterator erase(iterator p) { return table_.erase(const_iterator(p)); }
    size_type erase(const key_type& k) { return table_.erase_unique(k); }
    iterator erase(const_iterator first, const_iterator last) {
        return table_.erase(first, last);
    }
    void clear() noexcept { table_.clear(); }

    insert_return_type insert(node_type&& nh) {
        return table_.template node_handle_insert_unique<node_type, insert_return_type>(
            std::move(nh));
    }
    iterator insert(const_iterator hint, node_type&& nh) {
        return table_.template node_handle_insert_unique<node_type>(hint, std::move(nh));
    }
    node_type extract(const key_type& key) {
        return table_.template node_handle_extract<node_type>(key);
    }
    node_type extract(const_iterator it) {
        return table_.template node_handle_extract<node_type>(it);
    }

    template<class H2, class P2>
    void merge(unordered_map<key_type, mapped_type, H2, P2, allocator_type>& source) {
        return table_.node_handle_merge_unique(source.table_);
    }
    template<class H2, class P2>
    void merge(unordered_map<key_type, mapped_type, H2, P2, allocator_type>&& source) {
        return table_.node_handle_merge_unique(source.table_);
    }
    template<class H2, class P2>
    void merge(unordered_multimap<key_type, mapped_type, H2, P2, allocator_type>& source) {
        return table_.node_handle_merge_unique(source.table_);
    }
    template<class H2, class P2>
    void merge(unordered_multimap<key_type, mapped_type, H2, P2, allocator_type>&& source) {
        return table_.node_handle_merge_unique(source.table_);
    }

    void swap(unordered_map& u) noexcept(is_nothrow_swappable_v<table>) {
        table_.swap(u.table_);
    }

    // ------------------------------------------------------------------
    // Observers
    // ------------------------------------------------------------------

    hasher hash_function() const { return table_.hash_function().hash_function(); }
    key_equal key_eq() const { return table_.key_eq().key_eq(); }

    // ------------------------------------------------------------------
    // Lookup
    // ------------------------------------------------------------------

    iterator find(const key_type& k) { return table_.find(k); }
    const_iterator find(const key_type& k) const { return table_.find(k); }
    template<class K2, enable_if_t<detail::ht_is_transparent_v<hasher, K2> &&
                                   detail::ht_is_transparent_v<key_equal, K2>>* = nullptr>
    iterator find(const K2& k) { return table_.find(k); }
    template<class K2, enable_if_t<detail::ht_is_transparent_v<hasher, K2> &&
                                   detail::ht_is_transparent_v<key_equal, K2>>* = nullptr>
    const_iterator find(const K2& k) const { return table_.find(k); }

    size_type count(const key_type& k) const { return table_.count_unique(k); }
    template<class K2, enable_if_t<detail::ht_is_transparent_v<hasher, K2> &&
                                   detail::ht_is_transparent_v<key_equal, K2>>* = nullptr>
    size_type count(const K2& k) const { return table_.count_unique(k); }

    bool contains(const key_type& k) const { return find(k) != end(); }
    template<class K2, enable_if_t<detail::ht_is_transparent_v<hasher, K2> &&
                                   detail::ht_is_transparent_v<key_equal, K2>>* = nullptr>
    bool contains(const K2& k) const { return find(k) != end(); }

    pair<iterator, iterator> equal_range(const key_type& k) {
        return table_.equal_range_unique(k);
    }
    pair<const_iterator, const_iterator> equal_range(const key_type& k) const {
        return table_.equal_range_unique(k);
    }
    template<class K2, enable_if_t<detail::ht_is_transparent_v<hasher, K2> &&
                                   detail::ht_is_transparent_v<key_equal, K2>>* = nullptr>
    pair<iterator, iterator> equal_range(const K2& k) {
        return table_.equal_range_unique(k);
    }
    template<class K2, enable_if_t<detail::ht_is_transparent_v<hasher, K2> &&
                                   detail::ht_is_transparent_v<key_equal, K2>>* = nullptr>
    pair<const_iterator, const_iterator> equal_range(const K2& k) const {
        return table_.equal_range_unique(k);
    }

    mapped_type& operator[](const key_type& k) {
        return table_
            .emplace_unique_key_args(k, piecewise_construct, std::forward_as_tuple(k),
                                     std::forward_as_tuple())
            .first->second;
    }

    mapped_type& operator[](key_type&& k) {
        return table_
            .emplace_unique_key_args(k, piecewise_construct, std::forward_as_tuple(std::move(k)),
                                     std::forward_as_tuple())
            .first->second;
    }

    mapped_type& at(const key_type& k) {
        iterator i = find(k);
        if (i == end())
            __builtin_trap(); // would throw out_of_range
        return i->second;
    }

    const mapped_type& at(const key_type& k) const {
        const_iterator i = find(k);
        if (i == end())
            __builtin_trap(); // would throw out_of_range
        return i->second;
    }

    // ------------------------------------------------------------------
    // Bucket interface / hash policy
    // ------------------------------------------------------------------

    size_type bucket_count() const noexcept { return table_.bucket_count(); }
    size_type max_bucket_count() const noexcept { return table_.max_bucket_count(); }

    size_type bucket_size(size_type n) const { return table_.bucket_size(n); }
    size_type bucket(const key_type& k) const { return table_.bucket(k); }

    local_iterator begin(size_type n) { return table_.begin(n); }
    local_iterator end(size_type n) { return table_.end(n); }
    const_local_iterator begin(size_type n) const { return table_.cbegin(n); }
    const_local_iterator end(size_type n) const { return table_.cend(n); }
    const_local_iterator cbegin(size_type n) const { return table_.cbegin(n); }
    const_local_iterator cend(size_type n) const { return table_.cend(n); }

    float load_factor() const noexcept { return table_.load_factor(); }
    float max_load_factor() const noexcept { return table_.max_load_factor(); }
    void max_load_factor(float mlf) { table_.max_load_factor(mlf); }
    void rehash(size_type n) { table_.rehash_unique(n); }
    void reserve(size_type n) { table_.reserve_unique(n); }
};

// Deduction guides (libc++ unordered_map)
template<class InputIterator,
         class Hash      = hash<detail::ht_iter_key_type<InputIterator>>,
         class Pred      = equal_to<detail::ht_iter_key_type<InputIterator>>,
         class Allocator = allocator<detail::ht_iter_to_alloc_type<InputIterator>>,
         class           = void_t<detail::ht_iter_category_t<InputIterator>>,
         class           = enable_if_t<!detail::ht_is_allocator_v<Hash>>,
         class           = enable_if_t<!is_integral_v<Hash>>,
         class           = enable_if_t<!detail::ht_is_allocator_v<Pred>>,
         class           = enable_if_t<detail::ht_is_allocator_v<Allocator>>>
unordered_map(InputIterator, InputIterator,
              typename allocator_traits<Allocator>::size_type = 0,
              Hash = Hash(), Pred = Pred(), Allocator = Allocator())
    -> unordered_map<detail::ht_iter_key_type<InputIterator>,
                     detail::ht_iter_mapped_type<InputIterator>, Hash, Pred, Allocator>;

template<class Key, class Tp,
         class Hash      = hash<remove_const_t<Key>>,
         class Pred      = equal_to<remove_const_t<Key>>,
         class Allocator = allocator<pair<const Key, Tp>>,
         class           = enable_if_t<!detail::ht_is_allocator_v<Hash>>,
         class           = enable_if_t<!is_integral_v<Hash>>,
         class           = enable_if_t<!detail::ht_is_allocator_v<Pred>>,
         class           = enable_if_t<detail::ht_is_allocator_v<Allocator>>>
unordered_map(initializer_list<pair<Key, Tp>>,
              typename allocator_traits<Allocator>::size_type = 0,
              Hash = Hash(), Pred = Pred(), Allocator = Allocator())
    -> unordered_map<remove_const_t<Key>, Tp, Hash, Pred, Allocator>;

template<class InputIterator, class Allocator,
         class = void_t<detail::ht_iter_category_t<InputIterator>>,
         class = enable_if_t<detail::ht_is_allocator_v<Allocator>>>
unordered_map(InputIterator, InputIterator, typename allocator_traits<Allocator>::size_type,
              Allocator)
    -> unordered_map<detail::ht_iter_key_type<InputIterator>,
                     detail::ht_iter_mapped_type<InputIterator>,
                     hash<detail::ht_iter_key_type<InputIterator>>,
                     equal_to<detail::ht_iter_key_type<InputIterator>>, Allocator>;

template<class InputIterator, class Allocator,
         class = void_t<detail::ht_iter_category_t<InputIterator>>,
         class = enable_if_t<detail::ht_is_allocator_v<Allocator>>>
unordered_map(InputIterator, InputIterator, Allocator)
    -> unordered_map<detail::ht_iter_key_type<InputIterator>,
                     detail::ht_iter_mapped_type<InputIterator>,
                     hash<detail::ht_iter_key_type<InputIterator>>,
                     equal_to<detail::ht_iter_key_type<InputIterator>>, Allocator>;

template<class InputIterator, class Hash, class Allocator,
         class = void_t<detail::ht_iter_category_t<InputIterator>>,
         class = enable_if_t<!detail::ht_is_allocator_v<Hash>>,
         class = enable_if_t<!is_integral_v<Hash>>,
         class = enable_if_t<detail::ht_is_allocator_v<Allocator>>>
unordered_map(InputIterator, InputIterator, typename allocator_traits<Allocator>::size_type, Hash,
              Allocator)
    -> unordered_map<detail::ht_iter_key_type<InputIterator>,
                     detail::ht_iter_mapped_type<InputIterator>, Hash,
                     equal_to<detail::ht_iter_key_type<InputIterator>>, Allocator>;

template<class Key, class Tp, class Allocator,
         class = enable_if_t<detail::ht_is_allocator_v<Allocator>>>
unordered_map(initializer_list<pair<Key, Tp>>, typename allocator_traits<Allocator>::size_type,
              Allocator)
    -> unordered_map<remove_const_t<Key>, Tp, hash<remove_const_t<Key>>,
                     equal_to<remove_const_t<Key>>, Allocator>;

