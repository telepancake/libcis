// <bit> -- bit manipulation utilities.
// Mechanically ported from libc++ include/bit + include/__bit/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Builtin notes (gcc-10.2):
//   AVAILABLE: __builtin_clz/clzl/clzll, __builtin_ctz/ctzl/ctzll,
//              __builtin_popcount/popcountl/popcountll,
//              __builtin_bswap16/32/64,
//              __BYTE_ORDER__, __ORDER_LITTLE_ENDIAN__, __ORDER_BIG_ENDIAN__,
//              __builtin_memcpy
//   NOT AVAILABLE: __builtin_clzg, __builtin_ctzg, __builtin_popcountg,
//                  __builtin_bswapg, __builtin_bit_cast (gcc-11+)
//
// bit_cast: gcc-10.2 does NOT have __builtin_bit_cast (added in gcc-11).
//   libc++ guards bit_cast with #if __has_builtin(__builtin_bit_cast) and
//   provides no public fallback. We implement it with __builtin_memcpy, which
//   is NOT constexpr — it is a normal runtime function. The requires constraint
//   (same size + trivially copyable) is still enforced at compile time.
#pragma once

#include <type_traits>
#include <cstdint>
#include <climits>

namespace std {

//===----------------------------------------------------------------------===//
// Internal helpers
//===----------------------------------------------------------------------===//

namespace detail {

// bit_digits<T>: number of value (non-sign, non-padding) bits in T.
// Equivalent to numeric_limits<T>::digits for the types bit functions accept.
template<class T> inline constexpr int bit_digits_v = (int)(sizeof(T) * CHAR_BIT);
// Signed types: subtract the sign bit.
template<> inline constexpr int bit_digits_v<signed char>  = CHAR_BIT - 1;
template<> inline constexpr int bit_digits_v<short>        = (int)(sizeof(short) * CHAR_BIT) - 1;
template<> inline constexpr int bit_digits_v<int>          = (int)(sizeof(int) * CHAR_BIT) - 1;
template<> inline constexpr int bit_digits_v<long>         = (int)(sizeof(long) * CHAR_BIT) - 1;
template<> inline constexpr int bit_digits_v<long long>    = (int)(sizeof(long long) * CHAR_BIT) - 1;
#if defined(__SIZEOF_INT128__)
template<> inline constexpr int bit_digits_v<__int128>     = 127;
#endif
// bool: 1 value bit
template<> inline constexpr int bit_digits_v<bool>         = 1;

// The __unsigned_integer concept used by libc++ for bit functions.
// It is: integral, unsigned, not bool, not a character type, unqualified.
// (Matches libc++'s integer_traits.h __unsigned_integer concept.)
template<class T>
inline constexpr bool is_unsigned_integer_v =
    is_integral_v<T> && is_unsigned_v<T> &&
    !is_same_v<T, bool>     &&
    !is_same_v<T, char>     &&
    !is_same_v<T, wchar_t>  &&
    !is_same_v<T, char8_t>  &&
    !is_same_v<T, char16_t> &&
    !is_same_v<T, char32_t> &&
    is_same_v<T, remove_cv_t<T>>;   // unqualified

template<class T>
inline constexpr bool is_integral_type_v =
    is_integral_v<T> && is_same_v<T, remove_cv_t<T>>;

// The __signed_or_unsigned_integer concept for byteswap (C++23 integral).
template<class T>
inline constexpr bool is_integer_v =
    (is_integral_v<T>) &&
    !is_same_v<T, bool>     &&
    !is_same_v<T, char>     &&
    !is_same_v<T, wchar_t>  &&
    !is_same_v<T, char8_t>  &&
    !is_same_v<T, char16_t> &&
    !is_same_v<T, char32_t> &&
    is_same_v<T, remove_cv_t<T>>;

template<class T>
concept unsigned_integer_type = detail::is_unsigned_integer_v<T>;

template<class T>
concept integer_type = detail::is_integer_v<T>;

} // namespace detail

//===----------------------------------------------------------------------===//
// [bit.cast] bit_cast
// NOTE: gcc-10.2 lacks __builtin_bit_cast (added in gcc-11).
// This implementation uses __builtin_memcpy and is therefore NOT constexpr.
// libc++ itself would use __builtin_bit_cast if available; we use the memcpy
// fallback that libc++ uses internally for the pre-constexpr case.
//===----------------------------------------------------------------------===//

template<class To, class From>
    requires (sizeof(To) == sizeof(From) &&
              is_trivially_copyable_v<To> &&
              is_trivially_copyable_v<From>)
#if __has_builtin(__builtin_bit_cast)
[[nodiscard]] constexpr To bit_cast(const From& from) noexcept {
    return __builtin_bit_cast(To, from);
}
#else
[[nodiscard]] inline To bit_cast(const From& from) noexcept {
    // DEVIATION from libc++ (which uses __builtin_bit_cast unconditionally):
    // gcc-10.2 lacks the builtin (added in gcc-11), and a constexpr bit_cast
    // cannot be expressed in C++ without it. Runtime-only memcpy fallback.
    To to;
    __builtin_memcpy(&to, &from, sizeof(To));
    return to;
}
#endif

//===----------------------------------------------------------------------===//
// Internal dispatch: countl_zero / countr_zero / popcount per type width
// libc++ uses __builtin_clzg/__builtin_ctzg/__builtin_popcountg (gcc-13+).
// We dispatch manually to __builtin_clz/clzl/clzll etc. (gcc-10.2 available).
//===----------------------------------------------------------------------===//

namespace detail {

// countl_zero_impl: count leading zeros for unsigned integer types.
// Returns digits (== sizeof(T)*8) for zero input.
template<class T>
constexpr int countl_zero_impl(T t) noexcept {
    if (t == 0)
        return bit_digits_v<T>;
    if constexpr (sizeof(T) <= sizeof(unsigned int)) {
        // Promote to unsigned int, then adjust for the extra bits.
        const int extra = (int)(sizeof(unsigned int) * CHAR_BIT) - bit_digits_v<T>;
        return __builtin_clz((unsigned int)t) - extra;
    } else if constexpr (sizeof(T) == sizeof(unsigned long)) {
        const int extra = (int)(sizeof(unsigned long) * CHAR_BIT) - bit_digits_v<T>;
        return __builtin_clzl((unsigned long)t) - extra;
    } else if constexpr (sizeof(T) == sizeof(unsigned long long)) {
        const int extra = (int)(sizeof(unsigned long long) * CHAR_BIT) - bit_digits_v<T>;
        return __builtin_clzll((unsigned long long)t) - extra;
    } else {
        // __uint128_t: split into two 64-bit halves.
        static_assert(sizeof(T) == 16, "unexpected type size");
        unsigned long long hi = (unsigned long long)(t >> 64);
        unsigned long long lo = (unsigned long long)t;
        if (hi != 0)
            return __builtin_clzll(hi);
        else
            return 64 + __builtin_clzll(lo);
    }
}

// countr_zero_impl: count trailing zeros.
template<class T>
constexpr int countr_zero_impl(T t) noexcept {
    if (t == 0)
        return bit_digits_v<T>;
    if constexpr (sizeof(T) <= sizeof(unsigned int)) {
        return __builtin_ctz((unsigned int)t);
    } else if constexpr (sizeof(T) == sizeof(unsigned long)) {
        return __builtin_ctzl((unsigned long)t);
    } else if constexpr (sizeof(T) == sizeof(unsigned long long)) {
        return __builtin_ctzll((unsigned long long)t);
    } else {
        static_assert(sizeof(T) == 16, "unexpected type size");
        unsigned long long hi = (unsigned long long)(t >> 64);
        unsigned long long lo = (unsigned long long)t;
        if (lo != 0)
            return __builtin_ctzll(lo);
        else
            return 64 + __builtin_ctzll(hi);
    }
}

// popcount_impl: count set bits.
template<class T>
constexpr int popcount_impl(T t) noexcept {
    if constexpr (sizeof(T) <= sizeof(unsigned int)) {
        return __builtin_popcount((unsigned int)t);
    } else if constexpr (sizeof(T) == sizeof(unsigned long)) {
        return __builtin_popcountl((unsigned long)t);
    } else if constexpr (sizeof(T) == sizeof(unsigned long long)) {
        return __builtin_popcountll((unsigned long long)t);
    } else {
        static_assert(sizeof(T) == 16, "unexpected type size");
        unsigned long long hi = (unsigned long long)(t >> 64);
        unsigned long long lo = (unsigned long long)t;
        return __builtin_popcountll(hi) + __builtin_popcountll(lo);
    }
}

} // namespace detail

//===----------------------------------------------------------------------===//
// [bit.count] countl_zero, countl_one, countr_zero, countr_one, popcount
//===----------------------------------------------------------------------===//

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr int countl_zero(T t) noexcept {
    return detail::countl_zero_impl(t);
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr int countl_one(T t) noexcept {
    return countl_zero(static_cast<T>(~t));
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr int countr_zero(T t) noexcept {
    return detail::countr_zero_impl(t);
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr int countr_one(T t) noexcept {
    return countr_zero(static_cast<T>(~t));
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr int popcount(T t) noexcept {
    return detail::popcount_impl(t);
}

//===----------------------------------------------------------------------===//
// [bit.rotate] rotl, rotr
//===----------------------------------------------------------------------===//

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr T rotl(T t, int cnt) noexcept {
    const int n = detail::bit_digits_v<T>;
    int r = cnt % n;
    if (r == 0)
        return t;
    if (r > 0)
        return (t << r) | (t >> (n - r));
    return (t >> -r) | (t << (n + r));
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr T rotr(T t, int cnt) noexcept {
    const int n = detail::bit_digits_v<T>;
    int r = cnt % n;
    if (r == 0)
        return t;
    if (r > 0)
        return (t >> r) | (t << (n - r));
    return (t << -r) | (t >> (n + r));
}

//===----------------------------------------------------------------------===//
// Internal helper: bit_log2 (floor log2; undefined for t == 0)
// Used by bit_ceil, bit_floor, bit_width.
//===----------------------------------------------------------------------===//

namespace detail {

template<class T>
constexpr T bit_log2(T t) noexcept {
    return static_cast<T>(bit_digits_v<T> - 1 - countl_zero(t));
}

} // namespace detail

//===----------------------------------------------------------------------===//
// [bit.pow.two] has_single_bit, bit_ceil, bit_floor, bit_width
//===----------------------------------------------------------------------===//

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr bool has_single_bit(T t) noexcept {
    return detail::popcount_impl(t) == 1;
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr T bit_floor(T t) noexcept {
    return t == 0 ? T(0) : T(1) << detail::bit_log2(t);
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr int bit_width(T t) noexcept {
    return t == 0 ? 0 : (int)detail::bit_log2(t) + 1;
}

template<detail::unsigned_integer_type T>
[[nodiscard]] constexpr T bit_ceil(T t) noexcept {
    if (t < 2)
        return T(1);
    const unsigned n = (unsigned)detail::bit_digits_v<T> -
                       (unsigned)countl_zero(static_cast<T>(t - 1u));
    if constexpr (sizeof(T) >= sizeof(unsigned)) {
        return T(1) << n;
    } else {
        const unsigned extra = (unsigned)(sizeof(unsigned) * CHAR_BIT) -
                               (unsigned)detail::bit_digits_v<T>;
        const unsigned ret_val = 1u << (n + extra);
        return (T)(ret_val >> extra);
    }
}

//===----------------------------------------------------------------------===//
// [bit.byteswap] byteswap (C++23, included per the "maximally featureful" rule)
// Mandates: T has no padding bits (static_assert enforces this).
// __builtin_bswap16/32/64 available in gcc-10.2.
// No __builtin_bswapg in gcc-10 — dispatch per size.
//===----------------------------------------------------------------------===//

template<detail::integer_type T>
[[nodiscard]] constexpr T byteswap(T val) noexcept {
    static_assert(
        is_same_v<remove_cv_t<T>, bool> ||
        detail::bit_digits_v<T> + is_signed_v<T> == (int)(sizeof(T) * CHAR_BIT),
        "std::byteswap requires T to have no padding bits");

    if constexpr (sizeof(T) == 1) {
        return val;
    } else if constexpr (sizeof(T) == 2) {
        return static_cast<T>(__builtin_bswap16(static_cast<uint16_t>(val)));
    } else if constexpr (sizeof(T) == 4) {
        return static_cast<T>(__builtin_bswap32(static_cast<uint32_t>(val)));
    } else if constexpr (sizeof(T) == 8) {
        return static_cast<T>(__builtin_bswap64(static_cast<uint64_t>(val)));
    }
#if defined(__SIZEOF_INT128__)
    else {
        // __uint128_t / __int128: split into two 64-bit halves.
        static_assert(sizeof(T) == 16, "byteswap: unexpected type size");
        uint64_t hi = static_cast<uint64_t>(static_cast<__uint128_t>(val) >> 64);
        uint64_t lo = static_cast<uint64_t>(val);
        return static_cast<T>(
            (static_cast<__uint128_t>(__builtin_bswap64(lo)) << 64) |
            static_cast<__uint128_t>(__builtin_bswap64(hi)));
    }
#endif
}

//===----------------------------------------------------------------------===//
// [bit.endian] endian
// Use GCC predefined macros __BYTE_ORDER__ / __ORDER_LITTLE_ENDIAN__ etc.
// Available in gcc-10.2.
//===----------------------------------------------------------------------===//

enum class endian {
    little = __ORDER_LITTLE_ENDIAN__,
    big    = __ORDER_BIG_ENDIAN__,
#if __BYTE_ORDER__ == __ORDER_LITTLE_ENDIAN__
    native = little
#elif __BYTE_ORDER__ == __ORDER_BIG_ENDIAN__
    native = big
#else
    native = 0 // mixed/middle endian
#endif
};

} // namespace std
