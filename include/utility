//===----------------------------------------------------------------------===//
// [utility.intcmp], integer comparison functions (__utility/cmp.h)
// Requires: T and U are signed or unsigned integer types (not bool, char, etc.)
//===----------------------------------------------------------------------===//

namespace detail {
    // A type is a "signed integer type" per [basic.fundamental]: unqualified,
    // non-bool, non-character, signed integral.
    template<class T>
    inline constexpr bool is_character_type_v = false;
    template<> inline constexpr bool is_character_type_v<char>     = true;
    template<> inline constexpr bool is_character_type_v<wchar_t>  = true;
    template<> inline constexpr bool is_character_type_v<char8_t>  = true;
    template<> inline constexpr bool is_character_type_v<char16_t> = true;
    template<> inline constexpr bool is_character_type_v<char32_t> = true;

    template<class T>
    inline constexpr bool is_signed_integer_v =
        is_integral_v<T> && is_signed_v<T> &&
        !is_character_type_v<T> && !is_same_v<T, bool> &&
        is_same_v<T, remove_cv_t<T>>;

    template<class T>
    inline constexpr bool is_unsigned_integer_v =
        is_integral_v<T> && is_unsigned_v<T> &&
        !is_character_type_v<T> && !is_same_v<T, bool> &&
        is_same_v<T, remove_cv_t<T>>;

    template<class T>
    concept signed_integer = is_signed_integer_v<T>;

    template<class T>
    concept unsigned_integer = is_unsigned_integer_v<T>;

    template<class T>
    concept signed_or_unsigned_integer = signed_integer<T> || unsigned_integer<T>;

    // can_promote_to<T, I>: T can be losslessly widened to I
    template<class T, class I>
    concept comparison_can_promote_to =
        (sizeof(T) < sizeof(I)) ||
        (sizeof(T) == sizeof(I) && signed_integer<T>);
} // namespace detail

template<detail::signed_or_unsigned_integer T, detail::signed_or_unsigned_integer U>
[[nodiscard]] constexpr bool cmp_equal(T t, U u) noexcept {
    if constexpr (is_signed_v<T> == is_signed_v<U>)
        return t == u;
    else if constexpr (detail::comparison_can_promote_to<T, int> &&
                       detail::comparison_can_promote_to<U, int>)
        return static_cast<int>(t) == static_cast<int>(u);
    else if constexpr (detail::comparison_can_promote_to<T, long long> &&
                       detail::comparison_can_promote_to<U, long long>)
        return static_cast<long long>(t) == static_cast<long long>(u);
    else if constexpr (is_signed_v<T>)
        return t < 0 ? false : make_unsigned_t<T>(t) == u;
    else
        return u < 0 ? false : t == make_unsigned_t<U>(u);
}

template<detail::signed_or_unsigned_integer T, detail::signed_or_unsigned_integer U>
[[nodiscard]] constexpr bool cmp_not_equal(T t, U u) noexcept {
    return !cmp_equal(t, u);
}

template<detail::signed_or_unsigned_integer T, detail::signed_or_unsigned_integer U>
[[nodiscard]] constexpr bool cmp_less(T t, U u) noexcept {
    if constexpr (is_signed_v<T> == is_signed_v<U>)
        return t < u;
    else if constexpr (detail::comparison_can_promote_to<T, int> &&
                       detail::comparison_can_promote_to<U, int>)
        return static_cast<int>(t) < static_cast<int>(u);
    else if constexpr (detail::comparison_can_promote_to<T, long long> &&
                       detail::comparison_can_promote_to<U, long long>)
        return static_cast<long long>(t) < static_cast<long long>(u);
    else if constexpr (is_signed_v<T>)
        return t < 0 ? true : make_unsigned_t<T>(t) < u;
    else
        return u < 0 ? false : t < make_unsigned_t<U>(u);
}

template<detail::signed_or_unsigned_integer T, detail::signed_or_unsigned_integer U>
[[nodiscard]] constexpr bool cmp_greater(T t, U u) noexcept {
    return cmp_less(u, t);
}

template<detail::signed_or_unsigned_integer T, detail::signed_or_unsigned_integer U>
[[nodiscard]] constexpr bool cmp_less_equal(T t, U u) noexcept {
    return !cmp_greater(t, u);
}

template<detail::signed_or_unsigned_integer T, detail::signed_or_unsigned_integer U>
[[nodiscard]] constexpr bool cmp_greater_equal(T t, U u) noexcept {
    return !cmp_less(t, u);
}

// in_range: check if u fits in the range representable by T
// We implement numeric_limits<T>::max/min ourselves since <limits> is
// unavailable under -nostdinc++.
namespace detail {
    template<class T>
    constexpr T integer_max() noexcept {
        if constexpr (is_signed_v<T>) {
            // max = 2^(bits-1) - 1
            return static_cast<T>(make_unsigned_t<T>(-1) >> 1);
        } else {
            return static_cast<T>(~T(0));
        }
    }
    template<class T>
    constexpr T integer_min() noexcept {
        if constexpr (is_signed_v<T>) {
            return static_cast<T>(~detail::integer_max<T>());
        } else {
            return T(0);
        }
    }
} // namespace detail

template<detail::signed_or_unsigned_integer T,
         detail::signed_or_unsigned_integer U>
[[nodiscard]] constexpr bool in_range(U u) noexcept {
    return cmp_less_equal(u, detail::integer_max<T>()) &&
           cmp_greater_equal(u, detail::integer_min<T>());
}

