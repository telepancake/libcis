// [utility.underlying], to_underlying (__utility/to_underlying.h) — C++23
// Included here as it's a useful utility and is in scope for gnu++20
//===----------------------------------------------------------------------===//

template<class T>
    requires is_enum_v<T>
[[nodiscard]] constexpr underlying_type_t<T> to_underlying(T val) noexcept {
    return static_cast<underlying_type_t<T>>(val);
}

