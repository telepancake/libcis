// <utility> — mechanically ported from libc++ include/utility + __utility/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// All __utility/*.h fragments are folded inline; no include/bits/ file needed.
// Depends on <type_traits> (already provides declval, swap declarations,
// is_swappable/is_nothrow_swappable, unwrap_ref_decay) and <compare>
// (provides synth_three_way / synth_three_way_result).
//
// swap consistency note:
//   <type_traits> forward-declares swap with constraints
//     requires (is_move_constructible_v<T> && is_move_assignable_v<T>)
//   We provide the matching DEFINITION here (same signature/constraints).
//   Including both headers in the same TU is safe; there is no re-declaration
//   conflict because the constraints make these templated function declarations.
//
// integer_sequence builtin note:
//   gcc-10.2 lacks __make_integer_seq but provides __integer_pack inside
//   template context. We use that for O(1) sequence generation.
#pragma once

#include <type_traits>
#include <compare>
#include <initializer_list>

namespace std {

//===----------------------------------------------------------------------===//
// [utility.move], move (__utility/move.h)
//===----------------------------------------------------------------------===//

template<class T>
[[nodiscard]] constexpr remove_reference_t<T>&& move(T&& t) noexcept {
    return static_cast<remove_reference_t<T>&&>(t);
}

// move_if_noexcept: if T's move ctor can throw and T is copy-constructible,
// return const-lvalue-ref; otherwise return rvalue-ref.
namespace detail {
    template<class T>
    using move_if_noexcept_result_t =
        conditional_t<!is_nothrow_move_constructible_v<T> &&
                       is_copy_constructible_v<T>,
                      const T&, T&&>;
}

template<class T>
[[nodiscard]] constexpr detail::move_if_noexcept_result_t<T>
move_if_noexcept(T& x) noexcept {
    return move(x);
}

//===----------------------------------------------------------------------===//
// [utility.forward], forward (__utility/forward.h)
//===----------------------------------------------------------------------===//

template<class T>
[[nodiscard]] constexpr T&&
forward(remove_reference_t<T>& t) noexcept {
    return static_cast<T&&>(t);
}

template<class T>
[[nodiscard]] constexpr T&&
forward(remove_reference_t<T>&& t) noexcept {
    static_assert(!is_lvalue_reference_v<T>,
        "cannot forward an rvalue as an lvalue");
    return static_cast<T&&>(t);
}

//===----------------------------------------------------------------------===//
// [utility.as_const], as_const (__utility/as_const.h)
//===----------------------------------------------------------------------===//

template<class T>
[[nodiscard]] constexpr const T& as_const(T& t) noexcept { return t; }

template<class T>
void as_const(const T&&) = delete;

//===----------------------------------------------------------------------===//
// [utility.swap], swap (__utility/swap.h)
// The forward declarations in <type_traits> are:
//   template<class T>
//     requires (is_move_constructible_v<T> && is_move_assignable_v<T>)
//   void swap(T& x, T& y) noexcept(...);
//   template<class T, size_t N>
//     requires (is_move_constructible_v<T> && is_move_assignable_v<T>)
//   void swap(T (&a)[N], T (&b)[N]) noexcept(...);
// We provide the definitions here with matching constraints.
//===----------------------------------------------------------------------===//

// Definitions matching the forward-declarations in <type_traits> exactly.
// The declarations there are NOT constexpr (plain void), so we must NOT add
// constexpr here either — C++ forbids changing constexpr in a redeclaration.
template<class T>
    requires (is_move_constructible_v<T> && is_move_assignable_v<T>)
void swap(T& x, T& y)
    noexcept(is_nothrow_move_constructible_v<T> &&
             is_nothrow_move_assignable_v<T>)
{
    T tmp(move(x));
    x = move(y);
    y = move(tmp);
}

template<class T, size_t N>
    requires (is_move_constructible_v<T> && is_move_assignable_v<T>)
void swap(T (&a)[N], T (&b)[N])
    noexcept(noexcept(swap(*a, *b)))
{
    for (size_t i = 0; i != N; ++i)
        swap(a[i], b[i]);
}

//===----------------------------------------------------------------------===//
// [utility.exchange], exchange (__utility/exchange.h)
//===----------------------------------------------------------------------===//

template<class T, class U = T>
[[nodiscard]] constexpr T
exchange(T& obj, U&& new_value)
    noexcept(is_nothrow_move_constructible_v<T> &&
             is_nothrow_assignable_v<T&, U>)
{
    T old_value = move(obj);
    obj = forward<U>(new_value);
    return old_value;
}

