//===----------------------------------------------------------------------===//
// [intseq], integer_sequence (__utility/integer_sequence.h)
// gcc-10.2: __make_integer_seq is absent but __integer_pack works in templates.
//===----------------------------------------------------------------------===//

template<class T, T... Idx>
struct integer_sequence {
    using value_type = T;
    static_assert(is_integral_v<T>,
        "std::integer_sequence can only be instantiated with an integral type");
    [[nodiscard]] static constexpr size_t size() noexcept {
        return sizeof...(Idx);
    }
};

template<size_t... Idx>
using index_sequence = integer_sequence<size_t, Idx...>;

// Use __integer_pack builtin (available in gcc-10 in template context)
template<class T, T N>
using make_integer_sequence = integer_sequence<T, __integer_pack(N)...>;

template<size_t N>
using make_index_sequence = make_integer_sequence<size_t, N>;

template<class... Ts>
using index_sequence_for = make_index_sequence<sizeof...(Ts)>;

