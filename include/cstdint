// <cstdint> -- fixed-width integer types.
// Mechanically ported from libc++ include/cstdint.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// With -nostdinc++ the C <stdint.h> is still reachable via the system include
// path.  Include it and re-export every type into namespace std.
// The macros (INT8_MIN, UINT32_MAX, ...) remain in the global namespace as
// provided by <stdint.h>; the standard only requires them there.
#pragma once

// glibc declarations must keep DEFAULT visibility no matter where this
// wrapper is first included from: io headers wrap their bodies in
// `#pragma GCC visibility push(hidden)` (libstdc++-ABI isolation), and a
// libc prototype first seen inside such a region becomes a hidden symbol
// the linker then cannot resolve against libc (e.g. strtod via <sstream>).
#pragma GCC visibility push(default)
#include <stdint.h>
#pragma GCC visibility pop

namespace std {

using ::int8_t;
using ::int16_t;
using ::int32_t;
using ::int64_t;

using ::uint8_t;
using ::uint16_t;
using ::uint32_t;
using ::uint64_t;

using ::int_least8_t;
using ::int_least16_t;
using ::int_least32_t;
using ::int_least64_t;

using ::uint_least8_t;
using ::uint_least16_t;
using ::uint_least32_t;
using ::uint_least64_t;

using ::int_fast8_t;
using ::int_fast16_t;
using ::int_fast32_t;
using ::int_fast64_t;

using ::uint_fast8_t;
using ::uint_fast16_t;
using ::uint_fast32_t;
using ::uint_fast64_t;

using ::intptr_t;
using ::uintptr_t;

using ::intmax_t;
using ::uintmax_t;

} // namespace std
