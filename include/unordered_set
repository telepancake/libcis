namespace std {

// ============================================================================
// For unordered_set the value_type IS the key_type.
// The hash_table stores Key directly and uses Hash/Equal as-is.
// We wrap them so they operate on Key (identity).
// ============================================================================

namespace detail {

// Key extractor for unordered_set: identity
template<class Key, class Hash>
struct set_hash : Hash {
    using Hash::operator();
};

template<class Key, class Equal>
struct set_equal : Equal {
    using Equal::operator();
};

} // namespace detail

// ============================================================================
// unordered_set node handle
// ============================================================================

template<class Key, class Alloc>
struct us_node_handle {
    using value_type     = Key;
    using allocator_type = Alloc;

    using NodeAlloc = typename allocator_traits<Alloc>::template rebind_alloc<
        ht_node<Key, typename allocator_traits<Alloc>::void_pointer>>;
    using NodePtr = typename allocator_traits<NodeAlloc>::pointer;

    NodePtr ptr_ = nullptr;
    allocator_type alloc_;
    bool has_alloc_ = false;

    us_node_handle() noexcept = default;
    us_node_handle(NodePtr p, const Alloc& a)
        : ptr_(p), alloc_(a), has_alloc_(true) {}
    us_node_handle(us_node_handle&& o) noexcept
        : ptr_(o.ptr_), alloc_(move(o.alloc_)), has_alloc_(o.has_alloc_)
    { o.ptr_ = nullptr; }
    us_node_handle& operator=(us_node_handle&& o) noexcept {
        destroy();
        ptr_      = o.ptr_;
        alloc_    = move(o.alloc_);
        has_alloc_= o.has_alloc_;
        o.ptr_    = nullptr;
        return *this;
    }
    ~us_node_handle() { destroy(); }

    bool empty() const noexcept { return !ptr_; }
    explicit operator bool() const noexcept { return !empty(); }
    allocator_type get_allocator() const { return alloc_; }
    value_type& value() const { return ptr_->get_value(); }

    void swap(us_node_handle& o) noexcept {
        using std::swap;
        swap(ptr_, o.ptr_); swap(alloc_, o.alloc_); swap(has_alloc_, o.has_alloc_);
    }
private:
    void destroy() noexcept {
        if (ptr_) {
            NodeAlloc na(alloc_);
            allocator_traits<NodeAlloc>::destroy(na, addressof(ptr_->get_value()));
            allocator_traits<NodeAlloc>::deallocate(na, ptr_, 1);
            ptr_ = nullptr;
        }
    }
};

template<class Key, class Alloc>
void swap(us_node_handle<Key,Alloc>& a, us_node_handle<Key,Alloc>& b) noexcept { a.swap(b); }

// insert_return_type
template<class Iterator, class NodeHandle>
struct us_insert_return_type {
    Iterator   position;
    bool       inserted;
    NodeHandle node;
};

// ============================================================================
// unordered_set<Key, Hash, Pred, Alloc>
// ============================================================================

template<class Key,
         class Hash  = hash<Key>,
         class Pred  = equal_to<Key>,
         class Alloc = allocator<Key>>
class unordered_set {
public:
    using key_type        = Key;
    using value_type      = Key;
    using hasher          = Hash;
    using key_equal       = Pred;
    using allocator_type  = Alloc;
    using reference       = value_type&;
    using const_reference = const value_type&;
    using alloc_traits    = allocator_traits<Alloc>;
    using pointer         = typename alloc_traits::pointer;
    using const_pointer   = typename alloc_traits::const_pointer;
    using size_type       = typename alloc_traits::size_type;
    using difference_type = ptrdiff_t;

private:
    using SHash  = detail::set_hash<Key, Hash>;
    using SEqual = detail::set_equal<Key, Pred>;
    using Table  = hash_table<Key, SHash, SEqual, Alloc, /*Unique=*/true>;
    Table table_;

public:
    using iterator             = typename Table::const_iterator; // set iterators are const
    using const_iterator       = typename Table::const_iterator;
    using local_iterator       = typename Table::const_local_iterator;
    using const_local_iterator = typename Table::const_local_iterator;
    using node_type            = us_node_handle<Key, Alloc>;
    using insert_return_type   = us_insert_return_type<iterator, node_type>;

    // -------------------------------------------------------------------------
    // Constructors
    // -------------------------------------------------------------------------

    unordered_set() = default;

    explicit unordered_set(size_type n,
                           const Hash& hf  = Hash(),
                           const Pred& eql = Pred(),
                           const Alloc& a  = Alloc())
        : table_(n, SHash(hf), SEqual(eql), a) {}

    unordered_set(size_type n, const Alloc& a) : unordered_set(n, Hash(), Pred(), a) {}
    unordered_set(size_type n, const Hash& hf, const Alloc& a) : unordered_set(n, hf, Pred(), a) {}
    explicit unordered_set(const Alloc& a) : table_(a) {}

    template<class InputIt>
    unordered_set(InputIt first, InputIt last,
                  size_type n   = 0,
                  const Hash& hf = Hash(),
                  const Pred& eql= Pred(),
                  const Alloc& a = Alloc())
        : table_(n, SHash(hf), SEqual(eql), a)
    { for (; first != last; ++first) table_.emplace_unique(*first); }

    template<class InputIt>
    unordered_set(InputIt first, InputIt last, size_type n, const Alloc& a)
        : unordered_set(first, last, n, Hash(), Pred(), a) {}
    template<class InputIt>
    unordered_set(InputIt first, InputIt last, size_type n, const Hash& hf, const Alloc& a)
        : unordered_set(first, last, n, hf, Pred(), a) {}

    unordered_set(initializer_list<value_type> il,
                  size_type n   = 0,
                  const Hash& hf = Hash(),
                  const Pred& eql= Pred(),
                  const Alloc& a = Alloc())
        : unordered_set(il.begin(), il.end(), n, hf, eql, a) {}

    unordered_set(initializer_list<value_type> il, size_type n, const Alloc& a)
        : unordered_set(il, n, Hash(), Pred(), a) {}
    unordered_set(initializer_list<value_type> il, size_type n, const Hash& hf, const Alloc& a)
        : unordered_set(il, n, hf, Pred(), a) {}

    unordered_set(const unordered_set&)            = default;
    unordered_set(unordered_set&&)                 = default;
    unordered_set(const unordered_set& o, const Alloc& a) : table_(o.table_, a) {}
    unordered_set(unordered_set&& o, const Alloc& a)      : table_(move(o.table_), a) {}

    ~unordered_set() = default;
    unordered_set& operator=(const unordered_set&) = default;
    unordered_set& operator=(unordered_set&&)      = default;
    unordered_set& operator=(initializer_list<value_type> il) {
        table_.clear();
        for (auto& v : il) table_.emplace_unique(v);
        return *this;
    }

    // -------------------------------------------------------------------------
    // Iterators (const only for set)
    // -------------------------------------------------------------------------

    iterator       begin()        noexcept { return table_.begin(); }
    const_iterator begin()  const noexcept { return table_.begin(); }
    iterator       end()          noexcept { return table_.end(); }
    const_iterator end()    const noexcept { return table_.end(); }
    const_iterator cbegin() const noexcept { return table_.cbegin(); }
    const_iterator cend()   const noexcept { return table_.cend(); }

    // -------------------------------------------------------------------------
    // Capacity
    // -------------------------------------------------------------------------

    bool      empty()    const noexcept { return table_.empty(); }
    size_type size()     const noexcept { return table_.size(); }
    size_type max_size() const noexcept { return table_.max_size(); }

    // -------------------------------------------------------------------------
    // Modifiers
    // -------------------------------------------------------------------------

    void clear() noexcept { table_.clear(); }

    pair<iterator,bool> insert(const value_type& v) {
        auto [it, ins] = table_.emplace_unique(v);
        return {it, ins};
    }
    pair<iterator,bool> insert(value_type&& v) {
        auto [it, ins] = table_.emplace_unique(move(v));
        return {it, ins};
    }
    iterator insert(const_iterator, const value_type& v) { return insert(v).first; }
    iterator insert(const_iterator, value_type&& v)      { return insert(move(v)).first; }

    template<class InputIt>
    void insert(InputIt first, InputIt last) {
        for (; first != last; ++first) table_.emplace_unique(*first);
    }
    void insert(initializer_list<value_type> il) { insert(il.begin(), il.end()); }

    template<class... Args>
    pair<iterator,bool> emplace(Args&&... args) {
        auto [it, ins] = table_.emplace_unique(forward<Args>(args)...);
        return {it, ins};
    }
    template<class... Args>
    iterator emplace_hint(const_iterator, Args&&... args) {
        return emplace(forward<Args>(args)...).first;
    }

    iterator  erase(const_iterator pos)            { return table_.erase(pos); }
    iterator  erase(const_iterator f, const_iterator l) { return table_.erase(f, l); }
    size_type erase(const Key& k)                  { return table_.erase_unique(k); }

    node_type extract(const_iterator pos) {
        auto h = table_.extract_node(pos);
        return node_type(h.release(), get_allocator());
    }
    node_type extract(const Key& k) {
        auto it = find(k);
        if (it == end()) return node_type();
        return extract(it);
    }

    insert_return_type insert(node_type&& nh) {
        if (!nh.ptr_) return {end(), false, move(nh)};
        nh.ptr_->hash_val = table_.hash_function()(nh.ptr_->get_value());
        auto [it, ins] = table_.insert_node_unique(nh.ptr_);
        if (ins) nh.ptr_ = nullptr;
        return {it, ins, move(nh)};
    }
    iterator insert(const_iterator, node_type&& nh) { return insert(move(nh)).position; }

    template<class H2, class P2>
    void merge(unordered_set<Key,H2,P2,Alloc>& src) {
        for (auto it = src.begin(); it != src.end(); ) {
            auto cur = it++;
            if (find(*cur) == end()) {
                auto h = src.extract(cur);
                insert(move(h));
            }
        }
    }
    template<class H2, class P2>
    void merge(unordered_set<Key,H2,P2,Alloc>&& src) { merge(src); }

    // -------------------------------------------------------------------------
    // Lookup
    // -------------------------------------------------------------------------

    iterator       find(const Key& k)       { return table_.find(k); }
    const_iterator find(const Key& k) const { return table_.find(k); }

    size_type count(const Key& k)   const { return table_.count_unique(k); }
    bool      contains(const Key& k) const { return find(k) != end(); }

    pair<iterator,iterator> equal_range(const Key& k) {
        auto [i,j] = table_.equal_range_unique(k);
        return {i, j};
    }
    pair<const_iterator,const_iterator> equal_range(const Key& k) const {
        auto [i,j] = table_.equal_range_unique(k);
        return {i, j};
    }

    // -------------------------------------------------------------------------
    // Bucket interface
    // -------------------------------------------------------------------------

    size_type bucket_count()     const noexcept { return table_.bucket_count(); }
    size_type max_bucket_count() const noexcept { return table_.max_bucket_count(); }
    size_type bucket_size(size_type n) const    { return table_.bucket_size(n); }
    size_type bucket(const Key& k)     const    { return table_.bucket(k); }

    local_iterator       begin(size_type n)        { return table_.begin(n); }
    local_iterator       end(size_type n)          { return table_.end(n); }
    const_local_iterator begin(size_type n)  const { return table_.begin(n); }
    const_local_iterator end(size_type n)    const { return table_.end(n); }
    const_local_iterator cbegin(size_type n) const { return table_.cbegin(n); }
    const_local_iterator cend(size_type n)   const { return table_.cend(n); }

    float load_factor()          const noexcept { return table_.load_factor(); }
    float max_load_factor()      const noexcept { return table_.max_load_factor(); }
    void  max_load_factor(float mlf)             { table_.max_load_factor(mlf); }
    void  rehash(size_type n)                    { table_.rehash(n); }
    void  reserve(size_type n)                   { table_.reserve(n); }

    hasher         hash_function() const { return static_cast<const Hash&>(table_.hash_function()); }
    key_equal      key_eq()        const { return static_cast<const Pred&>(table_.key_eq()); }
    allocator_type get_allocator() const noexcept { return table_.get_allocator(); }

    void swap(unordered_set& other) noexcept(
        is_nothrow_swappable_v<Hash> && is_nothrow_swappable_v<Pred>)
    { table_.swap(other.table_); }

    friend bool operator==(const unordered_set& a, const unordered_set& b) {
        if (a.size() != b.size()) return false;
        for (auto& v : a)
            if (b.find(v) == b.end()) return false;
        return true;
    }
};

// Deduction guides
template<class InputIt,
         class Hash = hash<typename iterator_traits<InputIt>::value_type>,
         class Pred = equal_to<typename iterator_traits<InputIt>::value_type>,
         class Alloc = allocator<typename iterator_traits<InputIt>::value_type>>
unordered_set(InputIt, InputIt,
              typename allocator_traits<Alloc>::size_type = 0,
              Hash = Hash(), Pred = Pred(), Alloc = Alloc())
    -> unordered_set<typename iterator_traits<InputIt>::value_type, Hash, Pred, Alloc>;

template<class Key,
         class Hash = hash<Key>, class Pred = equal_to<Key>,
         class Alloc = allocator<Key>>
unordered_set(initializer_list<Key>,
              typename allocator_traits<Alloc>::size_type = 0,
              Hash = Hash(), Pred = Pred(), Alloc = Alloc())
    -> unordered_set<Key, Hash, Pred, Alloc>;

template<class Key, class Hash, class Pred, class Alloc>
void swap(unordered_set<Key,Hash,Pred,Alloc>& a,
          unordered_set<Key,Hash,Pred,Alloc>& b)
    noexcept(noexcept(a.swap(b)))
{ a.swap(b); }

template<class Key, class Hash, class Pred, class Alloc, class Pred2>
typename unordered_set<Key,Hash,Pred,Alloc>::size_type
erase_if(unordered_set<Key,Hash,Pred,Alloc>& c, Pred2 pred) {
    auto old = c.size();
    for (auto it = c.begin(); it != c.end(); )
        it = pred(*it) ? c.erase(it) : next(it);
    return old - c.size();
}

