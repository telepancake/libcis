        : ptr_(o.ptr_), alloc_(move(o.alloc_)), has_alloc_(o.has_alloc_)
    { o.ptr_ = nullptr; }
    ums_node_handle& operator=(ums_node_handle&& o) noexcept {
        destroy();
        ptr_ = o.ptr_; alloc_ = move(o.alloc_); has_alloc_ = o.has_alloc_;
