// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
#pragma once

#include <memory_resource>
#include <bits/hash_table.h>
#include <functional>
#include <memory>
#include <utility>
#include <iterator>
#include <algorithm>
#include <initializer_list>
