// <complex> — complex number types and math functions.
// Mechanically ported from libc++ include/complex
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// NOTE: stream operators operator<< / operator>> are DEFERRED — they depend
// on <iostream>/<sstream> which we have not ported yet.
#pragma once

#include <type_traits>
#include <cmath>

namespace std {

// Forward declarations
template<class T> class complex;
template<> class complex<float>;
template<> class complex<double>;
template<> class complex<long double>;

// Forward-declare the multiply/divide operators that have two specializations
// so that the floating-point specialization path can be chosen in the class.
template<class T>
requires is_floating_point_v<T>
constexpr complex<T> operator*(const complex<T>& z, const complex<T>& w);

template<class T>
requires (!is_floating_point_v<T>)
constexpr complex<T> operator*(const complex<T>& z, const complex<T>& w);

template<class T>
requires is_floating_point_v<T>
constexpr complex<T> operator/(const complex<T>& x, const complex<T>& y);

template<class T>
requires (!is_floating_point_v<T>)
constexpr complex<T> operator/(const complex<T>& x, const complex<T>& y);

//===----------------------------------------------------------------------===//
// Primary template: complex<T>
//===----------------------------------------------------------------------===//
template<class T>
class complex {
public:
    using value_type = T;

private:
    value_type re_;
    value_type im_;

public:
    constexpr complex(const value_type& re = value_type(),
                      const value_type& im = value_type())
        : re_(re), im_(im) {}

    template<class X>
    constexpr complex(const complex<X>& c)
        : re_(c.real()), im_(c.imag()) {}

    [[nodiscard]] constexpr value_type real() const { return re_; }
    [[nodiscard]] constexpr value_type imag() const { return im_; }

    constexpr void real(value_type re) { re_ = re; }
    constexpr void imag(value_type im) { im_ = im; }

    constexpr complex& operator=(const value_type& re) {
        re_ = re;
        im_ = value_type();
        return *this;
    }
    constexpr complex& operator+=(const value_type& re) { re_ += re; return *this; }
    constexpr complex& operator-=(const value_type& re) { re_ -= re; return *this; }
    constexpr complex& operator*=(const value_type& re) { re_ *= re; im_ *= re; return *this; }
    constexpr complex& operator/=(const value_type& re) { re_ /= re; im_ /= re; return *this; }

    template<class X>
    constexpr complex& operator=(const complex<X>& c) {
        re_ = c.real(); im_ = c.imag(); return *this;
    }
    template<class X>
    constexpr complex& operator+=(const complex<X>& c) {
        re_ += c.real(); im_ += c.imag(); return *this;
    }
    template<class X>
    constexpr complex& operator-=(const complex<X>& c) {
        re_ -= c.real(); im_ -= c.imag(); return *this;
    }
    template<class X>
    constexpr complex& operator*=(const complex<X>& c) {
        *this = *this * complex(c.real(), c.imag());
        return *this;
    }
    template<class X>
    constexpr complex& operator/=(const complex<X>& c) {
        *this = *this / complex(c.real(), c.imag());
        return *this;
    }
};

