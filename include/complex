// Suppress GCC's -Wliteral-suffix warning for the standard names i/if/il.
// These suffixes are reserved for std by [over.literal].
#pragma GCC diagnostic push
#pragma GCC diagnostic ignored "-Wliteral-suffix"

inline constexpr complex<long double> operator""il(long double im) {
    return {0.0l, im};
}
inline constexpr complex<long double> operator""il(unsigned long long im) {
    return {0.0l, static_cast<long double>(im)};
}
inline constexpr complex<double> operator""i(long double im) {
    return {0.0, static_cast<double>(im)};
}
inline constexpr complex<double> operator""i(unsigned long long im) {
    return {0.0, static_cast<double>(im)};
}
inline constexpr complex<float> operator""if(long double im) {
    return {0.0f, static_cast<float>(im)};
}
inline constexpr complex<float> operator""if(unsigned long long im) {
    return {0.0f, static_cast<float>(im)};
}

