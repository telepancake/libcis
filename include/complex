    return {0.0, static_cast<double>(im)};
}
inline constexpr complex<float> operator""if(long double im) {
    return {0.0f, static_cast<float>(im)};
}
inline constexpr complex<float> operator""if(unsigned long long im) {
    return {0.0f, static_cast<float>(im)};
}

