//===----------------------------------------------------------------------===//
// error_category (abstract polymorphic base)
//===----------------------------------------------------------------------===//

class error_category {
public:
    virtual ~error_category() noexcept;

    constexpr error_category() noexcept = default;
    error_category(const error_category&)            = delete;
    error_category& operator=(const error_category&) = delete;

    [[nodiscard]] virtual const char* name() const noexcept = 0;
    [[nodiscard]] virtual string message(int ev) const = 0;

    [[nodiscard]] virtual error_condition default_error_condition(int ev) const noexcept;
    [[nodiscard]] virtual bool equivalent(int code, const error_condition& condition) const noexcept;
    [[nodiscard]] virtual bool equivalent(const error_code& code, int condition) const noexcept;

    bool operator==(const error_category& rhs) const noexcept { return this == &rhs; }

    strong_ordering operator<=>(const error_category& rhs) const noexcept {
        return compare_three_way()(this, addressof(rhs));
    }
};

inline error_category::~error_category() noexcept {}

//===----------------------------------------------------------------------===//
// generic_category / system_category declarations
//===----------------------------------------------------------------------===//

[[nodiscard]] const error_category& generic_category() noexcept;
[[nodiscard]] const error_category& system_category() noexcept;

//===----------------------------------------------------------------------===//
// error_condition
//===----------------------------------------------------------------------===//

class error_condition {
    int val_;
    const error_category* cat_;

public:
    error_condition() noexcept : val_(0), cat_(&generic_category()) {}

    error_condition(int val, const error_category& cat) noexcept
        : val_(val), cat_(&cat) {}

    template <class Ep>
        requires is_error_condition_enum_v<Ep>
    error_condition(Ep e) noexcept {
        *this = make_error_condition(e);
    }

    void assign(int val, const error_category& cat) noexcept {
        val_ = val;
        cat_ = &cat;
    }

    template <class Ep>
        requires is_error_condition_enum_v<Ep>
    error_condition& operator=(Ep e) noexcept {
        *this = make_error_condition(e);
        return *this;
    }

    void clear() noexcept {
        val_ = 0;
        cat_ = &generic_category();
    }

    [[nodiscard]] int value() const noexcept { return val_; }
    [[nodiscard]] const error_category& category() const noexcept { return *cat_; }
    [[nodiscard]] string message() const { return cat_->message(val_); }
    explicit operator bool() const noexcept { return val_ != 0; }
};

[[nodiscard]] inline error_condition make_error_condition(errc e) noexcept {
    return error_condition(static_cast<int>(e), generic_category());
}

inline bool operator==(const error_condition& x, const error_condition& y) noexcept {
    return x.category() == y.category() && x.value() == y.value();
}

inline strong_ordering operator<=>(const error_condition& x, const error_condition& y) noexcept {
    if (auto c = x.category() <=> y.category(); c != 0)
        return c;
    return x.value() <=> y.value();
}

//===----------------------------------------------------------------------===//
// error_code
//===----------------------------------------------------------------------===//

class error_code {
    int val_;
    const error_category* cat_;

public:
    error_code() noexcept : val_(0), cat_(&system_category()) {}

    error_code(int val, const error_category& cat) noexcept
        : val_(val), cat_(&cat) {}

    template <class Ep>
        requires is_error_code_enum_v<Ep>
    error_code(Ep e) noexcept {
        *this = make_error_code(e);
    }

    void assign(int val, const error_category& cat) noexcept {
        val_ = val;
        cat_ = &cat;
    }

    template <class Ep>
        requires is_error_code_enum_v<Ep>
    error_code& operator=(Ep e) noexcept {
        *this = make_error_code(e);
        return *this;
    }

    void clear() noexcept {
        val_ = 0;
        cat_ = &system_category();
    }

    [[nodiscard]] int value() const noexcept { return val_; }
    [[nodiscard]] const error_category& category() const noexcept { return *cat_; }

    [[nodiscard]] error_condition default_error_condition() const noexcept {
        return cat_->default_error_condition(val_);
    }

    [[nodiscard]] string message() const { return cat_->message(val_); }
    explicit operator bool() const noexcept { return val_ != 0; }
};

inline bool operator==(const error_code& x, const error_code& y) noexcept {
    return x.category() == y.category() && x.value() == y.value();
}

inline bool operator==(const error_code& x, const error_condition& y) noexcept {
    return x.category().equivalent(x.value(), y) || y.category().equivalent(x, y.value());
}

inline strong_ordering operator<=>(const error_code& x, const error_code& y) noexcept {
    if (auto c = x.category() <=> y.category(); c != 0)
        return c;
    return x.value() <=> y.value();
}

//===----------------------------------------------------------------------===//
// make_error_code (errc maps to generic_category per standard)
//===----------------------------------------------------------------------===//

[[nodiscard]] inline error_code make_error_code(errc e) noexcept {
    return error_code(static_cast<int>(e), generic_category());
}

//===----------------------------------------------------------------------===//
// error_category virtual method bodies (depend on error_condition/error_code)
//===----------------------------------------------------------------------===//

inline error_condition
error_category::default_error_condition(int ev) const noexcept {
    return error_condition(ev, *this);
}

inline bool
error_category::equivalent(int code, const error_condition& condition) const noexcept {
    return default_error_condition(code) == condition;
}

inline bool
error_category::equivalent(const error_code& code, int condition) const noexcept {
    return *this == code.category() && code.value() == condition;
}

//===----------------------------------------------------------------------===//
// Concrete categories (implemented inline using strerror)
//===----------------------------------------------------------------------===//

namespace detail {

class generic_error_category : public error_category {
public:
    const char* name() const noexcept override { return "generic"; }
    string message(int ev) const override {
        const char* msg = ::strerror(ev);
        if (msg) return string(msg);
        char buf[64];
        snprintf(buf, sizeof(buf), "Unknown error %d", ev);
        return string(buf);
    }
};

class system_error_category : public error_category {
public:
    const char* name() const noexcept override { return "system"; }
    string message(int ev) const override {
        const char* msg = ::strerror(ev);
        if (msg) return string(msg);
        char buf[64];
        snprintf(buf, sizeof(buf), "Unknown error %d", ev);
        return string(buf);
    }
    error_condition default_error_condition(int ev) const noexcept override {
        return error_condition(ev, generic_category());
    }
};

} // namespace detail

inline const error_category& generic_category() noexcept {
    // Use a union trick to avoid destruction, matching libc++.
    union U {
        detail::generic_error_category cat;
        constexpr explicit U() : cat() {}
        ~U() {}
    };
    static constinit U u;
    return u.cat;
}

inline const error_category& system_category() noexcept {
    union U {
        detail::system_error_category cat;
        constexpr explicit U() : cat() {}
        ~U() {}
    };
    static constinit U u;
    return u.cat;
}

//===----------------------------------------------------------------------===//
// hash specializations
//===----------------------------------------------------------------------===//

template <>
struct hash<error_code> {
    size_t operator()(const error_code& ec) const noexcept {
        return static_cast<size_t>(ec.value());
    }
};

template <>
struct hash<error_condition> {
    size_t operator()(const error_condition& ec) const noexcept {
        return static_cast<size_t>(ec.value());
    }
};

//===----------------------------------------------------------------------===//
// system_error exception type (inherits runtime_error; virtual without RTTI)
//===----------------------------------------------------------------------===//

namespace detail {
// Build the what() string: "what_arg: message" or just "message"
inline string make_system_error_str(const error_code& ec, const string& what_arg) {
    if (ec) {
        string result = what_arg;
        if (!result.empty())
            result += ": ";
        result += ec.message();
        return result;
    }
    return what_arg;
}
inline string make_system_error_str(const error_code& ec) {
    if (ec) return ec.message();
    return string();
}
} // namespace detail

class system_error : public runtime_error {
    error_code ec_;
public:
    system_error(error_code ec, const string& what_arg)
        : runtime_error(detail::make_system_error_str(ec, what_arg).c_str())
        , ec_(ec) {}

    system_error(error_code ec, const char* what_arg)
        : runtime_error(detail::make_system_error_str(ec, string(what_arg)).c_str())
        , ec_(ec) {}

    system_error(error_code ec)
        : runtime_error(detail::make_system_error_str(ec).c_str())
        , ec_(ec) {}

    system_error(int ev, const error_category& ecat, const string& what_arg)
        : system_error(error_code(ev, ecat), what_arg) {}

    system_error(int ev, const error_category& ecat, const char* what_arg)
        : system_error(error_code(ev, ecat), what_arg) {}

    system_error(int ev, const error_category& ecat)
        : system_error(error_code(ev, ecat)) {}

    system_error(const system_error&) noexcept = default;
    ~system_error() noexcept override {}

    [[nodiscard]] const error_code& code() const noexcept { return ec_; }
};

} // namespace std
