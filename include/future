// Helper: allocate+construct an assoc_state_alloc through a user allocator.
template<class State, class Alloc>
State* make_assoc_state_alloc(const Alloc& a0) {
    using Al = typename allocator_traits<Alloc>::template rebind_alloc<State>;
    Al a(a0);
    using PT = pointer_traits<typename allocator_traits<Al>::pointer>;
    typename allocator_traits<Al>::pointer hold = a.allocate(1);
    State* p = std::addressof(*hold);
    ::new (static_cast<void*>(p)) State(a0);
    return p;
}

// --- deferred_assoc_state<R, F> : deferred callable ---
template<class R, class F>
class deferred_assoc_state : public assoc_state<R> {
    F func_;

    static void destroy_value_leaf(void* p) noexcept {
        auto* s = static_cast<deferred_assoc_state*>(p);
        if (s->state_ & assoc_sub_state::constructed)
            reinterpret_cast<R*>(s->value_ptr())->~R();
        ::delete s;
    }
    static void invoke_leaf(void* p) {
        auto* s = static_cast<deferred_assoc_state*>(p);
        s->set_value(s->func_());
    }

public:
    static constexpr detail::future_callback_ops cb_ops = {
        sizeof(R), alignof(R), detail::f_fcb_deferred,
        &deferred_assoc_state::destroy_value_leaf,
        &deferred_assoc_state::invoke_leaf,
    };

    explicit deferred_assoc_state(F&& f)
        : assoc_state<R>(&cb_ops), func_(std::forward<F>(f)) {
        this->set_deferred();
    }
};

template<class F>
class deferred_assoc_state<void, F> : public assoc_sub_state {
    F func_;

    static void destroy_value_leaf(void* p) noexcept {
        ::delete static_cast<deferred_assoc_state*>(p);
    }
    static void invoke_leaf(void* p) {
        auto* s = static_cast<deferred_assoc_state*>(p);
        s->func_();
        s->set_value_void();
    }

public:
    static constexpr detail::future_callback_ops cb_ops = {
        0, 1, detail::f_fcb_deferred,
        &deferred_assoc_state::destroy_value_leaf,
        &deferred_assoc_state::invoke_leaf,
    };

    explicit deferred_assoc_state(F&& f)
        : assoc_sub_state(&cb_ops), func_(std::forward<F>(f)) {
        this->set_deferred();
    }
};

// --- async_assoc_state<R, F> : spawned thread callable ---
template<class R, class F>
class async_assoc_state : public assoc_state<R> {
    F func_;

    static void destroy_value_leaf(void* p) noexcept {
        auto* s = static_cast<async_assoc_state*>(p);
        // Wait for the detached thread before freeing.
        s->wait();
        if (s->state_ & assoc_sub_state::constructed)
            reinterpret_cast<R*>(s->value_ptr())->~R();
        ::delete s;
    }
    static void invoke_leaf(void* p) {
        auto* s = static_cast<async_assoc_state*>(p);
        s->set_value(s->func_());
    }

public:
    static constexpr detail::future_callback_ops cb_ops = {
        sizeof(R), alignof(R), detail::f_fcb_async,
        &async_assoc_state::destroy_value_leaf,
        &async_assoc_state::invoke_leaf,
    };

    explicit async_assoc_state(F&& f)
        : assoc_state<R>(&cb_ops), func_(std::forward<F>(f)) {}
};

template<class F>
class async_assoc_state<void, F> : public assoc_sub_state {
    F func_;

    static void destroy_value_leaf(void* p) noexcept {
        auto* s = static_cast<async_assoc_state*>(p);
        s->wait();
        ::delete s;
    }
    static void invoke_leaf(void* p) {
        auto* s = static_cast<async_assoc_state*>(p);
        s->func_();
        s->set_value_void();
    }

public:
    static constexpr detail::future_callback_ops cb_ops = {
        0, 1, detail::f_fcb_async,
        &async_assoc_state::destroy_value_leaf,
        &async_assoc_state::invoke_leaf,
    };

    explicit async_assoc_state(F&& f)
        : assoc_sub_state(&cb_ops), func_(std::forward<F>(f)) {}
};

//===----------------------------------------------------------------------===//
// Forward declarations
//===----------------------------------------------------------------------===//

template<class R> class promise;
template<class R> class shared_future;
template<class F> class packaged_task;

//===----------------------------------------------------------------------===//
// future<R>
//===----------------------------------------------------------------------===//

template<class R>
class future {
    assoc_state<R>* state_;

    explicit future(assoc_state<R>* s) : state_(s) {
        state_->attach_future();
    }

    template<class> friend class promise;
    template<class> friend class shared_future;
    template<class R2, class F2>
