//===----------------------------------------------------------------------===//
// promise<R>
//===----------------------------------------------------------------------===//

template<class R>
class promise {
    assoc_state<R>* state_;

    explicit promise(nullptr_t) noexcept : state_(nullptr) {}
    template<class> friend class packaged_task;

public:
    promise() : state_(new assoc_state<R>) {}
    promise(promise&& rhs) noexcept : state_(rhs.state_) { rhs.state_ = nullptr; }
    promise(const promise&)            = delete;
    promise& operator=(const promise&) = delete;
    promise& operator=(promise&& rhs) noexcept {
        promise(move(rhs)).swap(*this);
        return *this;
    }
    ~promise() {
        if (state_) {
            // Broken promise: if future is waiting and no value was set, trap.
            // (Under -fno-exceptions we cannot deliver broken_promise exception.)
            state_->release_shared();
        }
    }

    void swap(promise& rhs) noexcept { std::swap(state_, rhs.state_); }

    [[nodiscard]] future<R> get_future() {
        if (!state_) throw_future_error(future_errc::no_state);
        return future<R>(state_);
    }

    void set_value(const R& r) {
        if (!state_) throw_future_error(future_errc::no_state);
        state_->set_value(r);
    }
    void set_value(R&& r) {
        if (!state_) throw_future_error(future_errc::no_state);
        state_->set_value(move(r));
    }

    // set_exception: UNUSABLE — exception_ptr unavailable under -fno-exceptions.
    void set_exception(void* /*exception_ptr*/) {
        // Traps: exception_ptr requires -fexceptions.
        __builtin_trap();
    }
};

template<class R>
inline void swap(promise<R>& x, promise<R>& y) noexcept { x.swap(y); }

