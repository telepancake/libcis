    }
    template<class Clock, class Duration>
    future_status wait_until(const chrono::time_point<Clock, Duration>& abs) const {
        return state_->wait_until(abs);
    }
};

template<class R>
inline void swap(shared_future<R>& x, shared_future<R>& y) noexcept { x.swap(y); }

// share() definitions (after shared_future is complete)
template<class R>
inline shared_future<R>  future<R>::share()  noexcept { return shared_future<R>(move(*this));  }
template<class R>
inline shared_future<R&> future<R&>::share() noexcept { return shared_future<R&>(move(*this)); }
inline shared_future<void> future<void>::share() noexcept { return shared_future<void>(move(*this)); }

//===----------------------------------------------------------------------===//
// Helper factories (used by async and packaged_task)
//===----------------------------------------------------------------------===//

template<class R, class F>
inline future<R> make_deferred_assoc_state(F&& f) {
    auto* s = new deferred_assoc_state<R, decay_t<F>>(forward<F>(f));
    return future<R>(s);
}

// Specialisation for void
template<class F>
inline future<void> make_deferred_assoc_state_void(F&& f) {
    auto* s = new deferred_assoc_state<void, decay_t<F>>(forward<F>(f));
    return future<void>(s);
}

template<class R, class F>
inline future<R> make_async_assoc_state(F&& f) {
    auto* s = new async_assoc_state<R, decay_t<F>>(forward<F>(f));
    // add_shared so the state stays alive while the thread runs
    s->add_shared();
    thread([s]() mutable {
        s->execute();
        s->release_shared();
    }).detach();
    return future<R>(s);
}

template<class F>
inline future<void> make_async_assoc_state_void(F&& f) {
    auto* s = new async_assoc_state<void, decay_t<F>>(forward<F>(f));
    s->add_shared();
    thread([s]() mutable {
        s->execute();
        s->release_shared();
    }).detach();
    return future<void>(s);
}

//===----------------------------------------------------------------------===//
// packaged_task<R(Args...)>
//===----------------------------------------------------------------------===//

template<class R, class... Args>
class packaged_task<R(Args...)> {
    using storage_t = decay_t<R(Args...)>;
    // We use a type-erased callable (simple function<> or inline).
    // Rather than pulling in std::function, use a small unique_ptr<base>.
    struct task_base {
        virtual ~task_base() = default;
        virtual R call(Args... args) = 0;
    };
    template<class F>
    struct task_impl : task_base {
        F f_;
        explicit task_impl(F&& fn) : f_(move(fn)) {}
        R call(Args... args) override { return invoke(f_, forward<Args>(args)...); }
    };

    unique_ptr<task_base> f_;
    promise<R>            p_;

public:
    packaged_task() noexcept : p_(nullptr) {}

    template<class F,
             class = enable_if_t<!is_same_v<remove_cvref_t<F>, packaged_task>>>
    explicit packaged_task(F&& fn)
        : f_(new task_impl<decay_t<F>>(forward<F>(fn)))
        , p_() {}

    packaged_task(const packaged_task&)            = delete;
    packaged_task& operator=(const packaged_task&) = delete;

    packaged_task(packaged_task&&) noexcept = default;
    packaged_task& operator=(packaged_task&&) noexcept = default;

    void swap(packaged_task& other) noexcept {
        f_.swap(other.f_);
        p_.swap(other.p_);
    }

    [[nodiscard]] bool valid() const noexcept { return f_ != nullptr; }

    [[nodiscard]] future<R> get_future() { return p_.get_future(); }

    void operator()(Args... args) {
        if (!f_) throw_future_error(future_errc::no_state);
        p_.set_value(f_->call(forward<Args>(args)...));
    }

    void reset() {
        if (!valid()) throw_future_error(future_errc::no_state);
        p_ = promise<R>();
    }
};

// packaged_task<void(Args...)>
template<class... Args>
class packaged_task<void(Args...)> {
    struct task_base {
        virtual ~task_base() = default;
        virtual void call(Args... args) = 0;
    };
    template<class F>
    struct task_impl : task_base {
        F f_;
        explicit task_impl(F&& fn) : f_(move(fn)) {}
        void call(Args... args) override { invoke(f_, forward<Args>(args)...); }
    };

    unique_ptr<task_base> f_;
    promise<void>         p_;

public:
    packaged_task() noexcept : p_(nullptr) {}

    template<class F,
             class = enable_if_t<!is_same_v<remove_cvref_t<F>, packaged_task>>>
    explicit packaged_task(F&& fn)
        : f_(new task_impl<decay_t<F>>(forward<F>(fn)))
        , p_() {}

    packaged_task(const packaged_task&)            = delete;
    packaged_task& operator=(const packaged_task&) = delete;

    packaged_task(packaged_task&&) noexcept = default;
    packaged_task& operator=(packaged_task&&) noexcept = default;

    void swap(packaged_task& other) noexcept {
        f_.swap(other.f_);
        p_.swap(other.p_);
    }

    [[nodiscard]] bool valid() const noexcept { return f_ != nullptr; }
    [[nodiscard]] future<void> get_future() { return p_.get_future(); }

    void operator()(Args... args) {
        if (!f_) throw_future_error(future_errc::no_state);
        f_->call(forward<Args>(args)...);
        p_.set_value();
    }

    void reset() {
        if (!valid()) throw_future_error(future_errc::no_state);
        p_ = promise<void>();
    }
};

template<class R, class... Args>
inline void swap(packaged_task<R(Args...)>& x, packaged_task<R(Args...)>& y) noexcept {
    x.swap(y);
}

//===----------------------------------------------------------------------===//
// async
//===----------------------------------------------------------------------===//

namespace future_detail {

// Wrap (F, Args...) into a zero-argument callable for the assoc state.
template<class F, class... Args>
class async_func {
    tuple<decay_t<F>, decay_t<Args>...> bound_;
public:
    using result_type = invoke_result_t<decay_t<F>, decay_t<Args>...>;

    template<class G, class... BArgs>
    explicit async_func(G&& g, BArgs&&... ba)
        : bound_(forward<G>(g), forward<BArgs>(ba)...) {}

    async_func(async_func&&) = default;

    result_type operator()() {
        return [&]<size_t... I>(index_sequence<I...>) -> result_type {
            return invoke(move(get<I>(bound_))...);
        }(index_sequence_for<F, Args...>{});
    }
};

inline bool policy_contains(launch policy, launch value) noexcept {
    return (static_cast<int>(policy) & static_cast<int>(value)) != 0;
}

} // namespace future_detail

template<class F, class... Args>
[[nodiscard]] auto async(launch policy, F&& f, Args&&... args)
    -> future<invoke_result_t<decay_t<F>, decay_t<Args>...>>
{
    using R  = invoke_result_t<decay_t<F>, decay_t<Args>...>;
    using BF = future_detail::async_func<decay_t<F>, decay_t<Args>...>;

    BF bound(forward<F>(f), forward<Args>(args)...);

    if (future_detail::policy_contains(policy, launch::async)) {
        if constexpr (is_void_v<R>)
            return make_async_assoc_state_void(move(bound));
        else
            return make_async_assoc_state<R>(move(bound));
    }
    if (future_detail::policy_contains(policy, launch::deferred)) {
        if constexpr (is_void_v<R>)
            return make_deferred_assoc_state_void(move(bound));
        else
            return make_deferred_assoc_state<R>(move(bound));
    }
    return future<R>{};
}

template<class F, class... Args>
[[nodiscard]] inline auto async(F&& f, Args&&... args)
    -> future<invoke_result_t<decay_t<F>, decay_t<Args>...>>
{
    return async(launch::async | launch::deferred,
                 forward<F>(f), forward<Args>(args)...);
}

} // namespace std
