// packaged_task<R(Args...)>
//===----------------------------------------------------------------------===//

template<class R, class... Args>
class packaged_task<R(Args...)> {
    using storage_t = decay_t<R(Args...)>;
    // We use a type-erased callable (simple function<> or inline).
    // Rather than pulling in std::function, use a small unique_ptr<base>.
    struct task_base {
        virtual ~task_base() = default;
        virtual R call(Args... args) = 0;
    };
    template<class F>
    struct task_impl : task_base {
        F f_;
        explicit task_impl(F&& fn) : f_(move(fn)) {}
        R call(Args... args) override { return invoke(f_, std::forward<Args>(args)...); }
    };

    unique_ptr<task_base> f_;
    promise<R>            p_;

public:
    packaged_task() noexcept : p_(nullptr) {}

    template<class F,
             class = enable_if_t<!is_same_v<remove_cvref_t<F>, packaged_task>>>
    explicit packaged_task(F&& fn)
        : f_(new task_impl<decay_t<F>>(std::forward<F>(fn)))
        , p_() {}

    packaged_task(const packaged_task&)            = delete;
    packaged_task& operator=(const packaged_task&) = delete;

    packaged_task(packaged_task&&) noexcept = default;
    packaged_task& operator=(packaged_task&&) noexcept = default;

    void swap(packaged_task& other) noexcept {
        f_.swap(other.f_);
        p_.swap(other.p_);
    }

    [[nodiscard]] bool valid() const noexcept { return f_ != nullptr; }

    [[nodiscard]] future<R> get_future() { return p_.get_future(); }

    void operator()(Args... args) {
        if (!f_) throw_future_error(future_errc::no_state);
        p_.set_value(f_->call(std::forward<Args>(args)...));
    }

    void make_ready_at_thread_exit(Args... args) {
        if (!f_) throw_future_error(future_errc::no_state);
        p_.set_value_at_thread_exit(f_->call(std::forward<Args>(args)...));
    }

    void reset() {
        if (!valid()) throw_future_error(future_errc::no_state);
        p_ = promise<R>();
    }
};

// packaged_task<void(Args...)>
template<class... Args>
class packaged_task<void(Args...)> {
    struct task_base {
        virtual ~task_base() = default;
        virtual void call(Args... args) = 0;
    };
    template<class F>
    struct task_impl : task_base {
        F f_;
        explicit task_impl(F&& fn) : f_(move(fn)) {}
        void call(Args... args) override { invoke(f_, std::forward<Args>(args)...); }
    };

    unique_ptr<task_base> f_;
    promise<void>         p_;

public:
    packaged_task() noexcept : p_(nullptr) {}

    template<class F,
             class = enable_if_t<!is_same_v<remove_cvref_t<F>, packaged_task>>>
    explicit packaged_task(F&& fn)
        : f_(new task_impl<decay_t<F>>(std::forward<F>(fn)))
        , p_() {}

    packaged_task(const packaged_task&)            = delete;
    packaged_task& operator=(const packaged_task&) = delete;

    packaged_task(packaged_task&&) noexcept = default;
    packaged_task& operator=(packaged_task&&) noexcept = default;

    void swap(packaged_task& other) noexcept {
        f_.swap(other.f_);
        p_.swap(other.p_);
    }

    [[nodiscard]] bool valid() const noexcept { return f_ != nullptr; }
    [[nodiscard]] future<void> get_future() { return p_.get_future(); }

    void operator()(Args... args) {
        if (!f_) throw_future_error(future_errc::no_state);
