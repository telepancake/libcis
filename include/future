// future<R>
//===----------------------------------------------------------------------===//

template<class R>
class future {
    assoc_state<R>* state_;

    explicit future(assoc_state<R>* s) : state_(s) {
        state_->attach_future();
    }

    template<class> friend class promise;
    template<class> friend class shared_future;
    template<class R2, class F2>
    friend future<R2> make_deferred_assoc_state(F2&&);
    template<class R2, class F2>
    friend future<R2> make_async_assoc_state(F2&&);
    template<class F2> friend future<void> make_deferred_assoc_state_void(F2&&);
    template<class F2> friend future<void> make_async_assoc_state_void(F2&&);

public:
    future() noexcept : state_(nullptr) {}
    future(future&& rhs) noexcept : state_(rhs.state_) { rhs.state_ = nullptr; }
    future(const future&)            = delete;
    future& operator=(const future&) = delete;
    future& operator=(future&& rhs) noexcept {
        future(move(rhs)).swap(*this);
        return *this;
    }
    ~future() { if (state_) state_->release_shared(); }

    [[nodiscard]] shared_future<R> share() noexcept;

    [[nodiscard]] R get() {
        // Transfer ownership so state is released after get().
        assoc_state<R>* s = state_;
        state_ = nullptr;
        auto guard = [s]() noexcept { s->release_shared(); };
        struct Guard { decltype(guard) g; ~Guard(){ g(); } } g{guard};
        return s->move_value();
    }

    void swap(future& rhs) noexcept { std::swap(state_, rhs.state_); }

    [[nodiscard]] bool valid() const noexcept { return state_ != nullptr; }

    void wait() const { state_->wait(); }
    template<class Rep, class Period>
    future_status wait_for(const chrono::duration<Rep, Period>& rel) const {
        return state_->wait_for(rel);
    }
    template<class Clock, class Duration>
    future_status wait_until(const chrono::time_point<Clock, Duration>& abs) const {
        return state_->wait_until(abs);
    }
};

