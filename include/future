template<class R, class F>
inline future<R> make_deferred_assoc_state(F&& f) {
    auto* s = new deferred_assoc_state<R, decay_t<F>>(std::forward<F>(f));
    return future<R>(s);
}

// Specialisation for void
template<class F>
inline future<void> make_deferred_assoc_state_void(F&& f) {
    auto* s = new deferred_assoc_state<void, decay_t<F>>(std::forward<F>(f));
    return future<void>(s);
}

template<class R, class F>
inline future<R> make_async_assoc_state(F&& f) {
    auto* s = new async_assoc_state<R, decay_t<F>>(std::forward<F>(f));
    // add_shared so the state stays alive while the thread runs
    s->add_shared();
    thread([s]() mutable {
        s->execute();
        s->release_shared();
    }).detach();
    return future<R>(s);
}

template<class F>
inline future<void> make_async_assoc_state_void(F&& f) {
    auto* s = new async_assoc_state<void, decay_t<F>>(std::forward<F>(f));
    s->add_shared();
    thread([s]() mutable {
        s->execute();
        s->release_shared();
    }).detach();
    return future<void>(s);
}

