// <initializer_list> -- compiler-coupled initializer list support.
// Mechanically ported from libc++ include/initializer_list.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// The layout (two-pointer private ctor, begin_/size_ members) MUST match what
// the compiler expects when it synthesises an std::initializer_list<E> object
// from a braced-init-list.  Do not change member names or order.
#pragma once

namespace std {

using size_t = decltype(sizeof(int));

template<class E>
class initializer_list {
    const E* begin_;
    size_t   size_;

    // Private constructor called by the compiler — must exist with this
    // exact signature so the compiler can construct the object.
    constexpr initializer_list(const E* b, size_t s) noexcept
        : begin_(b), size_(s) {}

public:
    using value_type      = E;
    using reference       = const E&;
    using const_reference = const E&;
    using size_type       = size_t;

    using iterator       = const E*;
    using const_iterator = const E*;

    constexpr initializer_list() noexcept : begin_(nullptr), size_(0) {}

    [[nodiscard]] constexpr size_t   size()  const noexcept { return size_; }
    [[nodiscard]] constexpr const E* begin() const noexcept { return begin_; }
    [[nodiscard]] constexpr const E* end()   const noexcept { return begin_ + size_; }
};

template<class E>
inline constexpr const E* begin(initializer_list<E> il) noexcept {
    return il.begin();
}

template<class E>
inline constexpr const E* end(initializer_list<E> il) noexcept {
    return il.end();
}

} // namespace std
