// <memory> — mechanically ported from libc++ include/memory + include/__memory/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// All __memory/*.h fragments are folded inline.
// Depends on: <type_traits>, <utility>, <iterator>, <new>, <bits/pointer.h>
// <compare> (for operator<=>), <functional> (for hash specialisations)
//
// Over-allocation handling: where libc++ would throw bad_alloc or
// length_error (allocator::allocate exceeds max_size), we call
// __builtin_trap() instead since exceptions are disabled.
#pragma once

#include <type_traits>
#include <utility>
#include <iterator>
#include <new>
#include <bits/pointer.h>
#include <bits/construct_at.h>
#include <compare>
#include <cstdint>  // uintptr_t
#include <atomic>   // memory_order (for the [util.smartptr.shared.atomic] API)
#include <iosfwd>   // basic_ostream forward declaration (for operator<<)
// <functional> is included here (before namespace std) so that <tuple>'s
// uses_allocator definition (pulled in transitively) is authoritative.
// <memory> itself does NOT redefine uses_allocator — it reuses the one
// from <tuple> (ODR rule: one definition only).
#include <functional>

namespace std {

//===----------------------------------------------------------------------===//
// Re-export from <bits/pointer.h>
// addressof, pointer_traits, to_address are already in std:: from
// <bits/pointer.h>.  They are NOT redefined here (ODR rule).
//===----------------------------------------------------------------------===//

//===----------------------------------------------------------------------===//
// allocation_result (C++23) / allocate_at_least
// (from __memory/allocate_at_least.h, __memory/allocator_traits.h)
//===----------------------------------------------------------------------===//

template<class Pointer, class SizeType = size_t>
struct allocation_result {
    Pointer ptr;
    SizeType count;
};

//===----------------------------------------------------------------------===//
// allocator_arg_t / allocator_arg
// (from __memory/allocator_arg_t.h)
//===----------------------------------------------------------------------===//

struct allocator_arg_t {
    explicit allocator_arg_t() = default;
};

inline constexpr allocator_arg_t allocator_arg{};

// uses_allocator / uses_allocator_v
// The primary template is defined in <tuple> (included transitively via
// <functional> above). That primary always returns false_type. Here we add
// the standard-mandated partial specialization for types that have a nested
// allocator_type that the Alloc is convertible to. Adding a specialization to
// an existing primary template is NOT an ODR violation.
namespace detail {
    template<class T, class Alloc, class = void>
    inline constexpr bool uses_allocator_impl_v = false;
    template<class T, class Alloc>
    inline constexpr bool uses_allocator_impl_v<T, Alloc,
        void_t<typename T::allocator_type>>
        = is_convertible_v<Alloc, typename T::allocator_type>;
}

// Partial specialisation: true when T has allocator_type convertible from Alloc.
template<class T, class Alloc>
    requires (detail::uses_allocator_impl_v<T, Alloc> &&
              !is_same_v<T, tuple<>>)  // avoid ambiguity with tuple<> specialisation
struct uses_allocator<T, Alloc> : true_type {};

//===----------------------------------------------------------------------===//
// [allocator.uses.construction]  uses_allocator_construction_args /
// make_obj_using_allocator / uninitialized_construct_using_allocator (C++20)
// (from __memory/uses_allocator_construction.h, C++20 subset)
//===----------------------------------------------------------------------===//

namespace detail {

template<class T>
inline constexpr bool is_std_pair = false;
template<class T1, class T2>
inline constexpr bool is_std_pair<pair<T1, T2>> = true;
template<class T>
inline constexpr bool is_cv_std_pair = is_std_pair<remove_cv_t<T>>;

template<class T, class = void>
struct uses_alloc_args;

namespace uses_alloc_detail {
    template<class A, class B>
    void pair_ref_fun(const pair<A, B>&);

    template<class T>
    decltype(uses_alloc_detail::pair_ref_fun(declval<T>()), true_type())
    convertible_to_const_pair_ref_impl(int);
    template<class>
    false_type convertible_to_const_pair_ref_impl(...);

    template<class T>
    inline constexpr bool convertible_to_const_pair_ref =
        decltype(uses_alloc_detail::convertible_to_const_pair_ref_impl<T>(0))::value;

    template<class T, class U>
    inline constexpr bool uses_allocator_constraints =
        is_cv_std_pair<T> && !convertible_to_const_pair_ref<U>;
} // namespace uses_alloc_detail

template<class Type, class Alloc, class... Args>
constexpr Type make_obj_using_allocator_impl(const Alloc& alloc, Args&&... args);

template<class Pair>
struct uses_alloc_args<Pair, enable_if_t<is_cv_std_pair<Pair>>> {
    template<class Alloc, class Tuple1, class Tuple2>
    static constexpr auto
    apply(const Alloc& alloc, piecewise_construct_t, Tuple1&& x, Tuple2&& y) noexcept {
        return std::make_tuple(
            piecewise_construct,
            std::apply(
                [&alloc](auto&&... args1) {
                    return uses_alloc_args<typename Pair::first_type>::apply(
                        alloc, std::forward<decltype(args1)>(args1)...);
                },
                std::forward<Tuple1>(x)),
            std::apply(
                [&alloc](auto&&... args2) {
                    return uses_alloc_args<typename Pair::second_type>::apply(
                        alloc, std::forward<decltype(args2)>(args2)...);
                },
                std::forward<Tuple2>(y)));
    }

    template<class Alloc>
    static constexpr auto apply(const Alloc& alloc) noexcept {
        return uses_alloc_args<Pair>::apply(alloc, piecewise_construct, tuple<>{}, tuple<>{});
    }

    template<class Alloc, class U, class V>
    static constexpr auto apply(const Alloc& alloc, U&& u, V&& v) noexcept {
        return uses_alloc_args<Pair>::apply(
            alloc, piecewise_construct,
            std::forward_as_tuple(std::forward<U>(u)),
            std::forward_as_tuple(std::forward<V>(v)));
    }

    template<class Alloc, class U, class V>
    static constexpr auto apply(const Alloc& alloc, const pair<U, V>& p) noexcept {
        return uses_alloc_args<Pair>::apply(
            alloc, piecewise_construct,
            std::forward_as_tuple(p.first), std::forward_as_tuple(p.second));
    }

    template<class Alloc, class U, class V>
    static constexpr auto apply(const Alloc& alloc, pair<U, V>&& p) noexcept {
        return uses_alloc_args<Pair>::apply(
            alloc, piecewise_construct,
            std::forward_as_tuple(std::get<0>(std::move(p))),
            std::forward_as_tuple(std::get<1>(std::move(p))));
    }

    // converting from a non-pair value that is convertible to the pair: defer
    // through a one-element tuple holding a converting proxy (libc++
    // __pair_constructor).
    template<class Alloc, class Type,
             enable_if_t<uses_alloc_detail::uses_allocator_constraints<Pair, Type>, int> = 0>
    static constexpr auto apply(const Alloc& alloc, Type&& value) noexcept {
        struct pair_constructor {
            using PairMutable = remove_cv_t<Pair>;

            constexpr auto do_construct(const PairMutable& p) const {
                return detail::make_obj_using_allocator_impl<PairMutable>(alloc_, p);
            }
            constexpr auto do_construct(PairMutable&& p) const {
                return detail::make_obj_using_allocator_impl<PairMutable>(alloc_, std::move(p));
            }

            const Alloc& alloc_;
            Type& value_;

            constexpr operator PairMutable() const {
                return do_construct(std::forward<Type>(value_));
            }
        };
        return std::make_tuple(pair_constructor{alloc, value});
    }
};

template<class Type>
struct uses_alloc_args<Type, enable_if_t<!is_cv_std_pair<Type>>> {
    template<class Alloc, class... Args>
    static constexpr auto apply(const Alloc& alloc, Args&&... args) noexcept {
        if constexpr (!uses_allocator_v<remove_cv_t<Type>, Alloc> &&
                      is_constructible_v<Type, Args...>) {
            return std::forward_as_tuple(std::forward<Args>(args)...);
        } else if constexpr (uses_allocator_v<remove_cv_t<Type>, Alloc> &&
                             is_constructible_v<Type, allocator_arg_t, const Alloc&, Args...>) {
            return tuple<allocator_arg_t, const Alloc&, Args&&...>(
                allocator_arg, alloc, std::forward<Args>(args)...);
        } else if constexpr (uses_allocator_v<remove_cv_t<Type>, Alloc> &&
                             is_constructible_v<Type, Args..., const Alloc&>) {
            return std::forward_as_tuple(std::forward<Args>(args)..., alloc);
        } else {
            static_assert(sizeof(Type) + 1 == 0,
                "If uses_allocator_v<Type> is true, the type has to be allocator-constructible");
        }
    }
};

template<class Type, class Alloc, class... Args>
constexpr Type make_obj_using_allocator_impl(const Alloc& alloc, Args&&... args) {
    return std::make_from_tuple<Type>(
        uses_alloc_args<Type>::apply(alloc, std::forward<Args>(args)...));
}

} // namespace detail

template<class Type, class Alloc, class... Args>
[[nodiscard]] constexpr auto
uses_allocator_construction_args(const Alloc& alloc, Args&&... args) noexcept
    -> decltype(detail::uses_alloc_args<Type>::apply(alloc, std::forward<Args>(args)...)) {
    return detail::uses_alloc_args<Type>::apply(alloc, std::forward<Args>(args)...);
}

template<class Type, class Alloc, class... Args>
[[nodiscard]] constexpr auto
make_obj_using_allocator(const Alloc& alloc, Args&&... args)
    -> decltype(detail::make_obj_using_allocator_impl<Type>(alloc, std::forward<Args>(args)...)) {
    return detail::make_obj_using_allocator_impl<Type>(alloc, std::forward<Args>(args)...);
}

// plain auto return: gcc-10 rejects a lambda in a trailing decltype here
// ("use of parameter outside function body").
template<class Type, class Alloc, class... Args>
constexpr Type*
uninitialized_construct_using_allocator(Type* ptr, const Alloc& alloc, Args&&... args) {
    return std::apply(
        [&ptr](auto&&... xs) { return std::construct_at(ptr, std::forward<decltype(xs)>(xs)...); },
        detail::uses_alloc_args<Type>::apply(alloc, std::forward<Args>(args)...));
}

//===----------------------------------------------------------------------===//
// construct_at / destroy_at  (C++20)
// (from __memory/construct_at.h)
//===----------------------------------------------------------------------===//

// Definition lives in bits/construct_at.h (<optional> needs it; including
// <memory> there would cycle through bits/memory_ranges.h -> <ranges>).

// Internal helper (used by allocator_traits and uninitialized algorithms).
// MUST forward to std::construct_at, not repeat the placement new: gcc-10 only
// blesses constexpr placement new inside the function literally named
// std::construct_at, so a copy under any other name is non-constexpr.
namespace detail {
    template<class T, class... Args>
        requires requires { ::new(declval<void*>()) T(declval<Args>()...); }
    constexpr T* construct_at_impl(T* loc, Args&&... args) {
        return std::construct_at(loc, std::forward<Args>(args)...);
    }
}

template<class T>
constexpr void destroy_at(T* loc) {
    if constexpr (is_array_v<T>) {
        for (auto& elem : *loc)
            std::destroy_at(std::addressof(elem));  // qualified: no ADL over T's associated classes
    } else {
        loc->~T();
    }
}

//===----------------------------------------------------------------------===//
// destroy / destroy_n  (C++17)
// (from __memory/destroy.h)
//===----------------------------------------------------------------------===//

template<class ForwardIter>
constexpr void destroy(ForwardIter first, ForwardIter last) {
    for (; first != last; ++first)
        std::destroy_at(std::addressof(*first));  // qualified: no ADL
}

template<class ForwardIter, class Size>
constexpr ForwardIter destroy_n(ForwardIter first, Size n) {
    for (; n > 0; (void)++first, --n)
        std::destroy_at(std::addressof(*first));  // qualified: no ADL
    return first;
}

//===----------------------------------------------------------------------===//
// allocator_traits
// (from __memory/allocator_traits.h)
//===----------------------------------------------------------------------===//

// Forward-declare allocator<T>
template<class T>
class allocator;

// --- Detection helpers ---
namespace detail {

    // pointer member
    template<class Alloc, class = void>
    struct alloc_pointer { using type = typename Alloc::value_type*; };
    template<class Alloc>
    struct alloc_pointer<Alloc, void_t<typename Alloc::pointer>> { using type = typename Alloc::pointer; };

    // const_pointer
    template<class Alloc, class Ptr, class = void>
    struct alloc_const_pointer {
        using type = typename pointer_traits<Ptr>::template rebind<const typename Alloc::value_type>;
    };
    template<class Alloc, class Ptr>
    struct alloc_const_pointer<Alloc, Ptr, void_t<typename Alloc::const_pointer>> {
        using type = typename Alloc::const_pointer;
    };

    // void_pointer
    template<class Alloc, class Ptr, class = void>
    struct alloc_void_pointer {
        using type = typename pointer_traits<Ptr>::template rebind<void>;
    };
    template<class Alloc, class Ptr>
    struct alloc_void_pointer<Alloc, Ptr, void_t<typename Alloc::void_pointer>> {
        using type = typename Alloc::void_pointer;
    };

    // const_void_pointer
    template<class Alloc, class Ptr, class = void>
    struct alloc_const_void_pointer {
        using type = typename pointer_traits<Ptr>::template rebind<const void>;
    };
    template<class Alloc, class Ptr>
    struct alloc_const_void_pointer<Alloc, Ptr, void_t<typename Alloc::const_void_pointer>> {
        using type = typename Alloc::const_void_pointer;
    };

    // difference_type
    template<class Alloc, class Ptr, class = void>
    struct alloc_difference_type {
        using type = typename pointer_traits<Ptr>::difference_type;
    };
    template<class Alloc, class Ptr>
    struct alloc_difference_type<Alloc, Ptr, void_t<typename Alloc::difference_type>> {
        using type = typename Alloc::difference_type;
    };

    // size_type
    template<class Alloc, class Diff, class = void>
    struct alloc_size_type { using type = make_unsigned_t<Diff>; };
    template<class Alloc, class Diff>
    struct alloc_size_type<Alloc, Diff, void_t<typename Alloc::size_type>> {
        using type = typename Alloc::size_type;
    };

    // propagate_on_container_copy_assignment
    template<class Alloc, class = void>
    struct alloc_pocca { using type = false_type; };
    template<class Alloc>
    struct alloc_pocca<Alloc, void_t<typename Alloc::propagate_on_container_copy_assignment>> {
        using type = typename Alloc::propagate_on_container_copy_assignment;
    };

    // propagate_on_container_move_assignment
    template<class Alloc, class = void>
    struct alloc_pocma { using type = false_type; };
    template<class Alloc>
    struct alloc_pocma<Alloc, void_t<typename Alloc::propagate_on_container_move_assignment>> {
        using type = typename Alloc::propagate_on_container_move_assignment;
    };

    // propagate_on_container_swap
    template<class Alloc, class = void>
    struct alloc_pocs { using type = false_type; };
    template<class Alloc>
    struct alloc_pocs<Alloc, void_t<typename Alloc::propagate_on_container_swap>> {
        using type = typename Alloc::propagate_on_container_swap;
    };

    // is_always_equal
    template<class Alloc, class = void>
    struct alloc_iae { using type = typename is_empty<Alloc>::type; };
    template<class Alloc>
    struct alloc_iae<Alloc, void_t<typename Alloc::is_always_equal>> {
        using type = typename Alloc::is_always_equal;
    };

    // rebind_alloc.  Dispatch on a bool (libc++ __allocator_traits_rebind), NOT
    // two void_t partial specializations: for a class template that ALSO has a
    // member rebind, both would match at <Alloc, U, void> and the
    // template-template pattern wins partial ordering -- silently ignoring the
    // member rebind, which the standard gives priority.
    template<class Alloc, class U>
    inline constexpr bool has_rebind_other =
        requires { typename Alloc::template rebind<U>::other; };

    template<class Alloc, class U, bool = has_rebind_other<Alloc, U>>
    struct alloc_rebind_impl {
        using type = typename Alloc::template rebind<U>::other;
    };
    template<template<class, class...> class AllocTpl, class T, class... Args, class U>
    struct alloc_rebind_impl<AllocTpl<T, Args...>, U, true> {
        using type = typename AllocTpl<T, Args...>::template rebind<U>::other;
    };
    template<template<class, class...> class AllocTpl, class T, class... Args, class U>
    struct alloc_rebind_impl<AllocTpl<T, Args...>, U, false> {
        using type = AllocTpl<U, Args...>;
    };

    template<class Alloc, class U>
    using alloc_rebind_t = typename alloc_rebind_impl<Alloc, U>::type;

    // has_construct / has_destroy.  requires-expressions, not the void_t-slot
    // arrangement: a pack after a defaulted detection slot silently ate the
    // first real Args argument at the call site (has_alloc_construct<Alloc, T*,
    // Args...> put Args[0] in the void slot), so allocator construct() members
    // were never detected when args were passed.
    template<class Alloc, class Ptr, class... Args>
    inline constexpr bool has_alloc_construct =
        requires(Alloc& a, Ptr p) { a.construct(p, declval<Args>()...); };

    template<class Alloc, class Ptr>
    inline constexpr bool has_alloc_destroy =
        requires(Alloc& a, Ptr p) { a.destroy(p); };

    // has_max_size
    template<class Alloc, class = void>
    inline constexpr bool has_alloc_max_size = false;
    template<class Alloc>
    inline constexpr bool has_alloc_max_size<Alloc,
        void_t<decltype(declval<const Alloc&>().max_size())>> = true;

    // has_select_on_container_copy_construction
    template<class Alloc, class = void>
    inline constexpr bool has_alloc_soccc = false;
    template<class Alloc>
    inline constexpr bool has_alloc_soccc<Alloc,
        void_t<decltype(declval<const Alloc&>().select_on_container_copy_construction())>> = true;

    // has_allocate_hint
    template<class Alloc, class SizeType, class ConstVoidPtr, class = void>
    inline constexpr bool has_alloc_hint = false;
    template<class Alloc, class SizeType, class ConstVoidPtr>
    inline constexpr bool has_alloc_hint<Alloc, SizeType, ConstVoidPtr,
        void_t<decltype(declval<Alloc&>().allocate(declval<SizeType>(), declval<ConstVoidPtr>()))>> = true;

    // has_allocate_at_least (C++23)
    template<class Alloc, class = void>
    inline constexpr bool has_alloc_at_least = false;
    template<class Alloc>
    inline constexpr bool has_alloc_at_least<Alloc,
        void_t<decltype(declval<Alloc&>().allocate_at_least(declval<size_t>()))>> = true;

} // namespace detail

template<class Alloc>
struct allocator_traits {
    using allocator_type   = Alloc;
    using value_type       = typename Alloc::value_type;
    using pointer          = typename detail::alloc_pointer<Alloc>::type;
    using const_pointer    = typename detail::alloc_const_pointer<Alloc, pointer>::type;
    using void_pointer     = typename detail::alloc_void_pointer<Alloc, pointer>::type;
    using const_void_pointer = typename detail::alloc_const_void_pointer<Alloc, pointer>::type;
    using difference_type  = typename detail::alloc_difference_type<Alloc, pointer>::type;
    using size_type        = typename detail::alloc_size_type<Alloc, difference_type>::type;
    using propagate_on_container_copy_assignment = typename detail::alloc_pocca<Alloc>::type;
    using propagate_on_container_move_assignment = typename detail::alloc_pocma<Alloc>::type;
    using propagate_on_container_swap            = typename detail::alloc_pocs<Alloc>::type;
    using is_always_equal                        = typename detail::alloc_iae<Alloc>::type;

    template<class U>
    using rebind_alloc = detail::alloc_rebind_t<Alloc, U>;
    template<class U>
    using rebind_traits = allocator_traits<rebind_alloc<U>>;

    [[nodiscard]] static constexpr pointer
    allocate(Alloc& a, size_type n) {
        return a.allocate(n);
    }

    template<class Ap = Alloc>
        requires detail::has_alloc_hint<Ap, size_type, const_void_pointer>
    [[nodiscard]] static constexpr pointer
    allocate(Alloc& a, size_type n, const_void_pointer hint) {
        return a.allocate(n, hint);
    }

    template<class Ap = Alloc>
        requires (!detail::has_alloc_hint<Ap, size_type, const_void_pointer>)
    [[nodiscard]] static constexpr pointer
    allocate(Alloc& a, size_type n, const_void_pointer) {
        return a.allocate(n);
    }

    [[nodiscard]] static constexpr allocation_result<pointer, size_type>
    allocate_at_least(Alloc& a, size_type n) {
        if constexpr (detail::has_alloc_at_least<Alloc>) {
            auto res = a.allocate_at_least(n);
            return {res.ptr, res.count};
        } else {
            return {a.allocate(n), n};
        }
    }

    static constexpr void
    deallocate(Alloc& a, pointer p, size_type n) noexcept {
        a.deallocate(p, n);
    }

    template<class T, class... Args>
    static constexpr void
    construct(Alloc& a, T* p, Args&&... args) {
        if constexpr (detail::has_alloc_construct<Alloc, T*, Args...>) {
            a.construct(p, std::forward<Args>(args)...);
        } else {
            detail::construct_at_impl(p, std::forward<Args>(args)...);
        }
    }

    template<class T>
    static constexpr void
    destroy(Alloc& a, T* p) {
        if constexpr (detail::has_alloc_destroy<Alloc, T*>) {
            a.destroy(p);
        } else {
            // qualified: an unqualified call ADL-scans T's associated classes,
            // instantiating them -- ill-formed when T is Holder<Incomplete>*.
            std::destroy_at(p);
        }
    }

    [[nodiscard]] static constexpr size_type
    max_size(const Alloc& a) noexcept {
        if constexpr (detail::has_alloc_max_size<Alloc>) {
            return a.max_size();
        } else {
            return size_type(~size_type(0)) / sizeof(value_type);
        }
    }

    [[nodiscard]] static constexpr Alloc
    select_on_container_copy_construction(const Alloc& a) {
        if constexpr (detail::has_alloc_soccc<Alloc>) {
            return a.select_on_container_copy_construction();
        } else {
            return a;
        }
    }
};

//===----------------------------------------------------------------------===//
// allocator<T>
// (from __memory/allocator.h)
//===----------------------------------------------------------------------===//

template<class T>
class allocator {
    static_assert(!is_const_v<T>, "std::allocator does not support const types");
    static_assert(!is_volatile_v<T>, "std::allocator does not support volatile types");
public:
    using size_type       = size_t;
    using difference_type = ptrdiff_t;
    using value_type      = T;
    using propagate_on_container_move_assignment = true_type;
    using is_always_equal                        = true_type;

    constexpr allocator() noexcept = default;

    template<class U>
    constexpr allocator(const allocator<U>&) noexcept {}

    [[nodiscard]] constexpr T* allocate(size_t n) {
        static_assert(sizeof(T) >= 0, "cannot allocate memory for an incomplete type");
        // Over-allocation guard: libc++ would throw bad_array_new_length here.
        // Since exceptions are disabled we trap instead.
        if (n > allocator_traits<allocator>::max_size(*this))
            __builtin_trap(); // would be bad_array_new_length
        return static_cast<T*>(::operator new(n * sizeof(T)));
    }

    [[nodiscard]] constexpr allocation_result<T*>
    allocate_at_least(size_t n) {
        return {allocate(n), n};
    }

    constexpr void deallocate(T* p, size_t) noexcept {
        ::operator delete(static_cast<void*>(p));
    }
};

template<class T, class U>
constexpr bool operator==(const allocator<T>&, const allocator<U>&) noexcept {
    return true;
}

//===----------------------------------------------------------------------===//
// allocate_at_least (C++23 free function)
//===----------------------------------------------------------------------===//

template<class Alloc>
[[nodiscard]] constexpr allocation_result<
    typename allocator_traits<Alloc>::pointer,
    typename allocator_traits<Alloc>::size_type>
allocate_at_least(Alloc& a, size_t n) {
    return allocator_traits<Alloc>::allocate_at_least(a, n);
}

//===----------------------------------------------------------------------===//
// default_delete<T> and default_delete<T[]>
// (from __memory/unique_ptr.h)
//===----------------------------------------------------------------------===//

template<class T>
struct default_delete {
    static_assert(!is_function_v<T>,
        "default_delete cannot be instantiated for function types");

    constexpr default_delete() noexcept = default;

    template<class U>
        requires is_convertible_v<U*, T*>
    constexpr default_delete(const default_delete<U>&) noexcept {}

    constexpr void operator()(T* ptr) const noexcept {
        static_assert(sizeof(T) >= 0, "cannot delete an incomplete type");
        static_assert(!is_void_v<T>, "cannot delete an incomplete type");
        delete ptr;
    }
};

template<class T>
struct default_delete<T[]> {
    constexpr default_delete() noexcept = default;

    template<class U>
        requires is_convertible_v<U(*)[], T(*)[]>
    constexpr default_delete(const default_delete<U[]>&) noexcept {}

    template<class U>
        requires is_convertible_v<U(*)[], T(*)[]>
    constexpr void operator()(U* ptr) const noexcept {
        static_assert(sizeof(U) >= 0, "cannot delete an incomplete type");
        delete[] ptr;
    }
};

//===----------------------------------------------------------------------===//
// unique_ptr<T, D>  — non-array specialisation
// (from __memory/unique_ptr.h)
// We use a simple pair of (pointer, deleter) members rather than
// libc++'s compressed_pair for clarity; EBO is not required by the standard.
// (We do however apply [[no_unique_address]] for EBO in practice.)
//===----------------------------------------------------------------------===//

namespace detail {
    // Detect whether Deleter has a nested pointer typedef
    template<class T, class D, class = void>
    struct unique_ptr_pointer { using type = T*; };
    template<class T, class D>
    struct unique_ptr_pointer<T, D, void_t<typename D::pointer>> { using type = typename D::pointer; };
} // namespace detail

template<class T, class D = default_delete<T>>
class unique_ptr {
public:
    using element_type = T;
    using deleter_type = D;
    using pointer      = typename detail::unique_ptr_pointer<T, remove_reference_t<D>>::type;

    static_assert(!is_rvalue_reference_v<D>,
        "the specified deleter type cannot be an rvalue reference");

private:
    [[no_unique_address]] pointer ptr_{};
    [[no_unique_address]] deleter_type del_{};

    // Enable-if helpers
    template<class Up, class Ep>
    static constexpr bool move_convertible =
        is_convertible_v<typename unique_ptr<Up,Ep>::pointer, pointer> &&
        !is_array_v<Up>;

    template<class Dp>
    static constexpr bool deleter_convertible =
        (is_reference_v<D> && is_same_v<D, Dp>) ||
        (!is_reference_v<D> && is_convertible_v<Dp, D>);

    template<class Dp>
    static constexpr bool deleter_assignable = is_assignable_v<D&, Dp&&>;

public:
    // Default / nullptr constructors
    template<class Dx = D>
        requires (is_default_constructible_v<Dx> && !is_pointer_v<Dx>)
    constexpr unique_ptr() noexcept : ptr_(), del_() {}

    template<class Dx = D>
        requires (is_default_constructible_v<Dx> && !is_pointer_v<Dx>)
    constexpr unique_ptr(nullptr_t) noexcept : ptr_(), del_() {}

    // Pointer constructors
    template<class Dx = D>
        requires (is_default_constructible_v<Dx> && !is_pointer_v<Dx>)
    constexpr explicit unique_ptr(pointer p) noexcept : ptr_(p), del_() {}

    template<class Dx = D>
        requires is_copy_constructible_v<Dx>
    constexpr unique_ptr(pointer p, const D& d) noexcept : ptr_(p), del_(d) {}

    template<class Dx = D>
        requires (!is_reference_v<Dx> && is_move_constructible_v<Dx>)
    constexpr unique_ptr(pointer p, D&& d) noexcept : ptr_(p), del_(move(d)) {}

    // Delete move-from-rvalue-ref-deleter taking rvalue ref to the ref's target type
    template<class Dx = D>
        requires is_reference_v<Dx>
    unique_ptr(pointer, remove_reference_t<D>&&) = delete;

    // Move constructor
    constexpr unique_ptr(unique_ptr&& u) noexcept
        : ptr_(u.release()), del_(std::forward<D>(u.get_deleter())) {}

    // Converting move constructor
    template<class Up, class Ep>
        requires (move_convertible<Up,Ep> && deleter_convertible<Ep>)
    constexpr unique_ptr(unique_ptr<Up,Ep>&& u) noexcept
        : ptr_(u.release()), del_(std::forward<Ep>(u.get_deleter())) {}

    unique_ptr(const unique_ptr&) = delete;
    unique_ptr& operator=(const unique_ptr&) = delete;

    constexpr ~unique_ptr() { reset(); }

    // Move assignment
    constexpr unique_ptr& operator=(unique_ptr&& u) noexcept {
        reset(u.release());
        del_ = std::forward<D>(u.get_deleter());
        return *this;
    }

    template<class Up, class Ep>
        requires (move_convertible<Up,Ep> && deleter_assignable<Ep>)
    constexpr unique_ptr& operator=(unique_ptr<Up,Ep>&& u) noexcept {
        reset(u.release());
        del_ = std::forward<Ep>(u.get_deleter());
        return *this;
    }

    constexpr unique_ptr& operator=(nullptr_t) noexcept {
        reset();
        return *this;
    }

    // Observers
    [[nodiscard]] constexpr add_lvalue_reference_t<T> operator*() const
        noexcept(noexcept(*declval<pointer>())) {
        return *ptr_;
    }

    constexpr pointer operator->() const noexcept { return ptr_; }
    [[nodiscard]] constexpr pointer get() const noexcept { return ptr_; }
    [[nodiscard]] constexpr deleter_type& get_deleter() noexcept { return del_; }
    [[nodiscard]] constexpr const deleter_type& get_deleter() const noexcept { return del_; }
    constexpr explicit operator bool() const noexcept { return ptr_ != nullptr; }

    // Modifiers
    constexpr pointer release() noexcept {
        pointer t = ptr_;
        ptr_ = pointer();
        return t;
    }

    constexpr void reset(pointer p = pointer()) noexcept {
        pointer tmp = ptr_;
        ptr_ = p;
        if (tmp)
            del_(tmp);
    }

    constexpr void swap(unique_ptr& u) noexcept {
        using std::swap;
        swap(ptr_, u.ptr_);
        swap(del_, u.del_);
    }
};

//===----------------------------------------------------------------------===//
// unique_ptr<T[], D>  — array specialisation
// (from __memory/unique_ptr.h)
//===----------------------------------------------------------------------===//

template<class T, class D>
class unique_ptr<T[], D> {
public:
    using element_type = T;
    using deleter_type = D;
    using pointer      = typename detail::unique_ptr_pointer<T, remove_reference_t<D>>::type;

private:
    [[no_unique_address]] pointer ptr_{};
    [[no_unique_address]] deleter_type del_{};

    // Allowed pointer types: same as pointer, or T* when pointer == T*
    template<class From>
    struct check_array_pointer : is_same<From, pointer> {};
    template<class FromElem>
    struct check_array_pointer<FromElem*>
        : bool_constant<
            is_same_v<FromElem*, pointer> ||
            (is_same_v<pointer, element_type*> &&
             is_convertible_v<FromElem(*)[], element_type(*)[]>)> {};

    template<class Up, class Ep>
    static constexpr bool move_convertible =
        is_array_v<Up> &&
        is_same_v<pointer, element_type*> &&
        is_same_v<typename unique_ptr<Up,Ep>::pointer,
                  typename remove_extent<Up>::type*> &&
        is_convertible_v<typename remove_extent<Up>::type(*)[],
                         element_type(*)[]>;

    template<class Dp>
    static constexpr bool deleter_convertible =
        (is_reference_v<D> && is_same_v<D, Dp>) ||
        (!is_reference_v<D> && is_convertible_v<Dp, D>);

    template<class Dp>
    static constexpr bool deleter_assignable = is_assignable_v<D&, Dp&&>;

public:
    template<class Dx = D>
        requires (is_default_constructible_v<Dx> && !is_pointer_v<Dx>)
    constexpr unique_ptr() noexcept : ptr_(), del_() {}

    template<class Dx = D>
        requires (is_default_constructible_v<Dx> && !is_pointer_v<Dx>)
    constexpr unique_ptr(nullptr_t) noexcept : ptr_(), del_() {}

    template<class Ptr, class Dx = D>
        requires (is_default_constructible_v<Dx> && !is_pointer_v<Dx> &&
                  check_array_pointer<Ptr>::value)
    constexpr explicit unique_ptr(Ptr p) noexcept : ptr_(p), del_() {}

    template<class Ptr, class Dx = D>
        requires (is_copy_constructible_v<Dx> && check_array_pointer<Ptr>::value)
    constexpr unique_ptr(Ptr p, const D& d) noexcept : ptr_(p), del_(d) {}

    template<class Dx = D>
        requires is_copy_constructible_v<Dx>
    constexpr unique_ptr(nullptr_t, const D& d) noexcept : ptr_(nullptr), del_(d) {}

    template<class Ptr, class Dx = D>
        requires (!is_reference_v<Dx> && is_move_constructible_v<Dx> &&
                  check_array_pointer<Ptr>::value)
    constexpr unique_ptr(Ptr p, D&& d) noexcept : ptr_(p), del_(move(d)) {}

    template<class Dx = D>
        requires (!is_reference_v<Dx> && is_move_constructible_v<Dx>)
    constexpr unique_ptr(nullptr_t, D&& d) noexcept : ptr_(nullptr), del_(move(d)) {}

    // Delete rvalue-ref-to-target of reference deleter
    template<class Ptr, class Dx = D>
        requires (is_reference_v<Dx> && check_array_pointer<Ptr>::value)
    unique_ptr(Ptr, remove_reference_t<D>&&) = delete;

    constexpr unique_ptr(unique_ptr&& u) noexcept
        : ptr_(u.release()), del_(std::forward<D>(u.get_deleter())) {}

    constexpr unique_ptr& operator=(unique_ptr&& u) noexcept {
        reset(u.release());
        del_ = std::forward<D>(u.get_deleter());
        return *this;
    }

    template<class Up, class Ep>
        requires (move_convertible<Up,Ep> && deleter_convertible<Ep>)
    constexpr unique_ptr(unique_ptr<Up,Ep>&& u) noexcept
        : ptr_(u.release()), del_(std::forward<Ep>(u.get_deleter())) {}

    template<class Up, class Ep>
        requires (move_convertible<Up,Ep> && deleter_assignable<Ep>)
    constexpr unique_ptr& operator=(unique_ptr<Up,Ep>&& u) noexcept {
        reset(u.release());
        del_ = std::forward<Ep>(u.get_deleter());
        return *this;
    }

    unique_ptr(const unique_ptr&) = delete;
    unique_ptr& operator=(const unique_ptr&) = delete;

    constexpr ~unique_ptr() { reset(); }

    constexpr unique_ptr& operator=(nullptr_t) noexcept {
        reset();
        return *this;
    }

    constexpr add_lvalue_reference_t<T> operator[](size_t i) const {
        return ptr_[i];
    }

    [[nodiscard]] constexpr pointer get() const noexcept { return ptr_; }
    [[nodiscard]] constexpr deleter_type& get_deleter() noexcept { return del_; }
    [[nodiscard]] constexpr const deleter_type& get_deleter() const noexcept { return del_; }
    constexpr explicit operator bool() const noexcept { return ptr_ != nullptr; }

    constexpr pointer release() noexcept {
        pointer t = ptr_;
        ptr_ = pointer();
        return t;
    }

    template<class Pp>
        requires check_array_pointer<Pp>::value
    constexpr void reset(Pp p) noexcept {
        pointer tmp = ptr_;
        ptr_ = p;
        if (tmp)
            del_(tmp);
    }

    constexpr void reset(nullptr_t = nullptr) noexcept {
        pointer tmp = ptr_;
        ptr_ = nullptr;
        if (tmp)
            del_(tmp);
    }

    constexpr void swap(unique_ptr& u) noexcept {
        using std::swap;
        swap(ptr_, u.ptr_);
        swap(del_, u.del_);
    }
};

//===----------------------------------------------------------------------===//
// unique_ptr free functions: swap, comparisons, operator<=>
//===----------------------------------------------------------------------===//

template<class T, class D>
    requires is_swappable_v<D>
constexpr void swap(unique_ptr<T,D>& x, unique_ptr<T,D>& y) noexcept {
    x.swap(y);
}

// unique_ptr vs unique_ptr
template<class T1, class D1, class T2, class D2>
constexpr bool operator==(const unique_ptr<T1,D1>& x, const unique_ptr<T2,D2>& y) {
    return x.get() == y.get();
}

template<class T1, class D1, class T2, class D2>
bool operator<(const unique_ptr<T1,D1>& x, const unique_ptr<T2,D2>& y) {
    using P1 = typename unique_ptr<T1,D1>::pointer;
    using P2 = typename unique_ptr<T2,D2>::pointer;
    using Vp = common_type_t<P1, P2>;
    return static_cast<Vp>(x.get()) < static_cast<Vp>(y.get());
}

template<class T1, class D1, class T2, class D2>
bool operator>(const unique_ptr<T1,D1>& x, const unique_ptr<T2,D2>& y) {
    return y < x;
}

template<class T1, class D1, class T2, class D2>
bool operator<=(const unique_ptr<T1,D1>& x, const unique_ptr<T2,D2>& y) {
    return !(y < x);
}

template<class T1, class D1, class T2, class D2>
bool operator>=(const unique_ptr<T1,D1>& x, const unique_ptr<T2,D2>& y) {
    return !(x < y);
}

template<class T1, class D1, class T2, class D2>
    requires three_way_comparable_with<
        typename unique_ptr<T1,D1>::pointer,
        typename unique_ptr<T2,D2>::pointer>
auto operator<=>(const unique_ptr<T1,D1>& x, const unique_ptr<T2,D2>& y) {
    return compare_three_way()(x.get(), y.get());
}

// unique_ptr vs nullptr
template<class T, class D>
constexpr bool operator==(const unique_ptr<T,D>& x, nullptr_t) noexcept {
    return !x;
}

template<class T, class D>
constexpr bool operator<(const unique_ptr<T,D>& x, nullptr_t) {
    using P = typename unique_ptr<T,D>::pointer;
    return static_cast<P>(x.get()) < static_cast<P>(nullptr);
}

template<class T, class D>
constexpr bool operator<(nullptr_t, const unique_ptr<T,D>& x) {
    using P = typename unique_ptr<T,D>::pointer;
    return static_cast<P>(nullptr) < static_cast<P>(x.get());
}

template<class T, class D>
constexpr bool operator>(const unique_ptr<T,D>& x, nullptr_t) {
    return nullptr < x;
}

template<class T, class D>
constexpr bool operator>(nullptr_t, const unique_ptr<T,D>& x) {
    return x < nullptr;
}

template<class T, class D>
constexpr bool operator<=(const unique_ptr<T,D>& x, nullptr_t) {
    return !(nullptr < x);
}

template<class T, class D>
constexpr bool operator<=(nullptr_t, const unique_ptr<T,D>& x) {
    return !(x < nullptr);
}

template<class T, class D>
constexpr bool operator>=(const unique_ptr<T,D>& x, nullptr_t) {
    return !(x < nullptr);
}

template<class T, class D>
constexpr bool operator>=(nullptr_t, const unique_ptr<T,D>& x) {
    return !(nullptr < x);
}

template<class T, class D>
    requires three_way_comparable<typename unique_ptr<T,D>::pointer>
constexpr auto operator<=>(const unique_ptr<T,D>& x, nullptr_t) {
    return compare_three_way()(x.get(),
        static_cast<typename unique_ptr<T,D>::pointer>(nullptr));
}

