template<class T, class U>
[[nodiscard]] shared_ptr<T>
static_pointer_cast(const shared_ptr<U>& r) noexcept {
    return shared_ptr<T>(r,
        static_cast<typename shared_ptr<T>::element_type*>(r.get()));
}

template<class T, class U>
[[nodiscard]] shared_ptr<T>
static_pointer_cast(shared_ptr<U>&& r) noexcept {
    return shared_ptr<T>(move(r),
        static_cast<typename shared_ptr<T>::element_type*>(r.get()));
}

template<class T, class U>
[[nodiscard]] shared_ptr<T>
const_pointer_cast(const shared_ptr<U>& r) noexcept {
    return shared_ptr<T>(r,
        const_cast<typename shared_ptr<T>::element_type*>(r.get()));
}

template<class T, class U>
[[nodiscard]] shared_ptr<T>
const_pointer_cast(shared_ptr<U>&& r) noexcept {
    return shared_ptr<T>(move(r),
        const_cast<typename shared_ptr<T>::element_type*>(r.get()));
}

template<class T, class U>
[[nodiscard]] shared_ptr<T>
reinterpret_pointer_cast(const shared_ptr<U>& r) noexcept {
    return shared_ptr<T>(r,
        reinterpret_cast<typename shared_ptr<T>::element_type*>(r.get()));
}

template<class T, class U>
[[nodiscard]] shared_ptr<T>
reinterpret_pointer_cast(shared_ptr<U>&& r) noexcept {
    return shared_ptr<T>(move(r),
        reinterpret_cast<typename shared_ptr<T>::element_type*>(r.get()));
}

//===----------------------------------------------------------------------===//
// owner_less
//===----------------------------------------------------------------------===//

template<class T = void>
struct owner_less;

template<class T>
struct owner_less<shared_ptr<T>> {
    bool operator()(const shared_ptr<T>& x, const shared_ptr<T>& y) const noexcept {
        return x.owner_before(y);
    }
    bool operator()(const shared_ptr<T>& x, const weak_ptr<T>& y) const noexcept {
        return x.owner_before(y);
    }
    bool operator()(const weak_ptr<T>& x, const shared_ptr<T>& y) const noexcept {
        return x.owner_before(y);
    }
};

template<class T>
struct owner_less<weak_ptr<T>> {
    bool operator()(const weak_ptr<T>& x, const weak_ptr<T>& y) const noexcept {
        return x.owner_before(y);
    }
    bool operator()(const shared_ptr<T>& x, const weak_ptr<T>& y) const noexcept {
        return x.owner_before(y);
    }
    bool operator()(const weak_ptr<T>& x, const shared_ptr<T>& y) const noexcept {
        return x.owner_before(y);
    }
};

template<>
struct owner_less<void> {
    using is_transparent = void;
    template<class T, class U>
    bool operator()(const shared_ptr<T>& x, const shared_ptr<U>& y) const noexcept {
        return x.owner_before(y);
    }
    template<class T, class U>
    bool operator()(const shared_ptr<T>& x, const weak_ptr<U>& y) const noexcept {
        return x.owner_before(y);
    }
    template<class T, class U>
    bool operator()(const weak_ptr<T>& x, const shared_ptr<U>& y) const noexcept {
        return x.owner_before(y);
    }
    template<class T, class U>
    bool operator()(const weak_ptr<T>& x, const weak_ptr<U>& y) const noexcept {
        return x.owner_before(y);
    }
};

//===----------------------------------------------------------------------===//
// make_shared / allocate_shared / make_shared_for_overwrite
//===----------------------------------------------------------------------===//

template<class T, class Alloc, class... Args>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
allocate_shared(const Alloc& a, Args&&... args) {
    using CB = sp_counted_emplace<T, Alloc>;
    using CbAlloc = typename allocator_traits<Alloc>::template rebind_alloc<CB>;
    using CbTraits = allocator_traits<CbAlloc>;
    CbAlloc ca(a);
    CB* cb = CbTraits::allocate(ca, 1);
    ::new(static_cast<void*>(cb)) CB(a, forward<Args>(args)...);
    return shared_ptr<T>::create_with_control_block(cb->get_elem(), cb);
}

template<class T, class... Args>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
make_shared(Args&&... args) {
    return allocate_shared<T>(allocator<remove_cv_t<T>>(),
                               forward<Args>(args)...);
}

template<class T>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
allocate_shared_for_overwrite(const allocator<T>& /* a */) {
    using OverwriteAlloc = allocator<sp_for_overwrite_tag>;
    OverwriteAlloc oa;
    // Use sp_counted_emplace with the for_overwrite tag allocator.
    // We pass a "rebound to sp_for_overwrite_tag" allocator so the control
    // block knows to use default-init instead of value-init.
    using CB = sp_counted_emplace<T, OverwriteAlloc>;
    using CbAlloc = typename allocator_traits<OverwriteAlloc>::template rebind_alloc<CB>;
    using CbTraits = allocator_traits<CbAlloc>;
    CbAlloc ca(oa);
    CB* cb = CbTraits::allocate(ca, 1);
    ::new(static_cast<void*>(cb)) CB(oa);
    return shared_ptr<T>::create_with_control_block(cb->get_elem(), cb);
}

template<class T>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
make_shared_for_overwrite() {
    return allocate_shared_for_overwrite<T>(allocator<T>());
}

//===----------------------------------------------------------------------===//
// hash specialisations for shared_ptr and unique_ptr
// (Replaces the "DEFERRED" comments in the header preamble)
//===----------------------------------------------------------------------===//

template<class T>
struct hash<shared_ptr<T>> {
    [[nodiscard]] size_t operator()(const shared_ptr<T>& p) const noexcept {
        return hash<typename shared_ptr<T>::element_type*>()(p.get());
    }
};

template<class T, class D>
struct hash<unique_ptr<T, D>> {
    [[nodiscard]] size_t operator()(const unique_ptr<T, D>& p) const noexcept {
        return hash<typename unique_ptr<T, D>::pointer>()(p.get());
    }
};

