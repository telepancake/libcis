// make_shared / allocate_shared / make_shared_for_overwrite
// (from libc++ __memory/shared_ptr.h)
//===----------------------------------------------------------------------===//

template<class T, class Alloc, class... Args>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
allocate_shared(const Alloc& a, Args&&... args) {
    using CB = sp_counted_emplace<T, Alloc>;
    using CbAlloc = typename allocator_traits<Alloc>::template rebind_alloc<CB>;
    using CbTraits = allocator_traits<CbAlloc>;
    CbAlloc ca(a);
    CB* cb = CbTraits::allocate(ca, 1);
    ::new(static_cast<void*>(cb)) CB(a, std::forward<Args>(args)...);
    return shared_ptr<T>::create_with_control_block(cb->get_elem(), cb);
}

template<class T, class... Args>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
make_shared(Args&&... args) {
    return allocate_shared<T>(allocator<remove_cv_t<T>>(),
                               std::forward<Args>(args)...);
}

// allocate_shared_for_overwrite / make_shared_for_overwrite, non-array
// (from libc++ __memory/shared_ptr.h): rebind the user's allocator to
// sp_for_overwrite_tag — sp_counted_emplace dispatches on that value_type to
// default-initialize instead of value-initialize.
template<class T, class Alloc>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
allocate_shared_for_overwrite(const Alloc& a) {
    using ForOverwriteAllocator =
        typename allocator_traits<Alloc>::template rebind_alloc<sp_for_overwrite_tag>;
    ForOverwriteAllocator alloc(a);
    return std::allocate_shared<T>(alloc);
}

template<class T>
    requires (!is_array_v<T>)
[[nodiscard]] shared_ptr<T>
make_shared_for_overwrite() {
    return std::allocate_shared_for_overwrite<T>(allocator<remove_cv_t<T>>());
}

//===----------------------------------------------------------------------===//
// Array support for make_shared / allocate_shared (C++20)
//
// Helper algorithms ported from libc++:
//   detail::reverse_destroy
//     — __memory/destroy.h __reverse_destroy
//   detail::allocator_destroy_multidimensional,
//   detail::allocator_construct_at_multidimensional,
//   detail::uninitialized_allocator_fill_n_multidimensional,
//   detail::uninitialized_allocator_value_construct_n_multidimensional
//     — __memory/uninitialized_algorithms.h (same names, __-prefixed).
// Under -fno-exceptions the libc++ exception guards around the construction
// loops are no-ops (construction failure cannot unwind), so they are omitted.
//===----------------------------------------------------------------------===//

namespace detail {

// from libc++ __memory/destroy.h __reverse_destroy
template<class BidirIter>
constexpr void reverse_destroy(BidirIter first, BidirIter last) {
    while (last != first) {
        --last;
        std::destroy_at(std::addressof(*last));
    }
}

// Destroys every element in [first, last) FROM RIGHT TO LEFT using allocator
// destruction. C-style-array elements are recursively destroyed elementwise.
// (libc++ __allocator_destroy_multidimensional)
template<class Alloc, class BidirIter>
constexpr void
allocator_destroy_multidimensional(Alloc& alloc, BidirIter first, BidirIter last) noexcept {
    using ValueType = typename iterator_traits<BidirIter>::value_type;

    if (first == last)
        return;

    if constexpr (is_array_v<ValueType>) {
        static_assert(!is_unbounded_array_v<ValueType>,
            "arrays of unbounded arrays don't exist, but if they did we would mess up here");

        using Element = remove_extent_t<ValueType>;
        typename allocator_traits<Alloc>::template rebind_alloc<Element> elem_alloc(alloc);
        do {
            --last;
            decltype(auto) array = *last;
            detail::allocator_destroy_multidimensional(
                elem_alloc, array, array + extent_v<ValueType>);
        } while (last != first);
    } else {
        do {
            --last;
            allocator_traits<Alloc>::destroy(alloc, std::addressof(*last));
        } while (last != first);
    }
}

// Constructs the object at the given location using the allocator's construct
// method; arrays are allocator-constructed elementwise, recursively.
// (libc++ __allocator_construct_at_multidimensional)
template<class Alloc, class T>
constexpr void allocator_construct_at_multidimensional(Alloc& alloc, T* loc) {
    if constexpr (is_array_v<T>) {
        using Element = remove_extent_t<T>;
        typename allocator_traits<Alloc>::template rebind_alloc<Element> elem_alloc(alloc);
        T& array = *loc;
        for (size_t i = 0; i != extent_v<T>; ++i)
            detail::allocator_construct_at_multidimensional(
                elem_alloc, std::addressof(array[i]));
    } else {
        allocator_traits<Alloc>::construct(alloc, loc);
    }
}

// Same, passing along the provided argument; if T is an array, the argument
// is assumed to be an array and is copied elementwise.
// (libc++ __allocator_construct_at_multidimensional)
template<class Alloc, class T, class Arg>
constexpr void
allocator_construct_at_multidimensional(Alloc& alloc, T* loc, Arg const& arg) {
    if constexpr (is_array_v<T>) {
        static_assert(is_array_v<Arg>,
            "Provided non-array initialization argument to "
            "allocator_construct_at_multidimensional when trying to construct an array.");

        using Element = remove_extent_t<T>;
        typename allocator_traits<Alloc>::template rebind_alloc<Element> elem_alloc(alloc);
        T& array = *loc;
        for (size_t i = 0; i != extent_v<T>; ++i)
            detail::allocator_construct_at_multidimensional(
                elem_alloc, std::addressof(array[i]), arg[i]);
    } else {
        allocator_traits<Alloc>::construct(alloc, loc, arg);
    }
}

// (libc++ __uninitialized_allocator_fill_n_multidimensional)
template<class Alloc, class BidirIter, class T,
         class Size = typename iterator_traits<BidirIter>::difference_type>
constexpr void
uninitialized_allocator_fill_n_multidimensional(Alloc& alloc, BidirIter it, Size n, T const& value) {
    using ValueType = typename iterator_traits<BidirIter>::value_type;
    typename allocator_traits<Alloc>::template rebind_alloc<ValueType> value_alloc(alloc);
    for (; n != 0; --n, ++it)
        detail::allocator_construct_at_multidimensional(
            value_alloc, std::addressof(*it), value);
}

// Same but with no initialization argument — value-initialization.
// (libc++ __uninitialized_allocator_value_construct_n_multidimensional)
template<class Alloc, class BidirIter,
         class Size = typename iterator_traits<BidirIter>::difference_type>
constexpr void
uninitialized_allocator_value_construct_n_multidimensional(Alloc& alloc, BidirIter it, Size n) {
    using ValueType = typename iterator_traits<BidirIter>::value_type;
    typename allocator_traits<Alloc>::template rebind_alloc<ValueType> value_alloc(alloc);
    for (; n != 0; --n, ++it)
        detail::allocator_construct_at_multidimensional(value_alloc, std::addressof(*it));
}

} // namespace detail

// (from libc++ __memory/shared_ptr.h __sp_aligned_storage)
template<size_t Alignment>
struct sp_aligned_storage {
    alignas(Alignment) char storage[Alignment];
};

// (from libc++ __memory/shared_ptr.h __unbounded_array_control_block)
template<class T, class Alloc>
struct sp_unbounded_array_control_block;

template<class T, class Alloc>
struct sp_unbounded_array_control_block<T[], Alloc> : sp_counted_base {
    constexpr T* get_data() noexcept { return data_; }

    explicit sp_unbounded_array_control_block(Alloc const& alloc, size_t count, T const& arg)
        : alloc_(alloc), count_(count) {
        detail::uninitialized_allocator_fill_n_multidimensional(alloc_, data_, count_, arg);
    }

    explicit sp_unbounded_array_control_block(Alloc const& alloc, size_t count)
        : alloc_(alloc), count_(count) {
        if constexpr (is_same_v<typename Alloc::value_type, sp_for_overwrite_tag>) {
            // We are purposefully not using an allocator-aware default construction
            // because the spec says so. There's currently no way of expressing
            // default initialization in an allocator-aware manner anyway.
            std::uninitialized_default_construct_n(data_, count_);
        } else {
            detail::uninitialized_allocator_value_construct_n_multidimensional(
                alloc_, data_, count_);
        }
    }

    // Returns the number of bytes required to store a control block followed by
    // the given number of elements of T, with the whole storage being aligned to
    // a multiple of T's alignment. (libc++ __bytes_for)
    static constexpr size_t bytes_for(size_t elements) {
        // When there's 0 elements, the control block alone is enough since it
        // holds one element. Otherwise, we allocate one fewer element than
        // requested because the control block already holds one. The bitwise
        // formula below ensures we allocate enough bytes for the whole
        // allocation to be a multiple of T's alignment.
        size_t bytes = elements == 0
            ? sizeof(sp_unbounded_array_control_block)
            : (elements - 1) * sizeof(T) + sizeof(sp_unbounded_array_control_block);
        constexpr size_t align = alignof(sp_unbounded_array_control_block);
        return (bytes + align - 1) & ~(align - 1);
    }

    ~sp_unbounded_array_control_block() override {
    } // can't be `= default` because of the sometimes-non-trivial union member data_

    void on_zero_shared() noexcept override {
        if constexpr (is_same_v<typename Alloc::value_type, sp_for_overwrite_tag>) {
            detail::reverse_destroy(data_, data_ + count_);
        } else {
            typename allocator_traits<Alloc>::template rebind_alloc<T> value_alloc(alloc_);
            detail::allocator_destroy_multidimensional(value_alloc, data_, data_ + count_);
        }
    }

    void on_zero_shared_weak() noexcept override {
        using AlignedStorage =
            sp_aligned_storage<alignof(sp_unbounded_array_control_block)>;
        using StorageAlloc =
            typename allocator_traits<Alloc>::template rebind_alloc<AlignedStorage>;
        using PtrTraits = pointer_traits<typename allocator_traits<StorageAlloc>::pointer>;

        StorageAlloc tmp(alloc_);
        alloc_.~Alloc();
        size_t size = sp_unbounded_array_control_block::bytes_for(count_);
        AlignedStorage* storage = reinterpret_cast<AlignedStorage*>(this);
        allocator_traits<StorageAlloc>::deallocate(
            tmp, PtrTraits::pointer_to(*storage), size / sizeof(AlignedStorage));
    }

    [[no_unique_address]] Alloc alloc_;
    size_t count_;
    union {
        T data_[1];
    };
};

namespace detail {

// (from libc++ __memory/shared_ptr.h __allocate_shared_unbounded_array)
template<class Array, class Alloc, class... Arg>
shared_ptr<Array> allocate_shared_unbounded_array(const Alloc& a, size_t n, Arg&&... arg) {
    static_assert(is_unbounded_array_v<Array>);
    // We compute the number of bytes necessary to hold the control block and the
    // array elements. Then, we allocate an array of properly-aligned dummy structs
    // large enough to hold the control block and array. This allows shifting the
    // burden of aligning memory properly from us to the allocator.
    using ControlBlock   = sp_unbounded_array_control_block<Array, Alloc>;
    using AlignedStorage = sp_aligned_storage<alignof(ControlBlock)>;
    using StorageAlloc   =
        typename allocator_traits<Alloc>::template rebind_alloc<AlignedStorage>;
    StorageAlloc sa(a);
    ControlBlock* control_block = reinterpret_cast<ControlBlock*>(
        std::addressof(*allocator_traits<StorageAlloc>::allocate(
            sa, ControlBlock::bytes_for(n) / sizeof(AlignedStorage))));
    ::new(static_cast<void*>(control_block)) ControlBlock(a, n, std::forward<Arg>(arg)...);
    return shared_ptr<Array>::create_with_control_block(
        control_block->get_data(), control_block);
}

