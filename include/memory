    return detail::allocate_shared_unbounded_array<T>(allocator<T>(), n, u);
}

template<class T>
    requires is_unbounded_array_v<T>
[[nodiscard]] shared_ptr<T> make_shared_for_overwrite(size_t n) {
    return detail::allocate_shared_unbounded_array<T>(allocator<sp_for_overwrite_tag>(), n);
}

//===----------------------------------------------------------------------===//
// operator<< for shared_ptr and unique_ptr
//
// shared_ptr: declared in libc++ __memory/shared_ptr.h, defined in
// __ostream/basic_ostream.h. unique_ptr (C++20, P1132): defined in
// __ostream/basic_ostream.h with a SFINAE constraint that the pointer is
// streamable. basic_ostream is forward-declared in <iosfwd>; the bodies are
// only instantiated at a call site, where <ostream> must be complete.
//===----------------------------------------------------------------------===//

template<class CharT, class Traits, class Y>
inline basic_ostream<CharT, Traits>&
operator<<(basic_ostream<CharT, Traits>& os, shared_ptr<Y> const& p) {
    return os << p.get();
}

template<class CharT, class Traits, class Y, class D,
         class = enable_if_t<is_same_v<
             void,
             void_t<decltype(declval<basic_ostream<CharT, Traits>&>()
                             << declval<typename unique_ptr<Y, D>::pointer>())>>>>
inline basic_ostream<CharT, Traits>&
operator<<(basic_ostream<CharT, Traits>& os, unique_ptr<Y, D> const& p) {
    return os << p.get();
}

//===----------------------------------------------------------------------===//
// shared_ptr atomic access [util.smartptr.shared.atomic] (the C++11 API)
//
// Ported from libc++ __memory/shared_ptr.h (the atomic_* free functions) and
// src/memory.cpp (__sp_mut / __get_sp_mut: a 32-entry mutex table indexed by
// hashing the shared_ptr's address). libc++ keeps the mutex table in the
// built library; we are header-only, so the table is a function-local static
// array and the mutex is a tiny spinlock on __atomic builtins.
//===----------------------------------------------------------------------===//

namespace detail {

class sp_mut {
    int lx_ = 0;  // 0 = unlocked, 1 = locked

    sp_mut(const sp_mut&) = delete;
    sp_mut& operator=(const sp_mut&) = delete;

public:
    constexpr sp_mut() noexcept = default;

    void lock() noexcept {
        while (__atomic_exchange_n(&lx_, 1, __ATOMIC_ACQUIRE) != 0) {
            while (__atomic_load_n(&lx_, __ATOMIC_RELAXED) != 0) {
                // spin
            }
        }
    }

    void unlock() noexcept { __atomic_store_n(&lx_, 0, __ATOMIC_RELEASE); }
};

// libc++ __get_sp_mut (src/memory.cpp)
inline sp_mut& get_sp_mut(const void* p) {
    constexpr size_t sp_mut_count = 32;
    static sp_mut muts[sp_mut_count];
    return muts[hash<const void*>()(p) & (sp_mut_count - 1)];
}

} // namespace detail

template<class T>
inline bool atomic_is_lock_free(const shared_ptr<T>*) {
    return false;
}

template<class T>
shared_ptr<T> atomic_load(const shared_ptr<T>* p) {
    detail::sp_mut& m = detail::get_sp_mut(p);
    m.lock();
    shared_ptr<T> q = *p;
    m.unlock();
    return q;
}

template<class T>
inline shared_ptr<T> atomic_load_explicit(const shared_ptr<T>* p, memory_order) {
    return std::atomic_load(p);
}

template<class T>
void atomic_store(shared_ptr<T>* p, shared_ptr<T> r) {
    detail::sp_mut& m = detail::get_sp_mut(p);
    m.lock();
    p->swap(r);
    m.unlock();
}

template<class T>
inline void atomic_store_explicit(shared_ptr<T>* p, shared_ptr<T> r, memory_order) {
    std::atomic_store(p, r);
}

template<class T>
shared_ptr<T> atomic_exchange(shared_ptr<T>* p, shared_ptr<T> r) {
    detail::sp_mut& m = detail::get_sp_mut(p);
    m.lock();
    p->swap(r);
    m.unlock();
    return r;
}

template<class T>
inline shared_ptr<T> atomic_exchange_explicit(shared_ptr<T>* p, shared_ptr<T> r, memory_order) {
    return std::atomic_exchange(p, r);
}

template<class T>
bool atomic_compare_exchange_strong(shared_ptr<T>* p, shared_ptr<T>* v, shared_ptr<T> w) {
    shared_ptr<T> temp;
    detail::sp_mut& m = detail::get_sp_mut(p);
    m.lock();
    if (p->owner_equivalent(*v)) {
        std::swap(temp, *p);
        *p = w;
        m.unlock();
        return true;
    }
    std::swap(temp, *v);
    *v = *p;
    m.unlock();
    return false;
}

template<class T>
inline bool atomic_compare_exchange_weak(shared_ptr<T>* p, shared_ptr<T>* v, shared_ptr<T> w) {
    return std::atomic_compare_exchange_strong(p, v, w);
}

template<class T>
inline bool atomic_compare_exchange_strong_explicit(
    shared_ptr<T>* p, shared_ptr<T>* v, shared_ptr<T> w, memory_order, memory_order) {
    return std::atomic_compare_exchange_strong(p, v, w);
}

template<class T>
inline bool atomic_compare_exchange_weak_explicit(
    shared_ptr<T>* p, shared_ptr<T>* v, shared_ptr<T> w, memory_order, memory_order) {
    return std::atomic_compare_exchange_weak(p, v, w);
}

//===----------------------------------------------------------------------===//
// hash specialisations for shared_ptr and unique_ptr
// (Replaces the "DEFERRED" comments in the header preamble)
//===----------------------------------------------------------------------===//

template<class T>
struct hash<shared_ptr<T>> {
    [[nodiscard]] size_t operator()(const shared_ptr<T>& p) const noexcept {
        return hash<typename shared_ptr<T>::element_type*>()(p.get());
    }
};

// Poisoned-hash support, ported from libc++ __functional/hash.h
// (__check_hash_requirements / __has_enabled_hash / __enable_hash_helper):
// the hash<unique_ptr> specialisation is itself disabled (so the deleted
// primary hash template is picked) unless hash<pointer> is enabled.
namespace detail {

template<class Key, class Hash = hash<Key>>
inline constexpr bool check_hash_requirements_v =
    is_copy_constructible_v<Hash> && is_move_constructible_v<Hash> &&
    is_invocable_r_v<size_t, Hash, const Key&>;

template<class Key, class Hash = hash<Key>>
inline constexpr bool has_enabled_hash_v =
    check_hash_requirements_v<Key, Hash> && is_default_constructible_v<Hash>;

template<class Type, class>
using enable_hash_helper_imp = Type;

template<class Type, class... Keys>
using enable_hash_helper =
    enable_hash_helper_imp<Type, enable_if_t<(has_enabled_hash_v<Keys> && ...)>>;

} // namespace detail

// NOT noexcept: the user's hash<pointer> may throw
// (libc++ __memory/unique_ptr.h hash<unique_ptr> is not noexcept either).
template<class T, class D>
struct hash<detail::enable_hash_helper<
    unique_ptr<T, D>, typename unique_ptr<T, D>::pointer>> {
    [[nodiscard]] size_t operator()(const unique_ptr<T, D>& p) const {
        using pointer = typename unique_ptr<T, D>::pointer;
        return hash<pointer>()(p.get());
    }
};

} // namespace std

