// <functional> — mechanically ported from libc++ include/__functional/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Folded sources:
//   __functional/reference_wrapper.h   -> reference_wrapper, ref, cref
//   __functional/invoke.h              -> invoke, invoke_r
//   __functional/mem_fn.h              -> mem_fn
//   __functional/operations.h          -> arithmetic/comparison/logical/bitwise functors
//   __functional/hash.h                -> hash, scalar_hash, murmur2_or_cityhash
//   __functional/not_fn.h              -> not_fn
//   __functional/bind_front.h          -> bind_front
//   __functional/bind_back.h           -> bind_back
//   __functional/bind.h                -> bind, is_bind_expression, is_placeholder, placeholders
//   __functional/function.h            -> function<R(Args...)>
//   __functional/perfect_forward.h     -> detail::perfect_forward_impl (internal)
//
//   __functional/default_searcher.h    -> default_searcher
//   __functional/boyer_moore_searcher.h-> boyer_moore_searcher, boyer_moore_horspool_searcher
//   __functional/unary_negate.h        -> unary_negate, not1 (C++20-removed; provided)
//   __functional/binary_negate.h       -> binary_negate, not2 (C++20-removed; provided)
//
// OMITTED (noted):
//   function::target() / function::target_type()
//     — require typeid (RTTI); omitted under -fno-rtti (noted in comment below).
//
// Empty-function call behaviour (no exceptions):
//   Calling an empty std::function uses __builtin_trap() instead of
//   throwing bad_function_call. bad_function_call is still defined as a type
//   (derived from std::exception, with what()).
//
// reference_wrapper INVOKE bullets:
//   The type_traits INVOKE machinery only had bullets 1,3,4,6,7.
//   Bullets 2 and 5 (reference_wrapper unwrapping) are added here now that
//   reference_wrapper is defined. They augment detail::invoke_impl via
//   additional overloads.
#pragma once

#include <type_traits>
#include <utility>
#include <tuple>
#include <exception>        // exception (base of bad_function_call)
#include <iterator>         // iterator_traits (searchers)
#include <new>              // placement new
