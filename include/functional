inline bool fn_is_null(Fp* p) noexcept { return !p; }
template<class Ret, class Class>
inline bool fn_is_null(Ret Class::* p) noexcept { return !p; }
template<class Fp>
inline bool fn_is_null(const function<Fp>& f) noexcept { return !f; }

// Abstract base for type-erased callable
template<class Fp>
class fn_base;

template<class Rp, class... ArgTypes>
class fn_base<Rp(ArgTypes...)> {
public:
    fn_base(const fn_base&)            = delete;
    fn_base& operator=(const fn_base&) = delete;
    fn_base() noexcept {}
    virtual ~fn_base() noexcept {}
    virtual fn_base* clone() const = 0;
    virtual void clone(fn_base*) const = 0;
    virtual void destroy() noexcept = 0;
    virtual void destroy_deallocate() noexcept = 0;
    virtual Rp operator()(ArgTypes&&...) = 0;
    // target() / target_type() OMITTED: require typeid (RTTI, -fno-rtti).
};

// Concrete implementation for a specific functor
template<class FD, class FB>
class fn_func;

template<class Fp, class Rp, class... ArgTypes>
class fn_func<Fp, Rp(ArgTypes...)> : public fn_base<Rp(ArgTypes...)> {
    Fp func_;

public:
    explicit fn_func(Fp&& f) : func_(move(f)) {}
    explicit fn_func(const Fp& f) : func_(f) {}

    fn_base<Rp(ArgTypes...)>* clone() const override {
        return new fn_func(func_);
    }
    void clone(fn_base<Rp(ArgTypes...)>* p) const override {
        ::new (static_cast<void*>(p)) fn_func(func_);
    }
    void destroy() noexcept override { func_.~Fp(); }
    void destroy_deallocate() noexcept override { delete this; }
    Rp operator()(ArgTypes&&... args) override {
        return invoke_r<Rp>(func_, forward<ArgTypes>(args)...);
    }
};

// value_func: owns the type-erased functor via small-buffer optimisation
template<class Fp>
class value_func;

template<class Rp, class... ArgTypes>
class value_func<Rp(ArgTypes...)> {
    // Small buffer: 3 pointers (matches libc++ default)
    alignas(alignof(void*)) char buf_[3 * sizeof(void*)];
    using base_t = fn_base<Rp(ArgTypes...)>;
    base_t* f_;

    static base_t* as_base(void* p) noexcept {
        return reinterpret_cast<base_t*>(p);
    }

public:
    value_func() noexcept : f_(nullptr) {}

    template<class Fp>
        requires (!is_same_v<decay_t<Fp>, value_func>)
    explicit value_func(Fp&& f) : f_(nullptr) {
        using Fun = fn_func<decay_t<Fp>, Rp(ArgTypes...)>;
        if (fn_is_null(f)) return;
        if (sizeof(Fun) <= sizeof(buf_) &&
            is_nothrow_copy_constructible_v<decay_t<Fp>>)
        {
            f_ = ::new (static_cast<void*>(buf_)) Fun(move(f));
        } else {
            f_ = new Fun(move(f));
        }
    }

    value_func(const value_func& other) {
        if (other.f_ == nullptr) {
            f_ = nullptr;
        } else if (reinterpret_cast<const void*>(other.f_) == other.buf_) {
            f_ = as_base(buf_);
            other.f_->clone(f_);
        } else {
            f_ = other.f_->clone();
        }
    }

    value_func(value_func&& other) noexcept {
        if (other.f_ == nullptr) {
            f_ = nullptr;
        } else if (reinterpret_cast<void*>(other.f_) == other.buf_) {
            f_ = as_base(buf_);
            other.f_->clone(f_);
        } else {
            f_ = other.f_;
            other.f_ = nullptr;
        }
    }

    ~value_func() {
        if (reinterpret_cast<void*>(f_) == buf_)
            f_->destroy();
        else if (f_)
            f_->destroy_deallocate();
    }

    value_func& operator=(value_func&& other) {
        *this = nullptr;
        if (other.f_ == nullptr) {
            f_ = nullptr;
        } else if (reinterpret_cast<void*>(other.f_) == other.buf_) {
            f_ = as_base(buf_);
            other.f_->clone(f_);
        } else {
            f_ = other.f_;
            other.f_ = nullptr;
        }
        return *this;
    }

    value_func& operator=(nullptr_t) noexcept {
        base_t* tmp = f_;
        f_ = nullptr;
        if (reinterpret_cast<void*>(tmp) == buf_)
            tmp->destroy();
        else if (tmp)
            tmp->destroy_deallocate();
        return *this;
    }

    Rp operator()(ArgTypes&&... args) const {
        if (f_ == nullptr)
            __builtin_trap(); // empty function call: __builtin_trap instead of throw
        return (*f_)(forward<ArgTypes>(args)...);
    }

    void swap(value_func& other) noexcept {
        if (addressof(other) == this) return;
        bool this_inline = (reinterpret_cast<void*>(f_) == buf_);
        bool other_inline = (reinterpret_cast<void*>(other.f_) == other.buf_);

        if (this_inline && other_inline) {
            // Both inline: temp-clone one, move/clone the other
            alignas(alignof(void*)) char tmp[3 * sizeof(void*)];
            base_t* t = as_base(tmp);
            f_->clone(t);
            f_->destroy(); f_ = nullptr;
            other.f_->clone(as_base(buf_));
            other.f_->destroy(); other.f_ = nullptr;
            f_ = as_base(buf_);
            t->clone(as_base(other.buf_));
            t->destroy();
            other.f_ = as_base(other.buf_);
        } else if (this_inline) {
            f_->clone(as_base(other.buf_));
            f_->destroy();
            f_ = other.f_;
            other.f_ = as_base(other.buf_);
        } else if (other_inline) {
            other.f_->clone(as_base(buf_));
            other.f_->destroy();
            other.f_ = f_;
            f_ = as_base(buf_);
        } else {
            base_t* tmp2 = f_; f_ = other.f_; other.f_ = tmp2;
        }
    }

    explicit operator bool() const noexcept { return f_ != nullptr; }
};

} // namespace detail

// function<R(Args...)>
template<class Rp, class... ArgTypes>
class function<Rp(ArgTypes...)> {
    using impl_t = detail::value_func<Rp(ArgTypes...)>;
    impl_t f_;

    template<class Fp>
    using enable_if_callable = enable_if_t<
        !is_same_v<remove_cvref_t<Fp>, function> &&
        is_invocable_r_v<Rp, Fp&, ArgTypes...>>;

public:
    using result_type = Rp;

    // Constructors
    function() noexcept {}
    function(nullptr_t) noexcept {}
    function(const function& other) : f_(other.f_) {}
    function(function&& other) noexcept : f_(move(other.f_)) {}

    template<class Fp, class = enable_if_callable<Fp>>
    function(Fp f) : f_(move(f)) {}

    // Assignment
    function& operator=(const function& other) {
        function(other).swap(*this);
        return *this;
    }
    function& operator=(function&& other) noexcept {
        f_ = move(other.f_);
        return *this;
    }
    function& operator=(nullptr_t) noexcept {
        f_ = nullptr;
        return *this;
    }
    template<class Fp, class = enable_if_callable<decay_t<Fp>>>
    function& operator=(Fp&& f) {
        function(forward<Fp>(f)).swap(*this);
        return *this;
    }

    ~function() {}

    // Modifiers
    void swap(function& other) noexcept { f_.swap(other.f_); }

    // Capacity
    explicit operator bool() const noexcept { return static_cast<bool>(f_); }

    // Deleted comparisons
    template<class R2, class... A2>
    bool operator==(const function<R2(A2...)>&) const = delete;

    // Invocation
    Rp operator()(ArgTypes... args) const {
        return f_(forward<ArgTypes>(args)...);
    }

    // target() and target_type() are OMITTED:
    // They require typeid() which needs RTTI (-fno-rtti is our target).
    // Callers should use template specialisation or tag-dispatch instead.
};

// Deduction guides (C++17)
template<class Rp, class... Ap>
function(Rp (*)(Ap...)) -> function<Rp(Ap...)>;

// Comparison with nullptr
template<class Rp, class... ArgTypes>
inline bool operator==(const function<Rp(ArgTypes...)>& f, nullptr_t) noexcept {
    return !f;
}

// swap specialisation
template<class Rp, class... ArgTypes>
inline void swap(function<Rp(ArgTypes...)>& x, function<Rp(ArgTypes...)>& y) noexcept {
    return x.swap(y);
}

