namespace std {

//===----------------------------------------------------------------------===//
// Searchers: default_searcher, boyer_moore_searcher,
//            boyer_moore_horspool_searcher
// NOTE: <iterator> is included here (mid-file) and not at the top:
// <iterator> -> <variant> -> <functional> needs std::hash to already be
// defined when the includer is <functional> itself.
// (from libc++ __functional/default_searcher.h, boyer_moore_searcher.h)
//
// Adaptation notes (containers):
//   libc++ stores the BM tables in shared_ptr / unordered_map / vector.
//   <functional> here cannot include <memory> or <unordered_map> (both include
//   <functional> back), so the tables live in small internal helpers in
//   std::detail (deep-copying dynamic arrays).  Behaviour matches: the
//   searchers remain copyable and the skip table keeps last-insert-wins
//   semantics like unordered_map operator[].
//===----------------------------------------------------------------------===//

// default_searcher
template<class ForwardIterator, class BinaryPredicate = equal_to<>>
class default_searcher {
public:
    constexpr default_searcher(ForwardIterator f, ForwardIterator l,
                               BinaryPredicate p = BinaryPredicate())
        : first_(f), last_(l), pred_(p) {}

    template<class ForwardIterator2>
    constexpr pair<ForwardIterator2, ForwardIterator2>
    operator()(ForwardIterator2 f, ForwardIterator2 l) const {
        // Inline forward search (libc++ delegates to std::__search_impl;
        // <algorithm> includes <functional>, so the loop is replicated here).
        while (true) {
            ForwardIterator2 it = f;
            ForwardIterator pit = first_;
            while (true) {
                if (pit == last_)
                    return pair<ForwardIterator2, ForwardIterator2>(f, it);
                if (it == l)
                    return pair<ForwardIterator2, ForwardIterator2>(l, l);
                if (!pred_(*it, *pit))
                    break;
                ++it;
                ++pit;
            }
            ++f;
        }
    }

private:
    ForwardIterator first_;
    ForwardIterator last_;
    BinaryPredicate pred_;
};

namespace detail {

// Deep-copying dynamic array (internal helper for the BM searchers).
template<class T>
class bm_dynarray {
    T* data_ = nullptr;
    size_t size_ = 0;

public:
    bm_dynarray() = default;
    explicit bm_dynarray(size_t n) : data_(n ? new T[n]() : nullptr), size_(n) {}
    bm_dynarray(const bm_dynarray& other)
        : data_(other.size_ ? new T[other.size_]() : nullptr), size_(other.size_) {
        for (size_t i = 0; i < size_; ++i)
            data_[i] = other.data_[i];
    }
    bm_dynarray(bm_dynarray&& other) noexcept : data_(other.data_), size_(other.size_) {
        other.data_ = nullptr;
        other.size_ = 0;
    }
    bm_dynarray& operator=(bm_dynarray other) noexcept {
        T* td = data_; data_ = other.data_; other.data_ = td;
        size_t ts = size_; size_ = other.size_; other.size_ = ts;
        return *this;
    }
    ~bm_dynarray() { delete[] data_; }

    T& operator[](size_t i) noexcept { return data_[i]; }
    const T& operator[](size_t i) const noexcept { return data_[i]; }
    size_t size() const noexcept { return size_; }
};

// Skip table.  General case: association list with last-insert-wins
// (replaces libc++'s unordered_map-based _BMSkipTable).
template<class Key, class Value, class Hash, class BinaryPredicate, bool UseArray>
class bm_skip_table {
    Value default_value_;
    BinaryPredicate pred_;
    bm_dynarray<Key> keys_;
    bm_dynarray<Value> values_;
    size_t count_ = 0;

public:
    explicit bm_skip_table(size_t sz, Value default_value, Hash, BinaryPredicate pred)
        : default_value_(default_value), pred_(pred), keys_(sz), values_(sz) {}

    void insert(const Key& key, Value val) {
        for (size_t i = 0; i < count_; ++i) {
            if (pred_(keys_[i], key)) {
                values_[i] = val;
                return;
            }
        }
        keys_[count_] = key;
        values_[count_] = val;
        ++count_;
    }

    Value operator[](const Key& key) const {
        for (size_t i = 0; i < count_; ++i)
            if (pred_(keys_[i], key))
                return values_[i];
        return default_value_;
    }
};

// Special case for small numeric keys: direct-indexed 256-entry table
// (mirrors libc++'s array-based _BMSkipTable specialisation).
template<class Key, class Value, class Hash, class BinaryPredicate>
class bm_skip_table<Key, Value, Hash, BinaryPredicate, true> {
    using unsigned_key_type = make_unsigned_t<Key>;
    bm_dynarray<Value> table_;
    static_assert(sizeof(Key) == 1);

public:
    explicit bm_skip_table(size_t, Value default_value, Hash, BinaryPredicate)
        : table_(256) {
        for (size_t i = 0; i < 256; ++i)
            table_[i] = default_value;
    }

    void insert(Key key, Value val) {
        table_[static_cast<unsigned_key_type>(key)] = val;
    }

    Value operator[](Key key) const {
        return table_[static_cast<unsigned_key_type>(key)];
    }
};

} // namespace detail

// boyer_moore_searcher
template<class RandomAccessIterator1,
         class Hash = hash<typename iterator_traits<RandomAccessIterator1>::value_type>,
         class BinaryPredicate = equal_to<>>
class boyer_moore_searcher {
private:
    using difference_type = typename iterator_traits<RandomAccessIterator1>::difference_type;
    using value_type      = typename iterator_traits<RandomAccessIterator1>::value_type;
    using skip_table_type =
        detail::bm_skip_table<value_type, difference_type, Hash, BinaryPredicate,
                              is_integral_v<value_type> && sizeof(value_type) == 1 &&
                                  is_same_v<Hash, hash<value_type>> &&
                                  is_same_v<BinaryPredicate, equal_to<>>>;

public:
    boyer_moore_searcher(RandomAccessIterator1 first,
                         RandomAccessIterator1 last,
                         Hash hash = Hash(),
                         BinaryPredicate pred = BinaryPredicate())
        : first_(first),
          last_(last),
          pred_(pred),
          pattern_length_(last - first),
          skip_table_(static_cast<size_t>(pattern_length_), -1, hash, pred_),
          suffix_(static_cast<size_t>(pattern_length_) + 1) {
        difference_type i = 0;
        while (first != last) {
            skip_table_.insert(*first, i);
            ++first;
            ++i;
        }
        build_suffix_table(first_, last_, pred_);
    }

    template<class RandomAccessIterator2>
    pair<RandomAccessIterator2, RandomAccessIterator2>
    operator()(RandomAccessIterator2 first, RandomAccessIterator2 last) const {
        static_assert(
            is_same_v<remove_cvref_t<typename iterator_traits<RandomAccessIterator1>::value_type>,
                      remove_cvref_t<typename iterator_traits<RandomAccessIterator2>::value_type>>,
            "Corpus and Pattern iterators must point to the same type");
        if (first == last)
            return make_pair(last, last);
        if (first_ == last_)
            return make_pair(first, first);
        if (pattern_length_ > (last - first))
            return make_pair(last, last);
        return search(first, last);
    }

private:
    RandomAccessIterator1 first_;
    RandomAccessIterator1 last_;
    BinaryPredicate pred_;
    difference_type pattern_length_;
    skip_table_type skip_table_;
    detail::bm_dynarray<difference_type> suffix_;

    template<class RandomAccessIterator2>
    pair<RandomAccessIterator2, RandomAccessIterator2>
    search(RandomAccessIterator2 f, RandomAccessIterator2 l) const {
        RandomAccessIterator2 current    = f;
        const RandomAccessIterator2 last = l - pattern_length_;

        while (current <= last) {
            difference_type j = pattern_length_;
            while (pred_(first_[j - 1], current[j - 1])) {
                --j;
                if (j == 0)
                    return make_pair(current, current + pattern_length_);
            }

            difference_type k = skip_table_[current[j - 1]];
            difference_type m = j - k - 1;
            if (k < j && m > suffix_[static_cast<size_t>(j)])
                current += m;
            else
                current += suffix_[static_cast<size_t>(j)];
        }
        return make_pair(l, l);
    }

    void compute_bm_prefix(RandomAccessIterator1 first, bool reversed, size_t count,
                           BinaryPredicate pred,
                           detail::bm_dynarray<difference_type>& prefix) {
        // libc++ runs this once forward and once over reverse_iterators;
        // "reversed" indexes from the back instead.
        auto at = [&](size_t i) -> decltype(auto) {
            return reversed ? first[static_cast<difference_type>(count - 1 - i)]
                            : first[static_cast<difference_type>(i)];
        };
        prefix[0] = 0;
        size_t k = 0;

        for (size_t i = 1; i != count; ++i) {
            while (k > 0 && !pred(at(k), at(i)))
                k = static_cast<size_t>(prefix[k - 1]);

            if (pred(at(k), at(i)))
                ++k;
            prefix[i] = static_cast<difference_type>(k);
        }
    }

    void build_suffix_table(RandomAccessIterator1 first, RandomAccessIterator1 last,
                            BinaryPredicate pred) {
        const size_t count = static_cast<size_t>(last - first);

        if (count == 0)
            return;

        detail::bm_dynarray<difference_type> scratch(count);

        compute_bm_prefix(first, false, count, pred, scratch);
        for (size_t i = 0; i <= count; ++i)
            suffix_[i] = static_cast<difference_type>(count) - scratch[count - 1];

        compute_bm_prefix(first, true, count, pred, scratch);

        for (size_t i = 0; i != count; ++i) {
            const size_t j = count - static_cast<size_t>(scratch[i]);
            const difference_type k =
                static_cast<difference_type>(i) - scratch[i] + 1;

            if (suffix_[j] > k)
                suffix_[j] = k;
        }
    }
};

// boyer_moore_horspool_searcher
template<class RandomAccessIterator1,
         class Hash = hash<typename iterator_traits<RandomAccessIterator1>::value_type>,
         class BinaryPredicate = equal_to<>>
class boyer_moore_horspool_searcher {
private:
    using difference_type = typename iterator_traits<RandomAccessIterator1>::difference_type;
    using value_type      = typename iterator_traits<RandomAccessIterator1>::value_type;
    using skip_table_type =
        detail::bm_skip_table<value_type, difference_type, Hash, BinaryPredicate,
                              is_integral_v<value_type> && sizeof(value_type) == 1 &&
                                  is_same_v<Hash, hash<value_type>> &&
                                  is_same_v<BinaryPredicate, equal_to<>>>;

public:
    boyer_moore_horspool_searcher(RandomAccessIterator1 first,
                                  RandomAccessIterator1 last,
                                  Hash hash = Hash(),
                                  BinaryPredicate pred = BinaryPredicate())
        : first_(first),
          last_(last),
          pred_(pred),
          pattern_length_(last - first),
          skip_table_(static_cast<size_t>(pattern_length_), pattern_length_, hash, pred_) {
        if (first == last)
            return;
        --last;
        difference_type i = 0;
        while (first != last) {
            skip_table_.insert(*first, pattern_length_ - 1 - i);
            ++first;
            ++i;
        }
    }

    template<class RandomAccessIterator2>
    pair<RandomAccessIterator2, RandomAccessIterator2>
    operator()(RandomAccessIterator2 first, RandomAccessIterator2 last) const {
        static_assert(
            is_same_v<remove_cvref_t<typename iterator_traits<RandomAccessIterator1>::value_type>,
                      remove_cvref_t<typename iterator_traits<RandomAccessIterator2>::value_type>>,
            "Corpus and Pattern iterators must point to the same type");
        if (first == last)
            return make_pair(last, last);
        if (first_ == last_)
            return make_pair(first, first);
        if (pattern_length_ > (last - first))
            return make_pair(last, last);
        return search(first, last);
    }

private:
    RandomAccessIterator1 first_;
    RandomAccessIterator1 last_;
    BinaryPredicate pred_;
    difference_type pattern_length_;
    skip_table_type skip_table_;

    template<class RandomAccessIterator2>
    pair<RandomAccessIterator2, RandomAccessIterator2>
    search(RandomAccessIterator2 f, RandomAccessIterator2 l) const {
        RandomAccessIterator2 current    = f;
        const RandomAccessIterator2 last = l - pattern_length_;

        while (current <= last) {
            difference_type j = pattern_length_;
            while (pred_(first_[j - 1], current[j - 1])) {
                --j;
                if (j == 0)
                    return make_pair(current, current + pattern_length_);
            }
            current += skip_table_[current[pattern_length_ - 1]];
        }
        return make_pair(l, l);
    }
};

