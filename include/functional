// value_func: owns the type-erased functor via small-buffer optimisation
template<class Fp>
class value_func;

template<class Rp, class... ArgTypes>
class value_func<Rp(ArgTypes...)> {
    // Small buffer: 3 pointers (matches libc++ default)
    alignas(alignof(void*)) char buf_[3 * sizeof(void*)];
    using base_t = fn_base<Rp(ArgTypes...)>;
    base_t* f_;

    static base_t* as_base(void* p) noexcept {
        return reinterpret_cast<base_t*>(p);
    }

public:
    value_func() noexcept : f_(nullptr) {}

    template<class Fp>
        requires (!is_same_v<decay_t<Fp>, value_func>)
    explicit value_func(Fp&& f) : f_(nullptr) {
        using Fun = fn_func<decay_t<Fp>, Rp(ArgTypes...)>;
        if (detail::fn_is_null(f)) return;
        if (sizeof(Fun) <= sizeof(buf_) &&
            is_nothrow_copy_constructible_v<decay_t<Fp>>)
        {
            f_ = ::new (static_cast<void*>(buf_)) Fun(std::move(f));
        } else {
            f_ = new Fun(std::move(f));
        }
    }

    value_func(const value_func& other) {
        if (other.f_ == nullptr) {
            f_ = nullptr;
        } else if (reinterpret_cast<const void*>(other.f_) == other.buf_) {
            f_ = as_base(buf_);
            other.f_->clone(f_);
        } else {
            f_ = other.f_->clone();
        }
    }

    value_func(value_func&& other) noexcept {
        if (other.f_ == nullptr) {
            f_ = nullptr;
        } else if (reinterpret_cast<void*>(other.f_) == other.buf_) {
            f_ = as_base(buf_);
            other.f_->clone(f_);
        } else {
            f_ = other.f_;
            other.f_ = nullptr;
        }
    }

    ~value_func() {
        if (reinterpret_cast<void*>(f_) == buf_)
            f_->destroy();
        else if (f_)
            f_->destroy_deallocate();
    }

    value_func& operator=(value_func&& other) {
        *this = nullptr;
        if (other.f_ == nullptr) {
            f_ = nullptr;
        } else if (reinterpret_cast<void*>(other.f_) == other.buf_) {
            f_ = as_base(buf_);
            other.f_->clone(f_);
        } else {
            f_ = other.f_;
            other.f_ = nullptr;
        }
        return *this;
    }

    value_func& operator=(nullptr_t) noexcept {
        base_t* tmp = f_;
        f_ = nullptr;
        if (reinterpret_cast<void*>(tmp) == buf_)
            tmp->destroy();
        else if (tmp)
            tmp->destroy_deallocate();
        return *this;
    }

    Rp operator()(ArgTypes&&... args) const {
        if (f_ == nullptr)
            __builtin_trap(); // empty function call: __builtin_trap instead of throw
        return (*f_)(std::forward<ArgTypes>(args)...);
    }

    void swap(value_func& other) noexcept {
        if (std::addressof(other) == this) return;
        bool this_inline = (reinterpret_cast<void*>(f_) == buf_);
        bool other_inline = (reinterpret_cast<void*>(other.f_) == other.buf_);

        if (this_inline && other_inline) {
            // Both inline: temp-clone one, move/clone the other
            alignas(alignof(void*)) char tmp[3 * sizeof(void*)];
            base_t* t = as_base(tmp);
            f_->clone(t);
            f_->destroy(); f_ = nullptr;
            other.f_->clone(as_base(buf_));
            other.f_->destroy(); other.f_ = nullptr;
            f_ = as_base(buf_);
            t->clone(as_base(other.buf_));
            t->destroy();
            other.f_ = as_base(other.buf_);
        } else if (this_inline) {
            f_->clone(as_base(other.buf_));
            f_->destroy();
            f_ = other.f_;
            other.f_ = as_base(other.buf_);
        } else if (other_inline) {
            other.f_->clone(as_base(buf_));
            other.f_->destroy();
            other.f_ = f_;
            f_ = as_base(buf_);
        } else {
            base_t* tmp2 = f_; f_ = other.f_; other.f_ = tmp2;
        }
    }

    explicit operator bool() const noexcept { return f_ != nullptr; }
};

