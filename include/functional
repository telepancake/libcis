// Forward declaration
template<class Fp>
class function;

namespace detail {

// null detection helpers for function wrappers
template<class Fp>
inline bool fn_is_null(const Fp&) noexcept { return false; }
template<class Fp>
inline bool fn_is_null(Fp* p) noexcept { return !p; }
template<class Ret, class Class>
inline bool fn_is_null(Ret Class::* p) noexcept { return !p; }
template<class Fp>
inline bool fn_is_null(const function<Fp>& f) noexcept { return !f; }

// value_func: owns the type-erased functor via small-buffer optimisation,
// with the per-F lifecycle / invoke dispatched through a const callable_ops*
// (stage 3 of notes/cores-design.md §3.4).
//
// Layout: 3-pointer inline buffer + one ops pointer + nothing else.
//   empty: ops_ == nullptr.
//   small: ops_ != nullptr, ops_->flags & f_is_small,
//          held object lives at &buf_[0].
//   large: ops_ != nullptr, !(ops_->flags & f_is_small),
//          held object lives on the heap, pointer cached in *(void**)&buf_[0].
//
// Lifecycle (construct/destroy/copy/move) routes through three typeless
// support.cpp helpers (func_copy_into / func_move_into / func_destroy_held)
// off the callable_ops_base prefix of ops_. Invoke and the swap-via-temporary
// stay per-signature here; both inline small at -Os.
template<class Fp>
class value_func;

template<class Rp, class... ArgTypes>
class value_func<Rp(ArgTypes...)> {
    using ops_t = detail::callable_ops<Rp(ArgTypes...)>;

    // 3-pointer inline buffer, void*-aligned. Bit-exactly the SBO shape the
    // value_ops.h `cb_small_buffer_*` constants describe; static_assert pins
    // it.
    alignas(alignof(void*)) char buf_[detail::cb_small_buffer_size];
    const ops_t* ops_;

    // Reinterpret-cast to the sig-independent prefix so we can call into the
    // typeless lifecycle cores in src/support.cpp. The struct layout is
    // static_asserted in bits/value_ops.h.
    const detail::callable_ops_base* base_ops() const noexcept {
        return reinterpret_cast<const detail::callable_ops_base*>(ops_);
    }

public:
    value_func() noexcept : ops_(nullptr) {}

    template<class Fp>
        requires (!is_same_v<decay_t<Fp>, value_func>)
    explicit value_func(Fp&& f) : ops_(nullptr) {
        using F = decay_t<Fp>;
        if (detail::fn_is_null(f)) return;
        constexpr const ops_t* table = &detail::callable_ops_for<F, Rp(ArgTypes...)>;
        if constexpr (detail::callable_is_small<F>) {
            ::new (static_cast<void*>(buf_)) F(std::forward<Fp>(f));
        } else {
            // Heap-allocate. align_val_t overload only when alignment exceeds
            // the platform default — std::function's typical F is void*-aligned.
            void* p;
            if constexpr (alignof(F) > __STDCPP_DEFAULT_NEW_ALIGNMENT__) {
                p = ::operator new(sizeof(F), std::align_val_t{alignof(F)});
            } else {
                p = ::operator new(sizeof(F));
            }
            ::new (p) F(std::forward<Fp>(f));
            *reinterpret_cast<void**>(buf_) = p;
        }
        ops_ = table;
    }

    value_func(const value_func& other) : ops_(nullptr) {
        if (other.ops_ != nullptr) {
            detail::func_copy_into(other.base_ops(), buf_, other.buf_);
            ops_ = other.ops_;
        }
    }

    value_func(value_func&& other) noexcept : ops_(nullptr) {
        if (other.ops_ != nullptr) {
            detail::func_move_into(other.base_ops(), buf_, other.buf_);
            ops_ = other.ops_;
            // For the inline case the source still holds a constructed
            // object: destroy + clear it. For the heap case func_move_into
            // already zeroed the source's heap-pointer slot, so the
            // func_destroy_held below is a no-op release.
            if (other.ops_->flags & detail::vo_f_is_small) {
                detail::func_destroy_held(other.base_ops(), other.buf_);
            }
            other.ops_ = nullptr;
        }
    }

    ~value_func() {
        if (ops_) detail::func_destroy_held(base_ops(), buf_);
    }

    value_func& operator=(value_func&& other) {
        *this = nullptr;
        if (other.ops_ != nullptr) {
            detail::func_move_into(other.base_ops(), buf_, other.buf_);
            ops_ = other.ops_;
            if (other.ops_->flags & detail::vo_f_is_small) {
                detail::func_destroy_held(other.base_ops(), other.buf_);
            }
            other.ops_ = nullptr;
        }
        return *this;
    }

    value_func& operator=(nullptr_t) noexcept {
        if (ops_) {
            detail::func_destroy_held(base_ops(), buf_);
            ops_ = nullptr;
        }
        return *this;
    }

    Rp operator()(ArgTypes&&... args) const {
        if (ops_ == nullptr)
            __builtin_trap(); // empty function call: __builtin_trap instead of throw
        // Inline case: held object is in buf_. Heap case: deref the pointer
        // stashed at buf_'s first slot.
        void* obj = (ops_->flags & detail::vo_f_is_small)
                    ? static_cast<void*>(const_cast<char*>(buf_))
                    : *reinterpret_cast<void* const*>(buf_);
        return ops_->invoke(obj, std::forward<ArgTypes>(args)...);
    }

    void swap(value_func& other) noexcept {
        if (std::addressof(other) == this) return;
        // swap-via-temporary: three move-constructions. Per-signature, but
        // small enough to inline at -Os. The temporary's destructor handles
        // any cleanup if a move leaves a moved-from-but-still-constructed
        // inline source (the move ctor above already destroys those).
        value_func tmp(std::move(*this));
        *this = std::move(other);
        other = std::move(tmp);
    }

    explicit operator bool() const noexcept { return ops_ != nullptr; }
};

} // namespace detail

// function<R(Args...)>
template<class Rp, class... ArgTypes>
class function<Rp(ArgTypes...)> {
    using impl_t = detail::value_func<Rp(ArgTypes...)>;
    impl_t f_;

    template<class Fp>
    using enable_if_callable = enable_if_t<
        !is_same_v<remove_cvref_t<Fp>, function> &&
        is_invocable_r_v<Rp, Fp&, ArgTypes...>>;

public:
    using result_type = Rp;

    // Constructors
    function() noexcept {}
    function(nullptr_t) noexcept {}
    function(const function& other) : f_(other.f_) {}
    function(function&& other) noexcept : f_(std::move(other.f_)) {}

    template<class Fp, class = enable_if_callable<Fp>>
    function(Fp f) : f_(std::move(f)) {}

    // Assignment
    function& operator=(const function& other) {
        function(other).swap(*this);
        return *this;
    }
    function& operator=(function&& other) noexcept {
        f_ = std::move(other.f_);
        return *this;
    }
    function& operator=(nullptr_t) noexcept {
        f_ = nullptr;
        return *this;
    }
    template<class Fp, class = enable_if_callable<decay_t<Fp>>>
    function& operator=(Fp&& f) {
        function(std::forward<Fp>(f)).swap(*this);
        return *this;
    }

    ~function() {}

    // Modifiers
    void swap(function& other) noexcept { f_.swap(other.f_); }

    // Capacity
    explicit operator bool() const noexcept { return static_cast<bool>(f_); }

    // Deleted comparisons
    template<class R2, class... A2>
    bool operator==(const function<R2(A2...)>&) const = delete;

    // Invocation
    Rp operator()(ArgTypes... args) const {
        return f_(std::forward<ArgTypes>(args)...);
    }

    // target() and target_type() are OMITTED:
    // They require typeid() which needs RTTI (-fno-rtti is our target).
    // Callers should use template specialisation or tag-dispatch instead.
};

