namespace detail {

template<class Arg, class Result>
struct unary_function_base {
    using argument_type = Arg;
    using result_type   = Result;
};

template<class Arg1, class Arg2, class Result>
struct binary_function_base {
    using first_argument_type  = Arg1;
    using second_argument_type = Arg2;
    using result_type          = Result;
};

} // namespace detail

template<class T = void>
struct plus : detail::binary_function_base<T, T, T> {
    constexpr T operator()(const T& x, const T& y) const { return x + y; }
};
template<>
struct plus<void> {
    template<class T1, class T2>
    constexpr auto operator()(T1&& t, T2&& u) const
        noexcept(noexcept(std::forward<T1>(t) + std::forward<T2>(u)))
        -> decltype(std::forward<T1>(t) + std::forward<T2>(u))
    { return std::forward<T1>(t) + std::forward<T2>(u); }
    using is_transparent = void;
};

