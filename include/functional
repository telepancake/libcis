// Folded sources:
//   __functional/reference_wrapper.h   -> reference_wrapper, ref, cref
//   __functional/invoke.h              -> invoke, invoke_r
//   __functional/mem_fn.h              -> mem_fn
//   __functional/operations.h          -> arithmetic/comparison/logical/bitwise functors
//   __functional/hash.h                -> hash, scalar_hash, murmur2_or_cityhash
//   __functional/not_fn.h              -> not_fn
//   __functional/bind_front.h          -> bind_front
//   __functional/bind_back.h           -> bind_back
//   __functional/bind.h                -> bind, is_bind_expression, is_placeholder, placeholders
//   __functional/function.h            -> function<R(Args...)>
//   __functional/perfect_forward.h     -> detail::perfect_forward_impl (internal)
//
// OMITTED (noted):
//   default_searcher, boyer_moore_searcher, boyer_moore_horspool_searcher
//     — heavy optional components; omitted per task spec.
//   function::target() / function::target_type()
//     — require typeid (RTTI); omitted under -fno-rtti (noted in comment below).
//
// Empty-function call behaviour (no exceptions):
//   Calling an empty std::function uses __builtin_trap() instead of
//   throwing bad_function_call. bad_function_call is still defined as a type.
