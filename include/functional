template<class Rp, class... Ap>
function(Rp (*)(Ap...)) -> function<Rp(Ap...)>;

template<class Fp,
         class Stripped = typename detail::strip_signature<decltype(&Fp::operator())>::type>
function(Fp) -> function<Stripped>;

// Comparison with nullptr
template<class Rp, class... ArgTypes>
inline bool operator==(const function<Rp(ArgTypes...)>& f, nullptr_t) noexcept {
    return !f;
}

// swap specialisation
template<class Rp, class... ArgTypes>
inline void swap(function<Rp(ArgTypes...)>& x, function<Rp(ArgTypes...)>& y) noexcept {
    return x.swap(y);
}


//===----------------------------------------------------------------------===//
// Negators: unary_negate / binary_negate, not1 / not2
// (from libc++ __functional/unary_negate.h, binary_negate.h)
// C++17-deprecated / C++20-removed, but the suite runs with libc++'s
// _LIBCPP_ENABLE_CXX20_REMOVED_NEGATORS semantics, so they are provided.
//===----------------------------------------------------------------------===//

template<class Predicate>
class unary_negate
    : public detail::unary_function_base<typename Predicate::argument_type, bool> {
    Predicate pred_;

public:
    constexpr explicit unary_negate(const Predicate& pred) : pred_(pred) {}

    constexpr bool operator()(const typename Predicate::argument_type& x) const {
        return !pred_(x);
    }
};

template<class Predicate>
inline constexpr unary_negate<Predicate> not1(const Predicate& pred) {
    return unary_negate<Predicate>(pred);
}

template<class Predicate>
class binary_negate
    : public detail::binary_function_base<typename Predicate::first_argument_type,
                                          typename Predicate::second_argument_type,
                                          bool> {
    Predicate pred_;

public:
    constexpr explicit binary_negate(const Predicate& pred) : pred_(pred) {}

    constexpr bool operator()(const typename Predicate::first_argument_type& x,
                              const typename Predicate::second_argument_type& y) const {
        return !pred_(x, y);
    }
};

template<class Predicate>
inline constexpr binary_negate<Predicate> not2(const Predicate& pred) {
    return binary_negate<Predicate>(pred);
}

