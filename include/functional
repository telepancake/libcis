// perfect_forward_impl: stores a tuple of bound args, calls Op()(args..., call_args...)
namespace detail {

template<class Op, class Indices, class... BoundArgs>
struct perfect_forward_impl;

template<class Op, size_t... Idx, class... BoundArgs>
struct perfect_forward_impl<Op, index_sequence<Idx...>, BoundArgs...> {
private:
    tuple<BoundArgs...> bound_args_;

public:
    template<class... Args>
        requires is_constructible_v<tuple<BoundArgs...>, Args&&...>
    explicit constexpr perfect_forward_impl(Args&&... bound_args)
        : bound_args_(forward<Args>(bound_args)...) {}

    perfect_forward_impl(const perfect_forward_impl&) = default;
    perfect_forward_impl(perfect_forward_impl&&)      = default;
    perfect_forward_impl& operator=(const perfect_forward_impl&) = default;
    perfect_forward_impl& operator=(perfect_forward_impl&&)      = default;

    // &
    template<class... Args>
        requires is_invocable_v<Op, BoundArgs&..., Args...>
    constexpr auto operator()(Args&&... args) &
        noexcept(noexcept(Op()(get<Idx>(bound_args_)..., forward<Args>(args)...)))
        -> decltype(Op()(get<Idx>(bound_args_)..., forward<Args>(args)...))
    { return Op()(get<Idx>(bound_args_)..., forward<Args>(args)...); }

    template<class... Args>
        requires (!is_invocable_v<Op, BoundArgs&..., Args...>)
    void operator()(Args&&...) & = delete;

    // const &
    template<class... Args>
        requires is_invocable_v<Op, const BoundArgs&..., Args...>
    constexpr auto operator()(Args&&... args) const&
        noexcept(noexcept(Op()(get<Idx>(bound_args_)..., forward<Args>(args)...)))
        -> decltype(Op()(get<Idx>(bound_args_)..., forward<Args>(args)...))
    { return Op()(get<Idx>(bound_args_)..., forward<Args>(args)...); }

    template<class... Args>
        requires (!is_invocable_v<Op, const BoundArgs&..., Args...>)
    void operator()(Args&&...) const& = delete;

    // &&
    template<class... Args>
        requires is_invocable_v<Op, BoundArgs..., Args...>
    constexpr auto operator()(Args&&... args) &&
        noexcept(noexcept(Op()(get<Idx>(move(bound_args_))..., forward<Args>(args)...)))
        -> decltype(Op()(get<Idx>(move(bound_args_))..., forward<Args>(args)...))
    { return Op()(get<Idx>(move(bound_args_))..., forward<Args>(args)...); }

    template<class... Args>
        requires (!is_invocable_v<Op, BoundArgs..., Args...>)
    void operator()(Args&&...) && = delete;

    // const &&
    template<class... Args>
        requires is_invocable_v<Op, const BoundArgs..., Args...>
    constexpr auto operator()(Args&&... args) const&&
        noexcept(noexcept(Op()(get<Idx>(move(bound_args_))..., forward<Args>(args)...)))
        -> decltype(Op()(get<Idx>(move(bound_args_))..., forward<Args>(args)...))
    { return Op()(get<Idx>(move(bound_args_))..., forward<Args>(args)...); }

    template<class... Args>
        requires (!is_invocable_v<Op, const BoundArgs..., Args...>)
    void operator()(Args&&...) const&& = delete;
};

template<class Op, class... Args>
using perfect_forward = perfect_forward_impl<Op, index_sequence_for<Args...>, Args...>;

} // namespace detail

// not_fn_op: calls !invoke(fn, args...)
namespace detail {
struct not_fn_op {
    template<class... Args>
    constexpr auto operator()(Args&&... args) const
        noexcept(noexcept(!invoke(forward<Args>(args)...)))
        -> decltype(!invoke(forward<Args>(args)...))
    { return !invoke(forward<Args>(args)...); }
};
} // namespace detail

template<class Fn>
struct not_fn_t : detail::perfect_forward<detail::not_fn_op, Fn> {
    using detail::perfect_forward<detail::not_fn_op, Fn>::perfect_forward;
};

template<class Fn>
    requires is_constructible_v<decay_t<Fn>, Fn> && is_move_constructible_v<decay_t<Fn>>
constexpr auto not_fn(Fn&& f) {
    return not_fn_t<decay_t<Fn>>(forward<Fn>(f));
}

