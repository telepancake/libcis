#include <utility>
#include <tuple>
#include <exception>        // exception (base of bad_function_call)
#include <new>              // placement new
#include <bits/value_ops.h> // callable_ops<Sig> (function's vocab table)
#include <bits/pointer.h>   // addressof
#include <bits/identity.h>  // identity (do NOT redefine)
