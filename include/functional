// is_bind_expression
// Strips cv/ref so that const bind_impl& -> is_bind_expression<bind_impl>
template<class T>
struct is_bind_expression
    : conditional_t<is_same_v<T, remove_cvref_t<T>>,
                    false_type,
                    is_bind_expression<remove_cvref_t<T>>> {};
template<class T>
inline constexpr bool is_bind_expression_v = is_bind_expression<T>::value;

// is_placeholder: default is 0 (not a placeholder)
// Strips cv/ref so const ph<1>& -> is_placeholder<ph<1>>
template<class T>
struct is_placeholder
    : conditional_t<is_same_v<T, remove_cvref_t<T>>,
                    integral_constant<int, 0>,
                    is_placeholder<remove_cvref_t<T>>> {};
template<class T>
inline constexpr int is_placeholder_v = is_placeholder<T>::value;

namespace placeholders {

template<int N>
struct ph {};

// Placeholders as inline constexpr (no shared-library ABI dependency here)
inline constexpr ph<1>  _1{};
inline constexpr ph<2>  _2{};
inline constexpr ph<3>  _3{};
inline constexpr ph<4>  _4{};
inline constexpr ph<5>  _5{};
inline constexpr ph<6>  _6{};
inline constexpr ph<7>  _7{};
inline constexpr ph<8>  _8{};
inline constexpr ph<9>  _9{};
inline constexpr ph<10> _10{};

} // namespace placeholders

template<int N>
struct is_placeholder<placeholders::ph<N>> : integral_constant<int, N> {};

// is_ref_wrapper helper
namespace detail {
    template<class T>
    inline constexpr bool is_ref_wrapper_v = false;
    template<class T>
    inline constexpr bool is_ref_wrapper_v<reference_wrapper<T>> = true;
}

// mu: maps a bound argument to its effective value for bind invocation
// Case 1: reference_wrapper<T> -> unwrap
template<class T, class Uj>
constexpr T& mu_impl(reference_wrapper<T> t, Uj&) {
    return t.get();
}

// Case 2: bind_expression -> call it with the call args
template<class Ti, class... Uj>
    requires is_bind_expression_v<Ti>
constexpr invoke_result_t<Ti&, Uj...>
mu_impl(Ti& ti, tuple<Uj...>& uj) {
    return [&]<size_t... Indices>(index_sequence<Indices...>) -> invoke_result_t<Ti&, Uj...> {
        return ti(forward<Uj>(get<Indices>(uj))...);
    }(index_sequence_for<Uj...>{});
}

// Case 3: placeholder -> forward the call arg
template<class Ti, class Uj>
    requires (0 < is_placeholder_v<Ti>)
constexpr auto mu_impl(Ti&, Uj& uj)
    -> tuple_element_t<is_placeholder_v<Ti> - 1, Uj>&&
{
    constexpr size_t idx = is_placeholder_v<Ti> - 1;
    return forward<tuple_element_t<idx, Uj>>(get<idx>(uj));
}

// Case 4: plain value -> return lvalue ref
template<class Ti, class Uj>
    requires (!is_bind_expression_v<Ti> &&
              is_placeholder_v<Ti> == 0 &&
              !detail::is_ref_wrapper_v<Ti>)
constexpr Ti& mu_impl(Ti& ti, Uj&) {
    return ti;
}

// mu_return: deduce the return type of mu_impl
namespace detail {

    template<class Ti, class TupleUj>
    struct mu_return;

    // reference_wrapper case
    template<class T, class TupleUj>
    struct mu_return<reference_wrapper<T>, TupleUj> {
        using type = T&;
    };

    // bind_expression case
    template<class Ti, class... Uj>
        requires is_bind_expression_v<Ti>
    struct mu_return<Ti, tuple<Uj...>> {
        using type = invoke_result_t<Ti&, Uj...>;
    };

    // placeholder case
    template<class Ti, class TupleUj>
        requires (0 < is_placeholder_v<Ti>)
    struct mu_return<Ti, TupleUj> {
        using type = tuple_element_t<is_placeholder_v<Ti> - 1, TupleUj>&&;
    };

    // plain value case
    template<class Ti, class TupleUj>
        requires (!is_bind_expression_v<Ti> &&
                  is_placeholder_v<Ti> == 0 &&
                  !is_ref_wrapper_v<Ti>)
    struct mu_return<Ti, TupleUj> {
        using type = Ti&;
    };

} // namespace detail

// is_valid_bind_return and bind_return: deduce invocation return type
namespace detail {

    template<class Fp, class BoundArgs, class TupleUj>
    struct is_valid_bind_return : false_type {};

    template<class Fp, class... BoundArgs, class TupleUj>
    struct is_valid_bind_return<Fp, tuple<BoundArgs...>, TupleUj>
        : bool_constant<is_invocable_v<Fp,
              typename mu_return<BoundArgs, TupleUj>::type...>> {};

    template<class Fp, class... BoundArgs, class TupleUj>
    struct is_valid_bind_return<Fp, const tuple<BoundArgs...>, TupleUj>
        : bool_constant<is_invocable_v<Fp,
              typename mu_return<const BoundArgs, TupleUj>::type...>> {};

    template<class Fp, class BoundArgs, class TupleUj,
             bool = is_valid_bind_return<Fp, BoundArgs, TupleUj>::value>
    struct bind_return {};

    template<class Fp, class... BoundArgs, class TupleUj>
    struct bind_return<Fp, tuple<BoundArgs...>, TupleUj, true> {
        using type = invoke_result_t<Fp&,
            typename mu_return<BoundArgs, TupleUj>::type...>;
    };

    template<class Fp, class... BoundArgs, class TupleUj>
    struct bind_return<Fp, const tuple<BoundArgs...>, TupleUj, true> {
        using type = invoke_result_t<Fp&,
            typename mu_return<const BoundArgs, TupleUj>::type...>;
    };

} // namespace detail

// apply_functor: call f with bound args expanded through mu_impl
template<class Fp, class BoundArgs, size_t... Indx, class Args>
constexpr typename detail::bind_return<Fp, BoundArgs, Args>::type
apply_functor_impl(Fp& f, BoundArgs& bound_args,
                   index_sequence<Indx...>, Args&& args) {
    return detail::invoke_impl(f,
        mu_impl(get<Indx>(bound_args), args)...);
}

// bind_impl (internal class)
template<class Fp, class... BoundArgs>
class bind_impl {
protected:
    using Fd = decay_t<Fp>;
    using Td = tuple<decay_t<BoundArgs>...>;

private:
    Fd f_;
    Td bound_args_;

public:
    template<class Gp, class... BA>
        requires is_constructible_v<Fd, Gp> &&
                 (!is_same_v<remove_reference_t<Gp>, bind_impl>)
    explicit constexpr bind_impl(Gp&& f, BA&&... bound_args)
        : f_(forward<Gp>(f)), bound_args_(forward<BA>(bound_args)...) {}

    template<class... Args>
    constexpr typename detail::bind_return<Fd, Td, tuple<Args&&...>>::type
    operator()(Args&&... args) {
        return apply_functor_impl(f_, bound_args_,
            index_sequence_for<BoundArgs...>(),
            tuple<Args&&...>(forward<Args>(args)...));
    }

    template<class... Args>
    constexpr typename detail::bind_return<const Fd, const Td, tuple<Args&&...>>::type
    operator()(Args&&... args) const {
        return apply_functor_impl(f_, bound_args_,
            index_sequence_for<BoundArgs...>(),
            tuple<Args&&...>(forward<Args>(args)...));
    }
};

template<class Fp, class... BoundArgs>
struct is_bind_expression<bind_impl<Fp, BoundArgs...>> : true_type {};

// bind_r_impl: typed result bind
template<class Rp, class Fp, class... BoundArgs>
class bind_r_impl : public bind_impl<Fp, BoundArgs...> {
    using base = bind_impl<Fp, BoundArgs...>;
    using Fd   = typename base::Fd;
    using Td   = typename base::Td;

public:
    using result_type = Rp;

    template<class Gp, class... BA>
        requires is_constructible_v<Fd, Gp> &&
                 (!is_same_v<remove_reference_t<Gp>, bind_r_impl>)
    explicit constexpr bind_r_impl(Gp&& f, BA&&... bound_args)
        : base(forward<Gp>(f), forward<BA>(bound_args)...) {}

    template<class... Args>
        requires (is_convertible_v<typename detail::bind_return<Fd, Td, tuple<Args&&...>>::type, Rp>
                  || is_void_v<Rp>)
    constexpr Rp operator()(Args&&... args) {
        return invoke_r<Rp>(static_cast<base&>(*this), forward<Args>(args)...);
    }

    template<class... Args>
        requires (is_convertible_v<typename detail::bind_return<const Fd, const Td, tuple<Args&&...>>::type, Rp>
                  || is_void_v<Rp>)
    constexpr Rp operator()(Args&&... args) const {
        return invoke_r<Rp>(static_cast<const base&>(*this), forward<Args>(args)...);
    }
};

template<class Rp, class Fp, class... BoundArgs>
struct is_bind_expression<bind_r_impl<Rp, Fp, BoundArgs...>> : true_type {};

// bind (untyped)
template<class Fp, class... BoundArgs>
[[nodiscard]] constexpr bind_impl<Fp, BoundArgs...>
bind(Fp&& f, BoundArgs&&... bound_args) {
    return bind_impl<Fp, BoundArgs...>(forward<Fp>(f), forward<BoundArgs>(bound_args)...);
}

// bind (typed result)
template<class Rp, class Fp, class... BoundArgs>
[[nodiscard]] constexpr bind_r_impl<Rp, Fp, BoundArgs...>
bind(Fp&& f, BoundArgs&&... bound_args) {
    return bind_r_impl<Rp, Fp, BoundArgs...>(forward<Fp>(f), forward<BoundArgs>(bound_args)...);
}

