    requires is_constructible_v<decay_t<Fn>, Fn> &&
             is_move_constructible_v<decay_t<Fn>> &&
             (is_constructible_v<decay_t<Args>, Args> && ...) &&
             (is_move_constructible_v<decay_t<Args>> && ...)
[[nodiscard]] constexpr auto bind_front(Fn&& f, Args&&... args) {
