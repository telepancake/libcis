//===----------------------------------------------------------------------===//
// reference_wrapper<T>
// (from libc++ __functional/reference_wrapper.h)
//===----------------------------------------------------------------------===//

template<class T>
class reference_wrapper {
public:
    using type = T;

private:
    type* ptr_;

    // Helper to reject rvalue bindings (deleted overload)
    static void fun(T&) noexcept;
    static void fun(T&&) = delete;

public:
    // Constructor: accepts any U that can bind to T& (but not reference_wrapper itself)
    template<class U,
             class = void_t<decltype(fun(declval<U>()))>,
             class = enable_if_t<!is_same_v<remove_cvref_t<U>, reference_wrapper>>>
    constexpr reference_wrapper(U&& u)
        noexcept(noexcept(fun(declval<U>())))
    {
        type& ref = static_cast<U&&>(u);
        ptr_ = addressof(ref);
    }

    // Access
    constexpr operator type&() const noexcept { return *ptr_; }
    [[nodiscard]] constexpr type& get() const noexcept { return *ptr_; }

    // Invoke
    template<class... ArgTypes>
    constexpr invoke_result_t<type&, ArgTypes...>
    operator()(ArgTypes&&... args) const
        noexcept(is_nothrow_invocable_v<type&, ArgTypes...>)
    {
        // Uses the public std::invoke defined below (forward declaration OK
        // because invoke is defined after reference_wrapper in this file).
        // We call detail::invoke_impl directly to avoid circular dependency.
        return detail::invoke_impl(get(), forward<ArgTypes>(args)...);
    }
};

// Deduction guide
template<class T>
reference_wrapper(T&) -> reference_wrapper<T>;

// ref / cref
template<class T>
[[nodiscard]] constexpr reference_wrapper<T> ref(T& t) noexcept {
    return reference_wrapper<T>(t);
}
template<class T>
[[nodiscard]] constexpr reference_wrapper<T> ref(reference_wrapper<T> t) noexcept {
    return t;
}
template<class T> void ref(const T&&) = delete;

template<class T>
[[nodiscard]] constexpr reference_wrapper<const T> cref(const T& t) noexcept {
    return reference_wrapper<const T>(t);
}
template<class T>
[[nodiscard]] constexpr reference_wrapper<const T> cref(reference_wrapper<T> t) noexcept {
    return reference_wrapper<const T>(t.get());
}
template<class T> void cref(const T&&) = delete;

// basic_common_reference specialisation for reference_wrapper (C++20)
namespace detail {
    template<class Rp, class Tp, class RpQual, class TpQual>
    concept ref_wrap_common_reference_exists_with =
        requires { typename common_reference_t<typename Rp::type&, TpQual>; } &&
        is_convertible_v<RpQual, common_reference_t<typename Rp::type&, TpQual>>;
}

template<class Rp, class Tp,
         template<class> class RpQual, template<class> class TpQual>
    requires (detail::ref_wrap_common_reference_exists_with<Rp, Tp, RpQual<Rp>, TpQual<Tp>> &&
              !detail::ref_wrap_common_reference_exists_with<Tp, Rp, TpQual<Tp>, RpQual<Rp>>)
struct basic_common_reference<Rp, Tp, RpQual, TpQual> {
    using type = common_reference_t<typename Rp::type&, TpQual<Tp>>;
};

template<class Tp, class Rp,
         template<class> class TpQual, template<class> class RpQual>
    requires (detail::ref_wrap_common_reference_exists_with<Rp, Tp, RpQual<Rp>, TpQual<Tp>> &&
              !detail::ref_wrap_common_reference_exists_with<Tp, Rp, TpQual<Tp>, RpQual<Rp>>)
struct basic_common_reference<Tp, Rp, TpQual, RpQual> {
    using type = common_reference_t<typename Rp::type&, TpQual<Tp>>;
};

// NOTE: INVOKE bullets 2 and 5 (reference_wrapper unwrapping) are now handled
// directly in type_traits via the is_ref_wrapper_for_v trait, which detects any
// type with a compatible .get() method. No additional overloads needed here.

//===----------------------------------------------------------------------===//
// invoke, invoke_r
// (from libc++ __functional/invoke.h)
//===----------------------------------------------------------------------===//

template<class Fn, class... Args>
constexpr invoke_result_t<Fn, Args...>
invoke(Fn&& f, Args&&... args)
    noexcept(is_nothrow_invocable_v<Fn, Args...>)
{
    return detail::invoke_impl(forward<Fn>(f), forward<Args>(args)...);
}

// invoke_r (C++23, but included since we're targeting C++20+)
template<class Result, class Fn, class... Args>
    requires is_invocable_r_v<Result, Fn, Args...>
constexpr Result
invoke_r(Fn&& f, Args&&... args)
    noexcept(is_nothrow_invocable_r_v<Result, Fn, Args...>)
{
    if constexpr (is_void_v<Result>) {
        static_cast<void>(invoke(forward<Fn>(f), forward<Args>(args)...));
    } else {
        return invoke(forward<Fn>(f), forward<Args>(args)...);
    }
}

//===----------------------------------------------------------------------===//
// mem_fn
// (from libc++ __functional/mem_fn.h)
// Simplified: no weak_result_type inheritance (deprecated C++17 typedef).
// Just a wrapper that stores a member pointer and invokes it.
//===----------------------------------------------------------------------===//

template<class Tp>
class mem_fn_wrapper {
public:
    using type = Tp;
private:
    type f_;
public:
    constexpr mem_fn_wrapper(type f) noexcept : f_(f) {}

    template<class... ArgTypes>
    constexpr invoke_result_t<const Tp&, ArgTypes...>
    operator()(ArgTypes&&... args) const
        noexcept(is_nothrow_invocable_v<const Tp&, ArgTypes...>)
    {
        return detail::invoke_impl(f_, forward<ArgTypes>(args)...);
    }
};

template<class Rp, class Tp>
[[nodiscard]] constexpr mem_fn_wrapper<Rp Tp::*>
mem_fn(Rp Tp::* pm) noexcept {
    return mem_fn_wrapper<Rp Tp::*>(pm);
}

