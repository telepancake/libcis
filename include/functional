namespace detail {

template<size_t NBound, class = make_index_sequence<NBound>>
struct bind_back_op;

template<size_t NBound, size_t... Ip>
struct bind_back_op<NBound, index_sequence<Ip...>> {
    template<class Fn2, class BoundArgs, class... Args>
    constexpr auto operator()(Fn2&& f, BoundArgs&& bound_args, Args&&... args) const
        noexcept(noexcept(std::invoke(std::forward<Fn2>(f),
                                  std::forward<Args>(args)...,
                                  std::get<Ip>(std::forward<BoundArgs>(bound_args))...)))
        -> decltype(std::invoke(std::forward<Fn2>(f),
                            std::forward<Args>(args)...,
                            std::get<Ip>(std::forward<BoundArgs>(bound_args))...))
    {
        return std::invoke(std::forward<Fn2>(f),
                      std::forward<Args>(args)...,
                      std::get<Ip>(std::forward<BoundArgs>(bound_args))...);
    }
};

} // namespace detail

template<class Fn, class BoundArgs>
struct bind_back_t
    : detail::perfect_forward<detail::bind_back_op<tuple_size_v<BoundArgs>>, Fn, BoundArgs>
{
    using detail::perfect_forward<
        detail::bind_back_op<tuple_size_v<BoundArgs>>, Fn, BoundArgs>::perfect_forward;
};

template<class Fn, class... Args>
    requires is_constructible_v<decay_t<Fn>, Fn> &&
             is_move_constructible_v<decay_t<Fn>> &&
             (is_constructible_v<decay_t<Args>, Args> && ...) &&
             (is_move_constructible_v<decay_t<Args>> && ...)
[[nodiscard]] constexpr auto bind_back(Fn&& f, Args&&... args) {
    return bind_back_t<decay_t<Fn>, tuple<decay_t<Args>...>>(
        std::forward<Fn>(f), forward_as_tuple(std::forward<Args>(args)...));
}

