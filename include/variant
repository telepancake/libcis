// <variant> — mechanically ported from libc++ include/variant + __variant/monostate.h
// + __fwd/variant.h + __tuple/sfinae_helpers.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// __type_pack_element fallback: gcc-10.2 lacks this builtin.
// We use variant_detail::type_at<I, Ts...>, a standard recursive template.
//
// bad_variant_access: kept as a type deriving from std::exception (the type
// must exist for the ABI). All throw-paths (get on wrong index, visit on
// valueless) call __builtin_trap() under -fno-exceptions with a comment.
//
// hash: provided at the bottom of this file (requires <functional>).
#pragma once

#include <type_traits>
#include <utility>
#include <compare>
#include <concepts>
#include <exception>
#include <initializer_list>
#include <new>
#include <functional>

namespace std {

// ============================================================================
// Forward declarations
// ============================================================================

template<class... Types>
class variant;

template<class T>
struct variant_size;

template<class T>
inline constexpr size_t variant_size_v = variant_size<T>::value;

template<size_t I, class T>
struct variant_alternative;

template<size_t I, class T>
using variant_alternative_t = typename variant_alternative<I, T>::type;

inline constexpr size_t variant_npos = static_cast<size_t>(-1);

// ============================================================================
// bad_variant_access — type kept; throw replaced by __builtin_trap()
// ============================================================================

class bad_variant_access : public exception {
public:
    bad_variant_access() noexcept {}
    bad_variant_access(const bad_variant_access&) noexcept = default;
    bad_variant_access& operator=(const bad_variant_access&) noexcept = default;
    ~bad_variant_access() noexcept override {}
    [[nodiscard]] const char* what() const noexcept override {
        return "bad_variant_access";
    }
};

// ============================================================================
// Throw helper — under -fno-exceptions, calls __builtin_trap().
// ============================================================================

[[noreturn]] inline void throw_bad_variant_access() {
    // -fno-exceptions: throwing bad_variant_access is replaced by trap.
    __builtin_trap();
}

// ============================================================================
// Internal helpers
// ============================================================================

namespace variant_detail {

// --------------------------------------------------------------------------
// type_at<I, Ts...>: C++ fallback for __type_pack_element<I, Ts...>
// gcc-10.2 does not have __type_pack_element; use recursive template.
// --------------------------------------------------------------------------
template<size_t I, class... Ts>
struct type_at_impl;

template<class H, class... Tail>
struct type_at_impl<0, H, Tail...> { using type = H; };

template<size_t I, class H, class... Tail>
struct type_at_impl<I, H, Tail...> : type_at_impl<I - 1, Tail...> {};

template<size_t I, class... Ts>
using type_at = typename type_at_impl<I, Ts...>::type;

// --------------------------------------------------------------------------
// all<Bs...>: true iff all booleans are true
// --------------------------------------------------------------------------
template<bool... Bs>
struct all_impl;

template<bool... Bs>
inline constexpr bool all_v = all_impl<Bs...>::value;

template<>
struct all_impl<> { static constexpr bool value = true; };

template<bool B, bool... Rest>
struct all_impl<B, Rest...> {
    static constexpr bool value = B && all_impl<Rest...>::value;
};

// Convenience wrapper matching libc++'s __all
template<bool... Bs>
struct all : bool_constant<all_v<Bs...>> {};

// --------------------------------------------------------------------------
// Valueless tag
// --------------------------------------------------------------------------
struct valueless_t {};

// --------------------------------------------------------------------------
// Trait enum: same as libc++
// --------------------------------------------------------------------------
enum class Trait { TriviallyAvailable, Available, Unavailable };

template<class T,
         template<class> class IsTrivially,
         template<class> class IsAvailable>
inline constexpr Trait trait_for =
    IsTrivially<T>::value ? Trait::TriviallyAvailable
    : IsAvailable<T>::value ? Trait::Available
    : Trait::Unavailable;

constexpr Trait common_trait(initializer_list<Trait> traits) {
    Trait result = Trait::TriviallyAvailable;
    for (Trait t : traits) {
        if (static_cast<int>(t) > static_cast<int>(result))
            result = t;
    }
    return result;
}

template<class... Types>
struct traits {
    static constexpr Trait copy_constructible_trait =
        common_trait({trait_for<Types, is_trivially_copy_constructible, is_copy_constructible>...});

    static constexpr Trait move_constructible_trait =
        common_trait({trait_for<Types, is_trivially_move_constructible, is_move_constructible>...});

    static constexpr Trait copy_assignable_trait =
        common_trait({copy_constructible_trait,
                      trait_for<Types, is_trivially_copy_assignable, is_copy_assignable>...});

    static constexpr Trait move_assignable_trait =
        common_trait({move_constructible_trait,
                      trait_for<Types, is_trivially_move_assignable, is_move_assignable>...});

    static constexpr Trait destructible_trait =
        common_trait({trait_for<Types, is_trivially_destructible, is_destructible>...});
};

// --------------------------------------------------------------------------
// variant_index_t: compact index type (just use unsigned int for simplicity)
// --------------------------------------------------------------------------
template<size_t NumAlts>
using variant_index_t = unsigned int;

template<class IndexType>
inline constexpr IndexType variant_npos_v = static_cast<IndexType>(-1);

// --------------------------------------------------------------------------
// alt: one slot of the recursive union
// --------------------------------------------------------------------------
template<size_t Index, class T>
struct alt {
    using value_type = T;
    static constexpr size_t index_val = Index;

    template<class... Args>
    explicit constexpr alt(in_place_t, Args&&... args)
        : value(forward<Args>(args)...) {}

    value_type value;
};

// --------------------------------------------------------------------------
// union_storage: recursive union parametrized by Trait + offset index
// --------------------------------------------------------------------------
template<Trait DestructTrait, size_t Index, class... Types>
union union_storage;

// Base case: empty union
template<Trait DestructTrait, size_t Index>
union union_storage<DestructTrait, Index> {};

// Trivially-destructible specialisation
template<size_t Index, class T, class... Types>
union union_storage<Trait::TriviallyAvailable, Index, T, Types...> {
public:
    explicit constexpr union_storage(valueless_t) noexcept : dummy{} {}

    template<class... Args>
    explicit constexpr union_storage(in_place_index_t<0>, Args&&... args)
        : head(in_place, forward<Args>(args)...) {}

    template<size_t I, class... Args>
    explicit constexpr union_storage(in_place_index_t<I>, Args&&... args)
        : tail(in_place_index<I - 1>, forward<Args>(args)...) {}

    union_storage(const union_storage&)            = default;
    union_storage(union_storage&&)                 = default;
    union_storage& operator=(const union_storage&) = default;
    union_storage& operator=(union_storage&&)      = default;
    ~union_storage()                               = default;

private:
    char dummy;
    alt<Index, T> head;
    union_storage<Trait::TriviallyAvailable, Index + 1, Types...> tail;

    friend struct access_union;
};

// Non-trivially-destructible specialisation
template<size_t Index, class T, class... Types>
union union_storage<Trait::Available, Index, T, Types...> {
public:
    explicit constexpr union_storage(valueless_t) noexcept : dummy{} {}

    template<class... Args>
    explicit constexpr union_storage(in_place_index_t<0>, Args&&... args)
        : head(in_place, forward<Args>(args)...) {}

    template<size_t I, class... Args>
    explicit constexpr union_storage(in_place_index_t<I>, Args&&... args)
        : tail(in_place_index<I - 1>, forward<Args>(args)...) {}

    union_storage(const union_storage&)            = default;
    union_storage(union_storage&&)                 = default;
    union_storage& operator=(const union_storage&) = default;
    union_storage& operator=(union_storage&&)      = default;
    ~union_storage() {}  // user-provided; does nothing (subobjects destroyed by dtor base)

private:
    char dummy;
    alt<Index, T> head;
    union_storage<Trait::Available, Index + 1, Types...> tail;

    friend struct access_union;
};

// Deleted-destructor specialisation
template<size_t Index, class T, class... Types>
union union_storage<Trait::Unavailable, Index, T, Types...> {
public:
    explicit constexpr union_storage(valueless_t) noexcept : dummy{} {}

    template<class... Args>
    explicit constexpr union_storage(in_place_index_t<0>, Args&&... args)
        : head(in_place, forward<Args>(args)...) {}

    template<size_t I, class... Args>
    explicit constexpr union_storage(in_place_index_t<I>, Args&&... args)
        : tail(in_place_index<I - 1>, forward<Args>(args)...) {}

    union_storage(const union_storage&)            = default;
    union_storage(union_storage&&)                 = default;
    union_storage& operator=(const union_storage&) = default;
    union_storage& operator=(union_storage&&)      = default;
    ~union_storage()                               = delete;

private:
    char dummy;
    alt<Index, T> head;
    union_storage<Trait::Unavailable, Index + 1, Types...> tail;

    friend struct access_union;
};

// --------------------------------------------------------------------------
// access_union: traverse the recursive union to get alt<I>
// --------------------------------------------------------------------------
struct access_union {
    template<class Vp>
    static constexpr auto&& get_alt(Vp&& v, in_place_index_t<0>) {
        return forward<Vp>(v).head;
    }

    template<class Vp, size_t I>
    static constexpr auto&& get_alt(Vp&& v, in_place_index_t<I>) {
        return get_alt(forward<Vp>(v).tail, in_place_index<I - 1>);
    }
};

// --------------------------------------------------------------------------
// access_base: get alt through __base's __data member
// --------------------------------------------------------------------------
struct access_base {
    template<size_t I, class Vp>
    static constexpr auto&& get_alt(Vp&& v) {
        return access_union::get_alt(forward<Vp>(v).data, in_place_index<I>);
    }
};

// --------------------------------------------------------------------------
// access_variant: get alt through variant's impl_ member
// --------------------------------------------------------------------------
struct access_variant {
    template<size_t I, class Vp>
    static constexpr auto&& get_alt(Vp&& v) {
        return access_base::get_alt<I>(forward<Vp>(v).impl_);
    }
};

// --------------------------------------------------------------------------
// Light N-dimensional function-pointer array (avoids std::array dependency)
// --------------------------------------------------------------------------
template<class T, size_t Size>
struct farray {
    static_assert(Size > 0, "farray should never be empty in std::visit");
    T buf[Size] = {};
    constexpr const T& operator[](size_t n) const noexcept { return buf[n]; }
};

// --------------------------------------------------------------------------
// Visitation machinery
// --------------------------------------------------------------------------

// Forward-declare visitation_variant so visitation_base can befriend it
struct visitation_variant;

struct visitation_base {
    template<class Visitor, class... Vs>
    static constexpr decltype(auto)
    visit_alt_at(size_t index, Visitor&& visitor, Vs&&... vs) {
        constexpr auto fdiag = make_fdiagonal<Visitor&&, decltype(forward<Vs>(vs).as_base())...>();
        return fdiag[index](forward<Visitor>(visitor), forward<Vs>(vs).as_base()...);
    }

    template<class Visitor, class... Vs>
    static constexpr decltype(auto)
    visit_alt(Visitor&& visitor, Vs&&... vs) {
        constexpr auto fmat = make_fmatrix<Visitor&&, decltype(forward<Vs>(vs).as_base())...>();
        return at(fmat, vs.index()...)(forward<Visitor>(visitor), forward<Vs>(vs).as_base()...);
    }

private:
    template<class T>
    static constexpr const T& at(const T& elem) { return elem; }

    template<class T, size_t N, class... Indices>
    static constexpr auto&& at(const farray<T, N>& elems, size_t index, Indices... indices) {
        return at(elems[index], indices...);
    }

    template<class Fp, class... Fs>
    static constexpr void check_visitor_return_type() {
        static_assert(all_v<is_same_v<Fp, Fs>...>,
            "std::visit requires the visitor to have a single return type.");
    }

    template<class... Fs>
    static constexpr auto make_farray_from(Fs&&... fs) {
        check_visitor_return_type<remove_cvref_t<Fs>...>();
        using Result = farray<common_type_t<remove_cvref_t<Fs>...>, sizeof...(Fs)>;
        return Result{{forward<Fs>(fs)...}};
    }

    template<size_t... Is>
    struct dispatcher {
        template<class Fp, class... Vs>
        static constexpr decltype(auto) dispatch(Fp f, Vs... vs) {
            return detail::invoke_impl(
                static_cast<Fp>(f),
                access_base::get_alt<Is>(static_cast<Vs>(vs))...);
        }
    };

    template<class Fp, class... Vs, size_t... Is>
    static constexpr auto make_dispatch(index_sequence<Is...>) {
        return dispatcher<Is...>::template dispatch<Fp, Vs...>;
    }

    template<size_t I, class Fp, class... Vs>
    static constexpr auto make_fdiagonal_impl() {
        return make_dispatch<Fp, Vs...>(
            index_sequence<((void)type_identity<Vs>{}, I)...>{});
    }

    template<class Fp, class... Vs, size_t... Is>
    static constexpr auto make_fdiagonal_impl(index_sequence<Is...>) {
        return make_farray_from(make_fdiagonal_impl<Is, Fp, Vs...>()...);
    }

    template<class Fp, class Vp, class... Vs>
    static constexpr auto make_fdiagonal() {
        constexpr size_t np = remove_cvref_t<Vp>::size_v();
        static_assert(all_v<(np == remove_cvref_t<Vs>::size_v())...>);
        return make_fdiagonal_impl<Fp, Vp, Vs...>(make_index_sequence<np>{});
    }

    template<class Fp, class... Vs, size_t... Is>
    static constexpr auto make_fmatrix_impl(index_sequence<Is...> is) {
        return make_dispatch<Fp, Vs...>(is);
    }

    template<class Fp, class... Vs, size_t... Is, size_t... Js, class... Ls>
    static constexpr auto make_fmatrix_impl(index_sequence<Is...>, index_sequence<Js...>, Ls... ls) {
        return make_farray_from(
            make_fmatrix_impl<Fp, Vs...>(index_sequence<Is..., Js>{}, ls...)...);
    }

    template<class Fp, class... Vs>
    static constexpr auto make_fmatrix() {
        return make_fmatrix_impl<Fp, Vs...>(
            index_sequence<>{},
            make_index_sequence<remove_cvref_t<Vs>::size_v()>{}...);
    }
};

// as_variant: used by visit to strip to the variant base type
template<class... Types>
constexpr variant<Types...>& as_variant(variant<Types...>& vs) noexcept { return vs; }
template<class... Types>
constexpr const variant<Types...>& as_variant(const variant<Types...>& vs) noexcept { return vs; }
template<class... Types>
constexpr variant<Types...>&& as_variant(variant<Types...>&& vs) noexcept { return move(vs); }
template<class... Types>
constexpr const variant<Types...>&& as_variant(const variant<Types...>&& vs) noexcept { return move(vs); }

struct visitation_variant {
    template<class Visitor, class... Vs>
    static constexpr decltype(auto)
    visit_alt_at(size_t index, Visitor&& visitor, Vs&&... vs) {
        return visitation_base::visit_alt_at(
            index, forward<Visitor>(visitor), forward<Vs>(vs).impl_...);
    }

    template<class Visitor, class... Vs>
    static constexpr decltype(auto)
    visit_alt(Visitor&& visitor, Vs&&... vs) {
        return visitation_base::visit_alt(
            forward<Visitor>(visitor),
            as_variant(forward<Vs>(vs)).impl_...);
    }

    template<class Visitor, class... Vs>
    static constexpr decltype(auto)
    visit_value_at(size_t index, Visitor&& visitor, Vs&&... vs) {
        return visit_alt_at(index,
            make_value_visitor(forward<Visitor>(visitor)),
            forward<Vs>(vs)...);
    }

    template<class Visitor, class... Vs>
    static constexpr decltype(auto)
    visit_value(Visitor&& visitor, Vs&&... vs) {
        return visit_alt(make_value_visitor(forward<Visitor>(visitor)),
                         forward<Vs>(vs)...);
    }

    template<class R, class Visitor, class... Vs>
    static constexpr R visit_value_r(Visitor&& visitor, Vs&&... vs) {
        return visit_alt(make_value_visitor_r<R>(forward<Visitor>(visitor)),
                         forward<Vs>(vs)...);
    }

private:
    template<class Visitor, class... Values>
    static constexpr void check_exhaustive() {
        static_assert(is_invocable_v<Visitor, Values...>,
            "std::visit requires the visitor to be exhaustive.");
    }

    template<class Visitor>
    struct value_visitor {
        template<class... Alts>
        constexpr auto operator()(Alts&&... alts) const
            -> invoke_result_t<Visitor&&, decltype((forward<Alts>(alts).value))...>
        {
            check_exhaustive<Visitor, decltype((forward<Alts>(alts).value))...>();
            return detail::invoke_impl(
                forward<Visitor>(visitor),
                forward<Alts>(alts).value...);
        }
        Visitor&& visitor;
    };

    template<class R, class Visitor>
    struct value_visitor_r {
        template<class... Alts>
        constexpr R operator()(Alts&&... alts) const {
            check_exhaustive<Visitor, decltype((forward<Alts>(alts).value))...>();
            if constexpr (is_void_v<R>) {
                detail::invoke_impl(forward<Visitor>(visitor), forward<Alts>(alts).value...);
            } else {
                return detail::invoke_impl(forward<Visitor>(visitor), forward<Alts>(alts).value...);
            }
        }
        Visitor&& visitor;
    };

    template<class Visitor>
    static constexpr auto make_value_visitor(Visitor&& visitor) {
        return value_visitor<Visitor>{forward<Visitor>(visitor)};
    }

    template<class R, class Visitor>
    static constexpr auto make_value_visitor_r(Visitor&& visitor) {
        return value_visitor_r<R, Visitor>{forward<Visitor>(visitor)};
    }
};

// --------------------------------------------------------------------------
// base: holds the union + index
// --------------------------------------------------------------------------
template<Trait DestructTrait, class... Types>
class vbase {
public:
    using index_t = variant_index_t<sizeof...(Types)>;

    explicit constexpr vbase(valueless_t tag) noexcept
        : data(tag), idx(variant_npos_v<index_t>) {}

    template<size_t I, class... Args>
    explicit constexpr vbase(in_place_index_t<I>, Args&&... args)
        : data(in_place_index<I>, forward<Args>(args)...), idx(static_cast<index_t>(I)) {}

    constexpr bool valueless_by_exception() const noexcept {
        return index() == variant_npos;
    }

    constexpr size_t index() const noexcept {
        return idx == variant_npos_v<index_t> ? variant_npos : static_cast<size_t>(idx);
    }

protected:
    constexpr auto&& as_base() &       { return *this; }
    constexpr auto&& as_base() &&      { return move(*this); }
    constexpr auto&& as_base() const&  { return *this; }
    constexpr auto&& as_base() const&& { return move(*this); }

    static constexpr size_t size_v() { return sizeof...(Types); }

    union_storage<DestructTrait, 0, Types...> data;
    index_t idx;

    friend struct access_base;
    friend struct visitation_base;
};

// --------------------------------------------------------------------------
// dtor: adds destroy() and the right destructor specialisation
// --------------------------------------------------------------------------

// Primary template (TriviallyAvailable)
template<class Traits, Trait = Traits::destructible_trait>
class vdtor;

// Trivially destructible
template<class... Types>
class vdtor<traits<Types...>, Trait::TriviallyAvailable>
    : public vbase<Trait::TriviallyAvailable, Types...>
{
    using base_type = vbase<Trait::TriviallyAvailable, Types...>;
public:
    using index_t   = typename base_type::index_t;
    using base_type::base_type;
    using base_type::operator=;
    vdtor(const vdtor&)            = default;
    vdtor(vdtor&&)                 = default;
    vdtor& operator=(const vdtor&) = default;
    vdtor& operator=(vdtor&&)      = default;
    ~vdtor()                       = default;

protected:
    void destroy() noexcept {
        this->idx = variant_npos_v<index_t>;
    }
};

// Non-trivially destructible
template<class... Types>
class vdtor<traits<Types...>, Trait::Available>
    : public vbase<Trait::Available, Types...>
{
    using base_type = vbase<Trait::Available, Types...>;
public:
    using index_t   = typename base_type::index_t;
    using base_type::base_type;
    using base_type::operator=;
    vdtor(const vdtor&)            = default;
    vdtor(vdtor&&)                 = default;
    vdtor& operator=(const vdtor&) = default;
    vdtor& operator=(vdtor&&)      = default;
    ~vdtor() { destroy(); }

protected:
    void destroy() noexcept {
        if (!this->valueless_by_exception()) {
            visitation_base::visit_alt(
                [](auto& a) noexcept {
                    using alt_type = remove_cvref_t<decltype(a)>;
                    a.~alt_type();
                },
                *this);
        }
        this->idx = variant_npos_v<index_t>;
    }
};

// Deleted destructor
template<class... Types>
class vdtor<traits<Types...>, Trait::Unavailable>
    : public vbase<Trait::Unavailable, Types...>
{
    using base_type = vbase<Trait::Unavailable, Types...>;
public:
    using index_t   = typename base_type::index_t;
    using base_type::base_type;
    using base_type::operator=;
    vdtor(const vdtor&)            = default;
    vdtor(vdtor&&)                 = default;
    vdtor& operator=(const vdtor&) = default;
    vdtor& operator=(vdtor&&)      = default;
    ~vdtor()                       = delete;

protected:
    void destroy() noexcept = delete;
};

// --------------------------------------------------------------------------
// vctor: adds generic_construct
// --------------------------------------------------------------------------
template<class Traits>
class vctor : public vdtor<Traits> {
    using base_type = vdtor<Traits>;
public:
    using base_type::base_type;
    using base_type::operator=;

protected:
    template<class Rhs>
    static void generic_construct(vctor& lhs, Rhs&& rhs) {
        lhs.destroy();
        if (!rhs.valueless_by_exception()) {
            auto rhs_index = rhs.index();
            visitation_base::visit_alt_at(
                rhs_index,
                [&lhs](auto&& rhs_alt) {
                    // placement-new into the data member
                    ::new (static_cast<void*>(__builtin_addressof(lhs.data)))
                        decay_t<decltype(lhs.data)>(
                            in_place_index<decay_t<decltype(rhs_alt)>::index_val>,
                            forward<decltype(rhs_alt)>(rhs_alt).value);
                },
                forward<Rhs>(rhs));
            lhs.idx = static_cast<typename vctor::index_t>(rhs_index);
        }
    }
};

// --------------------------------------------------------------------------
// vmove_ctor
// --------------------------------------------------------------------------
template<class Traits, Trait = Traits::move_constructible_trait>
class vmove_ctor;

// Trivially move-constructible
template<class... Types>
class vmove_ctor<traits<Types...>, Trait::TriviallyAvailable>
    : public vctor<traits<Types...>>
{
    using base_type = vctor<traits<Types...>>;
public:
    using base_type::base_type;
    using base_type::operator=;
    vmove_ctor(const vmove_ctor&)            = default;
    ~vmove_ctor()                            = default;
    vmove_ctor& operator=(const vmove_ctor&) = default;
    vmove_ctor& operator=(vmove_ctor&&)      = default;
    vmove_ctor(vmove_ctor&&)                 = default;
};

// Non-trivially move-constructible
template<class... Types>
class vmove_ctor<traits<Types...>, Trait::Available>
    : public vctor<traits<Types...>>
{
    using base_type = vctor<traits<Types...>>;
public:
    using base_type::base_type;
    using base_type::operator=;
    vmove_ctor(const vmove_ctor&)            = default;
    ~vmove_ctor()                            = default;
    vmove_ctor& operator=(const vmove_ctor&) = default;
    vmove_ctor& operator=(vmove_ctor&&)      = default;
    vmove_ctor(vmove_ctor&& that) noexcept(all_v<is_nothrow_move_constructible_v<Types>...>)
        : vmove_ctor(valueless_t{})
    {
        this->generic_construct(*this, move(that));
    }
};

// Move-constructible deleted
template<class... Types>
class vmove_ctor<traits<Types...>, Trait::Unavailable>
