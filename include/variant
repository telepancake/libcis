// --------------------------------------------------------------------------
// vimpl: top of the base chain; adds assign<I> and swap
// --------------------------------------------------------------------------
template<class... Types>
class vimpl : public vcopy_assign<traits<Types...>> {
    using base_type = vcopy_assign<traits<Types...>>;
public:
    using base_type::base_type;
    vimpl(const vimpl&)            = default;
    vimpl(vimpl&&)                 = default;
    vimpl& operator=(const vimpl&) = default;
    vimpl& operator=(vimpl&&)      = default;

    template<size_t I, class Arg>
    void assign(Arg&& arg) {
        this->assign_alt(access_base::get_alt<I>(*this), forward<Arg>(arg));
    }

    void do_swap(vimpl& that) {
        if (this->valueless_by_exception() && that.valueless_by_exception()) {
            // nothing
        } else if (this->index() == that.index()) {
            visitation_base::visit_alt_at(
                this->index(),
                [](auto& a, auto& b) {
                    using std::swap;
                    swap(a.value, b.value);
                },
                *this, that);
        } else {
            vimpl* lhs = this;
            vimpl* rhs = __builtin_addressof(that);
            if (lhs->move_nothrow() && !rhs->move_nothrow())
                swap(lhs, rhs);  // use std::swap of pointers
            vimpl tmp(move(*rhs));
            // Under -fno-exceptions: just proceed, no strong guarantee
            this->generic_construct(*rhs, move(*lhs));
            this->generic_construct(*lhs, move(tmp));
        }
    }

private:
    bool move_nothrow() const {
        constexpr bool results[] = {is_nothrow_move_constructible_v<Types>...};
        return this->valueless_by_exception() || results[this->index()];
    }
};

