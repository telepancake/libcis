// --------------------------------------------------------------------------
// vassignment: adds assign_alt, generic_assign, emplace
// --------------------------------------------------------------------------
template<class Traits>
class vassignment : public vcopy_ctor<Traits> {
    using base_type = vcopy_ctor<Traits>;
public:
    using base_type::base_type;
    using base_type::operator=;

    template<size_t I, class... Args>
    auto& do_emplace(Args&&... args) {
        this->destroy();
        ::new (static_cast<void*>(__builtin_addressof(this->data)))
            decay_t<decltype(this->data)>(in_place_index<I>, forward<Args>(args)...);
        this->idx = static_cast<typename vassignment::index_t>(I);
        return access_base::get_alt<I>(*this).value;
    }

protected:
    template<size_t I, class T, class Arg>
    void assign_alt(alt<I, T>& a, Arg&& arg) {
        if (this->index() == I) {
            a.value = forward<Arg>(arg);
        } else if constexpr (is_nothrow_constructible_v<T, Arg> ||
                             !is_nothrow_move_constructible_v<T>) {
            this->template do_emplace<I>(forward<Arg>(arg));
        } else {
            this->template do_emplace<I>(T(forward<Arg>(arg)));
        }
    }

    template<class That>
    void generic_assign(That&& that) {
        if (this->valueless_by_exception() && that.valueless_by_exception()) {
            // nothing
        } else if (that.valueless_by_exception()) {
            this->destroy();
        } else {
            visitation_base::visit_alt_at(
                that.index(),
                [this](auto& this_alt, auto&& that_alt) {
                    this->assign_alt(
                        this_alt,
                        forward<decltype(that_alt)>(that_alt).value);
                },
                *this,
                forward<That>(that));
        }
    }
};

