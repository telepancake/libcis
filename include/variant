// --------------------------------------------------------------------------
// Find helpers (mirrors libc++ __find_detail)
// --------------------------------------------------------------------------
namespace find_detail {

inline constexpr size_t not_found = static_cast<size_t>(-1);
inline constexpr size_t ambiguous = not_found - 1;

template<class T, class... Types>
constexpr size_t find_index() {
    constexpr bool matches[] = {is_same_v<T, Types>...};
    size_t result = not_found;
    for (size_t i = 0; i < sizeof...(Types); ++i) {
        if (matches[i]) {
            if (result != not_found) return ambiguous;
            result = i;
        }
    }
    return result;
}

template<size_t Index>
struct find_unambiguous_index_sfinae_impl : integral_constant<size_t, Index> {};
template<>
struct find_unambiguous_index_sfinae_impl<not_found> {};
template<>
struct find_unambiguous_index_sfinae_impl<ambiguous> {};

template<class T, class... Types>
struct find_unambiguous_index_sfinae_detail
    : find_unambiguous_index_sfinae_impl<find_detail::find_index<T, Types...>()> {};

} // namespace find_detail

// Alias at variant_detail scope so the variant class can use it directly
template<class T, class... Types>
struct find_unambiguous_index_sfinae
    : find_detail::find_unambiguous_index_sfinae_detail<T, Types...> {};

// find_exactly_one_t: like tuple's version but in this namespace
template<class T, class... Types>
struct find_exactly_one_t {
    static constexpr bool matches[sizeof...(Types)] = { is_same_v<T, Types>... };
    static constexpr size_t value = [] {
        size_t r = find_detail::not_found;
        for (size_t i = 0; i < sizeof...(Types); ++i) {
            if (matches[i]) {
                if (r != find_detail::not_found) return find_detail::ambiguous;
                r = i;
            }
        }
        return r;
    }();
    static_assert(value != find_detail::not_found, "type not found in variant type list");
    static_assert(value != find_detail::ambiguous, "type appears more than once in variant type list");
};

// --------------------------------------------------------------------------
// Narrowing check (for best_match_t)
// --------------------------------------------------------------------------
struct no_narrowing_check {
    template<class Dest, class Source>
    using apply = type_identity<Dest>;
};

struct narrowing_check {
    template<class Dest>
    static auto test_impl(Dest (&&)[1]) -> type_identity<Dest>;
    template<class Dest, class Source>
    using apply = decltype(test_impl<Dest>({declval<Source>()}));
};

template<class Dest, class Source>
using check_for_narrowing =
    typename conditional_t<is_arithmetic_v<Dest>,
                           narrowing_check,
                           no_narrowing_check>::template apply<Dest, Source>;

template<class T, size_t Idx>
struct overload_set {
    template<class U>
    auto operator()(T, U&&) const -> check_for_narrowing<T, U>;
};

template<class... Bases>
struct all_overloads : Bases... {
    void operator()() const;
    using Bases::operator()...;
};

template<class IdxSeq>
struct make_overloads_impl;

template<size_t... Idx>
struct make_overloads_impl<index_sequence<Idx...>> {
    template<class... Types>
    using apply = all_overloads<overload_set<Types, Idx>...>;
};

template<class... Types>
using make_overloads =
    typename make_overloads_impl<make_index_sequence<sizeof...(Types)>>::template apply<Types...>;

template<class T, class... Types>
using best_match_t = typename invoke_result_t<make_overloads<Types...>, T, T>::type;

// --------------------------------------------------------------------------
// Minimal comparison functors (std::equal_to etc. live in <functional>
// which is not yet ported; define minimal versions here for variant's use)
// --------------------------------------------------------------------------
struct equal_to_fn      { template<class T> constexpr bool operator()(const T& a, const T& b) const { return a == b; } };
struct not_equal_to_fn  { template<class T> constexpr bool operator()(const T& a, const T& b) const { return a != b; } };
struct less_fn          { template<class T> constexpr bool operator()(const T& a, const T& b) const { return a < b; } };
struct greater_fn       { template<class T> constexpr bool operator()(const T& a, const T& b) const { return a > b; } };
struct less_equal_fn    { template<class T> constexpr bool operator()(const T& a, const T& b) const { return a <= b; } };
struct greater_equal_fn { template<class T> constexpr bool operator()(const T& a, const T& b) const { return a >= b; } };

