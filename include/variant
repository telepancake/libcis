template<class... Types>
class variant
    : private variant_detail::sfinae_ctor_base<
          variant_detail::all_v<is_copy_constructible_v<Types>...>,
          variant_detail::all_v<is_move_constructible_v<Types>...>>,
      private variant_detail::sfinae_assign_base<
          variant_detail::all_v<(is_copy_constructible_v<Types> &&
                                  is_copy_assignable_v<Types>)...>,
          variant_detail::all_v<(is_move_constructible_v<Types> &&
                                  is_move_assignable_v<Types>)...>>
{
    static_assert(sizeof...(Types) > 0,
        "variant must consist of at least one alternative.");
    static_assert(variant_detail::all_v<!is_array_v<Types>...>,
        "variant can not have an array type as an alternative.");
    static_assert(variant_detail::all_v<!is_reference_v<Types>...>,
        "variant can not have a reference type as an alternative.");
    static_assert(variant_detail::all_v<!is_void_v<Types>...>,
        "variant can not have a void type as an alternative.");

    using first_type = variant_alternative_t<0, variant>;
    using impl_type  = variant_detail::vimpl<Types...>;

public:
    // ----- default constructor -----
    template<bool Dummy = true,
             enable_if_t<Dummy && is_default_constructible_v<first_type>, int> = 0>
    constexpr variant() noexcept(is_nothrow_default_constructible_v<first_type>)
        : impl_(in_place_index<0>) {}

    // ----- copy/move constructors -----
    constexpr variant(const variant&) = default;
    constexpr variant(variant&&)      = default;

    // ----- converting constructor -----
    template<class Arg,
             enable_if_t<!is_same_v<remove_cvref_t<Arg>, variant>, int>           = 0,
             enable_if_t<!is_inplace_type<remove_cvref_t<Arg>>::value, int>        = 0,
             enable_if_t<!is_inplace_index<remove_cvref_t<Arg>>::value, int>       = 0,
             class T  = variant_detail::best_match_t<Arg, Types...>,
             size_t I = variant_detail::find_unambiguous_index_sfinae<T, Types...>::value,
             enable_if_t<is_constructible_v<T, Arg>, int>                          = 0>
    constexpr variant(Arg&& arg) noexcept(is_nothrow_constructible_v<T, Arg>)
        : impl_(in_place_index<I>, forward<Arg>(arg)) {}

    // ----- in_place_index constructor -----
    template<size_t I,
             class... Args,
             enable_if_t<(I < sizeof...(Types)), int> = 0,
             class T = variant_alternative_t<I, variant<Types...>>,
             enable_if_t<is_constructible_v<T, Args...>, int> = 0>
    explicit constexpr variant(in_place_index_t<I>, Args&&... args)
        noexcept(is_nothrow_constructible_v<T, Args...>)
        : impl_(in_place_index<I>, forward<Args>(args)...) {}

    // ----- in_place_index + initializer_list constructor -----
    template<size_t I,
             class U,
             class... Args,
             enable_if_t<(I < sizeof...(Types)), int> = 0,
             class T = variant_alternative_t<I, variant<Types...>>,
             enable_if_t<is_constructible_v<T, initializer_list<U>&, Args...>, int> = 0>
    explicit constexpr variant(in_place_index_t<I>,
                               initializer_list<U> il,
                               Args&&... args)
        noexcept(is_nothrow_constructible_v<T, initializer_list<U>&, Args...>)
        : impl_(in_place_index<I>, il, forward<Args>(args)...) {}

    // ----- in_place_type constructor -----
    template<class T,
             class... Args,
             size_t I = variant_detail::find_unambiguous_index_sfinae<T, Types...>::value,
             enable_if_t<is_constructible_v<T, Args...>, int> = 0>
    explicit constexpr variant(in_place_type_t<T>, Args&&... args)
        noexcept(is_nothrow_constructible_v<T, Args...>)
        : impl_(in_place_index<I>, forward<Args>(args)...) {}

    // ----- in_place_type + initializer_list constructor -----
    template<class T,
             class U,
             class... Args,
             size_t I = variant_detail::find_unambiguous_index_sfinae<T, Types...>::value,
             enable_if_t<is_constructible_v<T, initializer_list<U>&, Args...>, int> = 0>
    explicit constexpr variant(in_place_type_t<T>,
                               initializer_list<U> il,
                               Args&&... args)
        noexcept(is_nothrow_constructible_v<T, initializer_list<U>&, Args...>)
        : impl_(in_place_index<I>, il, forward<Args>(args)...) {}

    // ----- destructor -----
    ~variant() = default;

    // ----- assignment -----
    constexpr variant& operator=(const variant&) = default;
    constexpr variant& operator=(variant&&)      = default;

    template<class Arg,
             enable_if_t<!is_same_v<remove_cvref_t<Arg>, variant>, int> = 0,
             class T  = variant_detail::best_match_t<Arg, Types...>,
             size_t I = variant_detail::find_unambiguous_index_sfinae<T, Types...>::value,
             enable_if_t<is_assignable_v<T&, Arg> && is_constructible_v<T, Arg>, int> = 0>
    constexpr variant& operator=(Arg&& arg)
        noexcept(is_nothrow_assignable_v<T&, Arg> && is_nothrow_constructible_v<T, Arg>)
    {
        impl_.template assign<I>(forward<Arg>(arg));
        return *this;
    }

    // ----- emplace<I> -----
    template<size_t I,
             class... Args,
             enable_if_t<(I < sizeof...(Types)), int>            = 0,
             class T = variant_alternative_t<I, variant<Types...>>,
             enable_if_t<is_constructible_v<T, Args...>, int>    = 0>
    constexpr T& emplace(Args&&... args) {
        return impl_.template do_emplace<I>(forward<Args>(args)...);
    }

    template<size_t I,
             class U,
             class... Args,
             enable_if_t<(I < sizeof...(Types)), int>                             = 0,
             class T = variant_alternative_t<I, variant<Types...>>,
             enable_if_t<is_constructible_v<T, initializer_list<U>&, Args...>, int> = 0>
    constexpr T& emplace(initializer_list<U> il, Args&&... args) {
        return impl_.template do_emplace<I>(il, forward<Args>(args)...);
    }

    // ----- emplace<T> -----
    template<class T,
             class... Args,
             size_t I = variant_detail::find_unambiguous_index_sfinae<T, Types...>::value,
             enable_if_t<is_constructible_v<T, Args...>, int> = 0>
    constexpr T& emplace(Args&&... args) {
        return impl_.template do_emplace<I>(forward<Args>(args)...);
    }

    template<class T,
             class U,
             class... Args,
             size_t I = variant_detail::find_unambiguous_index_sfinae<T, Types...>::value,
             enable_if_t<is_constructible_v<T, initializer_list<U>&, Args...>, int> = 0>
    constexpr T& emplace(initializer_list<U> il, Args&&... args) {
        return impl_.template do_emplace<I>(il, forward<Args>(args)...);
    }

    // ----- observers -----
    [[nodiscard]] constexpr bool valueless_by_exception() const noexcept {
        return impl_.valueless_by_exception();
    }
    [[nodiscard]] constexpr size_t index() const noexcept {
        return impl_.index();
    }

    // ----- swap -----
    template<bool Dummy = true,
             enable_if_t<variant_detail::all_v<
                 (is_move_constructible_v<Types> && is_swappable_v<Types>)...> && Dummy, int> = 0>
    void swap(variant& that)
        noexcept(variant_detail::all_v<
            (is_nothrow_move_constructible_v<Types> && is_nothrow_swappable_v<Types>)...>)
    {
        impl_.do_swap(that.impl_);
    }

private:
    impl_type impl_;

    friend struct variant_detail::access_variant;
    friend struct variant_detail::visitation_variant;
};

// ============================================================================
// holds_alternative
// ============================================================================

template<size_t I, class... Types>
constexpr bool holds_alternative_at(const variant<Types...>& v) noexcept {
    return v.index() == I;
}

template<class T, class... Types>
[[nodiscard]] constexpr bool holds_alternative(const variant<Types...>& v) noexcept {
    return holds_alternative_at<variant_detail::find_exactly_one_t<T, Types...>::value>(v);
}

// ============================================================================
// get<I> / get<T>
// ============================================================================

template<size_t I, class Vp>
constexpr auto&& generic_get(Vp&& v) {
    if (!holds_alternative_at<I>(v)) {
        // -fno-exceptions: trap instead of throw
        throw_bad_variant_access();
    }
    return variant_detail::access_variant::get_alt<I>(forward<Vp>(v)).value;
}

template<size_t I, class... Types>
[[nodiscard]] constexpr variant_alternative_t<I, variant<Types...>>&
get(variant<Types...>& v) {
    static_assert(I < sizeof...(Types));
    return generic_get<I>(v);
}

template<size_t I, class... Types>
[[nodiscard]] constexpr variant_alternative_t<I, variant<Types...>>&&
get(variant<Types...>&& v) {
    static_assert(I < sizeof...(Types));
    return generic_get<I>(move(v));
}

template<size_t I, class... Types>
[[nodiscard]] constexpr const variant_alternative_t<I, variant<Types...>>&
get(const variant<Types...>& v) {
    static_assert(I < sizeof...(Types));
    return generic_get<I>(v);
}

template<size_t I, class... Types>
[[nodiscard]] constexpr const variant_alternative_t<I, variant<Types...>>&&
get(const variant<Types...>&& v) {
    static_assert(I < sizeof...(Types));
    return generic_get<I>(move(v));
}

template<class T, class... Types>
[[nodiscard]] constexpr T& get(variant<Types...>& v) {
    static_assert(!is_void_v<T>);
    return get<variant_detail::find_exactly_one_t<T, Types...>::value>(v);
}
template<class T, class... Types>
[[nodiscard]] constexpr T&& get(variant<Types...>&& v) {
    static_assert(!is_void_v<T>);
    return get<variant_detail::find_exactly_one_t<T, Types...>::value>(move(v));
}
template<class T, class... Types>
[[nodiscard]] constexpr const T& get(const variant<Types...>& v) {
    static_assert(!is_void_v<T>);
    return get<variant_detail::find_exactly_one_t<T, Types...>::value>(v);
}
template<class T, class... Types>
[[nodiscard]] constexpr const T&& get(const variant<Types...>&& v) {
    static_assert(!is_void_v<T>);
    return get<variant_detail::find_exactly_one_t<T, Types...>::value>(move(v));
}

// ============================================================================
// get_if<I> / get_if<T>
// ============================================================================

template<size_t I, class Vp>
constexpr auto* generic_get_if(Vp* v) noexcept {
    return v && holds_alternative_at<I>(*v)
        ? __builtin_addressof(variant_detail::access_variant::get_alt<I>(*v).value)
        : nullptr;
}

template<size_t I, class... Types>
[[nodiscard]] constexpr add_pointer_t<variant_alternative_t<I, variant<Types...>>>
get_if(variant<Types...>* v) noexcept {
    static_assert(I < sizeof...(Types));
    return generic_get_if<I>(v);
}

template<size_t I, class... Types>
[[nodiscard]] constexpr add_pointer_t<const variant_alternative_t<I, variant<Types...>>>
get_if(const variant<Types...>* v) noexcept {
    static_assert(I < sizeof...(Types));
    return generic_get_if<I>(v);
}

template<class T, class... Types>
[[nodiscard]] constexpr add_pointer_t<T> get_if(variant<Types...>* v) noexcept {
    static_assert(!is_void_v<T>);
    return get_if<variant_detail::find_exactly_one_t<T, Types...>::value>(v);
}

template<class T, class... Types>
[[nodiscard]] constexpr add_pointer_t<const T> get_if(const variant<Types...>* v) noexcept {
    static_assert(!is_void_v<T>);
    return get_if<variant_detail::find_exactly_one_t<T, Types...>::value>(v);
}

// ============================================================================
// Relational operators
// ============================================================================

namespace variant_detail {

template<class Operator>
struct convert_to_bool {
    template<class T1, class T2>
    constexpr bool operator()(T1&& t1, T2&& t2) const {
        static_assert(is_convertible_v<
            decltype(Operator{}(forward<T1>(t1), forward<T2>(t2))), bool>,
            "relational operator does not return bool-convertible");
        return Operator{}(forward<T1>(t1), forward<T2>(t2));
    }
};

} // namespace variant_detail

template<class... Types>
constexpr bool operator==(const variant<Types...>& lhs, const variant<Types...>& rhs) {
    if (lhs.index() != rhs.index()) return false;
    if (lhs.valueless_by_exception()) return true;
    return variant_detail::visitation_variant::visit_value_at(
        lhs.index(),
        variant_detail::convert_to_bool<variant_detail::equal_to_fn>{},
        lhs, rhs);
}

template<class... Types>
constexpr bool operator!=(const variant<Types...>& lhs, const variant<Types...>& rhs) {
    if (lhs.index() != rhs.index()) return true;
    if (lhs.valueless_by_exception()) return false;
    return variant_detail::visitation_variant::visit_value_at(
        lhs.index(),
        variant_detail::convert_to_bool<variant_detail::not_equal_to_fn>{},
        lhs, rhs);
}

template<class... Types>
constexpr bool operator<(const variant<Types...>& lhs, const variant<Types...>& rhs) {
    if (rhs.valueless_by_exception()) return false;
    if (lhs.valueless_by_exception()) return true;
    if (lhs.index() < rhs.index()) return true;
    if (lhs.index() > rhs.index()) return false;
    return variant_detail::visitation_variant::visit_value_at(
        lhs.index(),
        variant_detail::convert_to_bool<variant_detail::less_fn>{},
        lhs, rhs);
}

template<class... Types>
constexpr bool operator>(const variant<Types...>& lhs, const variant<Types...>& rhs) {
    if (lhs.valueless_by_exception()) return false;
    if (rhs.valueless_by_exception()) return true;
    if (lhs.index() > rhs.index()) return true;
    if (lhs.index() < rhs.index()) return false;
    return variant_detail::visitation_variant::visit_value_at(
        lhs.index(),
        variant_detail::convert_to_bool<variant_detail::greater_fn>{},
        lhs, rhs);
}

template<class... Types>
constexpr bool operator<=(const variant<Types...>& lhs, const variant<Types...>& rhs) {
    if (lhs.valueless_by_exception()) return true;
    if (rhs.valueless_by_exception()) return false;
    if (lhs.index() < rhs.index()) return true;
    if (lhs.index() > rhs.index()) return false;
    return variant_detail::visitation_variant::visit_value_at(
        lhs.index(),
        variant_detail::convert_to_bool<variant_detail::less_equal_fn>{},
        lhs, rhs);
}

template<class... Types>
constexpr bool operator>=(const variant<Types...>& lhs, const variant<Types...>& rhs) {
    if (rhs.valueless_by_exception()) return true;
    if (lhs.valueless_by_exception()) return false;
    if (lhs.index() > rhs.index()) return true;
    if (lhs.index() < rhs.index()) return false;
    return variant_detail::visitation_variant::visit_value_at(
        lhs.index(),
        variant_detail::convert_to_bool<variant_detail::greater_equal_fn>{},
        lhs, rhs);
}

template<class... Types>
    requires (three_way_comparable<Types> && ...)
constexpr common_comparison_category_t<compare_three_way_result_t<Types>...>
operator<=>(const variant<Types...>& lhs, const variant<Types...>& rhs) {
    using result_t = common_comparison_category_t<compare_three_way_result_t<Types>...>;
    if (lhs.valueless_by_exception() && rhs.valueless_by_exception())
        return strong_ordering::equal;
    if (lhs.valueless_by_exception()) return strong_ordering::less;
    if (rhs.valueless_by_exception()) return strong_ordering::greater;
    if (auto c = lhs.index() <=> rhs.index(); c != 0) return c;
    auto three_way = []<class Type>(const Type& a, const Type& b) -> result_t {
        return a <=> b;
    };
    return variant_detail::visitation_variant::visit_value_at(
        lhs.index(), three_way, lhs, rhs);
}

// ============================================================================
// visit
// ============================================================================

namespace variant_detail {

template<class... Vs>
constexpr void throw_if_valueless(Vs&&... vs) {
    const bool valueless = (... || as_variant(vs).valueless_by_exception());
    if (valueless) {
        // -fno-exceptions: trap instead of throw
        throw_bad_variant_access();
    }
}

} // namespace variant_detail

template<class Visitor, class... Vs,
         class = void_t<decltype(variant_detail::as_variant(declval<Vs>()))...>>
constexpr decltype(auto) visit(Visitor&& visitor, Vs&&... vs) {
    variant_detail::throw_if_valueless(forward<Vs>(vs)...);
    return variant_detail::visitation_variant::visit_value(
        forward<Visitor>(visitor), forward<Vs>(vs)...);
}

template<class R, class Visitor, class... Vs,
         class = void_t<decltype(variant_detail::as_variant(declval<Vs>()))...>>
constexpr R visit(Visitor&& visitor, Vs&&... vs) {
    variant_detail::throw_if_valueless(forward<Vs>(vs)...);
    return variant_detail::visitation_variant::visit_value_r<R>(
        forward<Visitor>(visitor), forward<Vs>(vs)...);
}

// ============================================================================
// swap (free function)
// ============================================================================

template<class... Types>
auto swap(variant<Types...>& lhs, variant<Types...>& rhs)
    noexcept(noexcept(lhs.swap(rhs)))
    -> decltype(lhs.swap(rhs))
{
    return lhs.swap(rhs);
}

// ============================================================================
// [variant.hash] — hash<variant<Types...>> and hash<monostate>
// (ported from libc++ include/variant + __variant/monostate.h)
//
// hash<variant<Types...>>:
//   Enabled only when every remove_const_t<Ti> has an enabled hash.
//   For a non-valueless variant: hash the active value, then combine with
//   hash<size_t>{}(v.index()) using detail::hash_combine from <functional>.
//   For a valueless variant: use sentinel 299792458 (matches libc++).
//
// hash<monostate>:
//   Always enabled; returns a fixed constant (66740831, from libc++).
// ============================================================================

// hash<monostate> — always enabled, returns a fixed constant.
template<>
struct hash<monostate> {
    [[nodiscard]] size_t operator()(const monostate&) const noexcept {
        return 66740831; // return a fundamentally attractive random value.
    }
};

// hash<variant<Types...>> — enabled only when all remove_const_t<Ti> are hashable.
template<class... Types>
    requires (... && requires(const remove_const_t<Types>& v) {
                  { hash<remove_const_t<Types>>{}(v) } -> same_as<size_t>;
              })
struct hash<variant<Types...>> {
    [[nodiscard]] size_t operator()(const variant<Types...>& v) const {
        if (v.valueless_by_exception()) {
            return 299792458; // Random value chosen by the universe upon creation
        }
        size_t val_hash = variant_detail::visitation_variant::visit_value(
            [](const auto& x) -> size_t {
                using value_type = remove_const_t<remove_reference_t<decltype(x)>>;
                return hash<value_type>{}(x);
            },
            v);
        return detail::hash_combine(val_hash, hash<size_t>{}(v.index()));
    }
};

} // namespace std
