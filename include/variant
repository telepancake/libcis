    using base_type::operator=;
    vmove_ctor(const vmove_ctor&)            = default;
    ~vmove_ctor()                            = default;
    vmove_ctor& operator=(const vmove_ctor&) = default;
    vmove_ctor& operator=(vmove_ctor&&)      = default;
    vmove_ctor(vmove_ctor&&)                 = delete;
};

// --------------------------------------------------------------------------
// vcopy_ctor
// --------------------------------------------------------------------------
template<class Traits, Trait = Traits::copy_constructible_trait>
class vcopy_ctor;

// Trivially copy-constructible
template<class... Types>
class vcopy_ctor<traits<Types...>, Trait::TriviallyAvailable>
    : public vmove_ctor<traits<Types...>>
{
    using base_type = vmove_ctor<traits<Types...>>;
public:
    using base_type::base_type;
    using base_type::operator=;
