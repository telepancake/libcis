namespace detail {

inline long do_strtol(const char* s, size_t* idx, int base) {
    char* end = nullptr;
    errno = 0;
    long r = strtol(s, &end, base);
    if (end == s)         __builtin_trap();
    if (errno == ERANGE)  __builtin_trap();
    if (idx) *idx = static_cast<size_t>(end - s);
    return r;
}
inline unsigned long do_strtoul(const char* s, size_t* idx, int base) {
    char* end = nullptr;
    errno = 0;
    unsigned long r = strtoul(s, &end, base);
    if (end == s)        __builtin_trap();
    if (errno == ERANGE) __builtin_trap();
    if (idx) *idx = static_cast<size_t>(end - s);
    return r;
}
