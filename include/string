//=============================================================================
// to_string / to_wstring — via snprintf
//=============================================================================

namespace detail {

template<class T>
inline string int_to_string(const char* fmt, T v) {
    char buf[64];
    int n = snprintf(buf, sizeof(buf), fmt, v);
    return string(buf, static_cast<string::size_type>(n));
}
inline string flt_to_string(const char* fmt, double v) {
    char buf[64];
    int n = snprintf(buf, sizeof(buf), fmt, v);
    if (n < 0 || static_cast<size_t>(n) >= sizeof(buf)) {
        int n2 = snprintf(nullptr, 0, fmt, v);
        string s(static_cast<string::size_type>(n2), '\0');
        snprintf(s.data(), static_cast<size_t>(n2) + 1, fmt, v);
        return s;
    }
    return string(buf, static_cast<string::size_type>(n));
}
inline string flt_to_string_ld(const char* fmt, long double v) {
    char buf[64];
    int n = snprintf(buf, sizeof(buf), fmt, v);
    if (n < 0 || static_cast<size_t>(n) >= sizeof(buf)) {
        int n2 = snprintf(nullptr, 0, fmt, v);
        string s(static_cast<string::size_type>(n2), '\0');
        snprintf(s.data(), static_cast<size_t>(n2) + 1, fmt, v);
        return s;
    }
    return string(buf, static_cast<string::size_type>(n));
}

} // namespace detail

inline string to_string(int                val) { return detail::int_to_string("%d",   val); }
inline string to_string(unsigned           val) { return detail::int_to_string("%u",   val); }
inline string to_string(long               val) { return detail::int_to_string("%ld",  val); }
inline string to_string(unsigned long      val) { return detail::int_to_string("%lu",  val); }
inline string to_string(long long          val) { return detail::int_to_string("%lld", val); }
inline string to_string(unsigned long long val) { return detail::int_to_string("%llu", val); }
inline string to_string(float              val) { return detail::flt_to_string("%f",  static_cast<double>(val)); }
inline string to_string(double             val) { return detail::flt_to_string("%f",  val); }
inline string to_string(long double        val) { return detail::flt_to_string_ld("%Lf", val); }

namespace detail {

template<class T>
inline wstring int_to_wstring(const wchar_t* fmt, T v) {
    wchar_t buf[64];
    int n = swprintf(buf, sizeof(buf)/sizeof(wchar_t), fmt, v);
    return wstring(buf, static_cast<wstring::size_type>(n));
}
inline wstring flt_to_wstring(const wchar_t* fmt, double v) {
    wchar_t buf[64];
    int n = swprintf(buf, sizeof(buf)/sizeof(wchar_t), fmt, v);
    if (n < 0 || static_cast<size_t>(n) >= sizeof(buf)/sizeof(wchar_t)) {
        string ns = to_string(v);
        return wstring(ns.begin(), ns.end());
    }
    return wstring(buf, static_cast<wstring::size_type>(n));
}
inline wstring flt_to_wstring_ld(const wchar_t* fmt, long double v) {
    wchar_t buf[64];
    int n = swprintf(buf, sizeof(buf)/sizeof(wchar_t), fmt, v);
    if (n < 0 || static_cast<size_t>(n) >= sizeof(buf)/sizeof(wchar_t)) {
        string ns = to_string(v);
        return wstring(ns.begin(), ns.end());
    }
    return wstring(buf, static_cast<wstring::size_type>(n));
}

} // namespace detail

inline wstring to_wstring(int                val) { return detail::int_to_wstring(L"%d",   val); }
inline wstring to_wstring(unsigned           val) { return detail::int_to_wstring(L"%u",   val); }
inline wstring to_wstring(long               val) { return detail::int_to_wstring(L"%ld",  val); }
