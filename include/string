        return assign(il.begin(), il.size());
    }

    // =========================================================================
    // insert
    // =========================================================================

    constexpr basic_string& insert(size_type pos, const value_type* s, size_type n) {
        size_type sz = size();
        if (pos > sz) throw_out_of_range();
        if (n == 0) return *this;
        // Aliasing — if s lives inside our buffer, copy first.
        if (addr_in_range(s)) {
            basic_string tmp(s, n, alloc_);
            return insert(pos, tmp.data(), n);
        }
        if (capacity() - sz < n) reallocate_grow(recommend(sz + n));
        value_type* p = std::to_address(this->begin_);
        size_type n_move = sz - pos;
        if (n_move != 0)
            traits_type::move(p + pos + n, p + pos, n_move);
        traits_type::copy(p + pos, s, n);
        set_size_elems_(sz + n);
        traits_type::assign(p[sz + n], value_type());
        return *this;
    }

    constexpr basic_string& insert(size_type pos, const value_type* s) {
        return insert(pos, s, traits_type::length(s));
    }

    constexpr basic_string& insert(size_type pos, size_type n, value_type c) {
        size_type sz = size();
        if (pos > sz) throw_out_of_range();
        if (n == 0) return *this;
        if (capacity() - sz < n) reallocate_grow(recommend(sz + n));
        value_type* p = std::to_address(this->begin_);
        size_type n_move = sz - pos;
        if (n_move != 0)
            traits_type::move(p + pos + n, p + pos, n_move);
        traits_type::assign(p + pos, n, c);
        set_size_elems_(sz + n);
        traits_type::assign(p[sz + n], value_type());
        return *this;
    }

    constexpr basic_string& insert(size_type pos, const basic_string& str) {
