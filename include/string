    constexpr basic_string& operator=(const basic_string& other) {
        if (this == &other) return *this;
        if constexpr (alloc_traits::propagate_on_container_copy_assignment::value) {
            if (alloc_ != other.alloc_) {
                // must replace allocator: deallocate old first
                if (is_long())
                    alloc_traits::deallocate(alloc_, get_long_pointer(), get_long_cap());
                alloc_ = other.alloc_;
                reset_to_empty_rep();
            }
        }
        return assign_raw(other.data(), other.size());
    }

    constexpr basic_string& operator=(basic_string&& other)
        noexcept(alloc_traits::propagate_on_container_move_assignment::value ||
                 alloc_traits::is_always_equal::value)
    {
        // gcc-10 constexpr rejects comparing `this` against a pointer to a
        // different complete object (PR89074-class); libc++'s move-assign has
        // no self-check at all, so skipping it during constant evaluation is
        // conforming (constexpr self-move is then valid-but-unspecified).
        if (!__builtin_is_constant_evaluated() && this == std::addressof(other)) return *this;
        if constexpr (alloc_traits::propagate_on_container_move_assignment::value) {
            if (is_long())
                alloc_traits::deallocate(alloc_, get_long_pointer(), get_long_cap());
            alloc_ = move(other.alloc_);
            steal_rep(other);
        } else if (alloc_traits::is_always_equal::value || alloc_ == other.alloc_) {
            if (is_long())
                alloc_traits::deallocate(alloc_, get_long_pointer(), get_long_cap());
            steal_rep(other);
        } else {
            // allocators differ and don't propagate: copy
            assign_raw(other.data(), other.size());
        }
        return *this;
    }

