    // =========================================================================
    // Capacity
    // =========================================================================

    [[nodiscard]] constexpr size_type size()   const noexcept { return get_size(); }
    [[nodiscard]] constexpr size_type length() const noexcept { return size(); }
    [[nodiscard]] constexpr bool empty() const noexcept { return size() == 0; }

    [[nodiscard]] constexpr size_type max_size() const noexcept {
        size_type m = alloc_traits::max_size(alloc_);
        // With endian_factor==2 cap must be even so max usable size decreases
        if (m <= numeric_limits<size_type>::max() / 2) {
            size_type res = m - align_val;
            res &= ~size_type(1); // ensure cap is even
            return res - 1;
        } else {
            return (m / 2) - align_val - 1;
        }
    }

    [[nodiscard]] constexpr size_type capacity() const noexcept {
        return (is_long() ? get_long_cap()
                          : static_cast<size_type>(min_cap)) - 1;
    }

    constexpr void reserve(size_type n) {
        if (n <= capacity()) return;
        ensure_capacity(n);
    }

    // Deprecated-in-C++20 but still-present zero-argument reserve():
    // equivalent to shrink_to_fit (libc++ keeps this overload).
    constexpr void reserve() noexcept { shrink_to_fit(); }

    constexpr void shrink_to_fit() noexcept {
        if (!is_long()) return;
        size_type sz = size();
        if (!std::is_constant_evaluated() && fits_in_sso(sz)) {
            // move to short buffer
            pointer p = rep_.l.data.p;
            size_type old_cap = get_long_cap();
            value_type tmp[min_cap + 1];
            traits_type::copy(tmp, std::to_address(p), sz + 1);
            alloc_traits::deallocate(alloc_, p, old_cap);
            rep_ = rep_t{};
            set_short_size(sz);
            traits_type::copy(std::to_address(get_short_pointer()), tmp, sz + 1);
        } else {
            // reallocate to exact size
            size_type exact = align_alloc_size(sz);
            if (exact >= get_long_cap()) return; // already tight
            pointer new_p = alloc_chars(exact);
            size_type old_cap = get_long_cap();
            pointer old_p = get_long_pointer();
            traits_type::copy(std::to_address(new_p), std::to_address(old_p), sz + 1);
            alloc_traits::deallocate(alloc_, old_p, old_cap);
            set_long_rep(exact, sz, new_p);
        }
    }

    constexpr void clear() noexcept {
        set_size(0);
        traits_type::assign(raw_data()[0], value_type());
    }

    constexpr void resize(size_type n, value_type c = value_type()) {
        size_type sz = size();
        if (n < sz) {
            set_size(n);
            traits_type::assign(raw_data()[n], value_type());
        } else if (n > sz) {
            if (n > max_size()) __builtin_trap(); // would throw length_error
            if (n > capacity()) ensure_capacity(n);
            value_type* p = raw_data();
            traits_type::assign(p + sz, n - sz, c);
            traits_type::assign(p[n], value_type());
            set_size(n);
        }
    }

