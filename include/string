    // =========================================================================
    // Modifiers — push/pop
    // =========================================================================

    constexpr void push_back(value_type c) {
        size_type sz  = size();
        size_type cap = capacity();
        if (sz == cap) ensure_capacity(sz + 1);
        value_type* p = raw_data();
        traits_type::assign(p[sz], c);
        set_size(sz + 1);
        traits_type::assign(p[sz + 1], value_type());
    }

    constexpr void pop_back() noexcept {
        size_type sz = size() - 1;
        set_size(sz);
        traits_type::assign(raw_data()[sz], value_type());
    }

    // =========================================================================
    // append
    // =========================================================================

    constexpr basic_string& append(const value_type* s, size_type n) {
        size_type sz  = size();
        size_type cap = capacity();
        if (cap - sz < n) {
            if (addr_in_range(s)) {
                // source aliases our buffer — copy it first
                basic_string tmp(s, n, alloc_);
                return append(tmp.data(), n);
            }
            ensure_capacity(sz + n);
        }
        value_type* p = raw_data();
        traits_type::copy(p + sz, s, n);
        set_size(sz + n);
        traits_type::assign(p[sz + n], value_type());
        return *this;
    }

