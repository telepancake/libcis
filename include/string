// <string> — basic_string<CharT, Traits, Allocator> with SSO.
// Mechanically ported from libc++ include/string (non-alternate ABI layout,
// little-endian __endian_factor == 2).
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// SSO layout (little-endian, default ABI):
//   struct short_rep  { uint8_t is_long:1; uint8_t size:7; char pad[sizeof(CharT)-1]; CharT data[min_cap]; }
//   struct long_rep   { size_t  is_long:1; size_t  cap:63; size_t size; CharT* data; }
//   union rep { short_rep s; long_rep l; }
//   min_cap = (sizeof(long_rep)-1)/sizeof(CharT) >= 2 ? (sizeof(long_rep)-1)/sizeof(CharT) : 2
//   __endian_factor = 2 (little-endian): cap stored as real_cap/2 in the bitfield.
//
// Throwing paths (at, substr pos OOB, reserve/resize length_error):
//   -> __builtin_trap() with comment "would throw <X>"
//
// Deferred (noted inline):
//   getline, operator<<, operator>> (need <istream>/<ostream>)
//
// Reuses from <string_view>: char_traits, basic_string_view, str_find helpers
// Reuses from <memory>: allocator_traits, allocator
// Reuses from <functional>: hash, detail::hash_memory
#pragma once

#include <string_view>    // char_traits, basic_string_view, str_find helpers
#include <memory>         // allocator_traits, allocator, construct_at
#include <iterator>       // reverse_iterator, distance, iterator_traits
#include <algorithm>      // min, max
#include <functional>     // hash, detail::hash_memory
#include <initializer_list>
#include <type_traits>
#include <utility>        // move, forward, swap, exchange
#include <cstdlib>        // strtol, strtod, etc.
#include <cerrno>         // errno, ERANGE
#include <cstdio>         // snprintf
#include <cwchar>
#include <memory_resource>  // pmr::polymorphic_allocator (pmr aliases below)         // wcstol etc.
#include <climits>        // CHAR_BIT

namespace std {

//=============================================================================
// Helper: is_sv_compatible<CharT,Traits,T> — T converts to string_view but
// not to const CharT*. Used for the string_view overload set.
//=============================================================================

namespace detail {

template<class CharT, class Traits, class T>
inline constexpr bool sv_compatible_v =
    is_convertible_v<const T&, basic_string_view<CharT, Traits>> &&
    !is_convertible_v<const T&, const CharT*>;

// libc++ __has_input_iterator_category: the iterator's category must derive
// from input_iterator_tag (excludes e.g. back_insert_iterator, whose
// category is output_iterator_tag).
template<class It>
inline constexpr bool string_input_iter_v = requires {
    typename iterator_traits<It>::iterator_category;
    requires is_base_of_v<input_iterator_tag,
                          typename iterator_traits<It>::iterator_category>;
};

// libc++ __is_allocator: constrains basic_string's deduction guides so that
// a non-allocator second argument makes deduction fail (SFINAE) instead of
// hard-erroring inside allocator_traits.
template<class Alloc>
inline constexpr bool string_is_allocator_v = requires(Alloc& a) {
    typename Alloc::value_type;
    a.allocate(size_t{});
};

// Trivial iterator: pointer-to-arithmetic — safe for memcpy paths.
template<class Iter>
inline constexpr bool string_trivial_iter_v = false;
template<class T>
inline constexpr bool string_trivial_iter_v<T*> = is_arithmetic_v<T>;

} // namespace detail

//=============================================================================
// basic_string
//=============================================================================

template<class CharT,
         class Traits    = char_traits<CharT>,
         class Allocator = allocator<CharT>>
class basic_string {
public:
    // -------------------------------------------------------------------------
    // types
    // -------------------------------------------------------------------------
    using traits_type            = Traits;
    using value_type             = CharT;
    using allocator_type         = Allocator;
    using alloc_traits           = allocator_traits<Allocator>;
    using size_type              = typename alloc_traits::size_type;
    using difference_type        = typename alloc_traits::difference_type;
    using reference              = value_type&;
    using const_reference        = const value_type&;
    using pointer                = typename alloc_traits::pointer;
    using const_pointer          = typename alloc_traits::const_pointer;
    using iterator               = pointer;
    using const_iterator         = const_pointer;
    using reverse_iterator       = std::reverse_iterator<iterator>;
    using const_reverse_iterator = std::reverse_iterator<const_iterator>;

    static constexpr size_type npos = size_type(-1);

    static_assert(!is_array_v<value_type>,
        "Character type of basic_string must not be an array");
    static_assert(is_standard_layout_v<value_type>,
        "Character type of basic_string must be standard-layout");
    static_assert(is_trivially_copyable_v<value_type>,
        "Character type of basic_string must be trivially copyable");
    static_assert(is_same_v<CharT, typename traits_type::char_type>,
        "traits_type::char_type must be the same type as CharT");
    static_assert(is_same_v<typename allocator_type::value_type, value_type>,
        "Allocator::value_type must be same type as value_type");

private:
    // -------------------------------------------------------------------------
    // SSO representation
    //
    // We use a simple, portable layout that avoids __attribute__((packed)):
    //
    // short_rep (small string): all data fits in-line.
    //   - First byte: 0x00 (is_long=0) | size in bits [7:1]
    //     The is_long flag is in bit 0 of the first byte.
    //     Size is in bits 7:1 (i.e., stored as size<<1 in the byte).
    //   - Remaining bytes: the character array.
    //     data[] starts at offset sizeof(value_type) relative to the struct start.
    //
    // long_rep (heap-allocated):
    //   - First size_type word: cap_word where bit 0 == 1 (is_long flag),
    //     cap stored as (real_cap>>1) in bits [N:1].
    //   - Second size_type word: size.
    //   - pointer: the heap data.
    //
    // Both reps alias at byte offset 0 to detect is_long via bit 0.
    //
    // min_cap: size of inline buffer (number of CharT, excl. null terminator).
    //   sizeof(long_rep) == sizeof(size_type)*2 + sizeof(pointer)
    //   short_rep total size = sizeof(long_rep)
    //   minus one byte for the size/flag byte = (sizeof(long_rep)-1) / sizeof(CharT)
    //   but at least 2.
    //
    // For char (1 byte): sizeof(long_rep) = 24 on 64-bit -> min_cap = 23.
    // For wchar_t (4 byte): sizeof(long_rep) = 24 -> min_cap = 5 (>=2).
    // -------------------------------------------------------------------------

    // constexpr-only control block ("anchor"): g++-10 evaluates the destructor
    // of a by-value function parameter on the PRE-CALL value of its members
    // (mutations inside the callee are invisible to the destructor; proven by
    // a libcis-independent probe, fixed in later gcc).  Heap state IS visible,
    // so under constant evaluation the long rep's {data, cap, size} live in a
    // heap-allocated ce_anchor that is created once per object and never
    // replaced; all mutations go through it.  Zero effect on runtime layout:
    // the anchor pointer shares a union with the ordinary data pointer.
    struct ce_anchor { pointer data; size_type cap; size_type sz; };

    struct long_rep {
        size_type cap_word; // bit 0 = is_long (always 1), bits[N:1] = real_cap >> 1
        size_type sz;
        union data_u {
            pointer    p;   // runtime: heap character buffer
            ce_anchor* anc; // constant evaluation: control block
            constexpr data_u() : p() {}
            constexpr data_u(pointer q) : p(q) {}
        } data;
    };

    // Calculate min_cap as a constexpr function to avoid circular dependency
    // with sizeof(long_rep).
    // sizeof(long_rep) = 2*sizeof(size_type) + sizeof(pointer)
    // = 2*8 + 8 = 24 on 64-bit, 2*4+4=12 on 32-bit.
    // short_rep has (sizeof(long_rep)) bytes total; 1 byte for flag/size;
    // remaining = sizeof(long_rep)-1 bytes / sizeof(CharT) chars.
    static constexpr size_type compute_min_cap() {
        size_type lsz = sizeof(long_rep);
        size_type avail = (lsz - 1) / sizeof(value_type);
        return avail > 2 ? avail : 2;
    }
    enum : size_type { min_cap = compute_min_cap() };

    // short_rep: same total size as long_rep.
    // Layout: 1 byte flag/size, then (sizeof(long_rep)-1) raw bytes for data.
    // We use unsigned char[] for storage to avoid alignment issues.
    struct short_rep {
        unsigned char flag_sz; // bit 0 = 0 (is_long=0), bits[7:1] = size
        // Remaining storage for CharT array (aligned by the union).
        // We use a raw byte array; characters are accessed via reinterpret_cast
        // in get_short_pointer().
        unsigned char data_bytes[sizeof(long_rep) - 1];
    };

    static_assert(sizeof(short_rep) == sizeof(long_rep), "SSO layout mismatch");

    union rep_t {
        short_rep s;
        long_rep  l;
        unsigned char raw[sizeof(long_rep)]; // for flag detection
        constexpr rep_t() : s{} {}
    };

    rep_t          rep_;
    // EBO for empty allocators: keeps sizeof(string) at 24 (3 words) like
    // libc++, not 32.  (vector uses the same attribute on its allocator.)
    [[no_unique_address]] allocator_type alloc_;

    // -------------------------------------------------------------------------
    // rep accessors
    // -------------------------------------------------------------------------

    // is_long: bit 0 of the first byte of the union.
    // In constant evaluation the string is ALWAYS in the long (heap) rep —
    // the short rep needs reinterpret_cast / inactive-union-member reads,
    // which are forbidden in constexpr (libc++ uses the same strategy of
    // special-casing constant evaluation).
    constexpr bool is_long() const noexcept {
        if (std::is_constant_evaluated()) return true;
        return (rep_.raw[0] & 1) != 0;
    }
    static constexpr bool fits_in_sso(size_type sz) { return sz < min_cap; }

    // short accessors
    // size stored in bits [7:1] of flag_sz byte: size = flag_sz >> 1
    constexpr size_type get_short_size() const noexcept {
        return static_cast<size_type>(rep_.s.flag_sz >> 1);
    }
    constexpr void set_short_size(size_type n) noexcept {
        rep_.s.flag_sz = static_cast<unsigned char>(n << 1); // bit 0 = 0 (short)
    }

    // long accessors
    // cap_word: bit 0 = 1, cap = cap_word >> 1 (i.e., real_cap / 2 stored)
    constexpr size_type get_long_size() const noexcept {
        return std::is_constant_evaluated() ? rep_.l.data.anc->sz : rep_.l.sz;
    }
    constexpr void set_long_size(size_type n) noexcept {
        if (std::is_constant_evaluated()) rep_.l.data.anc->sz = n;
        else                              rep_.l.sz = n;
    }
    constexpr size_type get_long_cap() const noexcept {
        return std::is_constant_evaluated() ? rep_.l.data.anc->cap
                                            : (rep_.l.cap_word & ~size_type(1));
    }
    constexpr pointer get_long_pointer() noexcept {
        return std::is_constant_evaluated() ? rep_.l.data.anc->data : rep_.l.data.p;
    }
    constexpr const_pointer get_long_pointer() const noexcept {
        if (std::is_constant_evaluated()) return const_pointer(rep_.l.data.anc->data);
        return const_pointer(rep_.l.data.p);
    }

    // Install a freshly allocated long buffer.
    //  - set_long_rep:       object already long / has an anchor (ce).
    //  - set_long_rep_fresh: object is being constructed (creates the anchor).
    constexpr void set_long_rep(size_type actual, size_type szv, pointer p) noexcept {
        if (std::is_constant_evaluated()) {
            ce_anchor* a = rep_.l.data.anc;
            a->data = p; a->cap = actual; a->sz = szv;
        } else {
            rep_.l = long_rep{actual | size_type(1), szv, p};
        }
    }
    constexpr void set_long_rep_fresh(size_type actual, size_type szv, pointer p) {
        if (std::is_constant_evaluated()) {
            long_rep lr{};
            rep_.l = lr;                                 // activate long member
            rep_.l.data.anc = new ce_anchor{p, actual, szv};
        } else {
            rep_.l = long_rep{actual | size_type(1), szv, p};
        }
    }

    // libc++ __get_short_pointer: form the allocator `pointer` from the raw
    // in-union buffer via pointer_traits<pointer>::pointer_to (fancy-pointer
    // safe; raw pointers collapse to &buf[0]).  Never used in constexpr.
    pointer get_short_pointer() noexcept {
        return pointer_traits<pointer>::pointer_to(
            *reinterpret_cast<value_type*>(rep_.s.data_bytes));
    }
    const_pointer get_short_pointer() const noexcept {
        return pointer_traits<const_pointer>::pointer_to(
            *reinterpret_cast<const value_type*>(rep_.s.data_bytes));
    }

    constexpr pointer get_pointer() noexcept {
        return is_long() ? get_long_pointer() : get_short_pointer();
    }
    constexpr const_pointer get_pointer() const noexcept {
        return is_long() ? get_long_pointer() : get_short_pointer();
    }

    // raw (unfancied) data pointer for Traits ops — libc++ __to_data / std::__to_address
    constexpr value_type* raw_data() noexcept { return std::to_address(get_pointer()); }
    constexpr const value_type* raw_data() const noexcept { return std::to_address(get_pointer()); }

    // unified size get/set
    constexpr size_type get_size() const noexcept {
        return is_long() ? get_long_size() : get_short_size();
    }
    constexpr void set_size(size_type n) noexcept {
        if (is_long()) set_long_size(n);
        else           set_short_size(n);
    }

    // -------------------------------------------------------------------------
    // Internal allocation helpers
    // -------------------------------------------------------------------------

    static constexpr size_type align_val = 8; // allocation alignment hint

    static constexpr size_type align_alloc_size(size_type sz) noexcept {
        // Round up (sz+1) to a multiple of boundary, ensuring we allocate enough.
        const size_type boundary =
            sizeof(value_type) < align_val
            ? align_val / sizeof(value_type)
            : size_type(2);
        size_type guess = ((sz + 1) + (boundary - 1)) & ~(boundary - 1);
        if (guess == min_cap + 1) guess += 2;
        return guess;
    }

    constexpr size_type amortized_grow(size_type required) {
        size_type ms = max_size();
        if (required > ms) __builtin_trap(); // would throw length_error
        size_type cur = capacity();
        if (cur > ms / 2 - align_val) return ms;
        size_type dbl = 2 * cur;
        return required > dbl ? required : dbl;
    }

    // Allocate `actual` characters and (in constant evaluation) begin the
    // lifetime of every element so they can be written through Traits ops.
    constexpr pointer alloc_chars(size_type actual) {
        pointer p = alloc_traits::allocate(alloc_, actual);
        if (std::is_constant_evaluated()) {
            for (size_type i = 0; i < actual; ++i)
                std::construct_at(std::to_address(p) + i, value_type());
        }
        return p;
    }

    // Reset *this to an empty string without freeing anything (the caller
    // owns/has taken the old buffer).  In constant evaluation this allocates
    // an empty long buffer (constexpr strings are always long).
    constexpr void reset_to_empty_rep() {
        if (std::is_constant_evaluated()) {
            size_type actual = align_alloc_size(0);
            pointer p = alloc_chars(actual);
            ce_anchor* a = rep_.l.data.anc;
            a->data = p; a->cap = actual; a->sz = 0;
        } else {
            rep_ = rep_t{};
            set_short_size(0);
            traits_type::assign(get_short_pointer()[0], value_type());
        }
    }

    // Establish the empty state in a ctor (fresh object: creates the anchor).
    constexpr void init_empty() {
        if (std::is_constant_evaluated()) {
            size_type actual = align_alloc_size(0);
            pointer p = alloc_chars(actual);
            set_long_rep_fresh(actual, 0, p);
        } else {
            set_short_size(0);
            traits_type::assign(get_short_pointer()[0], value_type());
        }
    }

    // Take other's contents (O(1)); other becomes empty.  steal_rep_fresh is
    // for ctors (no anchor yet), steal_rep for assignment (anchor exists).
    constexpr void steal_rep_fresh(basic_string& other) {
        if (std::is_constant_evaluated()) {
            ce_anchor* oa = other.rep_.l.data.anc;
            set_long_rep_fresh(oa->cap, oa->sz, oa->data);
            other.reset_to_empty_rep();
        } else {
            rep_       = other.rep_;
            other.rep_ = rep_t{};
            other.set_short_size(0);
            traits_type::assign(other.get_short_pointer()[0], value_type());
        }
    }
    constexpr void steal_rep(basic_string& other) {
        if (std::is_constant_evaluated()) {
            ce_anchor* oa = other.rep_.l.data.anc;
            set_long_rep(oa->cap, oa->sz, oa->data);
            other.reset_to_empty_rep();
        } else {
            rep_       = other.rep_;
            other.rep_ = rep_t{};
            other.set_short_size(0);
            traits_type::assign(other.get_short_pointer()[0], value_type());
        }
    }

    // Free current long buffer (does NOT change rep)
    constexpr void dealloc_long() noexcept {
        if (is_long())
            alloc_traits::deallocate(alloc_, get_long_pointer(), get_long_cap());
    }

    // -------------------------------------------------------------------------
    // init(const CharT*, size_type)  — core initialiser
    // -------------------------------------------------------------------------
    constexpr void init(const value_type* s, size_type sz) {
        if (sz > max_size()) __builtin_trap(); // would throw length_error
        if (!std::is_constant_evaluated() && fits_in_sso(sz)) {
            set_short_size(sz);
            value_type* p = std::to_address(get_short_pointer());
            traits_type::copy(p, s, sz);
            traits_type::assign(p[sz], value_type());
        } else {
            size_type actual = align_alloc_size(sz);
            pointer pp = alloc_chars(actual);
            value_type* p = std::to_address(pp);
            traits_type::copy(p, s, sz);
            traits_type::assign(p[sz], value_type());
            set_long_rep_fresh(actual, sz, pp);
        }
    }

    constexpr void init(size_type n, value_type c) {
        if (n > max_size()) __builtin_trap(); // would throw length_error
        if (!std::is_constant_evaluated() && fits_in_sso(n)) {
            set_short_size(n);
            value_type* p = std::to_address(get_short_pointer());
            traits_type::assign(p, n, c);
            traits_type::assign(p[n], value_type());
        } else {
            size_type actual = align_alloc_size(n);
            pointer pp = alloc_chars(actual);
            value_type* p = std::to_address(pp);
            traits_type::assign(p, n, c);
            traits_type::assign(p[n], value_type());
            set_long_rep_fresh(actual, n, pp);
        }
    }

    template<class InputIt, class Sentinel>
    constexpr void init_sentinel(InputIt first, Sentinel last) {
        // slow path: unknown length — push_back one by one
        init_empty();
        for (; first != last; ++first) push_back(*first);
    }

    template<class FwdIt>
    constexpr void init_fwd(FwdIt first, FwdIt last) {
        size_type sz = static_cast<size_type>(std::distance(first, last));
        if (sz > max_size()) __builtin_trap(); // would throw length_error
        value_type* p;
        if (!std::is_constant_evaluated() && fits_in_sso(sz)) {
            set_short_size(sz);
            p = std::to_address(get_short_pointer());
            for (size_type i = 0; first != last; ++first, ++i)
                traits_type::assign(p[i], *first);
            traits_type::assign(p[sz], value_type());
        } else {
            size_type actual = align_alloc_size(sz);
            pointer pp = alloc_chars(actual);
            p = std::to_address(pp);
            for (size_type i = 0; first != last; ++first, ++i)
                traits_type::assign(p[i], *first);
            traits_type::assign(p[sz], value_type());
            set_long_rep_fresh(actual, sz, pp);
        }
    }

    // -------------------------------------------------------------------------
    // grow_by_and_replace: reallocate with new content inserted in the middle.
    //   Copies [0..n_copy) from old buffer, inserts n_add chars from p_new,
    //   then copies [n_copy+n_del..old_sz) from old buffer.
    // -------------------------------------------------------------------------
    constexpr void grow_by_and_replace(size_type old_cap,
                             size_type delta_cap,
                             size_type old_sz,
                             size_type n_copy,
                             size_type n_del,
                             size_type n_add,
                             const value_type* p_new)
    {
        size_type new_cap = amortized_grow(old_cap + delta_cap);
        size_type new_cap_actual = align_alloc_size(new_cap);
        pointer new_data  = alloc_chars(new_cap_actual);
        value_type* nd    = std::to_address(new_data);

        value_type* old_p = raw_data();
        if (n_copy != 0)
            traits_type::copy(nd, old_p, n_copy);
        if (n_add != 0)
            traits_type::copy(nd + n_copy, p_new, n_add);
        size_type sec = old_sz - n_del - n_copy;
        if (sec != 0)
            traits_type::copy(nd + n_copy + n_add, old_p + n_copy + n_del, sec);
        size_type new_sz = n_copy + n_add + sec;
        traits_type::assign(nd[new_sz], value_type());

        dealloc_long();
        set_long_rep(new_cap_actual, new_sz, new_data);
    }

    // grow_by_without_replace: reallocate and move content, no replacement.
    constexpr void grow_by_without_replace(size_type old_cap,
                                 size_type delta_cap,
                                 size_type old_sz,
                                 size_type n_copy,
                                 size_type n_del,
                                 size_type n_add = 0)
    {
        size_type new_cap = amortized_grow(old_cap + delta_cap);
        size_type new_cap_actual = align_alloc_size(new_cap);
        pointer new_data  = alloc_chars(new_cap_actual);
        value_type* nd    = std::to_address(new_data);

        value_type* old_p = raw_data();
        if (n_copy != 0)
            traits_type::copy(nd, old_p, n_copy);
        size_type sec = old_sz - n_del - n_copy;
        if (sec != 0)
            traits_type::copy(nd + n_copy + n_add, old_p + n_copy + n_del, sec);

        dealloc_long();
        set_long_rep(new_cap_actual, old_sz - n_del + n_add, new_data);
    }

    // ensure_capacity: reserve without changing size/content
    constexpr void ensure_capacity(size_type new_cap) {
        if (new_cap <= capacity()) return;
        if (new_cap > max_size()) __builtin_trap(); // would throw length_error
        size_type old_sz  = size();
        size_type old_cap = capacity();
        grow_by_without_replace(old_cap, new_cap - old_cap, old_sz, old_sz, 0);
        // Restore null terminator
        traits_type::assign(raw_data()[old_sz], value_type());
    }

    // -------------------------------------------------------------------------
    // assign helpers
    // -------------------------------------------------------------------------

    constexpr basic_string& assign_raw(const value_type* s, size_type n) {
        size_type cap = capacity();
        if (cap >= n) {
            // fits in current buffer
            traits_type::move(raw_data(), s, n);
            set_size(n);
            traits_type::assign(raw_data()[n], value_type());
        } else {
            size_type old_sz = size();
            grow_by_and_replace(cap, n - cap, old_sz, 0, old_sz, n, s);
        }
        return *this;
    }

    // half-open pointer-in-range check that is constexpr-safe: comparing
    // unrelated pointers is non-constant; libc++ (__is_pointer_in_range)
    // detects that with __builtin_constant_p and answers false (no overlap).
    static constexpr bool ptr_in_range(const value_type* lo, const value_type* hi,
                                       const value_type* p) noexcept {
        if (std::is_constant_evaluated()) {
            if (!__builtin_constant_p(lo <= p && p < hi)) return false;
        }
        return lo <= p && p < hi;
    }

    static constexpr bool ptr_in_range_void(const void* lo, const void* hi,
                                            const void* p) noexcept {
        if (std::is_constant_evaluated()) {
            if (!__builtin_constant_p(lo <= p && p < hi)) return false;
        }
        return lo <= p && p < hi;
    }

    // pointer in range [data(), data()+size()+1).  In constant evaluation
    // comparing unrelated pointers is non-constant; libc++ (__is_pointer_in_range)
    // detects that with __builtin_constant_p and answers false (no overlap).
    constexpr bool addr_in_range(const value_type* p) const noexcept {
        return ptr_in_range(data(), data() + size() + 1, p);
    }

public:
    // =========================================================================
    // Constructors
    // =========================================================================

    constexpr basic_string() noexcept(noexcept(allocator_type())) : rep_(), alloc_() {
        init_empty();
    }

    explicit constexpr basic_string(const allocator_type& a) noexcept : rep_(), alloc_(a) {
        init_empty();
    }

    // copy ctor
    constexpr basic_string(const basic_string& other)
        : rep_(), alloc_(alloc_traits::select_on_container_copy_construction(other.alloc_))
    {
        init(other.data(), other.size());
    }

