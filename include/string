inline long do_strtol(const char* s, size_t* idx, int base) {
    char* end = nullptr;
    errno = 0;
    long r = strtol(s, &end, base);
    if (end == s)         __builtin_trap(); // would throw invalid_argument
    if (errno == ERANGE)  __builtin_trap(); // would throw out_of_range
    if (idx) *idx = static_cast<size_t>(end - s);
    return r;
}
