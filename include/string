    // =========================================================================
    // erase
    // =========================================================================

    constexpr basic_string& erase(size_type pos = 0, size_type n = npos) {
        size_type sz = size();
        if (pos > sz) throw_out_of_range();
        size_type xlen = detail::sv_min(n, sz - pos);
        if (xlen == 0) return *this;
        size_type new_sz = sz - xlen;
        value_type* p = std::to_address(this->begin_);
        traits_type::move(p + pos, p + pos + xlen, new_sz - pos);
        set_size_elems_(new_sz);
        traits_type::assign(p[new_sz], value_type());
        return *this;
    }

    constexpr iterator erase(const_iterator position) {
        size_type ip = static_cast<size_type>(position - begin());
        erase(ip, 1);
        return begin() + ip;
    }

    constexpr iterator erase(const_iterator first, const_iterator last) {
        size_type pos = static_cast<size_type>(first - begin());
        size_type n   = static_cast<size_type>(last - first);
        erase(pos, n);
        return begin() + pos;
    }

    // =========================================================================
    // replace
    // =========================================================================

    constexpr basic_string& replace(size_type pos, size_type n1, const value_type* s, size_type n2) {
        size_type sz = size();
        if (pos > sz) throw_out_of_range();
        n1 = detail::sv_min(n1, sz - pos);
        size_type new_sz = sz - n1 + n2;
        // Aliasing: capture a copy when s points into our buffer.
        if (addr_in_range(s) && n2 != 0) {
            basic_string tmp(s, n2, alloc_);
            return replace(pos, n1, tmp.data(), n2);
        }
        if (new_sz > capacity()) reallocate_grow(recommend(new_sz));
        if (this->begin_ == nullptr) return *this; // new_sz == 0 && unallocated
        value_type* p = std::to_address(this->begin_);
        // Shift tail [pos+n1, sz) to [pos+n2, sz-n1+n2).
        if (sz - pos - n1 != 0)
            traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
        if (n2 != 0)
            traits_type::copy(p + pos, s, n2);
        set_size_elems_(new_sz);
        traits_type::assign(p[new_sz], value_type());
        return *this;
    }

    constexpr basic_string& replace(size_type pos, size_type n1, const value_type* s) {
        return replace(pos, n1, s, traits_type::length(s));
    }

    constexpr basic_string& replace(size_type pos, size_type n1, size_type n2, value_type c) {
        size_type sz = size();
        if (pos > sz) throw_out_of_range();
        n1 = detail::sv_min(n1, sz - pos);
        size_type new_sz = sz - n1 + n2;
        if (new_sz > capacity()) reallocate_grow(recommend(new_sz));
        if (this->begin_ == nullptr) return *this; // new_sz == 0 && unallocated
        value_type* p = std::to_address(this->begin_);
        if (sz - pos - n1 != 0)
            traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
        if (n2 != 0)
            traits_type::assign(p + pos, n2, c);
        set_size_elems_(new_sz);
        traits_type::assign(p[new_sz], value_type());
        return *this;
    }

    constexpr basic_string& replace(size_type pos, size_type n1, const basic_string& str) {
        return replace(pos, n1, str.data(), str.size());
    }

    constexpr basic_string& replace(size_type pos1, size_type n1, const basic_string& str,
