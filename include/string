    template<class InputIt>
        requires detail::string_input_iter_v<InputIt>
    constexpr iterator insert(const_iterator pos, InputIt first, InputIt last) {
        size_type ip = static_cast<size_type>(pos - begin());
        basic_string tmp(first, last, alloc_);
        insert(ip, tmp.data(), tmp.size());
        return begin() + ip;
    }

    constexpr iterator insert(const_iterator pos, initializer_list<value_type> il) {
        size_type ip = static_cast<size_type>(pos - begin());
        insert(ip, il.begin(), il.size());
        return begin() + ip;
    }

    // =========================================================================
    // erase
    // =========================================================================

    constexpr basic_string& erase(size_type pos = 0, size_type n = npos) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        size_type xlen = detail::sv_min(n, sz - pos);
        size_type new_sz = sz - xlen;
        value_type* p = raw_data();
        traits_type::move(p + pos, p + pos + xlen, new_sz - pos);
        set_size(new_sz);
        traits_type::assign(p[new_sz], value_type());
        return *this;
    }

    constexpr iterator erase(const_iterator position) {
        size_type ip = static_cast<size_type>(position - begin());
        erase(ip, 1);
        return begin() + ip;
    }

    constexpr iterator erase(const_iterator first, const_iterator last) {
        size_type pos = static_cast<size_type>(first - begin());
        size_type n   = static_cast<size_type>(last - first);
        erase(pos, n);
        return begin() + pos;
    }

    // =========================================================================
    // replace
    // =========================================================================

    constexpr basic_string& replace(size_type pos, size_type n1, const value_type* s, size_type n2) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        n1 = detail::sv_min(n1, sz - pos);
        size_type cap = capacity();
        if (sz - n1 + n2 > cap) {
            grow_by_and_replace(cap, sz - n1 + n2 - cap, sz, pos, n1, n2, s);
        } else {
            value_type* p = raw_data();
            // Handle possible alias
            if (addr_in_range(s)) {
                basic_string tmp(s, n2, alloc_);
                traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
                traits_type::copy(p + pos, tmp.data(), n2);
            } else {
                traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
                traits_type::copy(p + pos, s, n2);
            }
            size_type new_sz = sz - n1 + n2;
            set_size(new_sz);
            traits_type::assign(p[new_sz], value_type());
        }
        return *this;
    }

    constexpr basic_string& replace(size_type pos, size_type n1, const value_type* s) {
        return replace(pos, n1, s, traits_type::length(s));
    }

    constexpr basic_string& replace(size_type pos, size_type n1, size_type n2, value_type c) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        n1 = detail::sv_min(n1, sz - pos);
        size_type cap = capacity();
        value_type* p = raw_data();
        if (sz - n1 + n2 > cap) {
            // build fill buffer and replace
            basic_string tmp(n2, c, alloc_);
            grow_by_and_replace(cap, sz - n1 + n2 - cap, sz, pos, n1, n2, tmp.data());
        } else {
            traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
            traits_type::assign(p + pos, n2, c);
            size_type new_sz = sz - n1 + n2;
            set_size(new_sz);
            traits_type::assign(p[new_sz], value_type());
        }
        return *this;
    }

    constexpr basic_string& replace(size_type pos, size_type n1, const basic_string& str) {
        return replace(pos, n1, str.data(), str.size());
    }

    constexpr basic_string& replace(size_type pos1, size_type n1, const basic_string& str,
                          size_type pos2, size_type n2 = npos) {
        size_type sz = str.size();
        if (pos2 > sz) __builtin_trap(); // would throw out_of_range
        return replace(pos1, n1, str.data() + pos2, detail::sv_min(n2, sz - pos2));
    }

    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr basic_string& replace(size_type pos, size_type n, const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return replace(pos, n, sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    constexpr basic_string& replace(size_type pos1, size_type n1, const T& t,
                          size_type pos2, size_type n2 = npos) {
        basic_string_view<CharT, Traits> sv = t;
        if (pos2 > sv.size()) __builtin_trap(); // would throw out_of_range
        return replace(pos1, n1, sv.data() + pos2, detail::sv_min(n2, sv.size() - pos2));
    }

    // iterator-based replace overloads
    constexpr basic_string& replace(const_iterator i1, const_iterator i2, const basic_string& str) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1),
                       str.data(), str.size());
    }
    constexpr basic_string& replace(const_iterator i1, const_iterator i2,
                          const value_type* s, size_type n) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), s, n);
    }
    constexpr basic_string& replace(const_iterator i1, const_iterator i2, const value_type* s) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), s);
    }
    constexpr basic_string& replace(const_iterator i1, const_iterator i2,
                          size_type n, value_type c) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), n, c);
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr basic_string& replace(const_iterator i1, const_iterator i2, const T& t) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), t);
    }
    template<class InputIt>
        requires detail::string_input_iter_v<InputIt>
    constexpr basic_string& replace(const_iterator i1, const_iterator i2,
                          InputIt j1, InputIt j2) {
        basic_string tmp(j1, j2, alloc_);
        return replace(i1, i2, tmp);
    }
    constexpr basic_string& replace(const_iterator i1, const_iterator i2,
                          initializer_list<value_type> il) {
        return replace(i1, i2, il.begin(), il.end());
    }

    // =========================================================================
    // copy, substr, swap
    // =========================================================================

    constexpr size_type copy(value_type* s, size_type n, size_type pos = 0) const {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        size_type rlen = detail::sv_min(n, sz - pos);
        traits_type::copy(s, data() + pos, rlen);
        return rlen;
    }

    [[nodiscard]] constexpr basic_string substr(size_type pos = 0, size_type n = npos) const& {
        return basic_string(*this, pos, n);   // P2438: result uses Allocator()
    }

    [[nodiscard]] constexpr basic_string substr(size_type pos = 0, size_type n = npos) && {
        return basic_string(move(*this), pos, n);
    }

    constexpr void swap(basic_string& other) noexcept(
        alloc_traits::propagate_on_container_swap::value ||
        alloc_traits::is_always_equal::value)
    {
        if (std::is_constant_evaluated()) {
            // swap anchor CONTENTS, never the anchors themselves (each object's
            // anchor must stay with it for its whole lifetime — see ce_anchor).
            ce_anchor* a = rep_.l.data.anc;
            ce_anchor* b = other.rep_.l.data.anc;
            pointer   tp = a->data;
            size_type tc = a->cap;
            size_type ts = a->sz;
            a->data = b->data; a->cap = b->cap; a->sz = b->sz;
            b->data = tp;      b->cap = tc;     b->sz = ts;
        } else {
            std::swap(rep_, other.rep_);
        }
        if constexpr (alloc_traits::propagate_on_container_swap::value)
            std::swap(alloc_, other.alloc_);
    }

    // =========================================================================
    // Search (delegate to string_view helpers from <string_view>)
    // =========================================================================

    // --- find ---
    constexpr size_type find(const value_type* s, size_type pos, size_type n) const noexcept {
        return str_find<value_type, size_type, traits_type, npos>(data(), size(), s, pos, n);
    }
    constexpr size_type find(const value_type* s, size_type pos = 0) const noexcept {
        return find(s, pos, traits_type::length(s));
    }
    constexpr size_type find(value_type c, size_type pos = 0) const noexcept {
        return str_find<value_type, size_type, traits_type, npos>(data(), size(), c, pos);
    }
    constexpr size_type find(const basic_string& str, size_type pos = 0) const noexcept {
        return find(str.data(), pos, str.size());
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr size_type find(const T& t, size_type pos = 0) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return find(sv.data(), pos, sv.size());
    }

    // --- rfind ---
    constexpr size_type rfind(const value_type* s, size_type pos, size_type n) const noexcept {
        return str_rfind<value_type, size_type, traits_type, npos>(data(), size(), s, pos, n);
    }
    constexpr size_type rfind(const value_type* s, size_type pos = npos) const noexcept {
        return rfind(s, pos, traits_type::length(s));
    }
    constexpr size_type rfind(value_type c, size_type pos = npos) const noexcept {
        return str_rfind<value_type, size_type, traits_type, npos>(data(), size(), c, pos);
    }
    constexpr size_type rfind(const basic_string& str, size_type pos = npos) const noexcept {
        return rfind(str.data(), pos, str.size());
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr size_type rfind(const T& t, size_type pos = npos) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return rfind(sv.data(), pos, sv.size());
    }

    // --- find_first_of ---
    constexpr size_type find_first_of(const value_type* s, size_type pos, size_type n) const noexcept {
        return str_find_first_of<value_type, size_type, traits_type, npos>(data(), size(), s, pos, n);
    }
    constexpr size_type find_first_of(const value_type* s, size_type pos = 0) const noexcept {
        return find_first_of(s, pos, traits_type::length(s));
    }
    constexpr size_type find_first_of(value_type c, size_type pos = 0) const noexcept {
        return find(c, pos);
    }
    constexpr size_type find_first_of(const basic_string& str, size_type pos = 0) const noexcept {
        return find_first_of(str.data(), pos, str.size());
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr size_type find_first_of(const T& t, size_type pos = 0) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return find_first_of(sv.data(), pos, sv.size());
    }

    // --- find_last_of ---
    constexpr size_type find_last_of(const value_type* s, size_type pos, size_type n) const noexcept {
        return str_find_last_of<value_type, size_type, traits_type, npos>(data(), size(), s, pos, n);
    }
    constexpr size_type find_last_of(const value_type* s, size_type pos = npos) const noexcept {
        return find_last_of(s, pos, traits_type::length(s));
    }
    constexpr size_type find_last_of(value_type c, size_type pos = npos) const noexcept {
        return rfind(c, pos);
    }
    constexpr size_type find_last_of(const basic_string& str, size_type pos = npos) const noexcept {
        return find_last_of(str.data(), pos, str.size());
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr size_type find_last_of(const T& t, size_type pos = npos) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return find_last_of(sv.data(), pos, sv.size());
    }

    // --- find_first_not_of ---
    constexpr size_type find_first_not_of(const value_type* s, size_type pos, size_type n) const noexcept {
        return str_find_first_not_of<value_type, size_type, traits_type, npos>(data(), size(), s, pos, n);
    }
    constexpr size_type find_first_not_of(const value_type* s, size_type pos = 0) const noexcept {
        return find_first_not_of(s, pos, traits_type::length(s));
    }
    constexpr size_type find_first_not_of(value_type c, size_type pos = 0) const noexcept {
        return str_find_first_not_of<value_type, size_type, traits_type, npos>(data(), size(), c, pos);
    }
    constexpr size_type find_first_not_of(const basic_string& str, size_type pos = 0) const noexcept {
        return find_first_not_of(str.data(), pos, str.size());
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr size_type find_first_not_of(const T& t, size_type pos = 0) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return find_first_not_of(sv.data(), pos, sv.size());
    }

    // --- find_last_not_of ---
    constexpr size_type find_last_not_of(const value_type* s, size_type pos, size_type n) const noexcept {
        return str_find_last_not_of<value_type, size_type, traits_type, npos>(data(), size(), s, pos, n);
    }
    constexpr size_type find_last_not_of(const value_type* s, size_type pos = npos) const noexcept {
        return find_last_not_of(s, pos, traits_type::length(s));
    }
    constexpr size_type find_last_not_of(value_type c, size_type pos = npos) const noexcept {
        return str_find_last_not_of<value_type, size_type, traits_type, npos>(data(), size(), c, pos);
    }
    constexpr size_type find_last_not_of(const basic_string& str, size_type pos = npos) const noexcept {
        return find_last_not_of(str.data(), pos, str.size());
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr size_type find_last_not_of(const T& t, size_type pos = npos) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return find_last_not_of(sv.data(), pos, sv.size());
    }

    // =========================================================================
    // compare
    // =========================================================================

    constexpr int compare(const basic_string& str) const noexcept {
        return basic_string_view<CharT, Traits>(*this).compare(
               basic_string_view<CharT, Traits>(str));
    }
    constexpr int compare(size_type pos1, size_type n1, const basic_string& str) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(str));
    }
    constexpr int compare(size_type pos1, size_type n1, const basic_string& str,
                size_type pos2, size_type n2 = npos) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(str).substr(pos2, n2));
    }
    constexpr int compare(const value_type* s) const noexcept {
        return basic_string_view<CharT, Traits>(*this).compare(
               basic_string_view<CharT, Traits>(s));
    }
    constexpr int compare(size_type pos1, size_type n1, const value_type* s) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(s));
    }
    constexpr int compare(size_type pos1, size_type n1, const value_type* s, size_type n2) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(s, n2));
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr int compare(const T& t) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return basic_string_view<CharT, Traits>(*this).compare(sv);
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr int compare(size_type pos1, size_type n1, const T& t) const {
        basic_string_view<CharT, Traits> sv = t;
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(sv);
    }
    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    constexpr int compare(size_type pos1, size_type n1, const T& t,
                size_type pos2, size_type n2 = npos) const {
        basic_string_view<CharT, Traits> sv = t;
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1)
               .compare(sv.substr(pos2, n2));
    }

    // =========================================================================
    // starts_with / ends_with / contains
    // =========================================================================

    [[nodiscard]] constexpr bool starts_with(basic_string_view<CharT, Traits> sv) const noexcept {
        return basic_string_view<CharT, Traits>(*this).starts_with(sv);
    }
    [[nodiscard]] constexpr bool starts_with(value_type c) const noexcept {
        return !empty() && traits_type::eq(front(), c);
    }
    [[nodiscard]] constexpr bool starts_with(const value_type* s) const noexcept {
        return starts_with(basic_string_view<CharT, Traits>(s));
    }

    [[nodiscard]] constexpr bool ends_with(basic_string_view<CharT, Traits> sv) const noexcept {
        return basic_string_view<CharT, Traits>(*this).ends_with(sv);
    }
    [[nodiscard]] constexpr bool ends_with(value_type c) const noexcept {
        return !empty() && traits_type::eq(back(), c);
    }
    [[nodiscard]] constexpr bool ends_with(const value_type* s) const noexcept {
        return ends_with(basic_string_view<CharT, Traits>(s));
    }

    [[nodiscard]] constexpr bool contains(basic_string_view<CharT, Traits> sv) const noexcept {
        return find(sv.data(), 0, sv.size()) != npos;
    }
    [[nodiscard]] constexpr bool contains(value_type c) const noexcept {
        return find(c) != npos;
    }
    [[nodiscard]] constexpr bool contains(const value_type* s) const noexcept {
        return find(s) != npos;
    }
}; // class basic_string

//=============================================================================
// Deduction guides
//=============================================================================

template<class InputIt,
         class Alloc = allocator<typename iterator_traits<InputIt>::value_type>>
    requires (detail::string_input_iter_v<InputIt> &&
              detail::string_is_allocator_v<Alloc>)
basic_string(InputIt, InputIt, Alloc = Alloc())
    -> basic_string<typename iterator_traits<InputIt>::value_type,
                    char_traits<typename iterator_traits<InputIt>::value_type>,
                    Alloc>;

template<class CharT, class Traits, class Alloc = allocator<CharT>>
    requires detail::string_is_allocator_v<Alloc>
explicit basic_string(basic_string_view<CharT, Traits>, const Alloc& = Alloc())
    -> basic_string<CharT, Traits, Alloc>;

// NOTE: the size parameters are spelled size_t rather than
// basic_string<...>::size_type so that substitution does not instantiate
// basic_string/allocator_traits before the allocator constraint is checked
// (deviation: observably equivalent for deduction).
template<class CharT, class Traits, class Alloc = allocator<CharT>>
    requires detail::string_is_allocator_v<Alloc>
basic_string(basic_string_view<CharT, Traits>, size_t, size_t,
             const Alloc& = Alloc())
    -> basic_string<CharT, Traits, Alloc>;

//=============================================================================
// Non-member operator== and <=>
//=============================================================================

template<class CharT, class Traits, class Alloc>
[[nodiscard]] constexpr bool
operator==(const basic_string<CharT, Traits, Alloc>& lhs,
           const basic_string<CharT, Traits, Alloc>& rhs) noexcept {
    if (lhs.size() != rhs.size()) return false;
    return Traits::compare(lhs.data(), rhs.data(), lhs.size()) == 0;
}

// rhs const CharT* (C++20: == synthesises !=)
template<class CharT, class Traits, class Alloc>
[[nodiscard]] constexpr bool
operator==(const basic_string<CharT, Traits, Alloc>& lhs,
           const CharT* rhs) noexcept {
    return lhs.compare(rhs) == 0;
}

template<class CharT, class Traits, class Alloc>
[[nodiscard]] constexpr auto
operator<=>(const basic_string<CharT, Traits, Alloc>& lhs,
            const basic_string<CharT, Traits, Alloc>& rhs) noexcept {
    int r = Traits::compare(lhs.data(), rhs.data(),
                            detail::sv_min(lhs.size(), rhs.size()));
    if (r == 0) r = (lhs.size() < rhs.size()) ? -1 : (lhs.size() > rhs.size() ? 1 : 0);
    // [string.cmp]: the return type is Traits::comparison_category if
    // present, weak_ordering otherwise.
    if constexpr (requires { typename Traits::comparison_category; })
        return static_cast<typename Traits::comparison_category>(r <=> 0);
    else
        return static_cast<weak_ordering>(r <=> 0);
}

template<class CharT, class Traits, class Alloc>
[[nodiscard]] constexpr auto
operator<=>(const basic_string<CharT, Traits, Alloc>& lhs,
            const CharT* rhs) noexcept {
    int r = lhs.compare(rhs);
    if constexpr (requires { typename Traits::comparison_category; })
        return static_cast<typename Traits::comparison_category>(r <=> 0);
    else
        return static_cast<weak_ordering>(r <=> 0);
}

//=============================================================================
// Non-member operator+
//=============================================================================

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(const basic_string<CharT, Traits, Alloc>& lhs,
          const basic_string<CharT, Traits, Alloc>& rhs)
{
    // [string.op+]: the result's allocator is
    // SOCCC(lhs.get_allocator()) (libc++ __concatenate_strings).
    basic_string<CharT, Traits, Alloc> r(
        allocator_traits<Alloc>::select_on_container_copy_construction(lhs.get_allocator()));
    r.reserve(lhs.size() + rhs.size());
    r.append(lhs);
    r.append(rhs);
    return r;
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(basic_string<CharT, Traits, Alloc>&& lhs,
          const basic_string<CharT, Traits, Alloc>& rhs)
{
    lhs.append(rhs);
    return move(lhs);
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(const basic_string<CharT, Traits, Alloc>& lhs,
          basic_string<CharT, Traits, Alloc>&& rhs)
{
    rhs.insert(0, lhs);
    return move(rhs);
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(basic_string<CharT, Traits, Alloc>&& lhs,
          basic_string<CharT, Traits, Alloc>&& rhs)
{
    lhs.append(rhs);
    return move(lhs);
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(const CharT* lhs, const basic_string<CharT, Traits, Alloc>& rhs)
{
    basic_string<CharT, Traits, Alloc> r(
        allocator_traits<Alloc>::select_on_container_copy_construction(rhs.get_allocator()));
    r.reserve(Traits::length(lhs) + rhs.size());
    r.append(lhs);
    r.append(rhs);
    return r;
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(const CharT* lhs, basic_string<CharT, Traits, Alloc>&& rhs)
{
    rhs.insert(0, lhs);
    return move(rhs);
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(CharT lhs, const basic_string<CharT, Traits, Alloc>& rhs)
{
    basic_string<CharT, Traits, Alloc> r(
        allocator_traits<Alloc>::select_on_container_copy_construction(rhs.get_allocator()));
    r.reserve(1 + rhs.size());
    r.append(1, lhs);
    r.append(rhs);
    return r;
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(CharT lhs, basic_string<CharT, Traits, Alloc>&& rhs)
{
    rhs.insert(rhs.begin(), lhs);
    return move(rhs);
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(const basic_string<CharT, Traits, Alloc>& lhs, const CharT* rhs)
{
    basic_string<CharT, Traits, Alloc> r(
        allocator_traits<Alloc>::select_on_container_copy_construction(lhs.get_allocator()));
    r.reserve(lhs.size() + Traits::length(rhs));
    r.append(lhs);
    r.append(rhs);
    return r;
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(basic_string<CharT, Traits, Alloc>&& lhs, const CharT* rhs)
{
    lhs.append(rhs);
    return move(lhs);
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(const basic_string<CharT, Traits, Alloc>& lhs, CharT rhs)
{
    basic_string<CharT, Traits, Alloc> r(
        allocator_traits<Alloc>::select_on_container_copy_construction(lhs.get_allocator()));
    r.reserve(lhs.size() + 1);
    r.append(lhs);
    r.push_back(rhs);
    return r;
}

template<class CharT, class Traits, class Alloc>
constexpr basic_string<CharT, Traits, Alloc>
operator+(basic_string<CharT, Traits, Alloc>&& lhs, CharT rhs)
{
    lhs.push_back(rhs);
    return move(lhs);
}

