// <string> — basic_string<CharT, Traits, Allocator> with SSO.
// Mechanically ported from libc++ include/string (non-alternate ABI layout,
// little-endian __endian_factor == 2).
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// SSO layout (little-endian, default ABI):
//   struct short_rep  { uint8_t is_long:1; uint8_t size:7; char pad[sizeof(CharT)-1]; CharT data[min_cap]; }
//   struct long_rep   { size_t  is_long:1; size_t  cap:63; size_t size; CharT* data; }
//   union rep { short_rep s; long_rep l; }
//   min_cap = (sizeof(long_rep)-1)/sizeof(CharT) >= 2 ? (sizeof(long_rep)-1)/sizeof(CharT) : 2
//   __endian_factor = 2 (little-endian): cap stored as real_cap/2 in the bitfield.
//
// Throwing paths (at, substr pos OOB, reserve/resize length_error):
//   -> __builtin_trap() with comment "would throw <X>"
//
// Deferred (noted inline):
//   getline, operator<<, operator>> (need <istream>/<ostream>)
//
// Reuses from <string_view>: char_traits, basic_string_view, str_find helpers
// Reuses from <memory>: allocator_traits, allocator
// Reuses from <functional>: hash, detail::hash_memory
#pragma once

#include <string_view>    // char_traits, basic_string_view, str_find helpers
#include <memory>         // allocator_traits, allocator, construct_at
#include <iterator>       // reverse_iterator, distance, iterator_traits
#include <algorithm>      // min, max
#include <functional>     // hash, detail::hash_memory
#include <initializer_list>
#include <type_traits>
#include <utility>        // move, forward, swap, exchange
#include <cstdlib>        // strtol, strtod, etc.
#include <cerrno>         // errno, ERANGE
#include <cstdio>         // snprintf
#include <cwchar>         // wcstol etc.
#include <climits>        // CHAR_BIT

namespace std {

//=============================================================================
// Helper: is_sv_compatible<CharT,Traits,T> — T converts to string_view but
// not to const CharT*. Used for the string_view overload set.
//=============================================================================

namespace detail {

template<class CharT, class Traits, class T>
inline constexpr bool sv_compatible_v =
    is_convertible_v<const T&, basic_string_view<CharT, Traits>> &&
    !is_convertible_v<const T&, const CharT*>;

// Trivial iterator: pointer-to-arithmetic — safe for memcpy paths.
template<class Iter>
inline constexpr bool string_trivial_iter_v = false;
template<class T>
inline constexpr bool string_trivial_iter_v<T*> = is_arithmetic_v<T>;

} // namespace detail

//=============================================================================
// basic_string
//=============================================================================

template<class CharT,
         class Traits    = char_traits<CharT>,
         class Allocator = allocator<CharT>>
class basic_string {
public:
    // -------------------------------------------------------------------------
    // types
    // -------------------------------------------------------------------------
    using traits_type            = Traits;
    using value_type             = CharT;
    using allocator_type         = Allocator;
    using alloc_traits           = allocator_traits<Allocator>;
    using size_type              = typename alloc_traits::size_type;
    using difference_type        = typename alloc_traits::difference_type;
    using reference              = value_type&;
    using const_reference        = const value_type&;
    using pointer                = typename alloc_traits::pointer;
    using const_pointer          = typename alloc_traits::const_pointer;
    using iterator               = pointer;
    using const_iterator         = const_pointer;
    using reverse_iterator       = std::reverse_iterator<iterator>;
    using const_reverse_iterator = std::reverse_iterator<const_iterator>;

    static const size_type npos = size_type(-1);

    static_assert(!is_array_v<value_type>,
        "Character type of basic_string must not be an array");
    static_assert(is_standard_layout_v<value_type>,
        "Character type of basic_string must be standard-layout");
    static_assert(is_trivially_copyable_v<value_type>,
        "Character type of basic_string must be trivially copyable");
    static_assert(is_same_v<CharT, typename traits_type::char_type>,
        "traits_type::char_type must be the same type as CharT");
    static_assert(is_same_v<typename allocator_type::value_type, value_type>,
        "Allocator::value_type must be same type as value_type");

private:
    // -------------------------------------------------------------------------
    // SSO representation
    //
    // We use a simple, portable layout that avoids __attribute__((packed)):
    //
    // short_rep (small string): all data fits in-line.
    //   - First byte: 0x00 (is_long=0) | size in bits [7:1]
    //     The is_long flag is in bit 0 of the first byte.
    //     Size is in bits 7:1 (i.e., stored as size<<1 in the byte).
    //   - Remaining bytes: the character array.
    //     data[] starts at offset sizeof(value_type) relative to the struct start.
    //
    // long_rep (heap-allocated):
    //   - First size_type word: cap_word where bit 0 == 1 (is_long flag),
    //     cap stored as (real_cap>>1) in bits [N:1].
    //   - Second size_type word: size.
    //   - pointer: the heap data.
    //
    // Both reps alias at byte offset 0 to detect is_long via bit 0.
    //
    // min_cap: size of inline buffer (number of CharT, excl. null terminator).
    //   sizeof(long_rep) == sizeof(size_type)*2 + sizeof(pointer)
    //   short_rep total size = sizeof(long_rep)
    //   minus one byte for the size/flag byte = (sizeof(long_rep)-1) / sizeof(CharT)
    //   but at least 2.
    //
    // For char (1 byte): sizeof(long_rep) = 24 on 64-bit -> min_cap = 23.
    // For wchar_t (4 byte): sizeof(long_rep) = 24 -> min_cap = 5 (>=2).
    // -------------------------------------------------------------------------

    struct long_rep {
        size_type cap_word; // bit 0 = is_long (always 1), bits[N:1] = real_cap >> 1
        size_type sz;
        pointer   data;
    };

    // Calculate min_cap as a constexpr function to avoid circular dependency
    // with sizeof(long_rep).
    // sizeof(long_rep) = 2*sizeof(size_type) + sizeof(pointer)
    // = 2*8 + 8 = 24 on 64-bit, 2*4+4=12 on 32-bit.
    // short_rep has (sizeof(long_rep)) bytes total; 1 byte for flag/size;
    // remaining = sizeof(long_rep)-1 bytes / sizeof(CharT) chars.
    static constexpr size_type compute_min_cap() {
        size_type lsz = sizeof(long_rep);
        size_type avail = (lsz - 1) / sizeof(value_type);
        return avail > 2 ? avail : 2;
    }
    enum : size_type { min_cap = compute_min_cap() };

    // short_rep: same total size as long_rep.
    // Layout: 1 byte flag/size, then (sizeof(long_rep)-1) raw bytes for data.
    // We use unsigned char[] for storage to avoid alignment issues.
    struct short_rep {
        unsigned char flag_sz; // bit 0 = 0 (is_long=0), bits[7:1] = size
        // Remaining storage for CharT array (aligned by the union).
        // We use a raw byte array; characters are accessed via reinterpret_cast
        // in get_short_pointer().
        unsigned char data_bytes[sizeof(long_rep) - 1];
    };

    static_assert(sizeof(short_rep) == sizeof(long_rep), "SSO layout mismatch");

    union rep_t {
        short_rep s;
        long_rep  l;
        unsigned char raw[sizeof(long_rep)]; // for flag detection
        rep_t() : s{} {}
    };

    rep_t          rep_;
    allocator_type alloc_;

    // -------------------------------------------------------------------------
    // rep accessors
    // -------------------------------------------------------------------------

    // is_long: bit 0 of the first byte of the union
    bool is_long() const noexcept { return (rep_.raw[0] & 1) != 0; }
    static constexpr bool fits_in_sso(size_type sz) { return sz < min_cap; }

    // short accessors
    // size stored in bits [7:1] of flag_sz byte: size = flag_sz >> 1
    size_type get_short_size() const noexcept {
        return static_cast<size_type>(rep_.s.flag_sz >> 1);
    }
    void set_short_size(size_type n) noexcept {
        rep_.s.flag_sz = static_cast<unsigned char>(n << 1); // bit 0 = 0 (short)
    }

    // long accessors
    // cap_word: bit 0 = 1, cap = cap_word >> 1 (i.e., real_cap / 2 stored)
    size_type get_long_size()    const noexcept { return rep_.l.sz; }
    void set_long_size(size_type n) noexcept    { rep_.l.sz = n; }
    size_type get_long_cap()    const noexcept  { return rep_.l.cap_word & ~size_type(1); }
    void set_long_cap_word(size_type real_cap) noexcept {
        rep_.l.cap_word = real_cap | size_type(1); // keep bit 0 = 1
    }
    pointer get_long_pointer() noexcept         { return rep_.l.data; }
    const_pointer get_long_pointer() const noexcept { return rep_.l.data; }

    pointer get_short_pointer() noexcept {
        // The data array starts at byte offset 1 in short_rep.
        // We need to return a properly-aligned pointer to the CharT array.
        // data_bytes is a byte array inside the union, so we cast.
        return reinterpret_cast<pointer>(rep_.s.data_bytes);
    }
    const_pointer get_short_pointer() const noexcept {
        return reinterpret_cast<const_pointer>(rep_.s.data_bytes);
    }

    pointer get_pointer() noexcept {
        return is_long() ? get_long_pointer() : get_short_pointer();
    }
    const_pointer get_pointer() const noexcept {
        return is_long() ? get_long_pointer() : get_short_pointer();
    }

    // unified size get/set
    size_type get_size() const noexcept {
        return is_long() ? get_long_size() : get_short_size();
    }
    void set_size(size_type n) noexcept {
        if (is_long()) set_long_size(n);
        else           set_short_size(n);
    }

    // -------------------------------------------------------------------------
    // Internal allocation helpers
    // -------------------------------------------------------------------------

    static constexpr size_type align_val = 8; // allocation alignment hint

    static size_type align_alloc_size(size_type sz) noexcept {
        // Round up (sz+1) to a multiple of boundary, ensuring we allocate enough.
        const size_type boundary =
            sizeof(value_type) < align_val
            ? align_val / sizeof(value_type)
            : size_type(2);
        size_type guess = ((sz + 1) + (boundary - 1)) & ~(boundary - 1);
        if (guess == min_cap + 1) guess += 2;
        return guess;
    }

    size_type amortized_grow(size_type required) {
        size_type ms = max_size();
        if (required > ms) __builtin_trap(); // would throw length_error
        size_type cur = capacity();
        if (cur > ms / 2 - align_val) return ms;
        size_type dbl = 2 * cur;
        return required > dbl ? required : dbl;
    }

    // Allocate a long buffer of at least min_capacity characters (not counting null).
    // Stores cap_word in rep.l; caller must set rep_.l.sz and rep_.l.data.
    pointer alloc_long_buf(size_type min_capacity) {
        size_type actual = align_alloc_size(min_capacity);
        pointer p = alloc_traits::allocate(alloc_, actual);
        // actual is even (boundary >= 2), so bit 0 is 0; OR with 1 for is_long.
        rep_.l.cap_word = actual | size_type(1);
        return p;
    }

    // Free current long buffer (does NOT change rep)
    void dealloc_long() noexcept {
        if (is_long())
            alloc_traits::deallocate(alloc_, rep_.l.data, get_long_cap());
    }

    // -------------------------------------------------------------------------
    // init(const CharT*, size_type)  — core initialiser
    // -------------------------------------------------------------------------
    void init(const value_type* s, size_type sz) {
        if (sz > max_size()) __builtin_trap(); // would throw length_error
        if (fits_in_sso(sz)) {
            set_short_size(sz);
            value_type* p = get_short_pointer();
            traits_type::copy(p, s, sz);
            traits_type::assign(p[sz], value_type());
        } else {
            pointer p = alloc_long_buf(sz);
            rep_.l.data = p;
            rep_.l.sz   = sz;
            traits_type::copy(p, s, sz);
            traits_type::assign(p[sz], value_type());
        }
    }

    void init(size_type n, value_type c) {
        if (n > max_size()) __builtin_trap(); // would throw length_error
        if (fits_in_sso(n)) {
            set_short_size(n);
            value_type* p = get_short_pointer();
            traits_type::assign(p, n, c);
            traits_type::assign(p[n], value_type());
        } else {
            pointer p = alloc_long_buf(n);
            rep_.l.data = p;
            rep_.l.sz   = n;
            traits_type::assign(p, n, c);
            traits_type::assign(p[n], value_type());
        }
    }

    template<class InputIt, class Sentinel>
    void init_sentinel(InputIt first, Sentinel last) {
        // slow path: unknown length — push_back one by one
        rep_ = rep_t{};
        for (; first != last; ++first) push_back(*first);
    }

    template<class FwdIt>
    void init_fwd(FwdIt first, FwdIt last) {
        size_type sz = static_cast<size_type>(std::distance(first, last));
        if (sz > max_size()) __builtin_trap(); // would throw length_error
        value_type* p;
        if (fits_in_sso(sz)) {
            set_short_size(sz);
            p = get_short_pointer();
        } else {
            pointer pp = alloc_long_buf(sz);
            rep_.l.data = pp;
            rep_.l.sz   = sz;
            p = pp;
        }
        for (size_type i = 0; first != last; ++first, ++i)
            traits_type::assign(p[i], *first);
        traits_type::assign(p[sz], value_type());
    }

    // -------------------------------------------------------------------------
    // grow_by_and_replace: reallocate with new content inserted in the middle.
    //   Copies [0..n_copy) from old buffer, inserts n_add chars from p_new,
    //   then copies [n_copy+n_del..old_sz) from old buffer.
    // -------------------------------------------------------------------------
    void grow_by_and_replace(size_type old_cap,
                             size_type delta_cap,
                             size_type old_sz,
                             size_type n_copy,
                             size_type n_del,
                             size_type n_add,
                             const value_type* p_new)
    {
        size_type new_cap = amortized_grow(old_cap + delta_cap);
        pointer new_data  = alloc_traits::allocate(alloc_, align_alloc_size(new_cap));
        size_type new_cap_actual = align_alloc_size(new_cap);

        value_type* old_p = get_pointer();
        if (n_copy != 0)
            traits_type::copy(new_data, old_p, n_copy);
        if (n_add != 0)
            traits_type::copy(new_data + n_copy, p_new, n_add);
        size_type sec = old_sz - n_del - n_copy;
        if (sec != 0)
            traits_type::copy(new_data + n_copy + n_add, old_p + n_copy + n_del, sec);
        size_type new_sz = n_copy + n_add + sec;
        traits_type::assign(new_data[new_sz], value_type());

        dealloc_long();
        rep_.l.cap_word = new_cap_actual | size_type(1);
        rep_.l.sz       = new_sz;
        rep_.l.data     = new_data;
    }

    // grow_by_without_replace: reallocate and move content, no replacement.
    void grow_by_without_replace(size_type old_cap,
                                 size_type delta_cap,
                                 size_type old_sz,
                                 size_type n_copy,
                                 size_type n_del,
                                 size_type n_add = 0)
    {
        size_type new_cap = amortized_grow(old_cap + delta_cap);
        size_type new_cap_actual = align_alloc_size(new_cap);
        pointer new_data  = alloc_traits::allocate(alloc_, new_cap_actual);

        value_type* old_p = get_pointer();
        if (n_copy != 0)
            traits_type::copy(new_data, old_p, n_copy);
        size_type sec = old_sz - n_del - n_copy;
        if (sec != 0)
            traits_type::copy(new_data + n_copy + n_add, old_p + n_copy + n_del, sec);

        dealloc_long();
        rep_.l.cap_word = new_cap_actual | size_type(1);
        rep_.l.sz       = old_sz - n_del + n_add;
        rep_.l.data     = new_data;
    }

    // ensure_capacity: reserve without changing size/content
    void ensure_capacity(size_type new_cap) {
        if (new_cap <= capacity()) return;
        if (new_cap > max_size()) __builtin_trap(); // would throw length_error
        size_type old_sz  = size();
        size_type old_cap = capacity();
        grow_by_without_replace(old_cap, new_cap - old_cap, old_sz, old_sz, 0);
        // Restore null terminator
        traits_type::assign(rep_.l.data[old_sz], value_type());
    }

    // -------------------------------------------------------------------------
    // assign helpers
    // -------------------------------------------------------------------------

    basic_string& assign_raw(const value_type* s, size_type n) {
        size_type cap = capacity();
        if (cap >= n) {
            // fits in current buffer
            traits_type::move(get_pointer(), s, n);
            set_size(n);
            traits_type::assign(get_pointer()[n], value_type());
        } else {
            size_type old_sz = size();
            grow_by_and_replace(cap, n - cap, old_sz, 0, old_sz, n, s);
        }
        return *this;
    }

    // pointer in range [data(), data()+size()+1)
    bool addr_in_range(const value_type* p) const noexcept {
        return p >= data() && p <= data() + size();
    }

public:
    // =========================================================================
    // Constructors
    // =========================================================================

    basic_string() noexcept(noexcept(allocator_type())) : rep_(), alloc_() {
        set_short_size(0);
        traits_type::assign(get_short_pointer()[0], value_type());
    }

    explicit basic_string(const allocator_type& a) noexcept : rep_(), alloc_(a) {
        set_short_size(0);
        traits_type::assign(get_short_pointer()[0], value_type());
    }

    // copy ctor
    basic_string(const basic_string& other)
        : rep_(), alloc_(alloc_traits::select_on_container_copy_construction(other.alloc_))
    {
        init(other.data(), other.size());
    }

    basic_string(const basic_string& other, const allocator_type& a)
        : rep_(), alloc_(a)
    {
        init(other.data(), other.size());
    }

    // move ctor
    basic_string(basic_string&& other) noexcept
        : rep_(other.rep_), alloc_(move(other.alloc_))
    {
        other.rep_ = rep_t{};
        other.set_short_size(0);
        traits_type::assign(other.get_short_pointer()[0], value_type());
    }

    basic_string(basic_string&& other, const allocator_type& a) : rep_(), alloc_(a) {
        if (other.is_long() && a != other.alloc_) {
            // copy
            init(other.data(), other.size());
        } else {
            rep_       = other.rep_;
            other.rep_ = rep_t{};
            other.set_short_size(0);
            traits_type::assign(other.get_short_pointer()[0], value_type());
        }
    }

    // from const CharT*
    basic_string(const value_type* s, const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        init(s, traits_type::length(s));
    }

    basic_string(const value_type* s, size_type n, const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        init(s, n);
    }

    // nullptr_t deleted (C++23)
    basic_string(nullptr_t) = delete;

    // count + char
    basic_string(size_type n, value_type c, const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        init(n, c);
    }

    // substring of another string
    basic_string(const basic_string& other, size_type pos, size_type n = npos,
                 const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        size_type sz = other.size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        size_type len = detail::sv_min(n, sz - pos);
        init(other.data() + pos, len);
    }

    // from string_view-compatible T
    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    explicit basic_string(const T& t, const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        basic_string_view<CharT, Traits> sv = t;
        init(sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    basic_string(const T& t, size_type pos, size_type n,
                 const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        basic_string_view<CharT, Traits> sv0 = t;
        if (pos > sv0.size()) __builtin_trap(); // would throw out_of_range
        basic_string_view<CharT, Traits> sv = sv0.substr(pos, n);
        init(sv.data(), sv.size());
    }

    // iterator-range ctor
    template<class InputIt>
        requires requires { typename iterator_traits<InputIt>::iterator_category; }
    basic_string(InputIt first, InputIt last, const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        using cat = typename iterator_traits<InputIt>::iterator_category;
        if constexpr (is_base_of_v<forward_iterator_tag, cat>) {
            init_fwd(first, last);
        } else {
            init_sentinel(first, last);
        }
    }

    // initializer_list
    basic_string(initializer_list<value_type> il, const allocator_type& a = allocator_type())
        : rep_(), alloc_(a)
    {
        init(il.begin(), il.size());
    }

    // destructor
    ~basic_string() {
        if (is_long())
            alloc_traits::deallocate(alloc_, rep_.l.data, get_long_cap());
    }

    // =========================================================================
    // Assignment operators
    // =========================================================================

    basic_string& operator=(const basic_string& other) {
        if (this == &other) return *this;
        if constexpr (alloc_traits::propagate_on_container_copy_assignment::value) {
            if (alloc_ != other.alloc_) {
                // must replace allocator: deallocate old first
                if (is_long())
                    alloc_traits::deallocate(alloc_, rep_.l.data, get_long_cap());
                rep_   = rep_t{};
                alloc_ = other.alloc_;
            }
        }
        return assign_raw(other.data(), other.size());
    }

    basic_string& operator=(basic_string&& other)
        noexcept(alloc_traits::propagate_on_container_move_assignment::value ||
                 alloc_traits::is_always_equal::value)
    {
        if (this == &other) return *this;
        if constexpr (alloc_traits::propagate_on_container_move_assignment::value) {
            if (is_long())
                alloc_traits::deallocate(alloc_, rep_.l.data, get_long_cap());
            rep_   = other.rep_;
            alloc_ = move(other.alloc_);
            other.rep_ = rep_t{};
            other.set_short_size(0);
            traits_type::assign(other.get_short_pointer()[0], value_type());
        } else if (alloc_traits::is_always_equal::value || alloc_ == other.alloc_) {
            if (is_long())
                alloc_traits::deallocate(alloc_, rep_.l.data, get_long_cap());
            rep_       = other.rep_;
            other.rep_ = rep_t{};
            other.set_short_size(0);
            traits_type::assign(other.get_short_pointer()[0], value_type());
        } else {
            // allocators differ and don't propagate: copy
            assign_raw(other.data(), other.size());
        }
        return *this;
    }

    basic_string& operator=(const value_type* s) { return assign(s); }

    basic_string& operator=(value_type c) {
        value_type buf[2] = { c, value_type() };
        return assign_raw(buf, 1);
    }

    basic_string& operator=(initializer_list<value_type> il) {
        return assign(il.begin(), il.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    basic_string& operator=(const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return assign_raw(sv.data(), sv.size());
    }

    basic_string& operator=(nullptr_t) = delete;

    // string_view conversion
    operator basic_string_view<CharT, Traits>() const noexcept {
        return basic_string_view<CharT, Traits>(data(), size());
    }

    // =========================================================================
    // Iterators
    // =========================================================================

    iterator       begin()        noexcept { return get_pointer(); }
    const_iterator begin()  const noexcept { return get_pointer(); }
    iterator       end()          noexcept { return get_pointer() + size(); }
    const_iterator end()    const noexcept { return get_pointer() + size(); }

    reverse_iterator       rbegin()  noexcept { return reverse_iterator(end()); }
    const_reverse_iterator rbegin()  const noexcept { return const_reverse_iterator(end()); }
    reverse_iterator       rend()    noexcept { return reverse_iterator(begin()); }
    const_reverse_iterator rend()    const noexcept { return const_reverse_iterator(begin()); }

    const_iterator         cbegin()  const noexcept { return begin(); }
    const_iterator         cend()    const noexcept { return end(); }
    const_reverse_iterator crbegin() const noexcept { return rbegin(); }
    const_reverse_iterator crend()   const noexcept { return rend(); }

    // =========================================================================
    // Capacity
    // =========================================================================

    [[nodiscard]] size_type size()   const noexcept { return get_size(); }
    [[nodiscard]] size_type length() const noexcept { return size(); }
    [[nodiscard]] bool empty() const noexcept { return size() == 0; }

    [[nodiscard]] size_type max_size() const noexcept {
        size_type m = alloc_traits::max_size(alloc_);
        // With endian_factor==2 cap must be even so max usable size decreases
        if (m <= numeric_limits<size_type>::max() / 2) {
            size_type res = m - align_val;
            res &= ~size_type(1); // ensure cap is even
            return res - 1;
        } else {
            return (m / 2) - align_val - 1;
        }
    }

    [[nodiscard]] size_type capacity() const noexcept {
        return (is_long() ? get_long_cap()
                          : static_cast<size_type>(min_cap)) - 1;
    }

    void reserve(size_type n) {
        if (n <= capacity()) return;
        ensure_capacity(n);
    }

    void shrink_to_fit() noexcept {
        if (!is_long()) return;
        size_type sz = size();
        if (fits_in_sso(sz)) {
            // move to short buffer
            pointer p = rep_.l.data;
            size_type old_cap = get_long_cap();
            value_type tmp[min_cap + 1];
            traits_type::copy(tmp, p, sz + 1);
            alloc_traits::deallocate(alloc_, p, old_cap);
            rep_ = rep_t{};
            set_short_size(sz);
            traits_type::copy(get_short_pointer(), tmp, sz + 1);
        } else {
            // reallocate to exact size
            size_type exact = align_alloc_size(sz);
            if (exact >= get_long_cap()) return; // already tight
            pointer new_p = alloc_traits::allocate(alloc_, exact);
            traits_type::copy(new_p, rep_.l.data, sz + 1);
            alloc_traits::deallocate(alloc_, rep_.l.data, get_long_cap());
            rep_.l.cap_word = exact | size_type(1);
            rep_.l.data     = new_p;
        }
    }

    void clear() noexcept {
        set_size(0);
        traits_type::assign(get_pointer()[0], value_type());
    }

    void resize(size_type n, value_type c = value_type()) {
        size_type sz = size();
        if (n < sz) {
            set_size(n);
            traits_type::assign(get_pointer()[n], value_type());
        } else if (n > sz) {
            if (n > max_size()) __builtin_trap(); // would throw length_error
            if (n > capacity()) ensure_capacity(n);
            value_type* p = get_pointer();
            traits_type::assign(p + sz, n - sz, c);
            traits_type::assign(p[n], value_type());
            set_size(n);
        }
    }

    // =========================================================================
    // Element access
    // =========================================================================

    [[nodiscard]] const_reference operator[](size_type pos) const noexcept {
        return *(data() + pos);
    }
    [[nodiscard]] reference operator[](size_type pos) noexcept {
        return *(get_pointer() + pos);
    }

    [[nodiscard]] const_reference at(size_type pos) const {
        if (pos >= size()) __builtin_trap(); // would throw out_of_range
        return *(data() + pos);
    }
    [[nodiscard]] reference at(size_type pos) {
        if (pos >= size()) __builtin_trap(); // would throw out_of_range
        return *(get_pointer() + pos);
    }

    [[nodiscard]] reference       front()       noexcept { return *get_pointer(); }
    [[nodiscard]] const_reference front() const noexcept { return *data(); }
    [[nodiscard]] reference       back()        noexcept { return *(get_pointer() + size() - 1); }
    [[nodiscard]] const_reference back()  const noexcept { return *(data() + size() - 1); }

    [[nodiscard]] const value_type* c_str() const noexcept { return data(); }
    [[nodiscard]] const value_type* data()  const noexcept { return get_pointer(); }
    [[nodiscard]]       value_type* data()        noexcept { return get_pointer(); }

    allocator_type get_allocator() const noexcept { return alloc_; }

    // =========================================================================
    // Modifiers — push/pop
    // =========================================================================

    void push_back(value_type c) {
        size_type sz  = size();
        size_type cap = capacity();
        if (sz == cap) ensure_capacity(sz + 1);
        value_type* p = get_pointer();
        traits_type::assign(p[sz], c);
        set_size(sz + 1);
        traits_type::assign(p[sz + 1], value_type());
    }

    void pop_back() noexcept {
        size_type sz = size() - 1;
        set_size(sz);
        traits_type::assign(get_pointer()[sz], value_type());
    }

    // =========================================================================
    // append
    // =========================================================================

    basic_string& append(const value_type* s, size_type n) {
        size_type sz  = size();
        size_type cap = capacity();
        if (cap - sz < n) {
            if (addr_in_range(s)) {
                // source aliases our buffer — copy it first
                basic_string tmp(s, n);
                return append(tmp.data(), n);
            }
            ensure_capacity(sz + n);
        }
        value_type* p = get_pointer();
        traits_type::copy(p + sz, s, n);
        set_size(sz + n);
        traits_type::assign(p[sz + n], value_type());
        return *this;
    }

    basic_string& append(const value_type* s) {
        return append(s, traits_type::length(s));
    }

    basic_string& append(size_type n, value_type c) {
        size_type sz  = size();
        size_type cap = capacity();
        if (cap - sz < n) ensure_capacity(sz + n);
        value_type* p = get_pointer();
        traits_type::assign(p + sz, n, c);
        set_size(sz + n);
        traits_type::assign(p[sz + n], value_type());
        return *this;
    }

    basic_string& append(const basic_string& str) {
        return append(str.data(), str.size());
    }

    basic_string& append(const basic_string& str, size_type pos, size_type n = npos) {
        size_type sz = str.size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        return append(str.data() + pos, detail::sv_min(n, sz - pos));
    }

    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    basic_string& append(const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return append(sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    basic_string& append(const T& t, size_type pos, size_type n = npos) {
        basic_string_view<CharT, Traits> sv = t;
        if (pos > sv.size()) __builtin_trap(); // would throw out_of_range
        return append(sv.data() + pos, detail::sv_min(n, sv.size() - pos));
    }

    template<class InputIt>
        requires requires { typename iterator_traits<InputIt>::iterator_category; }
    basic_string& append(InputIt first, InputIt last) {
        using cat = typename iterator_traits<InputIt>::iterator_category;
        if constexpr (is_base_of_v<forward_iterator_tag, cat>) {
            size_type n = static_cast<size_type>(std::distance(first, last));
            size_type sz = size();
            if (capacity() - sz < n) ensure_capacity(sz + n);
            value_type* p = get_pointer();
            for (size_type i = 0; first != last; ++first, ++i)
                traits_type::assign(p[sz + i], *first);
            set_size(sz + n);
            traits_type::assign(p[sz + n], value_type());
        } else {
            for (; first != last; ++first) push_back(*first);
        }
        return *this;
    }

    basic_string& append(initializer_list<value_type> il) {
        return append(il.begin(), il.size());
    }

    // =========================================================================
    // operator+=
    // =========================================================================

    basic_string& operator+=(const basic_string& str)  { return append(str); }
    basic_string& operator+=(const value_type* s)       { return append(s); }
    basic_string& operator+=(value_type c)              { push_back(c); return *this; }
    basic_string& operator+=(initializer_list<value_type> il) { return append(il); }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    basic_string& operator+=(const T& t) { return append(t); }

    // =========================================================================
    // assign
    // =========================================================================

    basic_string& assign(const value_type* s, size_type n) { return assign_raw(s, n); }
    basic_string& assign(const value_type* s) { return assign_raw(s, traits_type::length(s)); }
    basic_string& assign(size_type n, value_type c) {
        if (n > capacity()) ensure_capacity(n);
        value_type* p = get_pointer();
        traits_type::assign(p, n, c);
        set_size(n);
        traits_type::assign(p[n], value_type());
        return *this;
    }
    basic_string& assign(const basic_string& str) { return *this = str; }
    basic_string& assign(basic_string&& str) noexcept(
        noexcept(move(*this) = move(str))) {
        *this = move(str);
        return *this;
    }
    basic_string& assign(const basic_string& str, size_type pos, size_type n = npos) {
        size_type sz = str.size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        return assign_raw(str.data() + pos, detail::sv_min(n, sz - pos));
    }

    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    basic_string& assign(const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return assign_raw(sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    basic_string& assign(const T& t, size_type pos, size_type n = npos) {
        basic_string_view<CharT, Traits> sv = t;
        if (pos > sv.size()) __builtin_trap(); // would throw out_of_range
        return assign_raw(sv.data() + pos, detail::sv_min(n, sv.size() - pos));
    }

    template<class InputIt>
        requires requires { typename iterator_traits<InputIt>::iterator_category; }
    basic_string& assign(InputIt first, InputIt last) {
        basic_string tmp(first, last, alloc_);
        return assign_raw(tmp.data(), tmp.size());
    }

    basic_string& assign(initializer_list<value_type> il) {
        return assign_raw(il.begin(), il.size());
    }

    // =========================================================================
    // insert
    // =========================================================================

    basic_string& insert(size_type pos, const value_type* s, size_type n) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        size_type cap = capacity();
        if (cap - sz < n) {
            // may alias: check before realloc
            if (s >= data() && s <= data() + sz) {
                basic_string tmp(s, n);
                grow_by_without_replace(cap, sz + n - cap, sz, pos, 0, n);
                traits_type::move(rep_.l.data + pos + n, rep_.l.data + pos, sz - pos);
                traits_type::copy(rep_.l.data + pos, tmp.data(), n);
                traits_type::assign(rep_.l.data[sz + n], value_type());
                return *this;
            }
            grow_by_without_replace(cap, sz + n - cap, sz, pos, 0, n);
            traits_type::copy(rep_.l.data + pos, s, n);
            traits_type::assign(rep_.l.data[sz + n], value_type());
        } else {
            value_type* p = get_pointer();
            traits_type::move(p + pos + n, p + pos, sz - pos);
            traits_type::copy(p + pos, s, n);
            set_size(sz + n);
            traits_type::assign(p[sz + n], value_type());
        }
        return *this;
    }

    basic_string& insert(size_type pos, const value_type* s) {
        return insert(pos, s, traits_type::length(s));
    }

    basic_string& insert(size_type pos, size_type n, value_type c) {
        size_type sz  = size();
        size_type cap = capacity();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        if (cap - sz < n) {
            grow_by_without_replace(cap, sz + n - cap, sz, pos, 0, n);
            traits_type::assign(rep_.l.data + pos, n, c);
            traits_type::assign(rep_.l.data[sz + n], value_type());
        } else {
            value_type* p = get_pointer();
            traits_type::move(p + pos + n, p + pos, sz - pos);
            traits_type::assign(p + pos, n, c);
            set_size(sz + n);
            traits_type::assign(p[sz + n], value_type());
        }
        return *this;
    }

    basic_string& insert(size_type pos, const basic_string& str) {
        return insert(pos, str.data(), str.size());
    }

    basic_string& insert(size_type pos1, const basic_string& str,
                         size_type pos2, size_type n = npos) {
        size_type sz = str.size();
        if (pos2 > sz) __builtin_trap(); // would throw out_of_range
        return insert(pos1, str.data() + pos2, detail::sv_min(n, sz - pos2));
    }

    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    basic_string& insert(size_type pos, const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return insert(pos, sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    basic_string& insert(size_type pos1, const T& t, size_type pos2, size_type n = npos) {
        basic_string_view<CharT, Traits> sv = t;
        if (pos2 > sv.size()) __builtin_trap(); // would throw out_of_range
        return insert(pos1, sv.data() + pos2, detail::sv_min(n, sv.size() - pos2));
    }

    iterator insert(const_iterator pos, value_type c) {
        size_type ip = static_cast<size_type>(pos - begin());
        insert(ip, 1, c);
        return begin() + ip;
    }

    iterator insert(const_iterator pos, size_type n, value_type c) {
        size_type ip = static_cast<size_type>(pos - begin());
        insert(ip, n, c);
        return begin() + ip;
    }

    template<class InputIt>
        requires requires { typename iterator_traits<InputIt>::iterator_category; }
    iterator insert(const_iterator pos, InputIt first, InputIt last) {
        size_type ip = static_cast<size_type>(pos - begin());
        basic_string tmp(first, last, alloc_);
        insert(ip, tmp.data(), tmp.size());
        return begin() + ip;
    }

    iterator insert(const_iterator pos, initializer_list<value_type> il) {
        size_type ip = static_cast<size_type>(pos - begin());
        insert(ip, il.begin(), il.size());
        return begin() + ip;
    }

    // =========================================================================
    // erase
    // =========================================================================

    basic_string& erase(size_type pos = 0, size_type n = npos) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        size_type xlen = detail::sv_min(n, sz - pos);
        size_type new_sz = sz - xlen;
        value_type* p = get_pointer();
        traits_type::move(p + pos, p + pos + xlen, new_sz - pos);
        set_size(new_sz);
        traits_type::assign(p[new_sz], value_type());
        return *this;
    }

    iterator erase(const_iterator position) {
        size_type ip = static_cast<size_type>(position - begin());
        erase(ip, 1);
        return begin() + ip;
    }

    iterator erase(const_iterator first, const_iterator last) {
        size_type pos = static_cast<size_type>(first - begin());
        size_type n   = static_cast<size_type>(last - first);
        erase(pos, n);
        return begin() + pos;
    }

    // =========================================================================
    // replace
    // =========================================================================

    basic_string& replace(size_type pos, size_type n1, const value_type* s, size_type n2) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        n1 = detail::sv_min(n1, sz - pos);
        size_type cap = capacity();
        if (sz - n1 + n2 > cap) {
            grow_by_and_replace(cap, sz - n1 + n2 - cap, sz, pos, n1, n2, s);
        } else {
            value_type* p = get_pointer();
            // Handle possible alias
            if (s >= p && s <= p + sz) {
                basic_string tmp(s, n2);
                traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
                traits_type::copy(p + pos, tmp.data(), n2);
            } else {
                traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
                traits_type::copy(p + pos, s, n2);
            }
            size_type new_sz = sz - n1 + n2;
            set_size(new_sz);
            traits_type::assign(p[new_sz], value_type());
        }
        return *this;
    }

    basic_string& replace(size_type pos, size_type n1, const value_type* s) {
        return replace(pos, n1, s, traits_type::length(s));
    }

    basic_string& replace(size_type pos, size_type n1, size_type n2, value_type c) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        n1 = detail::sv_min(n1, sz - pos);
        size_type cap = capacity();
        value_type* p = get_pointer();
        if (sz - n1 + n2 > cap) {
            // build fill buffer and replace
            basic_string tmp(n2, c);
            grow_by_and_replace(cap, sz - n1 + n2 - cap, sz, pos, n1, n2, tmp.data());
        } else {
            traits_type::move(p + pos + n2, p + pos + n1, sz - pos - n1);
            traits_type::assign(p + pos, n2, c);
            size_type new_sz = sz - n1 + n2;
            set_size(new_sz);
            traits_type::assign(p[new_sz], value_type());
        }
        return *this;
    }

    basic_string& replace(size_type pos, size_type n1, const basic_string& str) {
        return replace(pos, n1, str.data(), str.size());
    }

    basic_string& replace(size_type pos1, size_type n1, const basic_string& str,
                          size_type pos2, size_type n2 = npos) {
        size_type sz = str.size();
        if (pos2 > sz) __builtin_trap(); // would throw out_of_range
        return replace(pos1, n1, str.data() + pos2, detail::sv_min(n2, sz - pos2));
    }

    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    basic_string& replace(size_type pos, size_type n, const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return replace(pos, n, sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    basic_string& replace(size_type pos1, size_type n1, const T& t,
                          size_type pos2, size_type n2 = npos) {
        basic_string_view<CharT, Traits> sv = t;
        if (pos2 > sv.size()) __builtin_trap(); // would throw out_of_range
        return replace(pos1, n1, sv.data() + pos2, detail::sv_min(n2, sv.size() - pos2));
    }

    // iterator-based replace overloads
    basic_string& replace(const_iterator i1, const_iterator i2, const basic_string& str) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1),
                       str.data(), str.size());
    }
    basic_string& replace(const_iterator i1, const_iterator i2,
                          const value_type* s, size_type n) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), s, n);
    }
    basic_string& replace(const_iterator i1, const_iterator i2, const value_type* s) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), s);
    }
    basic_string& replace(const_iterator i1, const_iterator i2,
                          size_type n, value_type c) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), n, c);
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    basic_string& replace(const_iterator i1, const_iterator i2, const T& t) {
        return replace(static_cast<size_type>(i1 - begin()),
                       static_cast<size_type>(i2 - i1), t);
    }
    template<class InputIt>
        requires requires { typename iterator_traits<InputIt>::iterator_category; }
    basic_string& replace(const_iterator i1, const_iterator i2,
                          InputIt j1, InputIt j2) {
        basic_string tmp(j1, j2, alloc_);
        return replace(i1, i2, tmp);
    }
    basic_string& replace(const_iterator i1, const_iterator i2,
                          initializer_list<value_type> il) {
        return replace(i1, i2, il.begin(), il.end());
    }

    // =========================================================================
    // copy, substr, swap
    // =========================================================================

    size_type copy(value_type* s, size_type n, size_type pos = 0) const {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        size_type rlen = detail::sv_min(n, sz - pos);
        traits_type::copy(s, data() + pos, rlen);
        return rlen;
    }

    [[nodiscard]] basic_string substr(size_type pos = 0, size_type n = npos) const& {
        return basic_string(*this, pos, n, alloc_);
    }

    [[nodiscard]] basic_string substr(size_type pos = 0, size_type n = npos) && {
        return basic_string(move(*this), pos, n, alloc_);
    }

    void swap(basic_string& other) noexcept(
        alloc_traits::propagate_on_container_swap::value ||
        alloc_traits::is_always_equal::value)
    {
        std::swap(rep_,   other.rep_);
        if constexpr (alloc_traits::propagate_on_container_swap::value)
            std::swap(alloc_, other.alloc_);
    }

