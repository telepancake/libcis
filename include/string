    template<class InputIt>
        requires detail::string_input_iter_v<InputIt>
    constexpr basic_string& append(InputIt first, InputIt last) {
        using cat = typename iterator_traits<InputIt>::iterator_category;
        if constexpr (is_base_of_v<forward_iterator_tag, cat>) {
            size_type n = static_cast<size_type>(std::distance(first, last));
            size_type sz = size();
            // libc++ __append_forward_unsafe: if the range may alias *this
            // (only possible for trivial/pointer-like iterators), or needs a
            // reallocation while aliasing cannot be ruled out, append a copy.
            bool trivial_nonaliasing = false;
            if constexpr (detail::string_trivial_iter_v<InputIt>) {
                const volatile void* fp = std::to_address(first);
                trivial_nonaliasing = n == 0 ||
                    !ptr_in_range_void(data(), data() + size() + 1,
                                       const_cast<const void*>(fp));
            }
            if (!trivial_nonaliasing && n != 0) {
                // libc++ __append_forward_unsafe slow path: the iterators may
                // reference *this — append through a temporary.
                const basic_string tmp(first, last, alloc_);
                return append(tmp.data(), tmp.size());
            }
            if (capacity() - sz < n) ensure_capacity(sz + n);
            value_type* p = raw_data();
            for (size_type i = 0; first != last; ++first, ++i)
                traits_type::assign(p[sz + i], *first);
            set_size(sz + n);
            traits_type::assign(p[sz + n], value_type());
        } else {
            for (; first != last; ++first) push_back(*first);
        }
        return *this;
    }

