    // =========================================================================
    // compare
    // =========================================================================

    int compare(const basic_string& str) const noexcept {
        return basic_string_view<CharT, Traits>(*this).compare(
               basic_string_view<CharT, Traits>(str));
    }
    int compare(size_type pos1, size_type n1, const basic_string& str) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(str));
    }
    int compare(size_type pos1, size_type n1, const basic_string& str,
                size_type pos2, size_type n2 = npos) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(str).substr(pos2, n2));
    }
    int compare(const value_type* s) const noexcept {
        return basic_string_view<CharT, Traits>(*this).compare(
               basic_string_view<CharT, Traits>(s));
    }
    int compare(size_type pos1, size_type n1, const value_type* s) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(s));
    }
    int compare(size_type pos1, size_type n1, const value_type* s, size_type n2) const {
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(
               basic_string_view<CharT, Traits>(s, n2));
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    int compare(const T& t) const noexcept {
        basic_string_view<CharT, Traits> sv = t;
        return basic_string_view<CharT, Traits>(*this).compare(sv);
    }
    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    int compare(size_type pos1, size_type n1, const T& t) const {
        basic_string_view<CharT, Traits> sv = t;
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1).compare(sv);
    }
    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    int compare(size_type pos1, size_type n1, const T& t,
                size_type pos2, size_type n2 = npos) const {
        basic_string_view<CharT, Traits> sv = t;
        return basic_string_view<CharT, Traits>(*this).substr(pos1, n1)
               .compare(sv.substr(pos2, n2));
    }

    // =========================================================================
    // starts_with / ends_with / contains
    // =========================================================================

    [[nodiscard]] bool starts_with(basic_string_view<CharT, Traits> sv) const noexcept {
        return basic_string_view<CharT, Traits>(*this).starts_with(sv);
    }
    [[nodiscard]] bool starts_with(value_type c) const noexcept {
        return !empty() && traits_type::eq(front(), c);
    }
    [[nodiscard]] bool starts_with(const value_type* s) const noexcept {
        return starts_with(basic_string_view<CharT, Traits>(s));
    }

    [[nodiscard]] bool ends_with(basic_string_view<CharT, Traits> sv) const noexcept {
        return basic_string_view<CharT, Traits>(*this).ends_with(sv);
    }
    [[nodiscard]] bool ends_with(value_type c) const noexcept {
        return !empty() && traits_type::eq(back(), c);
    }
    [[nodiscard]] bool ends_with(const value_type* s) const noexcept {
        return ends_with(basic_string_view<CharT, Traits>(s));
    }

    [[nodiscard]] bool contains(basic_string_view<CharT, Traits> sv) const noexcept {
        return find(sv.data(), 0, sv.size()) != npos;
    }
    [[nodiscard]] bool contains(value_type c) const noexcept {
        return find(c) != npos;
    }
    [[nodiscard]] bool contains(const value_type* s) const noexcept {
        return find(s) != npos;
    }
}; // class basic_string

