    [[nodiscard]] constexpr const_reference front() const noexcept { return *data(); }
    [[nodiscard]] constexpr reference       back()        noexcept { return *(raw_data() + size() - 1); }
    [[nodiscard]] constexpr const_reference back()  const noexcept { return *(data() + size() - 1); }

    [[nodiscard]] constexpr const value_type* c_str() const noexcept { return data(); }
    [[nodiscard]] constexpr const value_type* data()  const noexcept { return raw_data(); }
    [[nodiscard]] constexpr       value_type* data()        noexcept { return raw_data(); }

