// narrow string conversions
inline int                stoi  (const string& s, size_t* idx=nullptr, int base=10) {
    long r = detail::do_strtol(s.c_str(), idx, base);
    if (r < INT_MIN || r > INT_MAX) __builtin_trap(); // would throw out_of_range
    return static_cast<int>(r);
}
inline long               stol  (const string& s, size_t* idx=nullptr, int base=10) { return detail::do_strtol(s.c_str(), idx, base); }
inline unsigned long      stoul (const string& s, size_t* idx=nullptr, int base=10) { return detail::do_strtoul(s.c_str(), idx, base); }
inline long long          stoll (const string& s, size_t* idx=nullptr, int base=10) { return detail::do_strtoll(s.c_str(), idx, base); }
inline unsigned long long stoull(const string& s, size_t* idx=nullptr, int base=10) { return detail::do_strtoull(s.c_str(), idx, base); }
inline float              stof  (const string& s, size_t* idx=nullptr) { return detail::do_strtof(s.c_str(), idx); }
inline double             stod  (const string& s, size_t* idx=nullptr) { return detail::do_strtod(s.c_str(), idx); }
