// <string> — basic_string<CharT, Traits, Allocator> on the vector design.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Layout (matches std::vector):
//   pointer begin_, end_, cap_;   // raw pointers (or fancy via allocator)
//   [[no_unique_address]] Allocator alloc_;
// Total size for std::allocator<char>: 24 bytes (3 words).
//
// Invariants:
//   * Default-constructed (empty, unallocated): begin_ == end_ == cap_ == nullptr.
//     c_str() returns a per-CharT static sentinel pointing at CharT(0).
//   * Allocated: cap_ > end_ (the "spare slot" is the null terminator).
//     *end_ == CharT(0) after every modifier.
//   * capacity() = (cap_ - begin_) - 1 when allocated; 0 otherwise.
//
// Heavy operations route through the shared cores in <bits/vector_cores.h>:
//   * detail::grow              — reserve / resize-grow / append grow / insert grow
//     (for char this hits the trivially-relocatable + default-life fast path:
//     a raw realloc through realloc_shim_.)
// Character-bulk ops use Traits::copy/move/assign/compare directly (already
// __builtin_memcpy / memmove / memset / memcmp for char_traits<char>).
//
// Throwing paths (at, substr pos OOB, reserve length_error):
//   -> __builtin_trap() with comment "would throw <X>"
//
// Deferred (noted inline):
//   getline, operator<<, operator>> (need <istream>/<ostream>)
//
// Reuses from <string_view>: char_traits, basic_string_view, str_find helpers
// Reuses from <memory>: allocator_traits, allocator
// Reuses from <functional>: hash, detail::hash_memory
#pragma once

#include <string_view>    // char_traits, basic_string_view, str_find helpers
#include <memory>         // allocator_traits, allocator, construct_at
#include <iterator>       // reverse_iterator, distance, iterator_traits
#include <algorithm>      // min, max
#include <functional>     // hash, detail::hash_memory
#include <initializer_list>
#include <type_traits>
#include <utility>        // move, forward, swap, exchange
#include <cstdlib>        // strtol, strtod, etc.
#include <cerrno>         // errno, ERANGE
#include <cstdio>         // snprintf
#include <cwchar>
#include <memory_resource>  // pmr::polymorphic_allocator (pmr aliases below)
#include <climits>        // CHAR_BIT
#include <bits/type_ops.h>
#include <bits/storage_ops.h>
#include <bits/vector_cores.h>

namespace std {

//=============================================================================
// Helpers: is_sv_compatible<CharT,Traits,T> — T converts to string_view but
// not to const CharT*. Used for the string_view overload set.
//=============================================================================

namespace detail {

template<class CharT, class Traits, class T>
inline constexpr bool sv_compatible_v =
    is_convertible_v<const T&, basic_string_view<CharT, Traits>> &&
    !is_convertible_v<const T&, const CharT*>;

// libc++ __has_input_iterator_category: the iterator's category must derive
// from input_iterator_tag (excludes e.g. back_insert_iterator, whose
// category is output_iterator_tag).
template<class It>
inline constexpr bool string_input_iter_v = requires {
    typename iterator_traits<It>::iterator_category;
    requires is_base_of_v<input_iterator_tag,
                          typename iterator_traits<It>::iterator_category>;
};

// libc++ __is_allocator: constrains basic_string's deduction guides so that
// a non-allocator second argument makes deduction fail (SFINAE) instead of
// hard-erroring inside allocator_traits.
template<class Alloc>
inline constexpr bool string_is_allocator_v = requires(Alloc& a) {
    typename Alloc::value_type;
    a.allocate(size_t{});
};

// Per-CharT static sentinel: a single CharT(0) used as the c_str() return for
// default-constructed (unallocated) strings. inline => one symbol per CharT
// program-wide.
template<class CharT>
inline constexpr CharT string_empty_sentinel[1] = { CharT() };

} // namespace detail

//=============================================================================
// basic_string
//=============================================================================

template<class CharT,
         class Traits    = char_traits<CharT>,
         class Allocator = allocator<CharT>>
class basic_string
    : private detail::string_layout<
          typename allocator_traits<Allocator>::pointer,
          detail::storage_uses_header_layout<basic_string<CharT, Traits, Allocator>, Allocator>> {
public:
    // -------------------------------------------------------------------------
    // types
    // -------------------------------------------------------------------------
    using traits_type            = Traits;
    using value_type             = CharT;
    using allocator_type         = Allocator;
    using alloc_traits           = allocator_traits<Allocator>;
    using size_type              = typename alloc_traits::size_type;
    using difference_type        = typename alloc_traits::difference_type;
    using reference              = value_type&;
    using const_reference        = const value_type&;
    using pointer                = typename alloc_traits::pointer;
    using const_pointer          = typename alloc_traits::const_pointer;
    using iterator               = pointer;
    using const_iterator         = const_pointer;
    using reverse_iterator       = std::reverse_iterator<iterator>;
    using const_reverse_iterator = std::reverse_iterator<const_iterator>;

    static constexpr size_type npos = size_type(-1);

    static_assert(!is_array_v<value_type>,
        "Character type of basic_string must not be an array");
    static_assert(is_standard_layout_v<value_type>,
        "Character type of basic_string must be standard-layout");
    static_assert(is_trivially_copyable_v<value_type>,
        "Character type of basic_string must be trivially copyable");
    static_assert(is_same_v<CharT, typename traits_type::char_type>,
        "traits_type::char_type must be the same type as CharT");
    static_assert(is_same_v<typename allocator_type::value_type, value_type>,
        "Allocator::value_type must be same type as value_type");

private:
    // Strategy B (1-pointer layout): selected for std::allocator<CharT>. The
    // buffer carries a small header with the live byte count; capacity comes
    // from ::malloc_usable_size. Otherwise Strategy A (3 pointers).
    static constexpr bool uses_header_layout_ =
        detail::storage_uses_header_layout<basic_string, allocator_type>;
    using layout_base_ = detail::string_layout<pointer, uses_header_layout_>;

    // alloc_ is declared FIRST as a member; the layout base subobject is
    // initialized before any member (default-init: pointers nullptr). With
    // [[no_unique_address]] the empty allocator collapses; Strategy A = 24 B,
    // Strategy B = 8 B.
    [[no_unique_address]] allocator_type alloc_;

    // Strategy-uniform accessors. See vector for parallel reasoning.
    constexpr pointer end_ptr_() const noexcept {
        if constexpr (!uses_header_layout_) {
            return this->end_;
        } else {
            if (this->begin_ == nullptr) return pointer{};
            auto sp = detail::storage_b_data<basic_string>(const_cast<basic_string*>(this));
            return this->begin_ + (sp.size / sizeof(value_type));
        }
    }
    constexpr pointer cap_ptr_() const noexcept {
        if constexpr (!uses_header_layout_) {
            return this->cap_;
        } else {
            if (this->begin_ == nullptr) return pointer{};
            void* e = detail::storage_b_cap_end<basic_string>(const_cast<basic_string*>(this));
            const size_t total_b = static_cast<unsigned char*>(e)
                                 - reinterpret_cast<unsigned char*>(std::to_address(this->begin_));
            return this->begin_ + (total_b / sizeof(value_type));
        }
    }
    constexpr void set_size_elems_(size_type n) noexcept {
        if constexpr (!uses_header_layout_) {
            this->end_ = this->begin_ + n;
        } else {
            detail::storage_b_set_size<basic_string>(this, n * sizeof(value_type));
        }
    }
    constexpr void clear_storage_() noexcept {
        this->begin_ = pointer{};
        if constexpr (!uses_header_layout_) {
            this->end_ = pointer{};
            this->cap_ = pointer{};
        }
    }
    constexpr void transfer_storage_from_(basic_string& other) noexcept {
        this->begin_ = other.begin_;
        other.begin_ = pointer{};
        if constexpr (!uses_header_layout_) {
            this->end_ = other.end_;
            this->cap_ = other.cap_;
            other.end_ = pointer{};
            other.cap_ = pointer{};
        }
    }
    constexpr void swap_storage_(basic_string& other) noexcept {
        using std::swap;
        swap(this->begin_, other.begin_);
        if constexpr (!uses_header_layout_) {
            swap(this->end_, other.end_);
            swap(this->cap_, other.cap_);
        }
    }

    layout_base_* layout_() noexcept { return this; }
    const layout_base_* layout_() const noexcept { return this; }

    // -------------------------------------------------------------------------
    // Internal helpers
    // -------------------------------------------------------------------------

    [[noreturn]] static void throw_length_error() noexcept { __builtin_trap(); }
    [[noreturn]] static void throw_out_of_range()  noexcept { __builtin_trap(); }

    // Write the null terminator at *end. No-op when the string is in the
    // unallocated state (begin_ == nullptr) — c_str() then returns the
    // per-CharT sentinel and there is no spare slot to maintain.
    constexpr void null_terminate_() noexcept {
        if (this->begin_ != nullptr)
            traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    // Amortized growth: double capacity, clamped to max_size.
    size_type recommend(size_type new_size) const {
        const size_type ms = max_size();
        if (new_size > ms) throw_length_error();
        const size_type cap = capacity();
        if (cap >= ms / 2) return ms;
        return std::max<size_type>(2 * cap, new_size);
    }

    // -------------------------------------------------------------------------
    // Type-erasure plumbing for the shared cores in src/support.cpp.
    //
    // Like vector, string only consumes destroy + move_construct from the
    // ops table. For trivially-relocatable + default-lifecycle T (which
    // includes char/wchar_t/char{8,16,32}_t under std::allocator), both
    // leaves are null and the cores take their memmove fast paths.
    //
    // No constexpr: the cores run only at runtime.
    // -------------------------------------------------------------------------
    static const detail::type_ops* ops_table_() noexcept {
        return &detail::ops_for<value_type, allocator_type,
                                detail::OP_DESTROY | detail::OP_MOVE_CONSTRUCT>;
    }

    // Friend the storage_*_glue specializations so they can reach our private
    // alloc_ and the layout base subobject (private inheritance hides
    // up-casts even for friends).
    template<class C2> friend struct detail::storage_a_glue;
    template<class C2> friend struct detail::storage_b_glue;

    static const detail::storage_ops* storage_table_() noexcept {
        return &detail::storage_for_v<basic_string>;
    }

    void* el_ctx_() noexcept {
        if constexpr (!detail::alloc_stateless<allocator_type>)
            return &alloc_;
        else
            return nullptr;
    }

    // Allocate space for n characters PLUS the one-slot spare (null
    // terminator) via the storage_ops::resize slot. After resize size is 0.
    void vallocate(size_type n) {
        if (n > max_size()) throw_length_error();
        detail::grow(ops_table_(), storage_table_(), this, el_ctx_(),
                     (n + 1) * sizeof(value_type));
        // size remains 0; spare slot is zero-initialized by the storage_ops
        // resize path, which is the null terminator.
    }

    void vdeallocate() noexcept {
        if (this->begin_ != nullptr) {
            detail::destroy_range(ops_table_(), el_ctx_(),
                                  std::to_address(this->begin_),
                                  std::to_address(end_ptr_()));
            storage_table_()->free(this);
        }
    }

    // Reallocate to at least new_cap usable chars (+ the spare slot) via the
    // storage_ops::resize slot. The spare slot at the new *end holds the
    // null terminator (zeroed automatically by resize).
    void reallocate_grow(size_type new_cap) {
        if (new_cap > max_size()) throw_length_error();
        detail::grow(ops_table_(), storage_table_(), this, el_ctx_(),
                     (new_cap + 1) * sizeof(value_type));
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    // Make sure capacity() - size() >= n. Internally adds 1 for the spare slot.
    void ensure_free_(size_type n = 1) {
        // capacity() excludes the spare slot. Use a + 1 spare slot threshold.
        if (capacity() - size() < n)
            reallocate_grow(recommend(size() + n));
    }

    constexpr void copy_assign_alloc(const basic_string& c) {
        if constexpr (alloc_traits::propagate_on_container_copy_assignment::value) {
            if (alloc_ != c.alloc_) vdeallocate();
            alloc_ = c.alloc_;
        }
    }

    constexpr void move_assign_alloc(basic_string& c) noexcept {
        if constexpr (alloc_traits::propagate_on_container_move_assignment::value)
            alloc_ = std::move(c.alloc_);
    }

    void move_assign_impl(basic_string& c, true_type) noexcept {
        vdeallocate();
        move_assign_alloc(c);
        transfer_storage_from_(c);
    }

    void move_assign_impl(basic_string& c, false_type) {
        if (alloc_ != c.alloc_) assign_raw(c.data(), c.size());
        else                    move_assign_impl(c, true_type{});
    }

    // -------------------------------------------------------------------------
    // Raw-buffer init (used by ctors): allocate n+1 then copy/assign n chars
    // and null-terminate. Leaves end_ = begin_ + n.
    // -------------------------------------------------------------------------
    void init_copy(const value_type* s, size_type n) {
        if (n == 0) return;
        vallocate(n);
        traits_type::copy(std::to_address(this->begin_), s, n);
        set_size_elems_(n);
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    void init_fill(size_type n, value_type c) {
        if (n == 0) return;
        vallocate(n);
        traits_type::assign(std::to_address(this->begin_), n, c);
        set_size_elems_(n);
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    template<class InputIt>
    void init_iter_fwd(InputIt first, InputIt last) {
        size_type n = static_cast<size_type>(std::distance(first, last));
        if (n == 0) return;
        vallocate(n);
        value_type* p = std::to_address(this->begin_);
        for (size_type i = 0; first != last; ++first, ++i)
            traits_type::assign(p[i], *first);
        set_size_elems_(n);
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    template<class InputIt, class Sentinel>
    void init_iter_input(InputIt first, Sentinel last) {
        for (; first != last; ++first) push_back(*first);
    }

    // -------------------------------------------------------------------------
    // assign_raw: replace contents with [s, s+n) of arbitrary alias status.
    // -------------------------------------------------------------------------
    basic_string& assign_raw(const value_type* s, size_type n) {
        if (capacity() >= n) {
            if (this->begin_ == nullptr) {
                // Unallocated + n == 0: nothing to do, no spare slot exists.
                return *this;
            }
            value_type* p = std::to_address(this->begin_);
            // move (not copy) — caller may have s aliased to *this.
            traits_type::move(p, s, n);
            set_size_elems_(n);
            traits_type::assign(p[n], value_type());
            return *this;
        }
        // Need to grow. Free the old and reallocate fresh (aliasing already
        // resolved: s is somewhere in our buffer, but after vdeallocate the
        // old data is gone — so the caller must NOT pass an aliasing source
        // when growth is needed. The public entry points handle aliasing by
        // taking a copy first; see e.g. append/insert.)
        vdeallocate();
        if (n > 0) {
            vallocate(n);
            traits_type::copy(std::to_address(this->begin_), s, n);
            set_size_elems_(n);
            traits_type::assign(*std::to_address(end_ptr_()), value_type());
        }
        return *this;
    }

    // pointer-in-range check (constexpr-safe). Same trick as before for
    // unrelated-pointer comparisons in constant evaluation, kept because the
    // accessors are still constexpr even if the modifiers aren't.
    static constexpr bool ptr_in_range(const value_type* lo, const value_type* hi,
                                       const value_type* p) noexcept {
        if (std::is_constant_evaluated()) {
            if (!__builtin_constant_p(lo <= p && p < hi)) return false;
        }
        return lo <= p && p < hi;
    }

    bool addr_in_range(const value_type* p) const noexcept {
        if (this->begin_ == nullptr) return false;
        return ptr_in_range(std::to_address(this->begin_),
                            std::to_address(end_ptr_()) + 1, p);
    }

public:
    // =========================================================================
    // Constructors
    // =========================================================================

    constexpr basic_string() noexcept(noexcept(allocator_type())) = default;

    explicit constexpr basic_string(const allocator_type& a) noexcept : alloc_(a) {}

    constexpr basic_string(const basic_string& other)
        : alloc_(alloc_traits::select_on_container_copy_construction(other.alloc_))
    { init_copy(other.data(), other.size()); }

    constexpr basic_string(const basic_string& other, const allocator_type& a)
        : alloc_(a)
    { init_copy(other.data(), other.size()); }

    constexpr basic_string(basic_string&& other) noexcept
        : alloc_(std::move(other.alloc_))
    {
        transfer_storage_from_(other);
    }

    constexpr basic_string(basic_string&& other, const allocator_type& a)
        : alloc_(a)
    {
        if (a == other.alloc_) {
            transfer_storage_from_(other);
        } else {
            init_copy(other.data(), other.size());
        }
    }

    // Moving substring ctors (P2438)
    constexpr basic_string(basic_string&& str, size_type pos,
                           const allocator_type& a = allocator_type())
        : basic_string(std::move(str), pos, npos, a) {}

    constexpr basic_string(basic_string&& str, size_type pos, size_type n,
                           const allocator_type& a = allocator_type())
        : alloc_(a)
    {
        size_type sz = str.size();
        if (pos > sz) throw_out_of_range(); // would throw out_of_range
        size_type len = detail::sv_min(n, sz - pos);
        if (alloc_traits::is_always_equal::value || alloc_ == str.alloc_) {
            transfer_storage_from_(str);
            if (pos != 0)     erase(0, pos);
            if (size() > len) erase(len, npos);
        } else {
            init_copy(str.data() + pos, len);
        }
    }

    constexpr basic_string(const value_type* s, const allocator_type& a = allocator_type())
        : alloc_(a)
    { init_copy(s, traits_type::length(s)); }

    constexpr basic_string(const value_type* s, size_type n, const allocator_type& a = allocator_type())
        : alloc_(a)
    { init_copy(s, n); }

    basic_string(nullptr_t) = delete;

    template<class A = Allocator,
             class = enable_if_t<detail::string_is_allocator_v<A>, nullptr_t>>
    constexpr basic_string(size_type n, value_type c, const allocator_type& a = allocator_type())
        : alloc_(a)
    { init_fill(n, c); }

    constexpr basic_string(const basic_string& other, size_type pos,
                           const allocator_type& a = allocator_type())
        : basic_string(other, pos, npos, a) {}

    constexpr basic_string(const basic_string& other, size_type pos, size_type n,
                           const allocator_type& a = allocator_type())
        : alloc_(a)
    {
        size_type sz = other.size();
        if (pos > sz) throw_out_of_range();
        size_type len = detail::sv_min(n, sz - pos);
        init_copy(other.data() + pos, len);
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    constexpr explicit basic_string(const T& t, const allocator_type& a = allocator_type())
        : alloc_(a)
    {
        basic_string_view<CharT, Traits> sv = t;
        init_copy(sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    constexpr basic_string(const T& t, size_type pos, size_type n,
                 const allocator_type& a = allocator_type())
        : alloc_(a)
    {
        basic_string_view<CharT, Traits> sv0 = t;
        if (pos > sv0.size()) throw_out_of_range();
        basic_string_view<CharT, Traits> sv = sv0.substr(pos, n);
        init_copy(sv.data(), sv.size());
    }

    template<class InputIt>
        requires detail::string_input_iter_v<InputIt>
    constexpr basic_string(InputIt first, InputIt last, const allocator_type& a = allocator_type())
        : alloc_(a)
    {
        using cat = typename iterator_traits<InputIt>::iterator_category;
        if constexpr (is_base_of_v<forward_iterator_tag, cat>)
            init_iter_fwd(first, last);
        else
            init_iter_input(first, last);
    }

    constexpr basic_string(initializer_list<value_type> il, const allocator_type& a = allocator_type())
        : alloc_(a)
    { init_copy(il.begin(), il.size()); }

    constexpr ~basic_string() { vdeallocate(); }

    // =========================================================================
    // Assignment operators
    // =========================================================================

    constexpr basic_string& operator=(const basic_string& other) {
        if (this == std::addressof(other)) return *this;
        copy_assign_alloc(other);
        return assign_raw(other.data(), other.size());
    }

    constexpr basic_string& operator=(basic_string&& other)
        noexcept(alloc_traits::propagate_on_container_move_assignment::value ||
                 alloc_traits::is_always_equal::value)
    {
        if (this == std::addressof(other)) return *this;
        move_assign_impl(other,
            typename alloc_traits::propagate_on_container_move_assignment{});
        return *this;
    }

    constexpr basic_string& operator=(const value_type* s) { return assign(s); }

    constexpr basic_string& operator=(value_type c) {
        value_type buf[2] = { c, value_type() };
        return assign_raw(buf, 1);
    }

    constexpr basic_string& operator=(initializer_list<value_type> il) {
        return assign(il.begin(), il.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    constexpr basic_string& operator=(const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return assign_raw(sv.data(), sv.size());
    }

    constexpr basic_string& operator=(nullptr_t) = delete;

    constexpr operator basic_string_view<CharT, Traits>() const noexcept {
        return basic_string_view<CharT, Traits>(data(), size());
    }

    // =========================================================================
    // Iterators
    // =========================================================================

    constexpr iterator       begin()        noexcept { return this->begin_ ? this->begin_ : iterator{}; }
    constexpr const_iterator begin()  const noexcept { return this->begin_ ? const_iterator(this->begin_) : const_iterator{}; }
    constexpr iterator       end()          noexcept { return this->begin_ ? end_ptr_() : iterator{}; }
    constexpr const_iterator end()    const noexcept { return this->begin_ ? const_iterator(end_ptr_()) : const_iterator{}; }

    constexpr reverse_iterator       rbegin()  noexcept { return reverse_iterator(end()); }
    constexpr const_reverse_iterator rbegin()  const noexcept { return const_reverse_iterator(end()); }
    constexpr reverse_iterator       rend()    noexcept { return reverse_iterator(begin()); }
    constexpr const_reverse_iterator rend()    const noexcept { return const_reverse_iterator(begin()); }

    constexpr const_iterator         cbegin()  const noexcept { return begin(); }
    constexpr const_iterator         cend()    const noexcept { return end(); }
    constexpr const_reverse_iterator crbegin() const noexcept { return rbegin(); }
    constexpr const_reverse_iterator crend()   const noexcept { return rend(); }

    // =========================================================================
    // Capacity
    // =========================================================================

    [[nodiscard]] constexpr size_type size() const noexcept {
        if constexpr (!uses_header_layout_) {
            return static_cast<size_type>(this->end_ - this->begin_);
        } else {
            if (this->begin_ == nullptr) return 0;
            auto sp = detail::storage_b_data<basic_string>(
                const_cast<basic_string*>(this));
            return static_cast<size_type>(sp.size / sizeof(value_type));
        }
    }
    [[nodiscard]] constexpr size_type length() const noexcept { return size(); }
    [[nodiscard]] constexpr bool empty() const noexcept { return size() == 0; }

    [[nodiscard]] constexpr size_type max_size() const noexcept {
        // -1 reserves a slot for the spare; clamp to difference_type max.
        size_type m = std::min<size_type>(alloc_traits::max_size(alloc_),
                                          numeric_limits<difference_type>::max());
        return m == 0 ? 0 : m - 1;
    }

    [[nodiscard]] constexpr size_type capacity() const noexcept {
        // capacity() excludes the spare slot. For unallocated: 0.
        if (this->begin_ == nullptr) return 0;
        if constexpr (!uses_header_layout_) {
            return static_cast<size_type>(this->cap_ - this->begin_) - 1;
        } else {
            void* e = detail::storage_b_cap_end<basic_string>(
                const_cast<basic_string*>(this));
            const size_t total_b = static_cast<unsigned char*>(e)
                                 - reinterpret_cast<unsigned char*>(std::to_address(this->begin_));
            size_type total = static_cast<size_type>(total_b / sizeof(value_type));
            return total == 0 ? 0 : total - 1;
        }
    }

    void reserve(size_type n) {
        if (n > capacity()) {
            if (n > max_size()) throw_length_error();
            reallocate_grow(n);
        }
    }

    // Deprecated-in-C++20 zero-arg reserve() == shrink_to_fit (libc++ keeps it).
    void reserve() noexcept { shrink_to_fit(); }

    void shrink_to_fit() noexcept {
        size_type sz = size();
        if (sz == 0) { vdeallocate(); return; }
        const size_type want = sz + 1;
        // capacity() returns chars excluding the spare slot.
        if (capacity() + 1 <= want) return;
        // Route through grow: allocates `want` chars exactly, relocates live
        // bytes, frees old. Spare slot zeroed by resize.
        detail::grow(ops_table_(), storage_table_(), this, el_ctx_(),
                     want * sizeof(value_type));
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    constexpr void clear() noexcept {
        if (this->begin_ == nullptr) return;
        set_size_elems_(0);
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    void resize(size_type n, value_type c = value_type()) {
        size_type sz = size();
        if (n < sz) {
            set_size_elems_(n);
            traits_type::assign(*std::to_address(end_ptr_()), value_type());
        } else if (n > sz) {
            if (n > capacity()) {
                if (n > max_size()) throw_length_error();
                reallocate_grow(recommend(n));
            }
            value_type* p = std::to_address(this->begin_);
            traits_type::assign(p + sz, n - sz, c);
            set_size_elems_(n);
            traits_type::assign(p[n], value_type());
        }
    }

    // =========================================================================
    // Element access
    // =========================================================================

    [[nodiscard]] constexpr const_reference operator[](size_type pos) const noexcept {
        return data()[pos];
    }
    [[nodiscard]] constexpr reference operator[](size_type pos) noexcept {
        // [string.access]: operator[](size()) returns CharT(); writing to it
        // is UB but reading is required to yield the terminator. For an
        // unallocated string both data() (read) and the writable terminator
        // route through the sentinel; the non-const overload returns a
        // reference to a const_cast'd sentinel byte, matching libc++'s
        // contract that *(s.data() + s.size()) is observably CharT().
        return data()[pos];
    }

    [[nodiscard]] constexpr const_reference at(size_type pos) const {
        if (pos >= size()) throw_out_of_range();
        return data()[pos];
    }
    [[nodiscard]] constexpr reference at(size_type pos) {
        if (pos >= size()) throw_out_of_range();
        return data()[pos];
    }

    [[nodiscard]] constexpr reference       front()       noexcept { return *std::to_address(this->begin_); }
    [[nodiscard]] constexpr const_reference front() const noexcept { return *data(); }
    [[nodiscard]] constexpr reference       back()        noexcept { return *(std::to_address(this->begin_) + size() - 1); }
    [[nodiscard]] constexpr const_reference back()  const noexcept { return *(data() + size() - 1); }

    [[nodiscard]] constexpr const value_type* c_str() const noexcept { return data(); }
    [[nodiscard]] constexpr const value_type* data()  const noexcept {
        return this->begin_ ? std::to_address(this->begin_) : detail::string_empty_sentinel<value_type>;
    }
    [[nodiscard]] constexpr value_type* data() noexcept {
        return this->begin_ ? std::to_address(this->begin_)
                      // The non-const data() of a default-constructed string
                      // is observably writable only at index 0 (the null
                      // terminator); returning the per-CharT sentinel would
                      // be UB-on-write. libc++ returns data() on the SSO
                      // buffer; for the no-SSO design we materialize storage.
                      // In practice no caller writes through data() on an
                      // empty string, so the sentinel cast is safe — but to
                      // be defensive, cast away const here.
                      : const_cast<value_type*>(detail::string_empty_sentinel<value_type>);
    }

    constexpr allocator_type get_allocator() const noexcept { return alloc_; }

    // =========================================================================
    // Modifiers — push/pop
    // =========================================================================

    constexpr void push_back(value_type c) {
        ensure_free_();
        value_type* p = std::to_address(this->begin_);
        size_type sz = size();
        traits_type::assign(p[sz], c);
        set_size_elems_(sz + 1);
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    constexpr void pop_back() noexcept {
        size_type sz = size();
        set_size_elems_(sz - 1);
        traits_type::assign(*std::to_address(end_ptr_()), value_type());
    }

    // =========================================================================
    // append
    // =========================================================================

    constexpr basic_string& append(const value_type* s, size_type n) {
        if (n == 0) return *this;
        size_type sz = size();
        if (capacity() - sz < n) {
            if (addr_in_range(s)) {
                // source aliases our buffer — copy it first.
                basic_string tmp(s, n, alloc_);
                return append(tmp.data(), n);
            }
            reallocate_grow(recommend(sz + n));
        }
        value_type* p = std::to_address(this->begin_);
        traits_type::copy(p + sz, s, n);
        set_size_elems_(sz + n);
        traits_type::assign(p[sz + n], value_type());
        return *this;
    }

    constexpr basic_string& append(const value_type* s) {
        return append(s, traits_type::length(s));
    }

    constexpr basic_string& append(size_type n, value_type c) {
        if (n == 0) return *this;
        size_type sz = size();
        if (capacity() - sz < n) reallocate_grow(recommend(sz + n));
        value_type* p = std::to_address(this->begin_);
        traits_type::assign(p + sz, n, c);
        set_size_elems_(sz + n);
        traits_type::assign(p[sz + n], value_type());
        return *this;
    }

    constexpr basic_string& append(const basic_string& str) {
        return append(str.data(), str.size());
    }

    constexpr basic_string& append(const basic_string& str, size_type pos, size_type n = npos) {
        size_type sz = str.size();
        if (pos > sz) throw_out_of_range();
        return append(str.data() + pos, detail::sv_min(n, sz - pos));
    }

    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr basic_string& append(const T& t) {
        basic_string_view<CharT, Traits> sv = t;
        return append(sv.data(), sv.size());
    }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    constexpr basic_string& append(const T& t, size_type pos, size_type n = npos) {
        basic_string_view<CharT, Traits> sv = t;
        if (pos > sv.size()) throw_out_of_range();
        return append(sv.data() + pos, detail::sv_min(n, sv.size() - pos));
    }

    template<class InputIt>
        requires detail::string_input_iter_v<InputIt>
    constexpr basic_string& append(InputIt first, InputIt last) {
        using cat = typename iterator_traits<InputIt>::iterator_category;
        if constexpr (is_base_of_v<forward_iterator_tag, cat>) {
            size_type n = static_cast<size_type>(std::distance(first, last));
            if (n == 0) return *this;
            // Be defensive about aliasing: if the iterators MIGHT point into
            // this string (only possible for pointer-like iterators), build a
            // temporary first. The runtime check uses addr_in_range, which
            // returns false for unrelated buffers.
            // For correctness in the common (non-aliasing) case we still need
            // a fast bulk copy.
            const basic_string tmp(first, last, alloc_);
            return append(tmp.data(), tmp.size());
        } else {
            for (; first != last; ++first) push_back(*first);
            return *this;
        }
    }

    constexpr basic_string& append(initializer_list<value_type> il) {
        return append(il.begin(), il.size());
    }

    // =========================================================================
    // operator+=
    // =========================================================================

    constexpr basic_string& operator+=(const basic_string& str)  { return append(str); }
    constexpr basic_string& operator+=(const value_type* s)       { return append(s); }
    constexpr basic_string& operator+=(value_type c)              { push_back(c); return *this; }
    constexpr basic_string& operator+=(initializer_list<value_type> il) { return append(il); }

    template<class T>
        requires (detail::sv_compatible_v<CharT, Traits, T> &&
                  !is_same_v<remove_cvref_t<T>, basic_string>)
    constexpr basic_string& operator+=(const T& t) { return append(t); }

    // =========================================================================
    // assign
    // =========================================================================

    constexpr basic_string& assign(const value_type* s, size_type n) {
        // If source aliases, take a copy before potentially deallocating.
        if (addr_in_range(s) && (n > capacity())) {
            basic_string tmp(s, n, alloc_);
            return assign_raw(tmp.data(), n);
        }
        return assign_raw(s, n);
    }
    constexpr basic_string& assign(const value_type* s) { return assign(s, traits_type::length(s)); }
    constexpr basic_string& assign(size_type n, value_type c) {
        if (n > capacity()) {
            vdeallocate();
            vallocate(n);
        }
        if (this->begin_ == nullptr) return *this; // n == 0 && unallocated
        value_type* p = std::to_address(this->begin_);
        traits_type::assign(p, n, c);
        set_size_elems_(n);
        traits_type::assign(p[n], value_type());
        return *this;
    }
    constexpr basic_string& assign(const basic_string& str) { return *this = str; }
    constexpr basic_string& assign(basic_string&& str) noexcept(
        noexcept(std::declval<basic_string&>() = std::move(str))) {
        *this = std::move(str);
        return *this;
    }
    constexpr basic_string& assign(const basic_string& str, size_type pos, size_type n = npos) {
        size_type sz = str.size();
        if (pos > sz) throw_out_of_range();
        return assign(str.data() + pos, detail::sv_min(n, sz - pos));
    }

    template<class T>
        requires detail::sv_compatible_v<CharT, Traits, T>
    constexpr basic_string& assign(const T& t) {
        basic_string_view<CharT, Traits> sv = t;
