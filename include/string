template<class InputIt,
         class Alloc = allocator<typename iterator_traits<InputIt>::value_type>>
    requires requires { typename iterator_traits<InputIt>::iterator_category; }
basic_string(InputIt, InputIt, Alloc = Alloc())
    -> basic_string<typename iterator_traits<InputIt>::value_type,
                    char_traits<typename iterator_traits<InputIt>::value_type>,
                    Alloc>;

template<class CharT, class Traits, class Alloc = allocator<CharT>>
explicit basic_string(basic_string_view<CharT, Traits>, const Alloc& = Alloc())
    -> basic_string<CharT, Traits, Alloc>;

template<class CharT, class Traits, class Alloc = allocator<CharT>>
basic_string(basic_string_view<CharT, Traits>,
             typename basic_string<CharT, Traits, Alloc>::size_type,
             typename basic_string<CharT, Traits, Alloc>::size_type,
             const Alloc& = Alloc())
    -> basic_string<CharT, Traits, Alloc>;

//=============================================================================
// Non-member operator== and <=>
//=============================================================================

template<class CharT, class Traits, class Alloc>
[[nodiscard]] bool
operator==(const basic_string<CharT, Traits, Alloc>& lhs,
           const basic_string<CharT, Traits, Alloc>& rhs) noexcept {
    if (lhs.size() != rhs.size()) return false;
    return Traits::compare(lhs.data(), rhs.data(), lhs.size()) == 0;
}

// rhs const CharT* (C++20: == synthesises !=)
template<class CharT, class Traits, class Alloc>
[[nodiscard]] bool
operator==(const basic_string<CharT, Traits, Alloc>& lhs,
           const CharT* rhs) noexcept {
    return lhs.compare(rhs) == 0;
}

template<class CharT, class Traits, class Alloc>
[[nodiscard]] auto
operator<=>(const basic_string<CharT, Traits, Alloc>& lhs,
            const basic_string<CharT, Traits, Alloc>& rhs) noexcept {
    int r = Traits::compare(lhs.data(), rhs.data(),
                            detail::sv_min(lhs.size(), rhs.size()));
    if (r == 0) r = (lhs.size() < rhs.size()) ? -1 : (lhs.size() > rhs.size() ? 1 : 0);
    if constexpr (requires { typename Traits::comparison_category; })
        return static_cast<typename Traits::comparison_category>(r <=> 0);
    else
        return static_cast<strong_ordering>(r <=> 0);
}

template<class CharT, class Traits, class Alloc>
[[nodiscard]] auto
operator<=>(const basic_string<CharT, Traits, Alloc>& lhs,
            const CharT* rhs) noexcept {
    int r = lhs.compare(rhs);
    if constexpr (requires { typename Traits::comparison_category; })
        return static_cast<typename Traits::comparison_category>(r <=> 0);
    else
        return static_cast<strong_ordering>(r <=> 0);
}

