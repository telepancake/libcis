    // =========================================================================
    // insert
    // =========================================================================

    constexpr basic_string& insert(size_type pos, const value_type* s, size_type n) {
        size_type sz = size();
        if (pos > sz) __builtin_trap(); // would throw out_of_range
        size_type cap = capacity();
        if (cap - sz < n) {
            // may alias: check before realloc.  grow_by_without_replace
            // already places the tail at [pos+n, ...), so only the gap is
            // filled afterwards (libc++ __grow_by_and_replace equivalent).
            if (addr_in_range(s)) {
                basic_string tmp(s, n, alloc_);
                grow_by_without_replace(cap, sz + n - cap, sz, pos, 0, n);
                value_type* p = raw_data();
                traits_type::copy(p + pos, tmp.data(), n);
                traits_type::assign(p[sz + n], value_type());
                return *this;
            }
            grow_by_without_replace(cap, sz + n - cap, sz, pos, 0, n);
            value_type* p = raw_data();
            traits_type::copy(p + pos, s, n);
            traits_type::assign(p[sz + n], value_type());
        } else if (n != 0) {
            // libc++ basic_string::insert: shift the tail, and if the source
            // lives inside the shifted region, re-aim it.
            value_type* p = raw_data();
            size_type n_move = sz - pos;
            if (n_move != 0) {
                if (ptr_in_range(p + pos, p + sz, s))
                    s += n;
                traits_type::move(p + pos + n, p + pos, n_move);
            }
            traits_type::move(p + pos, s, n);
            set_size(sz + n);
            traits_type::assign(p[sz + n], value_type());
        }
        return *this;
    }

