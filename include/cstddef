// <cstddef> -- fundamental supporting types.
// Mechanically ported from libc++ include/cstddef + include/__cstddef/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
#pragma once

#include <type_traits>

namespace std {

// size_t — defined in <type_traits> as well; re-using here is harmless since
// they expand to the same type.
// using size_t = decltype(sizeof(int));   // already in type_traits

// ptrdiff_t: result of pointer subtraction (from ptrdiff_t.h)
using ptrdiff_t = decltype(static_cast<int*>(nullptr) - static_cast<int*>(nullptr));

// nullptr_t (from nullptr_t.h)
using nullptr_t = decltype(nullptr);

// max_align_t (from max_align_t.h): alignment of the most aligned fundamental type.
// We define it as a union of all maximally-aligned fundamental types.
union max_align_t {
    long long   ll;
    long double ld;
    double      d;
    void*       p;
};

// byte (C++17, from byte.h): a distinct type for raw memory manipulation.
// Shift operators require an integral Integer per [support.types.byteops].
// SFINAE (__enable_if_t<is_integral<...>>) converted to requires clause.
enum class byte : unsigned char {};

template<class Integer>
    requires is_integral_v<Integer>
constexpr byte& operator<<=(byte& b, Integer shift) noexcept {
    return b = b << shift;
}
template<class Integer>
    requires is_integral_v<Integer>
constexpr byte operator<<(byte b, Integer shift) noexcept {
    return static_cast<byte>(
        static_cast<unsigned char>(static_cast<unsigned int>(b) << shift));
}
template<class Integer>
    requires is_integral_v<Integer>
constexpr byte& operator>>=(byte& b, Integer shift) noexcept {
    return b = b >> shift;
}
template<class Integer>
    requires is_integral_v<Integer>
constexpr byte operator>>(byte b, Integer shift) noexcept {
    return static_cast<byte>(
        static_cast<unsigned char>(static_cast<unsigned int>(b) >> shift));
}

inline constexpr byte operator|(byte l, byte r) noexcept {
    return static_cast<byte>(
        static_cast<unsigned char>(
            static_cast<unsigned int>(l) | static_cast<unsigned int>(r)));
}
inline constexpr byte& operator|=(byte& l, byte r) noexcept { return l = l | r; }

inline constexpr byte operator&(byte l, byte r) noexcept {
    return static_cast<byte>(
        static_cast<unsigned char>(
            static_cast<unsigned int>(l) & static_cast<unsigned int>(r)));
}
inline constexpr byte& operator&=(byte& l, byte r) noexcept { return l = l & r; }

inline constexpr byte operator^(byte l, byte r) noexcept {
    return static_cast<byte>(
        static_cast<unsigned char>(
            static_cast<unsigned int>(l) ^ static_cast<unsigned int>(r)));
}
inline constexpr byte& operator^=(byte& l, byte r) noexcept { return l = l ^ r; }

inline constexpr byte operator~(byte b) noexcept {
    return static_cast<byte>(
        static_cast<unsigned char>(~static_cast<unsigned int>(b)));
}

template<class Integer>
    requires is_integral_v<Integer>
[[nodiscard]] constexpr Integer to_integer(byte b) noexcept {
    return static_cast<Integer>(b);
}

}  // namespace std
