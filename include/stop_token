// <stop_token> — stop_token, stop_source, stop_callback, nostopstate_t
// Mechanically ported from libc++ include/__stop_token/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Design: intrusive reference-counted stop-state (atomic<uint32_t> refcount
// embedded in stop_state).  Callback list is a doubly-linked intrusive list
// protected by a lock bit inside the state word.
#pragma once

#include <atomic>
#include <type_traits>
#include <utility>
#include <bit>        // has_single_bit
#include <concepts>   // constructible_from, destructible
#include <pthread.h>  // pthread_t, pthread_self, pthread_equal

namespace std {

// ============================================================
// Forward declarations
// ============================================================
class stop_token;
class stop_source;
template<class Callback> class stop_callback;

// ============================================================
// intrusive_node_base — doubly-linked list node mixin
// ============================================================
namespace detail {

template<class Derived>
struct intrusive_node_base {
    Derived* next = nullptr;
    Derived* prev = nullptr;
};

// ============================================================
// intrusive_list_view — non-owning doubly-linked list operations
// ============================================================
template<class Node>
struct intrusive_list_view {
    intrusive_list_view()                                       = default;
    intrusive_list_view(intrusive_list_view const&)             = default;
    intrusive_list_view(intrusive_list_view&&)                  = default;
    intrusive_list_view& operator=(intrusive_list_view const&)  = default;
    intrusive_list_view& operator=(intrusive_list_view&&)       = default;
    ~intrusive_list_view()                                      = default;

    bool empty() const noexcept { return head == nullptr; }

    void push_front(Node* node) noexcept {
        node->next = head;
        if (head)
            head->prev = node;
        head = node;
    }

    Node* pop_front() noexcept {
        Node* front = head;
        head = head->next;
        if (head)
            head->prev = nullptr;
        return front;
    }

    void remove(Node* node) noexcept {
        if (node->prev) {
            node->prev->next = node->next;
            if (node->next)
                node->next->prev = node->prev;
        } else {
            // node is head
            pop_front();
        }
    }

    bool is_head(Node* node) noexcept { return node == head; }

private:
    Node* head = nullptr;
};

// ============================================================
// atomic_unique_lock — RAII lock using a bit inside an atomic<State>
// ============================================================
template<class State, State LockedBit>
class atomic_unique_lock {
    static_assert(has_single_bit(static_cast<unsigned long long>(LockedBit)),
                  "LockedBit must have exactly one bit set");

    atomic<State>& state_;
    bool is_locked_;

    static constexpr auto set_locked_bit = [](State s) { return s | LockedBit; };

    template<class Pred, class UnaryFn>
    bool lock_impl(Pred&& give_up, UnaryFn&& after_lock,
                   memory_order locked_ordering) noexcept {
        State cur = state_.load(memory_order_relaxed);
        do {
            while (true) {
                if (give_up(cur))
                    return false;
                if ((cur & LockedBit) != 0) {
                    state_.wait(cur, memory_order_relaxed);
                    cur = state_.load(memory_order_relaxed);
                } else {
                    break;
                }
            }
        } while (!state_.compare_exchange_weak(
            cur,
            after_lock(cur),
            locked_ordering,
            memory_order_relaxed));
        return true;
    }

public:
    // Always-lock constructor
    explicit atomic_unique_lock(atomic<State>& s) noexcept
        : state_(s), is_locked_(true) {
        auto never_give_up = [](State) { return false; };
        lock_impl(never_give_up, set_locked_bit, memory_order_acquire);
    }

    // Conditional-lock (give_up predicate)
    template<class Pred>
    atomic_unique_lock(atomic<State>& s, Pred&& give_up) noexcept
        : state_(s), is_locked_(false) {
        is_locked_ = lock_impl(give_up, set_locked_bit, memory_order_acquire);
    }

    // Full-control constructor
    template<class Pred, class UnaryFn>
    atomic_unique_lock(atomic<State>& s, Pred&& give_up,
                       UnaryFn&& after_lock,
                       memory_order locked_ordering) noexcept
        : state_(s), is_locked_(false) {
        is_locked_ = lock_impl(give_up, after_lock, locked_ordering);
    }

    atomic_unique_lock(const atomic_unique_lock&)            = delete;
    atomic_unique_lock(atomic_unique_lock&&)                 = delete;
    atomic_unique_lock& operator=(const atomic_unique_lock&) = delete;
    atomic_unique_lock& operator=(atomic_unique_lock&&)      = delete;

    ~atomic_unique_lock() {
        if (is_locked_)
            unlock();
    }

    bool owns_lock() const noexcept { return is_locked_; }

    void lock() noexcept {
        auto never_give_up = [](State) { return false; };
        lock_impl(never_give_up, set_locked_bit, memory_order_acquire);
        is_locked_ = true;
    }

    void unlock() noexcept {
        state_.fetch_and(static_cast<State>(~LockedBit), memory_order_release);
        state_.notify_all();
        is_locked_ = false;
    }
};

// ============================================================
// stop_callback_base — base for the callback list node
// ============================================================
struct stop_callback_base : intrusive_node_base<stop_callback_base> {
    using callback_fn_t = void(stop_callback_base*) noexcept;
    explicit stop_callback_base(callback_fn_t* fn) : callback_fn(fn) {}

    void invoke() noexcept { callback_fn(this); }

    callback_fn_t*   callback_fn;
    atomic<bool>     completed  = false;
    bool*            destroyed  = nullptr;
};

// ============================================================
// stop_state — the shared stop state
// ============================================================
class stop_state {
    static constexpr uint32_t stop_requested_bit       = 1;
    static constexpr uint32_t callback_list_locked_bit = 1 << 1;
    static constexpr uint32_t stop_source_counter_shift = 2;

    //  bits 31..2 = stop_source ref count
    //  bit  1     = callback list locked
    //  bit  0     = stop requested
    atomic<uint32_t> state_   = 0;

    // Lifetime ref count (stop_token + stop_source + stop_callback).
    // Stored here so intrusive_shared_ptr doesn't need a second allocation.
    atomic<uint32_t> ref_count_ = 0;

    using state_t            = uint32_t;
    using cb_list_lock       = atomic_unique_lock<state_t, callback_list_locked_bit>;
    using cb_list_t          = intrusive_list_view<stop_callback_base>;

    cb_list_t  cb_list_;
    pthread_t  requesting_thread_ = 0;   // thread that called request_stop

public:
    stop_state() noexcept = default;

    void increment_stop_source_counter() noexcept {
        state_.fetch_add(1u << stop_source_counter_shift, memory_order_relaxed);
    }

    void decrement_stop_source_counter() noexcept {
        state_.fetch_sub(1u << stop_source_counter_shift, memory_order_relaxed);
    }

    bool stop_requested() const noexcept {
        return (state_.load(memory_order_acquire) & stop_requested_bit) != 0;
    }

    bool stop_possible_for_token() const noexcept {
        state_t s = state_.load(memory_order_acquire);
        return ((s & stop_requested_bit) != 0) ||
               ((s >> stop_source_counter_shift) != 0);
    }

    bool request_stop() noexcept {
        auto lock = try_lock_for_request_stop();
        if (!lock.owns_lock())
            return false;

        requesting_thread_ = pthread_self();

        while (!cb_list_.empty()) {
            auto cb = cb_list_.pop_front();

            lock.unlock();

            bool cb_destroyed  = false;
            cb->destroyed = &cb_destroyed;

            cb->invoke();

            if (!cb_destroyed) {
                cb->destroyed = nullptr;
                cb->completed.store(true, memory_order_release);
                cb->completed.notify_all();
            }

            lock.lock();
        }
        return true;
    }

    bool add_callback(stop_callback_base* cb) noexcept {
        const auto give_up = [cb](state_t s) {
            if ((s & stop_requested_bit) != 0) {
                cb->invoke();
                return true;
            }
            return (s >> stop_source_counter_shift) == 0;
        };

        cb_list_lock lk(state_, give_up);
        if (!lk.owns_lock())
            return false;

        cb_list_.push_front(cb);
        return true;
    }

    void remove_callback(stop_callback_base* cb) noexcept {
        cb_list_lock lk(state_);

        bool potentially_executing = (cb->prev == nullptr) && !cb_list_.is_head(cb);

        if (potentially_executing) {
            pthread_t req = requesting_thread_;
            lk.unlock();

            if (pthread_self() != req) {
                cb->completed.wait(false, memory_order_acquire);
            } else {
                if (cb->destroyed)
                    *cb->destroyed = true;
            }
        } else {
            cb_list_.remove(cb);
        }
    }

    // For intrusive_shared_ptr
    atomic<uint32_t>& get_ref_count() noexcept { return ref_count_; }

private:
    cb_list_lock try_lock_for_request_stop() noexcept {
        const auto fail_cond = [](state_t s) {
            return (s & stop_requested_bit) != 0;
        };
        const auto after_lock = [](state_t s) {
            return s | callback_list_locked_bit | stop_requested_bit;
        };
        return cb_list_lock(state_, fail_cond, after_lock, memory_order_acq_rel);
    }
};

// ============================================================
// intrusive_shared_ptr<stop_state>
// ============================================================
struct intrusive_shared_ptr {
    stop_state* ptr = nullptr;

    intrusive_shared_ptr() noexcept = default;

    explicit intrusive_shared_ptr(stop_state* p) noexcept : ptr(p) {
        if (ptr) inc();
    }

    intrusive_shared_ptr(const intrusive_shared_ptr& o) noexcept : ptr(o.ptr) {
        if (ptr) inc();
    }

    intrusive_shared_ptr(intrusive_shared_ptr&& o) noexcept : ptr(o.ptr) {
        o.ptr = nullptr;
    }

    intrusive_shared_ptr& operator=(const intrusive_shared_ptr& o) noexcept {
        if (o.ptr != ptr) {
            if (o.ptr) o.ptr->get_ref_count().fetch_add(1, memory_order_relaxed);
            if (ptr)   dec();
            ptr = o.ptr;
        }
        return *this;
    }

    intrusive_shared_ptr& operator=(intrusive_shared_ptr&& o) noexcept {
        intrusive_shared_ptr(std::move(o)).swap(*this);
        return *this;
    }

    ~intrusive_shared_ptr() {
        if (ptr) dec();
    }

    stop_state* operator->() const noexcept { return ptr; }
    stop_state& operator*()  const noexcept { return *ptr; }
    explicit operator bool() const noexcept { return ptr != nullptr; }

    void swap(intrusive_shared_ptr& o) noexcept { std::swap(ptr, o.ptr); }

    friend bool operator==(const intrusive_shared_ptr& a,
                           const intrusive_shared_ptr& b) noexcept {
        return a.ptr == b.ptr;
    }
    friend bool operator==(const intrusive_shared_ptr& a, nullptr_t) noexcept {
        return a.ptr == nullptr;
    }
    friend bool operator==(nullptr_t, const intrusive_shared_ptr& b) noexcept {
        return b.ptr == nullptr;
    }

private:
    void inc() noexcept {
        ptr->get_ref_count().fetch_add(1, memory_order_relaxed);
    }
    void dec() noexcept {
        if (ptr->get_ref_count().fetch_sub(1, memory_order_acq_rel) == 1)
            delete ptr;
    }
};

} // namespace detail

// ============================================================
// nostopstate_t / nostopstate
// ============================================================
struct nostopstate_t {
    explicit nostopstate_t() = default;
};

inline constexpr nostopstate_t nostopstate{};

// ============================================================
// stop_token
// ============================================================
class stop_token {
public:
    stop_token() noexcept = default;

    stop_token(const stop_token&) noexcept            = default;
    stop_token(stop_token&&) noexcept                 = default;
    stop_token& operator=(const stop_token&) noexcept = default;
    stop_token& operator=(stop_token&&) noexcept      = default;
    ~stop_token()                                     = default;

    void swap(stop_token& other) noexcept { state_.swap(other.state_); }

    [[nodiscard]] bool stop_requested() const noexcept {
        return state_ != nullptr && state_->stop_requested();
    }

    [[nodiscard]] bool stop_possible() const noexcept {
        return state_ != nullptr && state_->stop_possible_for_token();
    }

    [[nodiscard]] friend bool operator==(const stop_token& a,
                                         const stop_token& b) noexcept {
        return a.state_ == b.state_;
    }

    friend void swap(stop_token& lhs, stop_token& rhs) noexcept { lhs.swap(rhs); }

private:
    detail::intrusive_shared_ptr state_;

    friend class stop_source;
    template<class Cb> friend class stop_callback;

    explicit stop_token(const detail::intrusive_shared_ptr& s) : state_(s) {}
    explicit stop_token(detail::intrusive_shared_ptr&& s) : state_(std::move(s)) {}
};

// ============================================================
// stop_source
// ============================================================
class stop_source {
public:
    stop_source() : state_(new detail::stop_state()) {
        state_->increment_stop_source_counter();
    }

    explicit stop_source(nostopstate_t) noexcept : state_(nullptr) {}

    stop_source(const stop_source& other) noexcept : state_(other.state_) {
        if (state_)
            state_->increment_stop_source_counter();
    }

    stop_source(stop_source&&) noexcept = default;

    stop_source& operator=(const stop_source& other) noexcept {
        // increment other first (safe for self-assignment)
        if (other.state_)
            other.state_->increment_stop_source_counter();
        if (state_)
            state_->decrement_stop_source_counter();
        state_ = other.state_;
        return *this;
    }

    stop_source& operator=(stop_source&&) noexcept = default;

    ~stop_source() {
        if (state_)
            state_->decrement_stop_source_counter();
    }

    void swap(stop_source& other) noexcept { state_.swap(other.state_); }

    [[nodiscard]] stop_token get_token() const noexcept {
        return stop_token(state_);
    }

    [[nodiscard]] bool stop_possible() const noexcept {
        return state_ != nullptr;
    }

    [[nodiscard]] bool stop_requested() const noexcept {
        return state_ != nullptr && state_->stop_requested();
    }

    bool request_stop() noexcept {
        return state_ && state_->request_stop();
    }

    [[nodiscard]] friend bool operator==(const stop_source& a,
                                          const stop_source& b) noexcept {
        return a.state_ == b.state_;
    }

    friend void swap(stop_source& lhs, stop_source& rhs) noexcept {
        lhs.swap(rhs);
    }

private:
    detail::intrusive_shared_ptr state_;
};

// ============================================================
// stop_callback<Callback>
// ============================================================
template<class Callback>
class stop_callback : private detail::stop_callback_base {
    static_assert(is_invocable_v<Callback>,
        "stop_callback requires an invocable Callback");
    static_assert(is_destructible_v<Callback>,
        "stop_callback requires a destructible Callback");

public:
    using callback_type = Callback;

    template<class Cb>
        requires constructible_from<Callback, Cb>
    explicit stop_callback(const stop_token& st, Cb&& cb)
        noexcept(is_nothrow_constructible_v<Callback, Cb>)
        : stop_callback(st.state_, std::forward<Cb>(cb)) {}

    template<class Cb>
        requires constructible_from<Callback, Cb>
    explicit stop_callback(stop_token&& st, Cb&& cb)
        noexcept(is_nothrow_constructible_v<Callback, Cb>)
        : stop_callback(std::move(st.state_), std::forward<Cb>(cb)) {}

    ~stop_callback() {
        if (state_)
            state_->remove_callback(this);
    }

    stop_callback(const stop_callback&)            = delete;
    stop_callback(stop_callback&&)                 = delete;
    stop_callback& operator=(const stop_callback&) = delete;
    stop_callback& operator=(stop_callback&&)      = delete;

private:
    [[no_unique_address]] Callback callback_;
    detail::intrusive_shared_ptr   state_;

    template<class StatePtr, class Cb>
    explicit stop_callback(StatePtr&& sptr, Cb&& cb)
        noexcept(is_nothrow_constructible_v<Callback, Cb>)
        : stop_callback_base([](stop_callback_base* base) noexcept {
              static_cast<stop_callback*>(base)->callback_();
          }),
          callback_(std::forward<Cb>(cb)),
          state_() {
        if (sptr && sptr->add_callback(this))
            state_ = std::forward<StatePtr>(sptr);
    }
};

template<class Callback>
stop_callback(stop_token, Callback) -> stop_callback<Callback>;

} // namespace std
