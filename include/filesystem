// weakly_canonical
[[nodiscard]] inline path weakly_canonical(const path& p, std::error_code& ec) {
    // Try to canonicalize as much as possible
    ec.clear();
    // Find longest prefix that exists
    path result;
    std::vector<std::string> tail;
    path cur = p.lexically_normal();

    // Walk from the full path backward to find the longest existing prefix.
    // Ported from libc++ __weakly_canonical (src/filesystem/operations.cpp).
    path existing = cur;
    std::vector<std::string> non_existing;
    bool found_existing = false;
    while (!existing.empty()) {
        struct ::stat st;
        if (::lstat(existing.c_str(), &st) == 0) {
            char buf[PATH_MAX];
            if (::realpath(existing.c_str(), buf) != nullptr)
                result = path(buf);
            else
                result = existing;
            found_existing = true;
            break;
        }
        // not found, strip last component
        auto fn = existing.filename().native();
        path parent = existing.parent_path();
        if (parent == existing) break;  // reached root with nothing existing
        // A trailing separator yields an empty filename; it contributes no
        // path component, so skip it but keep walking.
        if (!fn.empty())
            non_existing.push_back(fn);
        existing = parent;
    }

    if (!found_existing) {
        // No prefix exists: canonicalize the empty path (== current_path) so
        // the result is absolute, matching libc++'s __canonical("").
        char buf[PATH_MAX];
        if (::realpath(".", buf) != nullptr)
            result = path(buf);
        else
            result = current_path(ec);
    }

    // Append the non-existing parts back (front-to-back) and normalize.
    for (auto it = non_existing.rbegin(); it != non_existing.rend(); ++it)
        result /= *it;

    if (result.empty())
        result = cur;
    return result.lexically_normal();
}
[[nodiscard]] inline path weakly_canonical(const path& p) {
    std::error_code ec;
    auto r = weakly_canonical(p, ec);
    if (ec) __builtin_trap();
    return r;
}

// equivalent
[[nodiscard]] inline bool equivalent(const path& p1, const path& p2, std::error_code& ec) noexcept {
    struct ::stat st1, st2;
    if (::stat(p1.c_str(), &st1) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    if (::stat(p2.c_str(), &st2) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    ec.clear();
    return st1.st_dev == st2.st_dev && st1.st_ino == st2.st_ino;
}
[[nodiscard]] inline bool equivalent(const path& p1, const path& p2) {
    std::error_code ec;
    bool r = equivalent(p1, p2, ec);
    if (ec) __builtin_trap();
    return r;
}

// create_directory
inline bool create_directory(const path& p, std::error_code& ec) noexcept {
    if (::mkdir(p.c_str(), 0777) == 0) {
        ec.clear();
        return true;
    }
    if (errno == EEXIST) {
        ec.clear();
        return false;
    }
    ec = std::error_code(errno, std::generic_category());
    return false;
}
inline bool create_directory(const path& p) {
    std::error_code ec;
    bool r = create_directory(p, ec);
    if (ec) __builtin_trap();
    return r;
}
inline bool create_directory(const path& p, const path& attrs, std::error_code& ec) noexcept {
    struct ::stat st;
    if (::stat(attrs.c_str(), &st) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    mode_t m = st.st_mode & 07777;
    if (::mkdir(p.c_str(), m) == 0) {
        ec.clear();
        return true;
    }
    if (errno == EEXIST) {
        ec.clear();
        return false;
    }
    ec = std::error_code(errno, std::generic_category());
    return false;
}
inline bool create_directory(const path& p, const path& attrs) {
    std::error_code ec;
    bool r = create_directory(p, attrs, ec);
    if (ec) __builtin_trap();
    return r;
}

// create_directories
inline bool create_directories(const path& p, std::error_code& ec) {
    ec.clear();
    if (p.empty()) {
        ec = std::error_code(EINVAL, std::generic_category());
        return false;
    }
    // Check if already exists
    {
        struct ::stat st;
        if (::stat(p.c_str(), &st) == 0) {
            if (S_ISDIR(st.st_mode))
                return false;
            ec = std::error_code(ENOTDIR, std::generic_category());
            return false;
        }
    }
    // Recursively create parent
    path parent = p.parent_path();
    if (!parent.empty() && parent != p) {
        create_directories(parent, ec);
        if (ec) return false;
    }
    return create_directory(p, ec);
}
