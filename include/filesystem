// Helper: is this character a path separator?
inline bool path_is_sep(char c) noexcept { return c == '/'; }

// Traits for "is this type a source for path construction?"
template <class T>
struct can_convert_char { static constexpr bool value = false; };
template <> struct can_convert_char<char> {
    static constexpr bool value = true;
    using char_type = char;
};
template <> struct can_convert_char<wchar_t> {
    static constexpr bool value = true;
    using char_type = wchar_t;
};
template <> struct can_convert_char<char16_t> {
    static constexpr bool value = true;
    using char_type = char16_t;
};
template <> struct can_convert_char<char32_t> {
    static constexpr bool value = true;
    using char_type = char32_t;
};
template <> struct can_convert_char<char8_t> {
    static constexpr bool value = true;
    using char_type = char8_t;
};
template <class T> struct can_convert_char<const T> : can_convert_char<T> {};

struct null_sentinel_t {};

template <class T, class = void>
struct is_pathable_string : std::false_type {};

template <class ECharT, class Traits, class Alloc>
struct is_pathable_string<std::basic_string<ECharT, Traits, Alloc>,
                          std::void_t<typename can_convert_char<ECharT>::char_type>>
    : can_convert_char<ECharT> {
    using str_type = std::basic_string<ECharT, Traits, Alloc>;
    static const ECharT* range_begin(const str_type& s) { return s.data(); }
    static const ECharT* range_end(const str_type& s) { return s.data() + s.size(); }
    static ECharT first_or_null(const str_type& s) { return s.empty() ? ECharT{} : s[0]; }
};

template <class ECharT, class Traits>
struct is_pathable_string<std::basic_string_view<ECharT, Traits>,
                          std::void_t<typename can_convert_char<ECharT>::char_type>>
    : can_convert_char<ECharT> {
    using str_type = std::basic_string_view<ECharT, Traits>;
    static const ECharT* range_begin(const str_type& s) { return s.data(); }
    static const ECharT* range_end(const str_type& s) { return s.data() + s.size(); }
    static ECharT first_or_null(const str_type& s) { return s.empty() ? ECharT{} : s[0]; }
};

template <class Source,
          class DS            = std::decay_t<Source>,
          class UnqualPtrType = std::remove_const_t<std::remove_pointer_t<DS>>,
          bool IsCharPtr      = std::is_pointer_v<DS> && can_convert_char<UnqualPtrType>::value>
struct is_pathable_char_array : std::false_type {};

template <class Source, class ECharT, class UPtr>
struct is_pathable_char_array<Source, ECharT*, UPtr, true>
    : can_convert_char<std::remove_const_t<ECharT>> {
    static const ECharT* range_begin(const ECharT* b) { return b; }
    static const ECharT* range_end(const ECharT* b) {
        const ECharT sentinel = ECharT{};
        const ECharT* e = b;
        for (; *e != sentinel; ++e)
            ;
        return e;
    }
    static ECharT first_or_null(const ECharT* b) { return *b; }
};

template <class Iter, class = void>
struct has_input_iter_category : std::false_type {};
template <class Iter>
struct has_input_iter_category<Iter,
    std::void_t<typename std::iterator_traits<Iter>::iterator_category>>
    : std::bool_constant<std::is_base_of_v<
          std::input_iterator_tag,
          typename std::iterator_traits<Iter>::iterator_category>> {};

template <class Iter, bool IsIt = has_input_iter_category<Iter>::value, class = void>
struct is_pathable_iter : std::false_type {};

template <class Iter>
struct is_pathable_iter<Iter, true,
    std::void_t<typename can_convert_char<
        typename std::iterator_traits<Iter>::value_type>::char_type>>
    : can_convert_char<typename std::iterator_traits<Iter>::value_type> {
    using ECharT = typename std::iterator_traits<Iter>::value_type;
    static Iter range_begin(Iter b) { return b; }
    static null_sentinel_t range_end(Iter) { return null_sentinel_t{}; }
    static ECharT first_or_null(Iter b) { return *b; }
};

template <class T,
          bool IsString   = is_pathable_string<T>::value,
          bool IsCharArr  = is_pathable_char_array<T>::value,
          bool IsIter     = !is_pathable_char_array<T>::value && is_pathable_iter<T>::value>
struct is_pathable : std::false_type {};

template <class T> struct is_pathable<T, true,  false, false> : is_pathable_string<T> {};
template <class T> struct is_pathable<T, false, true,  false> : is_pathable_char_array<T> {};
template <class T> struct is_pathable<T, false, false, true>  : is_pathable_iter<T> {};

//===----------------------------------------------------------------------===//
// Self-contained UTF transcoding (path stores UTF-8 internally on POSIX).
// Independent of <locale>/<codecvt> (owned by other agents). Decodes any
// wide encoding (UTF-16 from 16-bit units, UTF-32 from 32-bit units, with
// the latin1/UCS subset for wchar_t) to/from UTF-8.
//===----------------------------------------------------------------------===//
namespace fs_utf {

// Append one Unicode scalar value as UTF-8 to dest.
inline void utf8_encode(std::string& dest, char32_t cp) {
    if (cp < 0x80) {
        dest.push_back(static_cast<char>(cp));
    } else if (cp < 0x800) {
        dest.push_back(static_cast<char>(0xC0 | (cp >> 6)));
        dest.push_back(static_cast<char>(0x80 | (cp & 0x3F)));
    } else if (cp < 0x10000) {
        dest.push_back(static_cast<char>(0xE0 | (cp >> 12)));
        dest.push_back(static_cast<char>(0x80 | ((cp >> 6) & 0x3F)));
        dest.push_back(static_cast<char>(0x80 | (cp & 0x3F)));
    } else {
        dest.push_back(static_cast<char>(0xF0 | (cp >> 18)));
        dest.push_back(static_cast<char>(0x80 | ((cp >> 12) & 0x3F)));
        dest.push_back(static_cast<char>(0x80 | ((cp >> 6) & 0x3F)));
        dest.push_back(static_cast<char>(0x80 | (cp & 0x3F)));
    }
}

// Decode the next scalar value from a UTF-8 byte range [b,e). Advances b.
inline char32_t utf8_decode(const char*& b, const char* e) {
    unsigned char c = static_cast<unsigned char>(*b++);
    if (c < 0x80) return c;
    int extra;
    char32_t cp;
    if ((c & 0xE0) == 0xC0) { extra = 1; cp = c & 0x1F; }
    else if ((c & 0xF0) == 0xE0) { extra = 2; cp = c & 0x0F; }
    else if ((c & 0xF8) == 0xF0) { extra = 3; cp = c & 0x07; }
    else return c; // invalid lead byte; pass through
    for (int i = 0; i < extra && b < e; ++i) {
        cp = (cp << 6) | (static_cast<unsigned char>(*b++) & 0x3F);
    }
    return cp;
}

// Encode a scalar value into UTF-16 code units appended to a wide string.
template <class WStr>
inline void utf16_encode(WStr& dest, char32_t cp) {
    if (cp < 0x10000) {
        dest.push_back(static_cast<typename WStr::value_type>(cp));
    } else {
        cp -= 0x10000;
        dest.push_back(static_cast<typename WStr::value_type>(0xD800 | (cp >> 10)));
        dest.push_back(static_cast<typename WStr::value_type>(0xDC00 | (cp & 0x3FF)));
    }
}

// Append UTF-8 bytes [b,e) decoded into a wide string (16- or 32-bit char).
// Templated on the destination string type so transcoding can target a
// caller-provided allocator string directly (no default-allocator temporary).
template <class WStr>
inline void from_utf8(WStr& dest, const char* b, const char* e) {
    using ECharT = typename WStr::value_type;
    while (b < e) {
        char32_t cp = utf8_decode(b, e);
        if constexpr (sizeof(ECharT) >= 4) {
            dest.push_back(static_cast<ECharT>(cp));
        } else {
            utf16_encode(dest, cp);
        }
    }
}

// Append a wide range [b,e) (ECharT 16/32-bit) to a UTF-8 std::string.
template <class ECharT, class Iter>
inline void to_utf8(std::string& dest, Iter b, Iter e) {
    if constexpr (sizeof(ECharT) >= 4) {
        for (; b != e; ++b)
            utf8_encode(dest, static_cast<char32_t>(static_cast<std::make_unsigned_t<ECharT>>(*b)));
    } else {
        // ECharT is 16-bit: combine surrogate pairs.
        while (b != e) {
            char32_t u = static_cast<char16_t>(*b++);
            if (u >= 0xD800 && u <= 0xDBFF && b != e) {
                char32_t lo = static_cast<char16_t>(*b);
                if (lo >= 0xDC00 && lo <= 0xDFFF) {
                    ++b;
                    u = 0x10000 + ((u - 0xD800) << 10) + (lo - 0xDC00);
                }
            }
            utf8_encode(dest, u);
        }
    }
}

} // namespace fs_utf

// PathCVT: converts from various char types to std::string (POSIX path).
// For char sources: direct append. For non-char sources: narrow via casting.
// Generic (wide) PathCVT: transcode UTF-16/UTF-32/wchar_t to UTF-8.
template <class ECharT>
struct path_cvt {
    static void append_range(std::string& dest, const ECharT* b, const ECharT* e) {
        fs_utf::to_utf8<ECharT>(dest, b, e);
    }
    template <class Iter>
    static void append_range(std::string& dest, Iter b, Iter e) {
        std::basic_string<ECharT> tmp;
        for (; b != e; ++b)
            tmp.push_back(static_cast<ECharT>(*b));
        fs_utf::to_utf8<ECharT>(dest, tmp.data(), tmp.data() + tmp.size());
    }
    template <class Iter>
    static void append_range(std::string& dest, Iter b, null_sentinel_t) {
        const ECharT sentinel = ECharT{};
        std::basic_string<ECharT> tmp;
        for (; *b != sentinel; ++b)
            tmp.push_back(static_cast<ECharT>(*b));
        fs_utf::to_utf8<ECharT>(dest, tmp.data(), tmp.data() + tmp.size());
    }
    template <class Source>
    static void append_source(std::string& dest, const Source& s) {
        using Traits = is_pathable<Source>;
        append_range(dest, Traits::range_begin(s), Traits::range_end(s));
    }
};

// char8_t is UTF-8 already: copy bytes verbatim.
template <>
struct path_cvt<char8_t> {
    template <class Iter>
    static void append_range(std::string& dest, Iter b, Iter e) {
        for (; b != e; ++b)
            dest.push_back(static_cast<char>(static_cast<unsigned char>(*b)));
    }
    template <class Iter>
    static void append_range(std::string& dest, Iter b, null_sentinel_t) {
        const char8_t sentinel = char8_t{};
        for (; *b != sentinel; ++b)
            dest.push_back(static_cast<char>(static_cast<unsigned char>(*b)));
    }
    template <class Source>
    static void append_source(std::string& dest, const Source& s) {
        using Traits = is_pathable<Source>;
        append_range(dest, Traits::range_begin(s), Traits::range_end(s));
    }
};

template <>
struct path_cvt<char> {
    template <class Iter>
    static void append_range(std::string& dest, Iter b, Iter e) {
        if constexpr (std::is_same_v<Iter, const char*> || std::is_same_v<Iter, char*>) {
            dest.append(b, e);
        } else {
            for (; b != e; ++b)
                dest.push_back(*b);
        }
    }
    static void append_range(std::string& dest, const char* b, const char* e) {
        dest.append(b, e);
    }
    static void append_range(std::string& dest, const char* b, null_sentinel_t) {
        dest.append(b);
    }
    template <class Iter>
    static void append_range(std::string& dest, Iter b, null_sentinel_t) {
        const char sentinel = '\0';
        for (; *b != sentinel; ++b)
            dest.push_back(*b);
    }
    template <class Source>
    static void append_source(std::string& dest, const Source& s) {
        using Traits = is_pathable<Source>;
        append_range(dest, Traits::range_begin(s), Traits::range_end(s));
    }
};

class path {
    template <class SourceOrIter, class T = path&>
    using enable_if_pathable = std::enable_if_t<is_pathable<SourceOrIter>::value, T>;

    template <class T>
    using source_char = typename is_pathable<T>::char_type;

    template <class T>
    using source_cvt = path_cvt<source_char<T>>;

public:
    using value_type  = char;
    using string_type = std::string;
    static constexpr value_type preferred_separator = '/';

    enum format : unsigned char { auto_format, native_format, generic_format };

    // constructors and destructor
    path() noexcept {}
    path(const path& p) : pn_(p.pn_) {}
    path(path&& p) noexcept : pn_(std::move(p.pn_)) {}
    path(string_type&& s, format = format::auto_format) noexcept : pn_(std::move(s)) {}

    template <class Source, class = enable_if_pathable<Source, void>>
    path(const Source& src, format = format::auto_format) {
        source_cvt<Source>::append_source(pn_, src);
    }

    template <class InputIt>
    path(InputIt first, InputIt last, format = format::auto_format) {
        using ItVal = typename std::iterator_traits<InputIt>::value_type;
        path_cvt<ItVal>::append_range(pn_, first, last);
    }

    ~path() = default;

    // assignments
    path& operator=(const path& p) { pn_ = p.pn_; return *this; }
    path& operator=(path&& p) noexcept { pn_ = std::move(p.pn_); return *this; }
    path& operator=(string_type&& s) noexcept { pn_ = std::move(s); return *this; }
    path& assign(string_type&& s) noexcept { pn_ = std::move(s); return *this; }

    template <class Source>
    enable_if_pathable<Source> operator=(const Source& src) { return this->assign(src); }

    template <class Source>
    enable_if_pathable<Source> assign(const Source& src) {
        pn_.clear();
        source_cvt<Source>::append_source(pn_, src);
        return *this;
    }

    template <class InputIt>
    path& assign(InputIt first, InputIt last) {
        using ItVal = typename std::iterator_traits<InputIt>::value_type;
        pn_.clear();
        path_cvt<ItVal>::append_range(pn_, first, last);
        return *this;
    }

    // appends (operator/=, append)
    path& operator/=(const path& p) {
        if (p.is_absolute()) {
            pn_ = p.pn_;
            return *this;
        }
        if (has_filename())
            pn_ += preferred_separator;
        pn_ += p.native();
        return *this;
    }

    template <class Source>
    enable_if_pathable<Source> operator/=(const Source& src) {
        return this->append(src);
    }

    template <class Source>
    enable_if_pathable<Source> append(const Source& src) {
        using Traits = is_pathable<Source>;
        using CVT    = path_cvt<source_char<Source>>;
        bool source_is_absolute = path_is_sep(
            static_cast<char>(Traits::first_or_null(src)));
        if (source_is_absolute)
            pn_.clear();
        else if (has_filename())
            pn_ += preferred_separator;
        CVT::append_source(pn_, src);
        return *this;
    }

    template <class InputIt>
    path& append(InputIt first, InputIt last) {
        using ItVal = typename std::iterator_traits<InputIt>::value_type;
        if (first != last && path_is_sep(static_cast<char>(*first)))
            pn_.clear();
        else if (has_filename())
            pn_ += preferred_separator;
        path_cvt<ItVal>::append_range(pn_, first, last);
        return *this;
    }

    // concatenation
    path& operator+=(const path& x)        { pn_ += x.pn_; return *this; }
    path& operator+=(const string_type& x)  { pn_ += x; return *this; }
    path& operator+=(std::string_view x)    { pn_ += x; return *this; }
    path& operator+=(const value_type* x)   { pn_ += x; return *this; }
    path& operator+=(value_type x)          { pn_ += x; return *this; }

    template <class ECharT>
    requires can_convert_char<ECharT>::value
    path& operator+=(ECharT x) {
        path_cvt<ECharT>::append_source(pn_,
            std::basic_string_view<ECharT>(std::addressof(x), 1));
        return *this;
    }

    template <class Source>
    enable_if_pathable<Source> operator+=(const Source& x) { return this->concat(x); }

    template <class Source>
    enable_if_pathable<Source> concat(const Source& x) {
        source_cvt<Source>::append_source(pn_, x);
        return *this;
    }

    template <class InputIt>
    path& concat(InputIt first, InputIt last) {
        using ItVal = typename std::iterator_traits<InputIt>::value_type;
        path_cvt<ItVal>::append_range(pn_, first, last);
        return *this;
    }

    // modifiers
    void  clear() noexcept { pn_.clear(); }

    path& make_preferred() { return *this; }  // POSIX: '/' is already preferred

    path& remove_filename() {
        auto fname = filename_sv();
        if (!fname.empty())
            pn_.erase(fname.data() - pn_.data());
        return *this;
    }

    path& replace_filename(const path& replacement) {
        remove_filename();
        return (*this /= replacement);
    }

    path& replace_extension(const path& replacement = path()) {
        // Remove existing extension
        auto ext = extension_sv();
        if (!ext.empty())
            pn_.erase(pn_.size() - ext.size());
        // Add new extension (prepend '.' if not already present and non-empty)
        if (!replacement.empty()) {
            if (replacement.pn_[0] != '.')
                pn_ += '.';
            pn_ += replacement.pn_;
        }
        return *this;
    }

    void swap(path& rhs) noexcept { pn_.swap(rhs.pn_); }

    // native format observers
    [[nodiscard]] const string_type& native() const noexcept { return pn_; }
    [[nodiscard]] const value_type* c_str() const noexcept { return pn_.c_str(); }
    operator string_type() const { return pn_; }

    // native format observers (POSIX: native string is UTF-8 in std::string)
    [[nodiscard]] std::string string() const { return pn_; }
    [[nodiscard]] std::u8string u8string() const {
        return std::u8string(pn_.begin(), pn_.end());
    }

    template <class ECharT, class Traits = std::char_traits<ECharT>,
              class Allocator = std::allocator<ECharT>>
    [[nodiscard]] std::basic_string<ECharT, Traits, Allocator>
    string(const Allocator& a = Allocator()) const {
        std::basic_string<ECharT, Traits, Allocator> s(a);
        if constexpr (std::is_same_v<ECharT, char>) {
            s.assign(pn_.begin(), pn_.end());
        } else if constexpr (std::is_same_v<ECharT, char8_t>) {
            s.assign(pn_.begin(), pn_.end());
        } else {
            // Transcode UTF-8 -> wide directly into the allocator-provided
            // string so all allocation goes through the supplied allocator.
            s.reserve(pn_.size());
            fs_utf::from_utf8(s, pn_.data(), pn_.data() + pn_.size());
        }
        return s;
    }

    [[nodiscard]] std::wstring wstring() const { return string<wchar_t>(); }
    [[nodiscard]] std::u16string u16string() const { return string<char16_t>(); }
    [[nodiscard]] std::u32string u32string() const { return string<char32_t>(); }

    // generic format observers (POSIX: identical to native, '/' separators)
    [[nodiscard]] std::string generic_string() const { return pn_; }
    [[nodiscard]] std::u8string generic_u8string() const { return u8string(); }

    template <class ECharT, class Traits = std::char_traits<ECharT>,
              class Allocator = std::allocator<ECharT>>
    [[nodiscard]] std::basic_string<ECharT, Traits, Allocator>
    generic_string(const Allocator& a = Allocator()) const {
        return string<ECharT, Traits, Allocator>(a);
    }

    [[nodiscard]] std::wstring generic_wstring() const { return string<wchar_t>(); }
    [[nodiscard]] std::u16string generic_u16string() const { return string<char16_t>(); }
    [[nodiscard]] std::u32string generic_u32string() const { return string<char32_t>(); }

    // compare
    [[nodiscard]] int compare(const path& p) const noexcept { return compare_sv(p.pn_); }
    [[nodiscard]] int compare(const string_type& s) const   { return compare_sv(s); }
    [[nodiscard]] int compare(std::string_view s) const     { return compare_sv(s); }
    [[nodiscard]] int compare(const value_type* s) const    { return compare_sv(s); }

    // decomposition
    [[nodiscard]] path root_name() const      { return string_type(root_name_sv()); }
    [[nodiscard]] path root_directory() const { return string_type(root_directory_sv()); }
    [[nodiscard]] path root_path() const      {
        return root_name().append(string_type(root_directory_sv()));
    }
    [[nodiscard]] path relative_path() const  { return string_type(relative_path_sv()); }
    [[nodiscard]] path parent_path() const    { return string_type(parent_path_sv()); }
    [[nodiscard]] path filename() const       { return string_type(filename_sv()); }
    [[nodiscard]] path stem() const           { return string_type(stem_sv()); }
    [[nodiscard]] path extension() const      { return string_type(extension_sv()); }

    // query
    [[nodiscard]] bool empty() const noexcept   { return pn_.empty(); }
    [[nodiscard]] bool has_root_name() const      { return !root_name_sv().empty(); }
    [[nodiscard]] bool has_root_directory() const { return !root_directory_sv().empty(); }
    [[nodiscard]] bool has_root_path() const {
        return has_root_name() || has_root_directory();
    }
    [[nodiscard]] bool has_relative_path() const  { return !relative_path_sv().empty(); }
    [[nodiscard]] bool has_parent_path() const    { return !parent_path_sv().empty(); }
    [[nodiscard]] bool has_filename() const       { return !filename_sv().empty(); }
    [[nodiscard]] bool has_stem() const           { return !stem_sv().empty(); }
    [[nodiscard]] bool has_extension() const      { return !extension_sv().empty(); }
    [[nodiscard]] bool is_absolute() const        { return has_root_directory(); }
    [[nodiscard]] bool is_relative() const        { return !is_absolute(); }

    // lexical operations
    [[nodiscard]] path lexically_normal() const;
    [[nodiscard]] path lexically_relative(const path& base) const;
    [[nodiscard]] path lexically_proximate(const path& base) const {
        path result = lexically_relative(base);
        if (result.native().empty())
            return *this;
        return result;
    }

    // operators
    friend bool operator==(const path& lhs, const path& rhs) noexcept {
        return lhs.compare_sv(rhs.pn_) == 0;
    }
    friend std::strong_ordering operator<=>(const path& lhs, const path& rhs) noexcept {
        int r = lhs.compare_sv(rhs.pn_);
        if (r < 0) return std::strong_ordering::less;
        if (r > 0) return std::strong_ordering::greater;
        return std::strong_ordering::equal;
    }

    friend path operator/(const path& lhs, const path& rhs) {
        path result(lhs);
        result /= rhs;
        return result;
    }

    // stream inserters/extractors. Templates on the stream char type, so they
    // are only instantiated in the user TU (which supplies the stream header).
    // The quoting logic (equivalent to std::quoted with delim '"', escape '\\')
    // is inlined here so <iomanip> need not be included by <filesystem>.
    template <class CharT, class Traits>
    friend std::basic_ostream<CharT, Traits>&
    operator<<(std::basic_ostream<CharT, Traits>& os, const path& p) {
        std::basic_string<CharT, Traits> src = p.string<CharT, Traits>();
        const CharT delim = CharT('"'), escape = CharT('\\');
        std::basic_string<CharT, Traits> buf;
        buf.push_back(delim);
        for (CharT c : src) {
            if (Traits::eq(c, escape) || Traits::eq(c, delim))
                buf.push_back(escape);
            buf.push_back(c);
        }
        buf.push_back(delim);
        os << buf;
        return os;
    }

    template <class CharT, class Traits>
    friend std::basic_istream<CharT, Traits>&
    operator>>(std::basic_istream<CharT, Traits>& is, path& p) {
        const CharT delim = CharT('"'), escape = CharT('\\');
        std::basic_string<CharT, Traits> tmp;
        CharT c;
        is >> c;  // skips leading whitespace
        if (is.fail()) return is;
        if (!Traits::eq(c, delim)) {
            is.putback(c);
            is >> tmp;
            p = tmp;
            return is;
        }
        // Inside the quotes: read raw characters (get() does not skip ws).
        while (is.get(c)) {
            if (Traits::eq(c, escape)) {
                if (!is.get(c)) break;
            } else if (Traits::eq(c, delim)) {
                break;
            }
            tmp.push_back(c);
        }
        p = tmp;
        return is;
    }

    // iterators
    class iterator;
    using const_iterator = iterator;
    [[nodiscard]] iterator begin() const;
    [[nodiscard]] iterator end() const;

private:
    // internal string_view helper that returns a view into pn_
    std::string_view root_name_sv() const noexcept {
        // POSIX: no root name (only UNC on Windows)
        (void)pn_;
        return {};
    }

    std::string_view root_directory_sv() const noexcept {
        if (!pn_.empty() && pn_[0] == '/')
            return std::string_view(pn_.data(), 1);
        return {};
    }

    std::string_view relative_path_sv() const noexcept {
        // relative_path = path with the root-path removed. On POSIX there is
        // no root-name; the root-directory is the leading separator run, so
        // skip ALL leading '/' characters.
        std::string_view sv(pn_);
        size_t i = 0;
        while (i < sv.size() && sv[i] == '/') ++i;
        sv.remove_prefix(i);
        return sv;
    }

    // Ported from libc++ path::__parent_path (src/filesystem/path.cpp):
    // remove a single trailing element. Handles the trailing empty element
    // (path ending in '/') correctly: "foo/" -> "foo".
    std::string_view parent_path_sv() const noexcept {
        if (pn_.empty())
            return {};
        std::string_view sv(pn_);
        // Root-dir-only path (e.g. "/"): parent is itself.
        bool root = sv[0] == '/';
        std::string_view rel = sv;
        if (root) rel.remove_prefix(1);
        // skip extra leading separators of the root run
        size_t relStart = 1;
        if (root) {
            while (relStart < sv.size() && sv[relStart] == '/') ++relStart;
        }
        if (root && relStart >= sv.size())
            return sv;  // only root dir, no relative path
        // Find the start of the last element by scanning from the end.
        size_t end = sv.size();
        // A trailing separator denotes a trailing empty element; the last
        // element is empty and starts at end. Otherwise the last element is
        // the final non-separator run.
        size_t lastStart;
        if (sv[end - 1] == '/') {
            lastStart = end;  // empty trailing element
        } else {
            size_t i = end;
            while (i > 0 && sv[i - 1] != '/') --i;
            lastStart = i;
        }
        // Strip the separators preceding the last element.
        size_t cut = lastStart;
        while (cut > 0 && sv[cut - 1] == '/') --cut;
        // Keep the root separator if present.
        if (root && cut == 0)
            cut = 1;
        if (cut == 0)
            return {};
        return std::string_view(sv.data(), cut);
    }

    std::string_view filename_sv() const noexcept {
        if (pn_.empty())
            return {};
        // Per [fs.path.decompose]: filename() == relative_path().empty() ? path() : *--end()
        // If relative_path is empty (e.g. path is just "/"), filename is empty.
        if (relative_path_sv().empty())
            return {};
        // Trailing separator means empty filename (e.g. "/foo/")
        if (pn_.back() == '/')
            return {};
        // Find last '/'
        auto pos = pn_.rfind('/');
        if (pos == std::string::npos)
            return std::string_view(pn_.data(), pn_.size());
        return std::string_view(pn_.data() + pos + 1, pn_.size() - pos - 1);
    }

    std::string_view stem_sv() const noexcept {
        auto fname = filename_sv();
        if (fname == "." || fname == "..")
            return fname;
        auto dot = fname.rfind('.');
        if (dot == std::string_view::npos || dot == 0)
            return fname;
        return fname.substr(0, dot);
    }

    std::string_view extension_sv() const noexcept {
        auto fname = filename_sv();
        if (fname == "." || fname == "..")
            return {};
        auto dot = fname.rfind('.');
        if (dot == std::string_view::npos || dot == 0)
            return {};
        return fname.substr(dot);
    }

    // Component-wise comparison per [fs.path.compare]. Ported from libc++
    // path::__compare (src/filesystem/path.cpp): compare root-name (none on
    // POSIX), then root-directory presence, then relative components
    // lexicographically, then end state. Allocation-free (string_view only).
    static int compare_sv_static(std::string_view a, std::string_view b) noexcept {
        // Root-directory: leading '/'.
        bool aRoot = !a.empty() && a[0] == '/';
        bool bRoot = !b.empty() && b[0] == '/';
        if (!aRoot && bRoot) return -1;
        if (aRoot && !bRoot) return 1;
        // Consume the entire root-directory separator run (ConsumeRootDir),
        // so "//" and "/" both reduce to an empty relative path.
        if (aRoot) { size_t i = 0; while (i < a.size() && a[i] == '/') ++i; a.remove_prefix(i); }
        if (bRoot) { size_t i = 0; while (i < b.size() && b[i] == '/') ++i; b.remove_prefix(i); }
        // Relative components, element-by-element. A path ending in a
        // separator yields a final empty ("") element (as libc++'s
        // PathParser does), so "a/b/" sorts after "a/b".
        auto next = [](std::string_view& s, std::string_view& out, bool& trailing) -> bool {
            // skip separator run
            bool sawSep = false;
            while (!s.empty() && s[0] == '/') { s.remove_prefix(1); sawSep = true; }
            if (s.empty()) {
                if (sawSep && trailing) { trailing = false; out = std::string_view(); return true; }
                return false;
            }
            size_t n = 0;
            while (n < s.size() && s[n] != '/') ++n;
            out = s.substr(0, n);
            s.remove_prefix(n);
            return true;
        };
        bool ta = true, tb = true;
        std::string_view ea, eb;
        while (true) {
            bool ha = next(a, ea, ta);
            bool hb = next(b, eb, tb);
            if (!ha && !hb) return 0;
            if (!ha) return -1;
            if (!hb) return 1;
            int r = ea.compare(eb);
            if (r != 0) return r < 0 ? -1 : 1;
        }
    }
    int compare_sv(std::string_view other) const noexcept {
        return compare_sv_static(pn_, other);
    }

    // Allow the iterator to access internals
    friend class iterator;

    string_type pn_;
};

inline void swap(path& lhs, path& rhs) noexcept { lhs.swap(rhs); }

// Ported from libc++ hash_value (src/filesystem/path.cpp): combine the hash
// of each path element (root-directory contributes "/"), so that paths that
// compare equal hash equally.
[[nodiscard]] inline size_t hash_value(const path& p) noexcept {
    std::string_view s(p.native());
    auto hash_combine = [](size_t lhs, size_t rhs) noexcept -> size_t {
        // Boost-style combine; deterministic and order-sensitive.
        lhs ^= rhs + 0x9e3779b97f4a7c15ULL + (lhs << 6) + (lhs >> 2);
        return lhs;
    };
    std::hash<std::string_view> hasher;
    size_t h = 0;
    bool root = !s.empty() && s[0] == '/';
    if (root) {
        h = hash_combine(h, hasher(std::string_view("/")));
        // Consume the whole root-directory separator run so "//" hashes as "/".
        size_t i = 0; while (i < s.size() && s[i] == '/') ++i;
        s.remove_prefix(i);
    }
    bool trailing = true;
    while (true) {
        bool sawSep = false;
        while (!s.empty() && s[0] == '/') { s.remove_prefix(1); sawSep = true; }
        if (s.empty()) {
            if (sawSep && trailing) {
                h = hash_combine(h, hasher(std::string_view()));
            }
            break;
        }
        size_t n = 0;
        while (n < s.size() && s[n] != '/') ++n;
        h = hash_combine(h, hasher(s.substr(0, n)));
        s.remove_prefix(n);
    }
    return h;
}

//===----------------------------------------------------------------------===//
// u8path — POSIX: input is UTF-8, stored verbatim (char/char8_t only).
//===----------------------------------------------------------------------===//
template <class Source,
          class = std::enable_if_t<is_pathable<Source>::value>>
[[nodiscard]] path u8path(const Source& s) {
    static_assert(
        std::is_same_v<typename is_pathable<Source>::char_type, char8_t> ||
        std::is_same_v<typename is_pathable<Source>::char_type, char>,
        "u8path(Source const&) requires Source have a character type of type "
        "'char' or 'char8_t'");
    return path(s);
}

template <class InputIt,
          class = std::enable_if_t<is_pathable<InputIt>::value>>
[[nodiscard]] path u8path(InputIt f, InputIt l) {
    static_assert(
        std::is_same_v<typename is_pathable<InputIt>::char_type, char8_t> ||
        std::is_same_v<typename is_pathable<InputIt>::char_type, char>,
        "u8path(Iter, Iter) requires Iter have a value_type of type 'char'"
        " or 'char8_t'");
    return path(f, l);
}

//===----------------------------------------------------------------------===//
// path::lexically_normal, lexically_relative — non-trivial, defined after class
//===----------------------------------------------------------------------===//

// Ported from libc++ path::lexically_normal (src/filesystem/path.cpp),
// using the path iterator (whose dereference already yields "/" for the
// root separator and "" for a trailing separator).

// Helper: split path string into components, excluding '/' and empty parts
inline std::vector<std::string> path_split_components(const path& p) {
    std::vector<std::string> comps;
    std::string_view sv(p.native());
    // skip leading '/'
    if (!sv.empty() && sv[0] == '/') sv.remove_prefix(1);
    while (!sv.empty()) {
        auto pos = sv.find('/');
        std::string_view comp = (pos == std::string_view::npos) ? sv : sv.substr(0, pos);
        if (!comp.empty())
            comps.push_back(std::string(comp));
        if (pos == std::string_view::npos) break;
        sv.remove_prefix(pos + 1);
    }
    return comps;
}

inline path path::lexically_relative(const path& base) const {
    // Check if both have same root
    if (root_path() != base.root_path())
        return path();

    std::vector<std::string> a = path_split_components(*this);
    std::vector<std::string> b = path_split_components(base);

    // Find common prefix length
    std::size_t i = 0;
    while (i < a.size() && i < b.size() && a[i] == b[i])
        ++i;

    // Number of ".." needed
    std::ptrdiff_t up = static_cast<std::ptrdiff_t>(b.size()) - static_cast<std::ptrdiff_t>(i);

    // Check for ".." in remaining base — can't go above ".."
    for (std::size_t j = i; j < b.size(); ++j)
        if (b[j] == "..")
            return path();

    path result;
    for (std::ptrdiff_t k = 0; k < up; ++k) {
        if (result.empty())
            result = path("..");
        else
            result /= path("..");
    }
    for (std::size_t j = i; j < a.size(); ++j) {
        if (result.empty())
            result = path(a[j]);
        else
            result /= path(a[j]);
    }
    if (result.empty())
        return path(".");
    return result;
}

//===----------------------------------------------------------------------===//
// path::iterator
//===----------------------------------------------------------------------===//
// POSIX PathParser, ported from libc++ src/filesystem/path_parser.h.
// No root-name support (no drive letters / network roots) and '/' is the only
// separator. Drives begin()/end()/increment()/decrement() and the
// filename/relative/parent decomposition so all of them stay consistent.
class path::iterator {
public:
    enum parser_state : unsigned char {
        singular        = 0,   // default-constructed (== before_begin sentinel)
        before_begin    = 1,
        in_root_dir     = 2,
        in_filenames    = 3,
        in_trailing_sep = 4,
        at_end          = 5
    };

    using iterator_category  = std::bidirectional_iterator_tag;
    using iterator_concept   = std::bidirectional_iterator_tag;
    using value_type         = path;
    using difference_type    = std::ptrdiff_t;
    using pointer            = const path*;
    using reference          = path;

    iterator() : stashed_elem_(), path_ptr_(nullptr), entry_(), state_(singular) {}
    iterator(const iterator&) = default;
    ~iterator() = default;
    iterator& operator=(const iterator&) = default;

    [[nodiscard]] reference operator*() const { return stashed_elem_; }
    pointer operator->() const { return &stashed_elem_; }

    iterator& operator++() { increment(); update_stash(); return *this; }
    iterator operator++(int) { iterator tmp(*this); ++(*this); return tmp; }
    iterator& operator--() { decrement(); update_stash(); return *this; }
    iterator operator--(int) { iterator tmp(*this); --(*this); return tmp; }

    friend bool operator==(const iterator& lhs, const iterator& rhs) noexcept {
        return lhs.path_ptr_ == rhs.path_ptr_ &&
               lhs.entry_.data() == rhs.entry_.data();
    }
    friend bool operator!=(const iterator& lhs, const iterator& rhs) noexcept {
        return !(lhs == rhs);
    }

private:
    friend class path;

    using PosPtr = const char*;

    PosPtr path_data() const noexcept { return path_ptr_->pn_.data(); }
    PosPtr getAfterBack() const noexcept {
        return path_ptr_->pn_.data() + path_ptr_->pn_.size();
    }
    PosPtr getBeforeFront() const noexcept { return path_ptr_->pn_.data() - 1; }

    static bool isSep(char c) noexcept { return c == '/'; }

    PosPtr getNextTokenStartPos() const noexcept {
        switch (state_) {
        case before_begin: return path_data();
        case in_root_dir:
        case in_filenames: return &entry_.back() + 1;
        case in_trailing_sep:
        case at_end:
        default:           return getAfterBack();
        }
    }
    PosPtr getCurrentTokenStartPos() const noexcept {
        switch (state_) {
        case before_begin: return &path_ptr_->pn_.front();
        case in_root_dir:
        case in_filenames:
        case in_trailing_sep: return &entry_.front();
        case at_end:
        default:              return &path_ptr_->pn_.back() + 1;
        }
    }

    PosPtr consumeAllSeparators(PosPtr P, PosPtr End) const noexcept {
        if (P == nullptr || P == End || !isSep(*P))
            return nullptr;
        const int Inc = P < End ? 1 : -1;
        P += Inc;
        while (P != End && isSep(*P))
            P += Inc;
        return P;
    }
    PosPtr consumeName(PosPtr P, PosPtr End) const noexcept {
        if (P == nullptr || P == End || isSep(*P))
            return nullptr;
        const int Inc = P < End ? 1 : -1;
        P += Inc;
        while (P != End && !isSep(*P))
            P += Inc;
        return P;
    }

    void makeState(parser_state s, PosPtr Start, PosPtr End) noexcept {
        state_ = s;
        entry_ = std::string_view(Start, static_cast<std::size_t>(End - Start));
    }
    void makeState(parser_state s) noexcept {
        state_ = s;
        // Anchor the sentinel entry one-past-the-end so an iterator that
        // reached at_end compares equal to end().
        entry_ = std::string_view(getAfterBack(), 0);
    }

    void increment() noexcept {
        const PosPtr End   = getAfterBack();
        const PosPtr Start = getNextTokenStartPos();
        if (Start == End) return makeState(at_end);

        switch (state_) {
        case before_begin: {
            if (PosPtr TkEnd = consumeAllSeparators(Start, End))
                return makeState(in_root_dir, Start, TkEnd);
            return makeState(in_filenames, Start, consumeName(Start, End));
        }
        case in_root_dir:
            return makeState(in_filenames, Start, consumeName(Start, End));
        case in_filenames: {
            PosPtr SepEnd = consumeAllSeparators(Start, End);
            if (SepEnd != End) {
                PosPtr TkEnd = consumeName(SepEnd, End);
                if (TkEnd)
                    return makeState(in_filenames, SepEnd, TkEnd);
            }
            return makeState(in_trailing_sep, Start, SepEnd);
        }
        case in_trailing_sep:
            return makeState(at_end);
        default:
            return;
        }
    }

    void decrement() noexcept {
        const PosPtr REnd   = getBeforeFront();
        const PosPtr RStart = getCurrentTokenStartPos() - 1;
        if (RStart == REnd) // decrementing begin
            return makeState(before_begin);

        switch (state_) {
        case at_end: {
            if (PosPtr SepEnd = consumeAllSeparators(RStart, REnd)) {
                if (SepEnd == REnd)
                    return makeState(in_root_dir, path_data(), RStart + 1);
                return makeState(in_trailing_sep, SepEnd + 1, RStart + 1);
            } else {
                PosPtr TkStart = consumeName(RStart, REnd);
                return makeState(in_filenames, TkStart + 1, RStart + 1);
            }
        }
        case in_trailing_sep:
            return makeState(in_filenames, consumeName(RStart, REnd) + 1, RStart + 1);
        case in_filenames: {
            PosPtr SepEnd = consumeAllSeparators(RStart, REnd);
            if (SepEnd == REnd)
                return makeState(in_root_dir, path_data(), RStart + 1);
            PosPtr TkStart = consumeName(SepEnd, REnd);
            return makeState(in_filenames, TkStart + 1, SepEnd + 1);
        }
        case in_root_dir:
            // No root name on POSIX: decrementing the root dir reaches begin.
            return makeState(before_begin);
        default:
            return;
        }
    }

    // The "preferred representation": root-dir shows as "/", trailing sep and
    // the end/before-begin sentinels show as empty.
    std::string_view deref_view() const noexcept {
        switch (state_) {
        case before_begin:
        case at_end:          return std::string_view();
        case in_root_dir:     return std::string_view("/");
        case in_trailing_sep: return std::string_view();
        case in_filenames:
        default:              return entry_;
        }
    }

    void update_stash() {
        stashed_elem_ = path(std::string(deref_view()));
    }

    path stashed_elem_;
    const path* path_ptr_;
    std::string_view entry_;
    parser_state state_;
};

inline path::iterator path::begin() const {
    iterator it;
    it.path_ptr_ = this;
    it.state_ = iterator::before_begin;
    it.entry_ = std::string_view();
    it.increment();
    it.update_stash();
    return it;
}

inline path::iterator path::end() const {
    iterator it;
    it.path_ptr_ = this;
    it.entry_ = std::string_view(pn_.data() + pn_.size(), 0);
    it.state_ = iterator::at_end;
    return it;
}

inline path path::lexically_normal() const {
    if (pn_.empty())
        return *this;

    enum part_kind : unsigned char {
        PK_None, PK_RootSep, PK_Filename, PK_Dot, PK_DotDot, PK_TrailingSep
    };
    auto classify = [](std::string_view part) -> part_kind {
        if (part.empty()) return PK_TrailingSep;
        if (part == ".") return PK_Dot;
        if (part == "..") return PK_DotDot;
        if (part == "/") return PK_RootSep;
        return PK_Filename;
    };

    std::vector<std::pair<std::string, part_kind>> parts;
    auto last_kind = [&]() -> part_kind {
        return parts.empty() ? PK_None : parts.back().second;
    };

    bool maybe_need_trailing_sep = false;
    for (auto it = begin(); it != end(); ++it) {
        std::string part = it->native();
        part_kind kind = classify(part);
        switch (kind) {
        case PK_Filename:
        case PK_RootSep:
            parts.emplace_back(std::move(part), kind);
            maybe_need_trailing_sep = false;
            break;
        case PK_DotDot: {
            part_kind lk = last_kind();
            if (lk == PK_Filename) {
                parts.pop_back();
            } else if (lk != PK_RootSep) {
                parts.emplace_back(std::string(".."), PK_DotDot);
            }
            maybe_need_trailing_sep = (lk == PK_Filename);
            break;
        }
        case PK_Dot:
        case PK_TrailingSep:
            maybe_need_trailing_sep = true;
            break;
        default:
            break;
        }
    }

    // [fs.path.generic]p6.8: empty -> ".".
    if (parts.empty())
        return path(".");

    // [fs.path.generic]p6.7: if the last filename is dot-dot, remove any
    // trailing directory-separator.
    bool need_trailing_sep = maybe_need_trailing_sep && last_kind() == PK_Filename;

    path result;
    for (auto& pk : parts)
        result /= pk.first;
    if (need_trailing_sep)
        result /= path("");
    return result;
}

//===----------------------------------------------------------------------===//
// filesystem_error
// NOTE: never thrown; throwing overloads call __builtin_trap().
//===----------------------------------------------------------------------===//
class filesystem_error : public std::system_error {
public:
    filesystem_error(const std::string& what_arg, std::error_code ec)
        : std::system_error(ec, what_arg),
          storage_(std::make_shared<Storage>(path(), path())) {
        create_what(0);
    }

    filesystem_error(const std::string& what_arg, const path& p1, std::error_code ec)
        : std::system_error(ec, what_arg),
          storage_(std::make_shared<Storage>(p1, path())) {
        create_what(1);
    }

    filesystem_error(const std::string& what_arg, const path& p1, const path& p2,
                     std::error_code ec)
        : std::system_error(ec, what_arg),
          storage_(std::make_shared<Storage>(p1, p2)) {
        create_what(2);
    }

    filesystem_error(const filesystem_error&) = default;
    ~filesystem_error() override = default;

    [[nodiscard]] const path& path1() const noexcept { return storage_->p1; }
    [[nodiscard]] const path& path2() const noexcept { return storage_->p2; }
    [[nodiscard]] const char* what() const noexcept override {
        return storage_->what.c_str();
    }

private:
    void create_what(int num_paths) {
        std::string w = std::system_error::what();
        storage_->what = w;
        if (num_paths >= 1) {
            storage_->what += " [";
            storage_->what += storage_->p1.native();
            storage_->what += "]";
        }
        if (num_paths >= 2) {
            storage_->what += " [";
            storage_->what += storage_->p2.native();
            storage_->what += "]";
        }
    }

    struct Storage {
        Storage(const path& a, const path& b) : p1(a), p2(b) {}
        path p1, p2;
        std::string what;
    };
    std::shared_ptr<Storage> storage_;
};

// Helper to "throw" a filesystem_error — in -fno-exceptions mode, trap.
template <class... Args>
[[noreturn]] inline void throw_filesystem_error(Args&&...) noexcept {
    __builtin_trap();
}

//===----------------------------------------------------------------------===//
// Internal POSIX helpers (stat -> file_status, file_time_type conversion)
//===----------------------------------------------------------------------===//
namespace detail {

inline file_status status_from_stat(const struct ::stat& st) noexcept {
    file_type ft = file_type::unknown;
    if (S_ISREG(st.st_mode))        ft = file_type::regular;
    else if (S_ISDIR(st.st_mode))   ft = file_type::directory;
    else if (S_ISLNK(st.st_mode))   ft = file_type::symlink;
    else if (S_ISBLK(st.st_mode))   ft = file_type::block;
    else if (S_ISCHR(st.st_mode))   ft = file_type::character;
    else if (S_ISFIFO(st.st_mode))  ft = file_type::fifo;
    else if (S_ISSOCK(st.st_mode))  ft = file_type::socket;
    perms prms = static_cast<perms>(st.st_mode & 07777);
    return file_status(ft, prms);
}

inline file_time_type time_from_stat(const struct ::stat& st) noexcept {
    using ns = std::chrono::nanoseconds;
#ifdef __linux__
    long long sec  = static_cast<long long>(st.st_mtim.tv_sec);
    long long nsec = static_cast<long long>(st.st_mtim.tv_nsec);
#else
    long long sec  = static_cast<long long>(st.st_mtime);
    long long nsec = 0;
#endif
    return file_time_type(ns(sec * 1'000'000'000LL + nsec));
}

// stat wrapper (follows symlinks)
inline file_status do_stat(const path& p, std::error_code* ec) noexcept {
    struct ::stat st;
    if (::stat(p.c_str(), &st) != 0) {
        int e = errno;
        if (ec) *ec = std::error_code(e, std::generic_category());
        if (e == ENOENT || e == ENOTDIR)
            return file_status(file_type::not_found);
        return file_status(file_type::none);
    }
    if (ec) ec->clear();
    return status_from_stat(st);
}

// lstat wrapper (does not follow symlinks)
inline file_status do_lstat(const path& p, std::error_code* ec) noexcept {
    struct ::stat st;
    if (::lstat(p.c_str(), &st) != 0) {
        int e = errno;
        if (ec) *ec = std::error_code(e, std::generic_category());
        if (e == ENOENT || e == ENOTDIR)
            return file_status(file_type::not_found);
        return file_status(file_type::none);
    }
    if (ec) ec->clear();
    return status_from_stat(st);
}

} // namespace detail

