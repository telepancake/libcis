    std::strong_ordering operator<=>(const directory_entry& rhs) const noexcept {
        return p_ <=> rhs.p_;
    }

private:
    friend class directory_iterator;
    friend class recursive_directory_iterator;
    friend struct dir_stream;

    // Cache for the stat result (simplified: just retype on access)
    void do_refresh(std::error_code* ec) noexcept {
        cached_status_ = detail::do_lstat(p_, ec);
        if (!ec || !*ec) {
            if (cached_status_.type() == file_type::symlink) {
                cached_followed_ = detail::do_stat(p_, ec);
            } else {
                cached_followed_ = cached_status_;
            }
        }
    }

    // Set from directory iteration result (with known type)
    void set_iter_entry(Path&& p, file_type ft) {
        p_ = std::move(p);
        cached_status_ = file_status(ft);
        if (ft == file_type::symlink) {
            std::error_code ec;
            cached_followed_ = detail::do_stat(p_, &ec);
        } else {
            cached_followed_ = cached_status_;
        }
    }

    file_type get_ft(std::error_code* ec = nullptr) const {
        if (ec) ec->clear();
        return cached_followed_.type();
    }
    file_type get_sym_ft(std::error_code* ec = nullptr) const {
        if (ec) ec->clear();
        return cached_status_.type();
    }
    file_status get_status(std::error_code* ec = nullptr) const {
        if (ec) ec->clear();
        return cached_followed_;
    }
    file_status get_symlink_status(std::error_code* ec = nullptr) const {
        if (ec) ec->clear();
        return cached_status_;
    }

    Path p_;
    file_status cached_status_;   // lstat result (symlink itself)
    file_status cached_followed_; // stat result (through symlink)
};

// proxy object for post-increment
class dir_element_proxy {
public:
    directory_entry operator*() { return std::move(elem_); }
private:
    friend class directory_iterator;
    friend class recursive_directory_iterator;
    explicit dir_element_proxy(const directory_entry& e) : elem_(e) {}
    dir_element_proxy(dir_element_proxy&& o) : elem_(std::move(o.elem_)) {}
    directory_entry elem_;
};

//===----------------------------------------------------------------------===//
// directory_iterator
//===----------------------------------------------------------------------===//
struct dir_stream {
    explicit dir_stream(const path& p, directory_options opts,
                        std::error_code* ec) {
        d_ = ::opendir(p.c_str());
        if (!d_) {
            int e = errno;
            if (ec) {
                if (e == EACCES &&
                    (opts & directory_options::skip_permission_denied) != directory_options::none)
                    ec->clear();
                else
                    *ec = std::error_code(e, std::generic_category());
            }
            return;
        }
        if (ec) ec->clear();
        // Advance to first entry
        advance(ec);
    }

    ~dir_stream() {
        if (d_) ::closedir(d_);
    }

    dir_stream(const dir_stream&) = delete;
    dir_stream& operator=(const dir_stream&) = delete;

    bool is_valid() const noexcept { return d_ != nullptr && entry_.has_value(); }

    const directory_entry& current() const noexcept { return *entry_; }

    void advance(std::error_code* ec) {
        entry_.reset();
        if (!d_) return;

        while (true) {
            errno = 0;
            struct ::dirent* de = ::readdir(d_);
            if (!de) {
                if (errno != 0 && ec)
                    *ec = std::error_code(errno, std::generic_category());
                else if (ec)
                    ec->clear();
                return;
            }
            std::string_view name(de->d_name);
            if (name == "." || name == "..") continue;

            // Build directory_entry
            path child = dir_path_ / path(std::string(name));
            file_type ft = file_type::unknown;
#ifdef DT_UNKNOWN
            if (de->d_type != DT_UNKNOWN) {
                switch (de->d_type) {
                case DT_REG:  ft = file_type::regular;   break;
                case DT_DIR:  ft = file_type::directory; break;
                case DT_LNK:  ft = file_type::symlink;   break;
                case DT_BLK:  ft = file_type::block;     break;
                case DT_CHR:  ft = file_type::character; break;
                case DT_FIFO: ft = file_type::fifo;      break;
                case DT_SOCK: ft = file_type::socket;    break;
                default:      ft = file_type::unknown;   break;
                }
            }
#endif
            directory_entry ent;
            ent.set_iter_entry(std::move(child), ft);
            entry_ = std::move(ent);
            if (ec) ec->clear();
            return;
        }
    }

    path dir_path_;
    DIR* d_ = nullptr;
    // Use optional-like storage
    struct optional_entry {
        bool has = false;
        directory_entry val;
        void reset() { has = false; }
        bool has_value() const { return has; }
        const directory_entry& operator*() const { return val; }
        directory_entry& operator*() { return val; }
        void operator=(directory_entry&& e) { val = std::move(e); has = true; }
        void reset(directory_entry e) { val = std::move(e); has = true; }
    } entry_;
};

class directory_iterator {
public:
    using value_type        = directory_entry;
    using difference_type   = std::ptrdiff_t;
    using pointer           = const directory_entry*;
    using reference         = const directory_entry&;
    using iterator_category = std::input_iterator_tag;

    directory_iterator() noexcept {}

    explicit directory_iterator(const path& p)
        : directory_iterator(p, nullptr, directory_options::none) {}

    directory_iterator(const path& p, directory_options opts)
        : directory_iterator(p, nullptr, opts) {}

    directory_iterator(const path& p, std::error_code& ec)
        : directory_iterator(p, &ec, directory_options::none) {}

    directory_iterator(const path& p, directory_options opts, std::error_code& ec)
        : directory_iterator(p, &ec, opts) {}

    directory_iterator(const directory_iterator&) = default;
    directory_iterator(directory_iterator&&) = default;
    directory_iterator& operator=(const directory_iterator&) = default;
    directory_iterator& operator=(directory_iterator&& o) noexcept {
        if (this != &o)
            imp_ = std::move(o.imp_);
        return *this;
    }
    ~directory_iterator() = default;

    [[nodiscard]] const directory_entry& operator*() const  { return imp_->current(); }
    const directory_entry* operator->() const { return &**this; }

    directory_iterator& operator++() { return increment(); }
    dir_element_proxy operator++(int) {
        dir_element_proxy p(**this);
        increment();
        return p;
    }
    directory_iterator& increment(std::error_code& ec) {
        return do_increment(&ec);
    }

    bool operator==(std::default_sentinel_t) const noexcept {
        return *this == directory_iterator();
    }

    friend bool operator==(const directory_iterator& lhs,
                           const directory_iterator& rhs) noexcept {
        return lhs.imp_ == rhs.imp_;
    }
    friend bool operator!=(const directory_iterator& lhs,
                           const directory_iterator& rhs) noexcept {
        return !(lhs == rhs);
    }

private:
    directory_iterator(const path& p, std::error_code* ec,
                       directory_options opts) {
        auto s = std::make_shared<dir_stream>(p, opts, ec);
        if (s->is_valid())
            imp_ = std::move(s);
    }

    directory_iterator& increment() {
        return do_increment(nullptr);
    }

    directory_iterator& do_increment(std::error_code* ec) {
        if (!imp_) return *this;
        imp_->advance(ec);
        if (!imp_->is_valid())
            imp_.reset();
        return *this;
    }

    std::shared_ptr<dir_stream> imp_;
};

[[nodiscard]] inline directory_iterator begin(directory_iterator iter) noexcept {
    return iter;
}
[[nodiscard]] inline directory_iterator end(directory_iterator) noexcept {
    return directory_iterator();
}

//===----------------------------------------------------------------------===//
// recursive_directory_iterator
//===----------------------------------------------------------------------===//
struct recursive_dir_impl {
    struct level {
        std::shared_ptr<dir_stream> stream;
    };

    std::vector<level> stack;
    directory_options opts;
    bool recursion_pending = true;

    recursive_dir_impl(const path& p, directory_options o, std::error_code* ec)
        : opts(o) {
        auto s = std::make_shared<dir_stream>(p, o, ec);
        if (s->is_valid())
            stack.push_back({std::move(s)});
    }
};

class recursive_directory_iterator {
public:
    using value_type        = directory_entry;
    using difference_type   = std::ptrdiff_t;
    using pointer           = const directory_entry*;
    using reference         = const directory_entry&;
    using iterator_category = std::input_iterator_tag;

    recursive_directory_iterator() noexcept : rec_(false) {}

    explicit recursive_directory_iterator(const path& p,
        directory_options opts = directory_options::none)
        : recursive_directory_iterator(p, opts, nullptr) {}

    recursive_directory_iterator(const path& p, directory_options opts,
                                 std::error_code& ec)
        : recursive_directory_iterator(p, opts, &ec) {}

    recursive_directory_iterator(const path& p, std::error_code& ec)
        : recursive_directory_iterator(p, directory_options::none, &ec) {}

    recursive_directory_iterator(const recursive_directory_iterator&) = default;
    recursive_directory_iterator(recursive_directory_iterator&&) = default;
    recursive_directory_iterator& operator=(const recursive_directory_iterator&) = default;
    recursive_directory_iterator& operator=(recursive_directory_iterator&& o) noexcept {
        if (this != &o) {
            imp_ = std::move(o.imp_);
            rec_ = o.rec_;
        }
        return *this;
    }
    ~recursive_directory_iterator() = default;

    [[nodiscard]] const directory_entry& operator*() const { return current(); }
    const directory_entry* operator->() const { return &current(); }

    recursive_directory_iterator& operator++() { return do_increment(nullptr); }
    dir_element_proxy operator++(int) {
        dir_element_proxy p(**this);
        ++(*this);
        return p;
    }
    recursive_directory_iterator& increment(std::error_code& ec) {
        return do_increment(&ec);
    }

    [[nodiscard]] directory_options options() const {
        if (imp_) return imp_->opts;
        return directory_options::none;
    }
    [[nodiscard]] int depth() const {
        if (!imp_) return 0;
        return static_cast<int>(imp_->stack.size()) - 1;
    }
    [[nodiscard]] bool recursion_pending() const { return rec_; }
    void disable_recursion_pending() { rec_ = false; }

    void pop(std::error_code& ec) { do_pop(&ec); }
    void pop() { do_pop(nullptr); }

    bool operator==(std::default_sentinel_t) const noexcept {
        return *this == recursive_directory_iterator();
    }

    friend bool operator==(const recursive_directory_iterator& lhs,
                           const recursive_directory_iterator& rhs) noexcept {
        return lhs.imp_ == rhs.imp_;
    }
    friend bool operator!=(const recursive_directory_iterator& lhs,
                           const recursive_directory_iterator& rhs) noexcept {
        return !(lhs == rhs);
    }

private:
    recursive_directory_iterator(const path& p, directory_options opts,
                                 std::error_code* ec)
        : rec_(true) {
        auto impl = std::make_shared<recursive_dir_impl>(p, opts, ec);
        if (!impl->stack.empty())
            imp_ = std::move(impl);
    }

    const directory_entry& current() const {
        return imp_->stack.back().stream->current();
    }

    recursive_directory_iterator& do_increment(std::error_code* ec) {
        if (!imp_) return *this;

        // Try to recurse into current entry if it's a directory
        if (rec_) {
            const directory_entry& cur = current();
            if (cur.is_directory()) {
                auto s = std::make_shared<dir_stream>(
                    cur.path(), imp_->opts, ec);
                if (s->is_valid()) {
                    imp_->stack.push_back({std::move(s)});
                    rec_ = true;
                    return *this;
                }
                // Failed to open directory, skip
                if (ec && *ec) {
                    if ((imp_->opts & directory_options::skip_permission_denied) != directory_options::none &&
                        ec->value() == EACCES) {
                        ec->clear();
                    } else {
                        return *this;
                    }
                }
            }
        }
        rec_ = true;

        // Advance in current level
        while (!imp_->stack.empty()) {
            imp_->stack.back().stream->advance(ec);
            if (ec && *ec) return *this;
            if (imp_->stack.back().stream->is_valid())
                return *this;
            // Done with this level, pop
            imp_->stack.pop_back();
        }
        // Stack empty = end
        imp_.reset();
        return *this;
    }

    void do_pop(std::error_code* ec) {
        if (!imp_) return;
        if (imp_->stack.empty()) { imp_.reset(); return; }
        imp_->stack.pop_back();
        if (imp_->stack.empty()) { imp_.reset(); return; }
        // Advance to next entry in parent
        do_increment(ec);
    }

    std::shared_ptr<recursive_dir_impl> imp_;
    bool rec_;
};

[[nodiscard]] inline recursive_directory_iterator
begin(recursive_directory_iterator iter) noexcept { return iter; }

[[nodiscard]] inline recursive_directory_iterator
end(recursive_directory_iterator) noexcept {
    return recursive_directory_iterator();
}

