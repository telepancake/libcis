// last_write_time
[[nodiscard]] inline file_time_type last_write_time(const path& p, std::error_code& ec) noexcept {
    struct ::stat st;
    if (::stat(p.c_str(), &st) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return file_time_type::min();
    }
    ec.clear();
    return detail::time_from_stat(st);
}
[[nodiscard]] inline file_time_type last_write_time(const path& p) {
    std::error_code ec;
    auto t = last_write_time(p, ec);
    if (ec) __builtin_trap();
    return t;
}
inline void last_write_time(const path& p, file_time_type new_time, std::error_code& ec) noexcept {
    using ns = std::chrono::nanoseconds;
    auto d = new_time.time_since_epoch();
    auto total_ns = std::chrono::duration_cast<ns>(d).count();
    struct ::timespec ts[2];
    ts[0].tv_sec  = static_cast<time_t>(total_ns / 1'000'000'000LL);
    ts[0].tv_nsec = static_cast<long>(total_ns % 1'000'000'000LL);
    ts[1] = ts[0];
    // Use UTIME_OMIT for access time
    ts[0].tv_nsec = UTIME_OMIT;
    if (::utimensat(AT_FDCWD, p.c_str(), ts, 0) != 0)
        ec = std::error_code(errno, std::generic_category());
    else
        ec.clear();
}
