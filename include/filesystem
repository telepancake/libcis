// temp_directory_path
// Ported from libc++ __temp_directory_path (src/filesystem/operations.cpp).
[[nodiscard]] inline path temp_directory_path(std::error_code& ec) {
    const char* env_paths[] = {"TMPDIR", "TMP", "TEMP", "TEMPDIR"};
    const char* ret = nullptr;
    for (const char* ep : env_paths)
        if ((ret = ::getenv(ep)))
            break;
    if (ret == nullptr)
        ret = "/tmp";
    path p(ret);
    struct ::stat st;
    if (::stat(p.c_str(), &st) != 0) {
        int e = errno;
        if (e == ENOENT || e == ENOTDIR) {
            // Path is simply absent / not a directory component: report
            // not_a_directory (matches libc++'s status_known + !exists path).
            ec = std::error_code(static_cast<int>(std::errc::not_a_directory),
                                 std::generic_category());
        } else {
            // e.g. EACCES -> permission_denied (status could not be obtained).
            ec = std::error_code(e, std::generic_category());
        }
        return {};
    }
    if (!S_ISDIR(st.st_mode)) {
        ec = std::error_code(static_cast<int>(std::errc::not_a_directory),
                             std::generic_category());
        return {};
    }
    ec.clear();
    return p;
}
[[nodiscard]] inline path temp_directory_path() {
    std::error_code ec;
    auto r = temp_directory_path(ec);
    if (ec) __builtin_trap();
    return r;
}

