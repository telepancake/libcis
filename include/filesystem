// copy_file
inline bool copy_file(const path& from, const path& to,
                      copy_options opt, std::error_code& ec) {
    // Determine if destination exists
    struct ::stat st_to;
    bool to_exists = (::stat(to.c_str(), &st_to) == 0);

    if (to_exists) {
        if ((opt & copy_options::skip_existing) != copy_options::none) {
            ec.clear();
            return false;
        }
        if ((opt & copy_options::overwrite_existing) == copy_options::none &&
            (opt & copy_options::update_existing) == copy_options::none) {
            ec = std::error_code(EEXIST, std::generic_category());
            return false;
        }
        if ((opt & copy_options::update_existing) != copy_options::none) {
            struct ::stat st_from;
            if (::stat(from.c_str(), &st_from) != 0) {
                ec = std::error_code(errno, std::generic_category());
                return false;
            }
#ifdef __linux__
            if (st_from.st_mtim.tv_sec < st_to.st_mtim.tv_sec ||
                (st_from.st_mtim.tv_sec == st_to.st_mtim.tv_sec &&
                 st_from.st_mtim.tv_nsec <= st_to.st_mtim.tv_nsec)) {
#else
            if (st_from.st_mtime <= st_to.st_mtime) {
#endif
                ec.clear();
                return false;
            }
        }
    }

    // Open source
    int src_fd = ::open(from.c_str(), O_RDONLY);
    if (src_fd < 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    struct ::stat st_src;
    if (::fstat(src_fd, &st_src) != 0) {
        ::close(src_fd);
        ec = std::error_code(errno, std::generic_category());
        return false;
    }

    // Open destination
    int dst_fd = ::open(to.c_str(), O_WRONLY | O_CREAT | O_TRUNC, st_src.st_mode & 07777);
    if (dst_fd < 0) {
        ::close(src_fd);
        ec = std::error_code(errno, std::generic_category());
        return false;
    }

    // Copy contents
    char buf[65536];
    ssize_t n;
    while ((n = ::read(src_fd, buf, sizeof(buf))) > 0) {
        ssize_t written = 0;
        while (written < n) {
            ssize_t w = ::write(dst_fd, buf + written, static_cast<size_t>(n - written));
            if (w < 0) {
                ::close(src_fd);
                ::close(dst_fd);
                ec = std::error_code(errno, std::generic_category());
                return false;
            }
            written += w;
        }
    }
    ::close(src_fd);
    ::close(dst_fd);
    if (n < 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    ec.clear();
    return true;
}
