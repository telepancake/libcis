// copy
inline void copy(const path& from, const path& to, copy_options opt, std::error_code& ec) {
    file_status f_st = symlink_status(from, ec);
    if (ec) return;

    if (is_symlink(f_st)) {
        if ((opt & copy_options::skip_symlinks) != copy_options::none) {
            ec.clear();
            return;
        }
        if ((opt & copy_options::copy_symlinks) != copy_options::none) {
            copy_symlink(from, to, ec);
            return;
        }
        // Follow symlink
        f_st = status(from, ec);
        if (ec) return;
    }

    if (is_regular_file(f_st)) {
        copy_file(from, to, opt, ec);
        return;
    }

    if (is_directory(f_st)) {
        // Create destination directory
        bool created = create_directory(to, from, ec);
        if (ec) return;
        (void)created;

        if ((opt & copy_options::recursive) != copy_options::none) {
            DIR* d = ::opendir(from.c_str());
            if (!d) {
                ec = std::error_code(errno, std::generic_category());
                return;
            }
            struct ::dirent* de;
            while ((de = ::readdir(d)) != nullptr) {
                std::string_view name(de->d_name);
                if (name == "." || name == "..") continue;
                path child_from = from / path(std::string(name));
                path child_to   = to   / path(std::string(name));
                copy(child_from, child_to,
                     opt | copy_options::in_recursive_copy, ec);
                if (ec) { ::closedir(d); return; }
            }
            ::closedir(d);
        }
        ec.clear();
        return;
    }
    ec.clear();
}
