// permissions
inline void permissions(const path& p, perms prms, perm_options opts,
                        std::error_code& ec) noexcept {
    // Get current permissions if needed
    mode_t mode = 0;
    if ((opts & perm_options::add) != static_cast<perm_options>(0) ||
        (opts & perm_options::remove) != static_cast<perm_options>(0)) {
        struct ::stat st;
        bool use_lstat = (opts & perm_options::nofollow) != static_cast<perm_options>(0);
        int r = use_lstat ? ::lstat(p.c_str(), &st) : ::stat(p.c_str(), &st);
        if (r != 0) {
            ec = std::error_code(errno, std::generic_category());
            return;
        }
        mode = st.st_mode & 07777;
    }

    unsigned uv = static_cast<unsigned>(prms) & 07777u;
    if ((opts & perm_options::replace) != static_cast<perm_options>(0)) {
        mode = static_cast<mode_t>(uv);
    } else if ((opts & perm_options::add) != static_cast<perm_options>(0)) {
        mode |= static_cast<mode_t>(uv);
    } else if ((opts & perm_options::remove) != static_cast<perm_options>(0)) {
        mode &= ~static_cast<mode_t>(uv);
    }

    bool use_lchmod = (opts & perm_options::nofollow) != static_cast<perm_options>(0);
    int r;
    if (use_lchmod) {
        // lchmod doesn't exist on Linux; fallback to chmod on the symlink target
        r = ::chmod(p.c_str(), mode);
    } else {
        r = ::chmod(p.c_str(), mode);
    }
    if (r != 0)
        ec = std::error_code(errno, std::generic_category());
    else
        ec.clear();
}
inline void permissions(const path& p, perms prms, perm_options opts = perm_options::replace) {
    std::error_code ec;
    permissions(p, prms, opts, ec);
    if (ec) __builtin_trap();
}
