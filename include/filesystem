[[nodiscard]] inline bool is_fifo(const path& p, std::error_code& ec) noexcept          { return is_fifo(status(p, ec)); }
[[nodiscard]] inline bool is_fifo(const path& p)                                         { return is_fifo(status(p)); }
[[nodiscard]] inline bool is_regular_file(const path& p, std::error_code& ec) noexcept  { return is_regular_file(status(p, ec)); }
[[nodiscard]] inline bool is_regular_file(const path& p)                                 { return is_regular_file(status(p)); }
[[nodiscard]] inline bool is_socket(const path& p, std::error_code& ec) noexcept        { return is_socket(status(p, ec)); }
[[nodiscard]] inline bool is_socket(const path& p)                                       { return is_socket(status(p)); }
[[nodiscard]] inline bool is_symlink(const path& p, std::error_code& ec) noexcept       { return is_symlink(symlink_status(p, ec)); }
[[nodiscard]] inline bool is_symlink(const path& p)                                      { return is_symlink(symlink_status(p)); }
[[nodiscard]] inline bool is_other(const path& p, std::error_code& ec) noexcept         { return is_other(status(p, ec)); }
[[nodiscard]] inline bool is_other(const path& p)                                        { return is_other(status(p)); }

// file_size
[[nodiscard]] inline uintmax_t file_size(const path& p, std::error_code& ec) noexcept {
    struct ::stat st;
    if (::stat(p.c_str(), &st) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return static_cast<uintmax_t>(-1);
    }
    ec.clear();
    return static_cast<uintmax_t>(st.st_size);
}
[[nodiscard]] inline uintmax_t file_size(const path& p) {
    std::error_code ec;
    auto sz = file_size(p, ec);
    if (ec) __builtin_trap();
    return sz;
}

// hard_link_count
[[nodiscard]] inline uintmax_t hard_link_count(const path& p, std::error_code& ec) noexcept {
    struct ::stat st;
    if (::lstat(p.c_str(), &st) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return static_cast<uintmax_t>(-1);
    }
    ec.clear();
    return static_cast<uintmax_t>(st.st_nlink);
