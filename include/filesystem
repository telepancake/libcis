// remove_all (recursive)
inline uintmax_t remove_all(const path& p, std::error_code& ec) {
    uintmax_t count = 0;
    struct ::stat st;
    if (::lstat(p.c_str(), &st) != 0) {
        if (errno == ENOENT) { ec.clear(); return 0; }
        ec = std::error_code(errno, std::generic_category());
        return 0;
    }
    if (S_ISDIR(st.st_mode)) {
        DIR* d = ::opendir(p.c_str());
        if (!d) {
            ec = std::error_code(errno, std::generic_category());
            return 0;
        }
        struct ::dirent* de;
        while ((de = ::readdir(d)) != nullptr) {
            std::string_view name(de->d_name);
            if (name == "." || name == "..") continue;
            path child = p / path(std::string(name));
            count += remove_all(child, ec);
            if (ec) { ::closedir(d); return count; }
        }
        ::closedir(d);
        if (::rmdir(p.c_str()) != 0) {
            ec = std::error_code(errno, std::generic_category());
            return count;
        }
        ++count;
        ec.clear();
        return count;
    }
    if (::unlink(p.c_str()) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return 0;
    }
    ec.clear();
    return 1;
}
