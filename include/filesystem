// remove_all (recursive). Ported from libc++ remove_all_impl
// (src/filesystem/operations.cpp), the openat()-based variant that threads
// file descriptors through recursion to be safe against TOCTOU symlink swaps:
// directories are opened with O_NOFOLLOW|O_DIRECTORY and entries removed via
// unlinkat relative to the parent fd, so a path swapped for a symlink mid-walk
// cannot redirect the deletion.
inline uintmax_t remove_all_impl(int parent_directory, const path& p, std::error_code& ec) {
    const int options = O_CLOEXEC | O_RDONLY | O_DIRECTORY | O_NOFOLLOW;
    int fd = ::openat(parent_directory, p.c_str(), options);
    if (fd != -1) {
        DIR* stream = ::fdopendir(fd);
        if (stream == nullptr) {
            ::close(fd);
            ec = std::error_code(errno, std::generic_category());
            return 0;
        }
        uintmax_t count = 0;
        struct ::dirent* de;
        errno = 0;
        while ((de = ::readdir(stream)) != nullptr) {
            std::string_view name(de->d_name);
            if (name == "." || name == "..") { errno = 0; continue; }
            count += remove_all_impl(fd, path(std::string(name)), ec);
            if (ec) { ::closedir(stream); return count; }
            errno = 0;
        }
        if (errno != 0) {
            ec = std::error_code(errno, std::generic_category());
            ::closedir(stream);
            return count;
        }
        // closedir also closes fd.
        ::closedir(stream);
        if (::unlinkat(parent_directory, p.c_str(), AT_REMOVEDIR) == -1) {
            ec = std::error_code(errno, std::generic_category());
            return count;
        }
        ec.clear();
        return count + 1;
    }

    int e = errno;
    // Vanished already: not an error.
    if (e == ENOENT) { ec.clear(); return 0; }
    // Not a directory (or a symlink we refused to follow): remove as a file.
    if (e == ENOTDIR || e == ELOOP || e == EMLINK) {
        if (::unlinkat(parent_directory, p.c_str(), 0) == -1) {
            ec = std::error_code(errno, std::generic_category());
            return 0;
        }
        ec.clear();
        return 1;
    }
    ec = std::error_code(e, std::generic_category());
    return 0;
}

inline uintmax_t remove_all(const path& p, std::error_code& ec) {
    return remove_all_impl(AT_FDCWD, p, ec);
}
