    uintmax_t cap = static_cast<uintmax_t>(sv.f_blocks) * static_cast<uintmax_t>(sv.f_frsize);
    uintmax_t fr  = static_cast<uintmax_t>(sv.f_bfree)  * static_cast<uintmax_t>(sv.f_frsize);
    uintmax_t av  = static_cast<uintmax_t>(sv.f_bavail) * static_cast<uintmax_t>(sv.f_frsize);
    return {cap, fr, av};
}
