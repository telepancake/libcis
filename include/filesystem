// copy_file
inline bool copy_file(const path& from, const path& to,
                      copy_options opt, std::error_code& ec) {
    // Ported from libc++ __copy_file (src/filesystem/operations.cpp).
    // Open + stat the source.
    // O_NONBLOCK so that opening a FIFO/device as the source does not block
    // (matches libc++'s FileDescriptor open flags); the source must be a
    // regular file anyway, checked below.
    int src_fd = ::open(from.c_str(), O_RDONLY | O_NONBLOCK);
    if (src_fd < 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    struct ::stat st_src;
    if (::fstat(src_fd, &st_src) != 0) {
        ::close(src_fd);
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    // Source must be a regular file.
    if (!S_ISREG(st_src.st_mode)) {
        ::close(src_fd);
        ec = std::error_code(static_cast<int>(std::errc::not_supported),
                             std::generic_category());
        return false;
    }

    // Stat the destination.
    struct ::stat st_to;
    bool to_exists = (::stat(to.c_str(), &st_to) == 0);

    if (to_exists) {
        // Destination must be a regular file.
        if (!S_ISREG(st_to.st_mode)) {
            ::close(src_fd);
            ec = std::error_code(static_cast<int>(std::errc::not_supported),
                                 std::generic_category());
            return false;
        }
        // from == to (same device + inode): error file_exists.
        if (st_src.st_dev == st_to.st_dev && st_src.st_ino == st_to.st_ino) {
            ::close(src_fd);
            ec = std::error_code(EEXIST, std::generic_category());
            return false;
        }
        if ((opt & copy_options::skip_existing) != copy_options::none) {
            ::close(src_fd);
            ec.clear();
            return false;
        }
        if ((opt & copy_options::update_existing) != copy_options::none) {
#ifdef __linux__
            if (st_src.st_mtim.tv_sec < st_to.st_mtim.tv_sec ||
                (st_src.st_mtim.tv_sec == st_to.st_mtim.tv_sec &&
                 st_src.st_mtim.tv_nsec <= st_to.st_mtim.tv_nsec)) {
#else
            if (st_src.st_mtime <= st_to.st_mtime) {
#endif
                ::close(src_fd);
                ec.clear();
                return false;
            }
        } else if ((opt & copy_options::overwrite_existing) == copy_options::none) {
            ::close(src_fd);
            ec = std::error_code(EEXIST, std::generic_category());
            return false;
        }
    }

    // Open destination
    int dst_fd = ::open(to.c_str(), O_WRONLY | O_CREAT | O_TRUNC, st_src.st_mode & 07777);
    if (dst_fd < 0) {
        ::close(src_fd);
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    // open() ignores the mode argument for a pre-existing file, so explicitly
    // copy the source's permission bits to the destination (the copy_file
    // postcondition is that 'to' gets 'from's permissions).
    if (::fchmod(dst_fd, st_src.st_mode & 07777) != 0) {
        int e = errno;
        ::close(src_fd);
        ::close(dst_fd);
        ec = std::error_code(e, std::generic_category());
        return false;
    }

    // Copy contents
    char buf[65536];
    ssize_t n;
    while ((n = ::read(src_fd, buf, sizeof(buf))) > 0) {
        ssize_t written = 0;
        while (written < n) {
            ssize_t w = ::write(dst_fd, buf + written, static_cast<size_t>(n - written));
            if (w < 0) {
                ::close(src_fd);
                ::close(dst_fd);
                ec = std::error_code(errno, std::generic_category());
                return false;
            }
            written += w;
        }
    }
    ::close(src_fd);
    ::close(dst_fd);
    if (n < 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    ec.clear();
    return true;
}
