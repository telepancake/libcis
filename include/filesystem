[[nodiscard]] inline bool is_empty(const path& p, std::error_code& ec) noexcept {
    struct ::stat st;
    if (::stat(p.c_str(), &st) != 0) {
        ec = std::error_code(errno, std::generic_category());
        return false;
    }
    ec.clear();
    if (S_ISDIR(st.st_mode)) {
        // empty directory check
        DIR* d = ::opendir(p.c_str());
        if (!d) {
            ec = std::error_code(errno, std::generic_category());
            return false;
