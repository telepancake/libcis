// <iosfwd> — forward declarations for all iostream types  [iosfwd.syn].
// Mechanically ported from libc++ include/iosfwd +
//   include/__fwd/ios.h + include/__ios/fpos.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// SINGLE HOME for the stream template default arguments: the declarations here
// carry the Traits/Allocator defaults, and the DEFINITIONS in <ios>,
// <streambuf>, <istream>, <ostream>, <sstream> intentionally omit them (a
// default argument may only be specified once per scope).
// Also the single home for streamoff / fpos<State> / streampos.
#pragma once

#include <cwchar>   // mbstate_t

namespace std {

// Forward declarations for char_traits (defined in <string_view>)
template<class CharT> struct char_traits;
template<> struct char_traits<char>;
template<> struct char_traits<char8_t>;
template<> struct char_traits<char16_t>;
template<> struct char_traits<char32_t>;
template<> struct char_traits<wchar_t>;

// Forward declaration for allocator (defined in <memory>)
template<class T> class allocator;

//===----------------------------------------------------------------------===//
// streamoff — implementation-defined signed offset type (glibc/Linux: long long)
//===----------------------------------------------------------------------===//
using streamoff = long long;

//===----------------------------------------------------------------------===//
// fpos<State>  [fpos]
//===----------------------------------------------------------------------===//
template<class State>
class fpos {
    State     st_;
    streamoff off_;
public:
    fpos(streamoff off = streamoff()) : st_(), off_(off) {}

    operator streamoff() const { return off_; }

    [[nodiscard]] State state() const { return st_; }
    void state(State st) { st_ = st; }

    fpos& operator+=(streamoff off) { off_ += off; return *this; }
    fpos& operator-=(streamoff off) { off_ -= off; return *this; }
    [[nodiscard]] fpos operator+(streamoff off) const { fpos t(*this); t += off; return t; }
    [[nodiscard]] fpos operator-(streamoff off) const { fpos t(*this); t -= off; return t; }
};

template<class State>
[[nodiscard]] inline streamoff operator-(const fpos<State>& x, const fpos<State>& y) {
    return streamoff(x) - streamoff(y);
}
template<class State>
inline bool operator==(const fpos<State>& x, const fpos<State>& y) {
    return streamoff(x) == streamoff(y);
}
template<class State>
inline bool operator!=(const fpos<State>& x, const fpos<State>& y) {
    return streamoff(x) != streamoff(y);
}

//===----------------------------------------------------------------------===//
// Stream position typedefs ([iosfwd.syn])
//===----------------------------------------------------------------------===//
using streampos    = fpos<mbstate_t>;
using wstreampos   = fpos<mbstate_t>;
using u8streampos  = fpos<mbstate_t>;
using u16streampos = fpos<mbstate_t>;
using u32streampos = fpos<mbstate_t>;

