// <chrono> — time utilities.
// Mechanically ported from libc++ include/chrono + include/__chrono/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// IMPLEMENTED here: durations, time_points, the calendar types, hh_mm_ss,
//   system_clock, steady_clock, file_clock, and utc_clock (with an embedded
//   immutable historical leap-second table; see utc_leap_table below).
//
// DEFERRED (requires additional facilities not yet ported):
//   - operator<<, from_stream, parse, and the chrono formatters: these route
//     through std::format in libc++ (<format> is owned by another agent and
//     its runtime engine is not yet functional — even std::format("{}",7)
//     currently traps). All time .../ostream.pass.cpp and time.syn/formatter.*
//     tests are blocked on that, NOT on chrono.
//   - time zones: tzdb, zoned_time, time_zone, locate_zone/get_tzdb,
//     leap_second, time_zone_link, the local-time exceptions — libc++ ships
//     these as a separately-compiled experimental feature that parses the
//     system IANA database; not header-only and not portable here. The whole
//     time/time.zone subtree depends on it.
//   - tai_clock, gps_clock (no tests transferred), clock_cast
#pragma once

#include <ratio>
#include <type_traits>
#include <compare>
#include <limits>
#include <cstdint>
#include <time.h>   // clock_gettime, CLOCK_REALTIME, CLOCK_MONOTONIC, time_t

namespace std {

//===----------------------------------------------------------------------===//
// ratio_gcd helper — GCD of the ratio periods, used by common_type<duration>
//===----------------------------------------------------------------------===//
template <class R1, class R2>
using ratio_gcd = ratio<static_gcd<R1::num, R2::num>, static_lcm<R1::den, R2::den>>;

namespace chrono {

//===----------------------------------------------------------------------===//
// Forward declarations
//===----------------------------------------------------------------------===//
template <class Rep, class Period = ratio<1>> class duration;
template <class Clock, class Duration = typename Clock::duration> class time_point;

// Calendar type forward declarations (needed for weekday ctor from sys_days)
class year_month_day;
class year_month_day_last;

//===----------------------------------------------------------------------===//
// is_duration helper
//===----------------------------------------------------------------------===//
template <class T>
inline constexpr bool is_duration_v = false;

template <class Rep, class Period>
inline constexpr bool is_duration_v<duration<Rep, Period>> = true;

template <class Rep, class Period>
inline constexpr bool is_duration_v<const duration<Rep, Period>> = true;

template <class Rep, class Period>
inline constexpr bool is_duration_v<volatile duration<Rep, Period>> = true;

template <class Rep, class Period>
inline constexpr bool is_duration_v<const volatile duration<Rep, Period>> = true;

} // namespace chrono

//===----------------------------------------------------------------------===//
// common_type specializations for duration and time_point
// (must be in namespace std, outside namespace chrono)
//===----------------------------------------------------------------------===//
template <class Rep1, class Period1, class Rep2, class Period2>
struct common_type<chrono::duration<Rep1, Period1>, chrono::duration<Rep2, Period2>> {
    using type = chrono::duration<typename common_type<Rep1, Rep2>::type,
                                  ratio_gcd<Period1, Period2>>;
};

template <class Clock, class Duration1, class Duration2>
struct common_type<chrono::time_point<Clock, Duration1>, chrono::time_point<Clock, Duration2>> {
    using type = chrono::time_point<Clock, typename common_type<Duration1, Duration2>::type>;
};

namespace chrono {

//===----------------------------------------------------------------------===//
// treat_as_floating_point, duration_values
//===----------------------------------------------------------------------===//
template <class Rep>
struct treat_as_floating_point : is_floating_point<Rep> {};

template <class Rep>
inline constexpr bool treat_as_floating_point_v = treat_as_floating_point<Rep>::value;

template <class Rep>
struct duration_values {
    [[nodiscard]] static constexpr Rep zero() noexcept { return Rep(0); }
    [[nodiscard]] static constexpr Rep max()  noexcept { return numeric_limits<Rep>::max(); }
    [[nodiscard]] static constexpr Rep min()  noexcept { return numeric_limits<Rep>::lowest(); }
};

//===----------------------------------------------------------------------===//
// duration_cast helpers
//===----------------------------------------------------------------------===//
template <class FromDuration, class ToDuration, class Period,
          bool num_is_1, bool den_is_1>
struct duration_cast_impl;

template <class FromDuration, class ToDuration, class Period>
struct duration_cast_impl<FromDuration, ToDuration, Period, true, true> {
    constexpr ToDuration operator()(const FromDuration& fd) const {
        return ToDuration(static_cast<typename ToDuration::rep>(fd.count()));
    }
};

template <class FromDuration, class ToDuration, class Period>
struct duration_cast_impl<FromDuration, ToDuration, Period, true, false> {
    constexpr ToDuration operator()(const FromDuration& fd) const {
        using Ct = typename common_type<typename ToDuration::rep,
                                        typename FromDuration::rep, intmax_t>::type;
        return ToDuration(static_cast<typename ToDuration::rep>(
            static_cast<Ct>(fd.count()) / static_cast<Ct>(Period::den)));
    }
};

template <class FromDuration, class ToDuration, class Period>
struct duration_cast_impl<FromDuration, ToDuration, Period, false, true> {
    constexpr ToDuration operator()(const FromDuration& fd) const {
        using Ct = typename common_type<typename ToDuration::rep,
                                        typename FromDuration::rep, intmax_t>::type;
        return ToDuration(static_cast<typename ToDuration::rep>(
            static_cast<Ct>(fd.count()) * static_cast<Ct>(Period::num)));
    }
};

template <class FromDuration, class ToDuration, class Period>
struct duration_cast_impl<FromDuration, ToDuration, Period, false, false> {
    constexpr ToDuration operator()(const FromDuration& fd) const {
        using Ct = typename common_type<typename ToDuration::rep,
                                        typename FromDuration::rep, intmax_t>::type;
        return ToDuration(static_cast<typename ToDuration::rep>(
            static_cast<Ct>(fd.count()) * static_cast<Ct>(Period::num)
            / static_cast<Ct>(Period::den)));
    }
};

template <class ToDuration, class Rep, class Period>
    requires is_duration_v<ToDuration>
[[nodiscard]] constexpr ToDuration duration_cast(const duration<Rep, Period>& fd) {
    // Compute the conversion ratio explicitly to avoid namespace issues
    using P = std::ratio_divide<Period, typename ToDuration::period>;
    return duration_cast_impl<duration<Rep, Period>, ToDuration, P,
                               P::num == 1, P::den == 1>()(fd);
}

//===----------------------------------------------------------------------===//
// floor / ceil / round / abs for duration
//===----------------------------------------------------------------------===//
template <class ToDuration, class Rep, class Period>
    requires is_duration_v<ToDuration>
[[nodiscard]] constexpr ToDuration floor(const duration<Rep, Period>& d) {
    ToDuration t = duration_cast<ToDuration>(d);
    if (t > d) t = t - ToDuration{1};
    return t;
}

template <class ToDuration, class Rep, class Period>
    requires is_duration_v<ToDuration>
[[nodiscard]] constexpr ToDuration ceil(const duration<Rep, Period>& d) {
    ToDuration t = duration_cast<ToDuration>(d);
    if (t < d) t = t + ToDuration{1};
    return t;
}

template <class ToDuration, class Rep, class Period>
    requires is_duration_v<ToDuration>
[[nodiscard]] constexpr ToDuration round(const duration<Rep, Period>& d) {
    ToDuration lower = chrono::floor<ToDuration>(d);
    ToDuration upper = lower + ToDuration{1};
    auto lower_diff  = d - lower;
    auto upper_diff  = upper - d;
    if (lower_diff < upper_diff) return lower;
    if (lower_diff > upper_diff) return upper;
    return lower.count() & 1 ? upper : lower;
}

template <class Rep, class Period>
    requires numeric_limits<Rep>::is_signed
[[nodiscard]] constexpr duration<Rep, Period> abs(duration<Rep, Period> d) {
    return d >= d.zero() ? +d : -d;
}

//===----------------------------------------------------------------------===//
// duration<Rep, Period>
//===----------------------------------------------------------------------===//
template <class Rep, class Period>
class duration {
    static_assert(!is_duration_v<Rep>,
        "A duration representation cannot be a duration");
    static_assert(is_ratio_v<Period>,
        "Second template parameter of duration must be a std::ratio");
    static_assert(Period::num > 0, "duration period must be positive");

    // Overflow-check helper: can Period2 convert to Period without overflow?
    template <class R1, class R2>
    struct no_overflow {
    private:
        static constexpr intmax_t gcd_n1_n2 = static_gcd<R1::num, R2::num>;
        static constexpr intmax_t gcd_d1_d2 = static_gcd<R1::den, R2::den>;
        static constexpr intmax_t n1  = R1::num / gcd_n1_n2;
        static constexpr intmax_t d1  = R1::den / gcd_d1_d2;
        static constexpr intmax_t n2  = R2::num / gcd_n1_n2;
        static constexpr intmax_t d2  = R2::den / gcd_d1_d2;
        static constexpr intmax_t mx  = -((intmax_t(1) << (sizeof(intmax_t)*8 - 1)) + 1);

        template <intmax_t X, intmax_t Y, bool ovf>
        struct mul_t { static constexpr intmax_t value = X * Y; };
        template <intmax_t X, intmax_t Y>
        struct mul_t<X, Y, true> { static constexpr intmax_t value = 1; };

    public:
        static constexpr bool value = (n1 <= mx / d2) && (n2 <= mx / d1);
        using type = ratio<mul_t<n1, d2, !value>::value,
                           mul_t<n2, d1, !value>::value>;
    };

public:
    using rep    = Rep;
    using period = typename Period::type;

private:
    rep rep_;

public:
    constexpr duration() = default;

    template <class Rep2>
        requires is_convertible_v<const Rep2&, rep> &&
                 (treat_as_floating_point_v<rep> || !treat_as_floating_point_v<Rep2>)
    constexpr explicit duration(const Rep2& r) : rep_(r) {}

    template <class Rep2, class Period2>
        requires no_overflow<Period2, period>::value &&
                 (treat_as_floating_point_v<rep> ||
                  (no_overflow<Period2, period>::type::den == 1 &&
                   !treat_as_floating_point_v<Rep2>))
    constexpr duration(const duration<Rep2, Period2>& d)
        : rep_(chrono::duration_cast<duration>(d).count()) {}

    [[nodiscard]] constexpr rep count() const { return rep_; }

    [[nodiscard]] constexpr typename common_type<duration>::type operator+() const {
        return typename common_type<duration>::type(*this);
    }
    [[nodiscard]] constexpr typename common_type<duration>::type operator-() const {
        return typename common_type<duration>::type(-rep_);
    }

    constexpr duration& operator++()    { ++rep_; return *this; }
    constexpr duration  operator++(int) { return duration(rep_++); }
    constexpr duration& operator--()    { --rep_; return *this; }
    constexpr duration  operator--(int) { return duration(rep_--); }

    constexpr duration& operator+=(const duration& d) { rep_ += d.count(); return *this; }
    constexpr duration& operator-=(const duration& d) { rep_ -= d.count(); return *this; }
    constexpr duration& operator*=(const rep& rhs)    { rep_ *= rhs; return *this; }
    constexpr duration& operator/=(const rep& rhs)    { rep_ /= rhs; return *this; }
    constexpr duration& operator%=(const rep& rhs)    { rep_ %= rhs; return *this; }
    constexpr duration& operator%=(const duration& d) { rep_ %= d.count(); return *this; }

    [[nodiscard]] static constexpr duration zero() noexcept {
        return duration(duration_values<rep>::zero());
    }
    [[nodiscard]] static constexpr duration min() noexcept {
        return duration(duration_values<rep>::min());
    }
    [[nodiscard]] static constexpr duration max() noexcept {
        return duration(duration_values<rep>::max());
    }
};

//===----------------------------------------------------------------------===//
// duration comparison operators
//===----------------------------------------------------------------------===//
template <class Rep1, class Period1, class Rep2, class Period2>
constexpr bool operator==(const duration<Rep1,Period1>& lhs,
                           const duration<Rep2,Period2>& rhs) {
    using Ct = typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type;
    return Ct(lhs).count() == Ct(rhs).count();
}

template <class Rep1, class Period1, class Rep2, class Period2>
    requires three_way_comparable<common_type_t<Rep1, Rep2>>
constexpr auto operator<=>(const duration<Rep1,Period1>& lhs,
                            const duration<Rep2,Period2>& rhs) {
    using Ct = common_type_t<duration<Rep1,Period1>, duration<Rep2,Period2>>;
    return Ct(lhs).count() <=> Ct(rhs).count();
}

template <class Rep1, class Period1, class Rep2, class Period2>
constexpr bool operator<(const duration<Rep1,Period1>& lhs,
                          const duration<Rep2,Period2>& rhs) {
    using Ct = typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type;
    return Ct(lhs).count() < Ct(rhs).count();
}
template <class Rep1, class Period1, class Rep2, class Period2>
constexpr bool operator>(const duration<Rep1,Period1>& lhs,
                          const duration<Rep2,Period2>& rhs) { return rhs < lhs; }
template <class Rep1, class Period1, class Rep2, class Period2>
constexpr bool operator<=(const duration<Rep1,Period1>& lhs,
                           const duration<Rep2,Period2>& rhs) { return !(rhs < lhs); }
template <class Rep1, class Period1, class Rep2, class Period2>
constexpr bool operator>=(const duration<Rep1,Period1>& lhs,
                           const duration<Rep2,Period2>& rhs) { return !(lhs < rhs); }

//===----------------------------------------------------------------------===//
// duration arithmetic operators
//===----------------------------------------------------------------------===//
template <class Rep1, class Period1, class Rep2, class Period2>
[[nodiscard]] constexpr
typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type
operator+(const duration<Rep1,Period1>& lhs, const duration<Rep2,Period2>& rhs) {
    using Cd = typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type;
    return Cd(Cd(lhs).count() + Cd(rhs).count());
}

template <class Rep1, class Period1, class Rep2, class Period2>
[[nodiscard]] constexpr
typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type
operator-(const duration<Rep1,Period1>& lhs, const duration<Rep2,Period2>& rhs) {
    using Cd = typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type;
    return Cd(Cd(lhs).count() - Cd(rhs).count());
}

template <class Rep1, class Period, class Rep2>
    requires is_convertible_v<const Rep2&, typename common_type<Rep1,Rep2>::type>
[[nodiscard]] constexpr
duration<typename common_type<Rep1,Rep2>::type, Period>
operator*(const duration<Rep1,Period>& d, const Rep2& s) {
    using Cr = typename common_type<Rep1,Rep2>::type;
    return duration<Cr,Period>(duration<Cr,Period>(d).count() * static_cast<Cr>(s));
}

template <class Rep1, class Period, class Rep2>
    requires is_convertible_v<const Rep1&, typename common_type<Rep1,Rep2>::type>
[[nodiscard]] constexpr
duration<typename common_type<Rep1,Rep2>::type, Period>
operator*(const Rep1& s, const duration<Rep2,Period>& d) { return d * s; }

template <class Rep1, class Period, class Rep2>
    requires (!is_duration_v<Rep2>) &&
              is_convertible_v<const Rep2&, typename common_type<Rep1,Rep2>::type>
[[nodiscard]] constexpr
duration<typename common_type<Rep1,Rep2>::type, Period>
operator/(const duration<Rep1,Period>& d, const Rep2& s) {
    using Cr = typename common_type<Rep1,Rep2>::type;
    return duration<Cr,Period>(duration<Cr,Period>(d).count() / static_cast<Cr>(s));
}

template <class Rep1, class Period1, class Rep2, class Period2>
[[nodiscard]] constexpr typename common_type<Rep1,Rep2>::type
operator/(const duration<Rep1,Period1>& lhs, const duration<Rep2,Period2>& rhs) {
    using Ct = typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type;
    return Ct(lhs).count() / Ct(rhs).count();
}

template <class Rep1, class Period, class Rep2>
    requires (!is_duration_v<Rep2>) &&
              is_convertible_v<const Rep2&, typename common_type<Rep1,Rep2>::type>
[[nodiscard]] constexpr
duration<typename common_type<Rep1,Rep2>::type, Period>
operator%(const duration<Rep1,Period>& d, const Rep2& s) {
    using Cr = typename common_type<Rep1,Rep2>::type;
    return duration<Cr,Period>(duration<Cr,Period>(d).count() % static_cast<Cr>(s));
}

template <class Rep1, class Period1, class Rep2, class Period2>
[[nodiscard]] constexpr
typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type
operator%(const duration<Rep1,Period1>& lhs, const duration<Rep2,Period2>& rhs) {
    using Cr = typename common_type<Rep1,Rep2>::type;
    using Cd = typename common_type<duration<Rep1,Period1>, duration<Rep2,Period2>>::type;
    return Cd(static_cast<Cr>(Cd(lhs).count()) % static_cast<Cr>(Cd(rhs).count()));
}

