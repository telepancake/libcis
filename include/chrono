// libc++ derives the leap-second list from the tzdb (parsed from the system
// IANA database). The historical leap seconds (1972..) are immutable data, so
// we embed that fixed table directly: this keeps utc_clock header-only and
// independent of any runtime time-zone database. Each entry is the sys_seconds
// instant at which one positive leap second was inserted.
//===----------------------------------------------------------------------===//
class utc_clock;

template <class Duration>
using utc_time    = time_point<utc_clock, Duration>;
using utc_seconds = utc_time<seconds>;

