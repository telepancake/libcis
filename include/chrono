class weekday {
    unsigned char wd_ = 0;

    static constexpr unsigned char weekday_from_days(int d) noexcept {
        return static_cast<unsigned char>(
            static_cast<unsigned>(
                d >= -4 ? (d + 4) % 7 : (d + 5) % 7 + 6));
    }

public:
    weekday() = default;
    explicit constexpr weekday(unsigned v) noexcept
        : wd_(static_cast<unsigned char>(v == 7 ? 0 : v)) {}
    constexpr weekday(const sys_days& sd) noexcept
        : wd_(weekday_from_days(sd.time_since_epoch().count())) {}
    explicit constexpr weekday(const local_days& ld) noexcept
        : wd_(weekday_from_days(ld.time_since_epoch().count())) {}

    constexpr weekday& operator++() noexcept {
        wd_ = (wd_ == 6 ? 0 : wd_ + 1); return *this;
    }
    constexpr weekday  operator++(int) noexcept { weekday t=*this; ++(*this); return t; }
    constexpr weekday& operator--() noexcept {
        wd_ = (wd_ == 0 ? 6 : wd_ - 1); return *this;
    }
    constexpr weekday  operator--(int) noexcept { weekday t=*this; --(*this); return t; }
    constexpr weekday& operator+=(const days& dd) noexcept;
    constexpr weekday& operator-=(const days& dd) noexcept;

    [[nodiscard]] constexpr unsigned c_encoding()   const noexcept { return wd_; }
    [[nodiscard]] constexpr unsigned iso_encoding() const noexcept {
        return wd_ == 0u ? 7u : wd_;
    }
    [[nodiscard]] constexpr bool ok() const noexcept { return wd_ <= 6; }
    [[nodiscard]] constexpr weekday_indexed operator[](unsigned idx) const noexcept;
    [[nodiscard]] constexpr weekday_last    operator[](last_spec)    const noexcept;
};

constexpr bool operator==(const weekday& a, const weekday& b) noexcept {
    return a.c_encoding() == b.c_encoding();
}
[[nodiscard]] constexpr weekday operator+(const weekday& wd, const days& dd) noexcept {
    auto mu = static_cast<long long>(wd.c_encoding()) + dd.count();
    auto yr = (mu >= 0 ? mu : mu - 6) / 7;
    return weekday{static_cast<unsigned>(mu - yr * 7)};
}
[[nodiscard]] constexpr weekday operator+(const days& dd, const weekday& wd) noexcept { return wd+dd; }
[[nodiscard]] constexpr weekday operator-(const weekday& wd, const days& dd) noexcept { return wd + -dd; }
[[nodiscard]] constexpr days operator-(const weekday& a, const weekday& b) noexcept {
    const int wdu = static_cast<int>(a.c_encoding()) - static_cast<int>(b.c_encoding());
    const int wk  = (wdu >= 0 ? wdu : wdu - 6) / 7;
    return days{wdu - wk * 7};
}
constexpr weekday& weekday::operator+=(const days& dd) noexcept { *this = *this+dd; return *this; }
constexpr weekday& weekday::operator-=(const days& dd) noexcept { *this = *this-dd; return *this; }

class weekday_indexed {
    chrono::weekday wd_;
    unsigned char   idx_ = 0;
public:
    weekday_indexed() = default;
    constexpr weekday_indexed(const chrono::weekday& wd, unsigned idx) noexcept
        : wd_{wd}, idx_(static_cast<unsigned char>(idx)) {}
    [[nodiscard]] constexpr chrono::weekday weekday() const noexcept { return wd_; }
    [[nodiscard]] constexpr unsigned index() const noexcept { return idx_; }
    [[nodiscard]] constexpr bool ok() const noexcept {
        return wd_.ok() && idx_ >= 1 && idx_ <= 5;
    }
};

constexpr bool operator==(const weekday_indexed& a, const weekday_indexed& b) noexcept {
    return a.weekday() == b.weekday() && a.index() == b.index();
}

