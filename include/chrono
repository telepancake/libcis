class month_day {
    chrono::month m_;
    chrono::day   d_;
public:
    month_day() = default;
    constexpr month_day(const chrono::month& m, const chrono::day& d) noexcept
        : m_{m}, d_{d} {}
    [[nodiscard]] constexpr chrono::month month() const noexcept { return m_; }
    [[nodiscard]] constexpr chrono::day   day()   const noexcept { return d_; }
    [[nodiscard]] constexpr bool ok() const noexcept {
        if (!m_.ok()) return false;
        unsigned dv = static_cast<unsigned>(d_);
        if (dv < 1 || dv > 31) return false;
        if (dv <= 29) return true;
        unsigned mv = static_cast<unsigned>(m_);
        if (mv == 2) return false;
        if (mv == 4 || mv == 6 || mv == 9 || mv == 11) return dv == 30;
        return true;
    }
};

