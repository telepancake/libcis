[[nodiscard]] constexpr month operator-(const month& m, const months& dm) noexcept { return m + -dm; }
[[nodiscard]] constexpr months operator-(const month& a, const month& b) noexcept {
    auto dm = static_cast<unsigned>(a) - static_cast<unsigned>(b);
    return months(dm <= 11 ? dm : dm + 12);
}
