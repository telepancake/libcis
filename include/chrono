        sys_seconds{sys_days{January   / 1 / 2006}.time_since_epoch()},
        sys_seconds{sys_days{January   / 1 / 2009}.time_since_epoch()},
        sys_seconds{sys_days{July      / 1 / 2012}.time_since_epoch()},
        sys_seconds{sys_days{July      / 1 / 2015}.time_since_epoch()},
        sys_seconds{sys_days{January   / 1 / 2017}.time_since_epoch()},
    };
    count = sizeof(table) / sizeof(table[0]);
    return table;
}

struct leap_second_info {
    bool is_leap_second;
    seconds elapsed;
};

template <class Duration>
[[nodiscard]] leap_second_info get_leap_second_info(const utc_time<Duration>& time) {
    size_t n = 0;
    const sys_seconds* leaps = utc_leap_table(n);
    sys_seconds sys{chrono::floor<seconds>(time).time_since_epoch()};
    seconds elapsed{0};
    for (size_t i = 0; i < n; ++i) {
        // Each historical leap second has value +1s.
        if (sys == leaps[i] + elapsed)
            return {true, elapsed + seconds{1}};
        if (sys < leaps[i] + elapsed)
            return {false, elapsed};
        elapsed += seconds{1};
    }
    return {false, elapsed};
}

class utc_clock {
public:
    using rep        = system_clock::rep;
    using period     = system_clock::period;
    using duration   = chrono::duration<rep, period>;
    using time_point = chrono::time_point<utc_clock>;
    static constexpr bool is_steady = false;

    [[nodiscard]] static time_point now() { return from_sys(system_clock::now()); }

    template <class Duration>
    [[nodiscard]] static sys_time<common_type_t<Duration, seconds>>
    to_sys(const utc_time<Duration>& time);

    template <class Duration>
    [[nodiscard]] static utc_time<common_type_t<Duration, seconds>>
    from_sys(const sys_time<Duration>& time) {
        using R = utc_time<common_type_t<Duration, seconds>>;
        size_t n = 0;
        const sys_seconds* leaps = utc_leap_table(n);
        R result{time.time_since_epoch()};
        for (size_t i = 0; i < n; ++i) {
            if (sys_time<common_type_t<Duration, seconds>>{leaps[i].time_since_epoch()} > time)
                return result;
            result += seconds{1};
        }
        return result;
    }
};

template <class Duration>
[[nodiscard]] sys_time<common_type_t<Duration, seconds>>
utc_clock::to_sys(const utc_time<Duration>& time) {
    using D = common_type_t<Duration, seconds>;
    leap_second_info info = chrono::get_leap_second_info(time);
    // [time.clock.utc.members]/2: during a positive leap-second insertion the
    // conversion counts the leap second as not inserted and returns the last
    // representable sys_time prior to the insertion.
    sys_time<D> result{time.time_since_epoch() - info.elapsed};
    if (info.is_leap_second)
        return chrono::floor<seconds>(result) + chrono::seconds{1} - D{1};
    return result;
}

