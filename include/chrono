    [[nodiscard]] constexpr chrono::weekday      weekday()      const noexcept { return wdl_.weekday(); }
    [[nodiscard]] constexpr chrono::weekday_last weekday_last() const noexcept { return wdl_; }

    constexpr operator sys_days() const noexcept { return sys_days{to_days_impl()}; }
