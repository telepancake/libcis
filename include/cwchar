// constexpr wcslen helper (C++14 constexpr-since)
inline constexpr size_t constexpr_wcslen(const wchar_t* str) {
#if __has_builtin(__builtin_wcslen)
    return __builtin_wcslen(str);
#else
    size_t len = 0;
    for (; *str != L'\0'; ++str)
        ++len;
    return len;
#endif
}

// constexpr wmemcmp helper
inline constexpr int constexpr_wmemcmp(const wchar_t* lhs, const wchar_t* rhs, size_t count) {
#if __has_builtin(__builtin_wmemcmp)
    return __builtin_wmemcmp(lhs, rhs, count);
#else
    for (; count; --count, ++lhs, ++rhs) {
        if (*lhs < *rhs)
            return -1;
        if (*rhs < *lhs)
            return 1;
    }
    return 0;
#endif
}

