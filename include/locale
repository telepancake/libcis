template <class CharT, class InputIterator = istreambuf_iterator<CharT> >
class money_get : public locale::facet, private money_get_base<CharT> {
public:
  typedef CharT char_type;
  typedef InputIterator iter_type;
  typedef basic_string<char_type> string_type;

  explicit money_get(size_t refs = 0) : locale::facet(refs) {}

  iter_type
  get(iter_type b, iter_type e, bool intl, ios_base& iob, detail::ios_iostate& err, long double& v) const {
    return do_get(b, e, intl, iob, err, v);
  }

  iter_type
  get(iter_type b, iter_type e, bool intl, ios_base& iob, detail::ios_iostate& err, string_type& v) const {
    return do_get(b, e, intl, iob, err, v);
  }

  static locale::id id;

protected:
  ~money_get() override {}

  virtual iter_type
  do_get(iter_type b, iter_type e, bool intl, ios_base& iob, detail::ios_iostate& err, long double& v) const;
  virtual iter_type
  do_get(iter_type b, iter_type e, bool intl, ios_base& iob, detail::ios_iostate& err, string_type& v) const;

private:
  static bool do_get_impl(
      iter_type& b,
      iter_type e,
      bool intl,
      const locale& loc,
      detail::ios_fmtflags flags,
      detail::ios_iostate& err,
      bool& neg,
      const ctype<char_type>& ct,
      unique_ptr<char_type, void (*)(void*)>& wb,
      char_type*& wn,
      char_type* we);
};

template <class CharT, class InputIterator>
locale::id money_get<CharT, InputIterator>::id;

// true == success
template <class CharT, class InputIterator>
bool money_get<CharT, InputIterator>::do_get_impl(
    iter_type& b,
    iter_type e,
    bool intl,
    const locale& loc,
    detail::ios_fmtflags flags,
    detail::ios_iostate& err,
    bool& neg,
    const ctype<char_type>& ct,
    unique_ptr<char_type, void (*)(void*)>& wb,
    char_type*& wn,
    char_type* we) {
  if (b == e) {
    err |= detail::ios_failbit;
    return false;
  }
  const unsigned bz = 100;
  unsigned gbuf[bz];
  unique_ptr<unsigned, void (*)(void*)> gb(gbuf, detail::money_do_nothing);
  unsigned* gn = gb.get();
  unsigned* ge = gn + bz;
  money_base::pattern pat;
  char_type dp;
  char_type ts;
  string grp;
  string_type sym;
  string_type psn;
  string_type nsn;
  string_type spaces;
  int fd;
  money_get_base<CharT>::gather_info(intl, loc, pat, dp, ts, grp, sym, psn, nsn, fd);
  const string_type* trailing_sign = 0;
  wn                               = wb.get();
  for (unsigned p = 0; p < 4 && b != e; ++p) {
    switch (pat.field[p]) {
    case money_base::space:
      if (p != 3) {
        if (ct.is(ctype_base::space, *b))
          spaces.push_back(*b++);
        else {
          err |= detail::ios_failbit;
          return false;
        }
      }
      [[fallthrough]];
    case money_base::none:
      if (p != 3) {
        while (b != e && ct.is(ctype_base::space, *b))
          spaces.push_back(*b++);
      }
      break;
    case money_base::sign:
      if (psn.size() > 0 && *b == psn[0]) {
        ++b;
        neg = false;
        if (psn.size() > 1)
          trailing_sign = &psn;
        break;
      }
      if (nsn.size() > 0 && *b == nsn[0]) {
        ++b;
        neg = true;
        if (nsn.size() > 1)
          trailing_sign = &nsn;
        break;
      }
      if (psn.size() > 0 && nsn.size() > 0) { // sign is required
        err |= detail::ios_failbit;
        return false;
      }
      if (psn.size() == 0 && nsn.size() == 0)
        break;
      neg = (nsn.size() == 0);
      break;
    case money_base::symbol: {
      bool more_needed =
          trailing_sign || (p < 2) || (p == 2 && pat.field[3] != static_cast<char>(money_base::none));
      bool sb = (flags & detail::ios_showbase) != 0;
      if (sb || more_needed) {
        typename string_type::const_iterator sym_space_end = sym.begin();
        if (p > 0 && (pat.field[p - 1] == money_base::none || pat.field[p - 1] == money_base::space)) {
          while (sym_space_end != sym.end() && ct.is(ctype_base::space, *sym_space_end))
            ++sym_space_end;
          const size_t num_spaces = sym_space_end - sym.begin();
          if (num_spaces > spaces.size() ||
              !std::equal(spaces.end() - num_spaces, spaces.end(), sym.begin())) {
            sym_space_end = sym.begin();
          }
        }
        typename string_type::const_iterator sym_curr_char = sym_space_end;
        while (sym_curr_char != sym.end() && b != e && *b == *sym_curr_char) {
          ++b;
          ++sym_curr_char;
        }
        if (sb && sym_curr_char != sym.end()) {
          err |= detail::ios_failbit;
          return false;
        }
      }
    } break;
    case money_base::value: {
      unsigned ng = 0;
      for (; b != e; ++b) {
        char_type c = *b;
        if (ct.is(ctype_base::digit, c)) {
          if (wn == we)
            detail::money_double_or_nothing(wb, wn, we);
          *wn++ = c;
          ++ng;
        } else if (grp.size() > 0 && ng > 0 && c == ts) {
          if (gn == ge)
            detail::money_double_or_nothing(gb, gn, ge);
          *gn++ = ng;
          ng    = 0;
        } else
          break;
      }
      if (gb.get() != gn && ng > 0) {
        if (gn == ge)
          detail::money_double_or_nothing(gb, gn, ge);
        *gn++ = ng;
      }
      if (fd > 0) {
        if (b == e || *b != dp) {
          err |= detail::ios_failbit;
          return false;
        }
        for (++b; fd > 0; --fd, ++b) {
          if (b == e || !ct.is(ctype_base::digit, *b)) {
            err |= detail::ios_failbit;
            return false;
          }
          if (wn == we)
            detail::money_double_or_nothing(wb, wn, we);
          *wn++ = *b;
        }
      }
      if (wn == wb.get()) {
        err |= detail::ios_failbit;
        return false;
      }
    } break;
    }
  }
  if (trailing_sign) {
    for (unsigned i = 1; i < trailing_sign->size(); ++i, ++b) {
      if (b == e || *b != (*trailing_sign)[i]) {
        err |= detail::ios_failbit;
        return false;
      }
    }
  }
  if (gb.get() != gn) {
    detail::ios_iostate et = detail::ios_goodbit;
    detail::money_check_grouping(grp, gb.get(), gn, et);
    if (et) {
      err |= detail::ios_failbit;
      return false;
    }
  }
  return true;
}

template <class CharT, class InputIterator>
InputIterator money_get<CharT, InputIterator>::do_get(
    iter_type b, iter_type e, bool intl, ios_base& iob, detail::ios_iostate& err, long double& v) const {
  const int bz = 100;
  char_type wbuf[bz];
  unique_ptr<char_type, void (*)(void*)> wb(wbuf, detail::money_do_nothing);
  char_type* wn;
  char_type* we              = wbuf + bz;
  locale loc                 = iob.getloc();
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(loc);
  bool neg                   = false;
  if (do_get_impl(b, e, intl, loc, iob.flags(), err, neg, ct, wb, wn, we)) {
    const char src[] = "0123456789";
    char_type atoms[sizeof(src) - 1];
    ct.widen(src, src + (sizeof(src) - 1), atoms);
    char nbuf[bz];
    char* nc = nbuf;
    unique_ptr<char, void (*)(void*)> h(nullptr, free);
    if (wn - wb.get() > bz - 2) {
      h.reset((char*)malloc(static_cast<size_t>(wn - wb.get() + 2)));
      if (h.get() == nullptr)
        __builtin_trap();
      nc = h.get();
    }
    if (neg)
      *nc++ = '-';
    for (const char_type* w = wb.get(); w < wn; ++w, ++nc)
      *nc = src[std::find(atoms, std::end(atoms), *w) - atoms];
    *nc = char();
    if (sscanf(nbuf, "%Lf", &v) != 1)
      __builtin_trap();
  }
  if (b == e)
    err |= detail::ios_eofbit;
  return b;
}

template <class CharT, class InputIterator>
InputIterator money_get<CharT, InputIterator>::do_get(
    iter_type b, iter_type e, bool intl, ios_base& iob, detail::ios_iostate& err, string_type& v) const {
  const int bz = 100;
  char_type wbuf[bz];
  unique_ptr<char_type, void (*)(void*)> wb(wbuf, detail::money_do_nothing);
  char_type* wn;
  char_type* we              = wbuf + bz;
  locale loc                 = iob.getloc();
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(loc);
  bool neg                   = false;
  if (do_get_impl(b, e, intl, loc, iob.flags(), err, neg, ct, wb, wn, we)) {
    v.clear();
    if (neg)
      v.push_back(ct.widen('-'));
    char_type z = ct.widen('0');
    char_type* w;
    for (w = wb.get(); w < wn - 1; ++w)
      if (*w != z)
        break;
    v.append(w, wn);
  }
  if (b == e)
    err |= detail::ios_eofbit;
  return b;
}

