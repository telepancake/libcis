OutputIterator num_put<CharT, OutputIterator>::do_put(iter_type s, ios_base& iob, char_type fl, unsigned long long v) const {
  return this->do_put_integral(s, iob, fl, v, "ll");
}

template <class CharT, class OutputIterator>
template <class Float>
OutputIterator num_put<CharT, OutputIterator>::do_put_floating_point(
    iter_type s, ios_base& iob, char_type fl, Float v, char const* len) const {
  char fmt[8]             = {'%', 0};
  bool specify_precision  = this->format_float(fmt + 1, len, iob.flags());
  const unsigned nbuf     = 30;
  char nar[nbuf];
  char* nb = nar;
  char* heap_nb = nullptr;       // dynamic buffer if the fixed one is too small
  int nc;
  if (specify_precision)
    nc = std::snprintf(nb, nbuf, fmt, (int)iob.precision(), v);
  else
    nc = std::snprintf(nb, nbuf, fmt, v);
  // libc++ falls back to a heap buffer when nc exceeds the fixed buffer.
  if (nc > static_cast<int>(nbuf - 1)) {
    heap_nb = static_cast<char*>(::operator new(static_cast<size_t>(nc) + 1));
    nb = heap_nb;
    if (specify_precision)
      nc = std::snprintf(nb, static_cast<size_t>(nc) + 1, fmt, (int)iob.precision(), v);
    else
      nc = std::snprintf(nb, static_cast<size_t>(nc) + 1, fmt, v);
  }
  char* ne = nb + nc;
  char* np = this->identify_padding(nb, ne, iob);
  // widened/grouped output buffer: worst case 2*nc-1 (grouping inserts seps).
  char_type ostk[2 * (nbuf - 1) - 1];
  char_type* o = ostk;
  char_type* heap_o = nullptr;
  if (static_cast<unsigned>(nc) > nbuf - 1) {
    heap_o = static_cast<char_type*>(::operator new(sizeof(char_type) * (2 * static_cast<size_t>(nc) - 1)));
    o = heap_o;
  }
  char_type* ob = o;
  char_type* op;
  char_type* oe;
  this->widen_and_group_float(nb, np, ne, ob, op, oe, iob.getloc());
  s = detail::pad_and_output(s, ob, op, oe, iob, fl);
  if (heap_nb) ::operator delete(heap_nb);
  if (heap_o)  ::operator delete(heap_o);
  return s;
}

template <class CharT, class OutputIterator>
OutputIterator num_put<CharT, OutputIterator>::do_put(iter_type s, ios_base& iob, char_type fl, double v) const {
  return this->do_put_floating_point(s, iob, fl, v, "");
}
template <class CharT, class OutputIterator>
OutputIterator num_put<CharT, OutputIterator>::do_put(iter_type s, ios_base& iob, char_type fl, long double v) const {
  return this->do_put_floating_point(s, iob, fl, v, "L");
}

template <class CharT, class OutputIterator>
OutputIterator num_put<CharT, OutputIterator>::do_put(iter_type s, ios_base& iob, char_type fl, const void* v) const {
  const unsigned nbuf = 20;
  char nar[nbuf];
  int nc     = std::snprintf(nar, sizeof(nar), "%p", v);
  char* ne   = nar + nc;
  char* np   = this->identify_padding(nar, ne, iob);
  char_type o[2 * (nbuf - 1) - 1];
  char_type* op;
  char_type* oe;
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(iob.getloc());
  ct.widen(nar, ne, o);
  oe = o + (ne - nar);
  if (np == ne)
    op = oe;
  else
    op = o + (np - nar);
  return detail::pad_and_output(s, o, op, oe, iob, fl);
}



