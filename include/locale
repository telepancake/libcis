// <locale> — locale + codecvt base/specialisations for <ios> and <codecvt>.
// Mechanically ported from libc++ include/__locale + include/locale (selective).
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// DESIGN NOTE (libcis reduced iostreams):
//   This is intentionally minimal: only "C" and "" (system default, treated as
//   "C") locale names are fully supported.  A named constructor receiving any
//   other name traps (would throw runtime_error per the standard; per libcis
//   convention: __builtin_trap() // would throw runtime_error).
//
//   Facets provided: ctype_base, ctype<char>, ctype<wchar_t>,
//                    numpunct<char>, numpunct<wchar_t>,
//                    codecvt_base, codecvt<char,char,mbstate_t>,
//                    codecvt<char16_t,char,mbstate_t>,
//                    codecvt<char32_t,char,mbstate_t>,
//                    codecvt<char16_t,char8_t,mbstate_t>,
//                    codecvt<char32_t,char8_t,mbstate_t>.
//   Intentionally OMITTED: collate, num_get, num_put, money_*, time_*,
//   messages, codecvt<wchar_t,char,mbstate_t> (needs newlocale/mbrtowc).
//
//   locale::name() returns "C" for classic/default, "*" for unnamed.
//   locale(const char*) / locale(const string&) accept "C" and "" (treated
//   as classic); any other name traps.
#pragma once

// C system headers must be included BEFORE the visibility push so their symbol
// declarations (like 'extern FILE *stderr') stay at default (global) visibility.
// This prevents the linker error "hidden symbol 'stderr' isn't defined".
#pragma GCC visibility push(default)
#include <stdio.h>   // FILE*, stderr, etc. (pulled in transitively via <string>/<cstdio>)
#include <wchar.h>   // wint_t, mbstate_t, iswspace etc.
#pragma GCC visibility pop

// Hide all our symbols so they don't conflict with libstdc++.so symbols at runtime.
// libstdc++ links in as a shared lib; without hidden visibility our weak std::locale,
// std::ctype<> etc. would be interposed by libstdc++'s strong symbols, causing ABI mismatch.
#pragma GCC visibility push(hidden)

#include <cstddef>   // size_t
#include <cctype>    // isspace, isdigit, etc.
#include <cwchar>    // wint_t
#include <cstring>   // strcmp
#include <string>    // std::string
#include <type_traits>
#include <cstdint>   // uint8_t, uint16_t, uint32_t

namespace std {

// Forward declarations needed internally.
class locale;
template<class Facet> const Facet& use_facet(const locale&);
template<class Facet> bool has_facet(const locale&) noexcept;

//===----------------------------------------------------------------------===//
// locale
//===----------------------------------------------------------------------===//
//
// Design: libcis locale has two facet lookup layers:
//   1. A per-locale "imp" (shared, refcounted) that holds injected facets.
//      Created only by locale(const locale&, Facet*).  Shared by copy/assign.
//   2. The global static facet_registry for the classic-locale built-in facets.
//
// use_facet / has_facet check the per-locale imp first, then fall back to
// the global registry.  This preserves the existing classic-locale fast path.
//
// Ported semantics from:
//   /home/user/llvm-project/libcxx/include/__locale  — locale class, template
//     <class Facet> locale(const locale&, Facet*) [line 171],
//     combine<Facet> [line 92], has_facet/use_facet [lines 176-183].
//   /home/user/llvm-project/libcxx/src/locale.cpp   — __install_ctor [line 532],
//     facet ownership / refcounting [lines 425-452, 561].
//
// Ownership: facet::refs_ mirrors libc++'s __shared_count semantics:
//   refs_==0 (default) → locale takes ownership (will delete on last ref drop).
//   refs_>=1 → caller retains ownership; locale does not delete.
class locale {
public:
    // --- nested class id ---
    class id {
    public:
        id() = default;
        id(const id&) = delete;
        id& operator=(const id&) = delete;

        // Returns a unique non-zero integer for this id object.
        // Assigned lazily on first call (thread-unsafe; acceptable here).
        size_t __get() const {
            if (val == 0) {
                val = ++counter;
            }
            return val;
        }
    private:
        mutable size_t val = 0;
        static size_t counter;
    };

    // --- nested class facet ---
    class facet {
    protected:
        explicit facet(size_t refs = 0) : refs_(refs) {}
        virtual ~facet() = default;
        facet(const facet&) = delete;
        facet& operator=(const facet&) = delete;
    private:
        friend class locale;
        // refs_ == 0: locale owns this facet (will delete when refcount reaches 0)
        // refs_ >= 1: externally owned / pinned (classic-locale statics use refs_=1)
        size_t refs_;
    };

    // category bitmask
    typedef int category;
    static constexpr category none     = 0x000;
    static constexpr category collate  = 0x010;
    static constexpr category ctype    = 0x020;
    static constexpr category monetary = 0x040;
    static constexpr category numeric  = 0x080;
    static constexpr category time     = 0x100;
    static constexpr category messages = 0x200;
    static constexpr category all      = collate | ctype | monetary | numeric | time | messages;

    // -----------------------------------------------------------------------
    // imp: shared per-locale facet table for injected facets.
    // Ported from libc++ locale::__imp (locale.cpp); simplified to a plain
    // refcounted struct because we don't need the full category machinery.
    // -----------------------------------------------------------------------
    struct imp {
        // Small per-locale override table for injected facets.
        // Indexed by facet id (same namespace as global registry).
        static constexpr size_t max_facets = 64;
        const facet* table[max_facets] = {};
        // owns[i] is true when table[i] is owned by this imp and must be
        // deleted when this imp is destroyed.
        bool owns[max_facets] = {};
        // Shared refcount — starts at 1 (the constructing locale).
        size_t refs = 1;

        void add_ref() noexcept { ++refs; }
        // Returns true if this imp should be deleted.
        bool release() noexcept { return --refs == 0; }

        ~imp() {
            for (size_t i = 0; i < max_facets; ++i) {
                if (table[i] && owns[i])
                    release_facet(const_cast<facet*>(table[i]));
            }
        }

        // Install a facet at slot id.  Takes ownership iff f->refs_ == 0.
        void install(size_t id, facet* f) {
            if (id == 0 || id >= max_facets) return;
            if (table[id] && owns[id])
                release_facet(const_cast<facet*>(table[id]));
            table[id] = f;
            owns[id]  = (f->refs_ == 0);
            // Bump refs_ so caller can't double-delete even if refs_==0.
            ++f->refs_;
        }

        // Release a facet we own: call its virtual destructor then free.
        // We use explicit dtor + ::operator delete(void*) rather than
        // delete-expression so that test instrumentation overriding
        // operator delete(void*) intercepts the deallocation.  A plain
        // delete-expression on a base pointer would generate a sized-delete
        // call (C++14) which is a separate symbol not overridden by libc++
        // test helpers.
        static void release_facet(facet* f) {
            f->~facet();                  // virtual dispatch → derived dtor
            ::operator delete(f);         // unsized delete, interceptable by tests
        }

        const facet* get(size_t id) const noexcept {
            if (id == 0 || id >= max_facets) return nullptr;
            return table[id];
        }
    };

    // Free an imp that we own: explicit dtor + unsized ::operator delete.
    // Mirrors the same rationale as imp::release_facet.
    static void release_imp(imp* p) {
        p->~imp();
        ::operator delete(p);
    }

    // --- construct/copy/destroy ---

    // default: the current global locale (for libcis, always "C")
    locale() noexcept : name_("C"), imp_(nullptr) {}

    locale(const locale& other) noexcept
        : name_(other.name_), imp_(other.imp_) {
        if (imp_) imp_->add_ref();
    }

    locale& operator=(const locale& other) noexcept {
        if (this != &other) {
            if (imp_ && imp_->release()) release_imp(imp_);
            name_ = other.name_;
            imp_  = other.imp_;
            if (imp_) imp_->add_ref();
        }
        return *this;
    }

    ~locale() {
        if (imp_ && imp_->release()) release_imp(imp_);
    }

    // named constructors — only "C" and "" (empty = system default = "C") are
    // supported on this freestanding target.  Any other name would throw
    // runtime_error per the standard; we __builtin_trap() instead.
    explicit locale(const char* name) : imp_(nullptr) {
        if (name == nullptr)
            __builtin_trap(); // would throw runtime_error
        if (name[0] == '\0' || (name[0] == 'C' && name[1] == '\0')) {
            name_ = "C";
        } else {
            __builtin_trap(); // would throw runtime_error: unsupported locale name
        }
    }
    explicit locale(const string& name) : locale(name.c_str()) {}

    // Replace selected categories of one locale with those from a named locale.
    // For libcis only "C" / "" are supported; category is ignored since all
    // facets are the same.
    locale(const locale& other, const char* name, category) : imp_(nullptr) {
        if (name == nullptr)
            __builtin_trap(); // would throw runtime_error
        if (name[0] == '\0' || (name[0] == 'C' && name[1] == '\0')) {
            name_ = other.name_;
        } else {
            __builtin_trap(); // would throw runtime_error: unsupported locale name
        }
    }
    locale(const locale& other, const string& name, category cat)
        : locale(other, name.c_str(), cat) {}

    // [locale.cons]p14: locale(const locale& other, Facet* f)
    // Result is a copy of other with f installed as its Facet facet.
    // If f is null, the result is a plain copy of other.
    // The locale takes ownership of f if f->refs_ == 0 (f was heap-allocated
    // with refs=0); otherwise the caller retains ownership.
    // The resulting locale's name() is "*" (unnamed) per the standard.
    //
    // Ported from: libc++ include/__locale line 171 (template body) and
    // src/locale.cpp line 532 (__install_ctor).
    template<class Facet>
    locale(const locale& other, Facet* f) : locale(other) {
        if (!f) return;  // null f → plain copy (name unchanged)
        // Need our own imp so we don't mutate the shared one from 'other'.
        imp* new_imp = new imp();
        // Copy any existing per-locale overrides from other.
        if (other.imp_) {
            for (size_t i = 0; i < imp::max_facets; ++i) {
                if (other.imp_->table[i]) {
                    new_imp->table[i] = other.imp_->table[i];
                    new_imp->owns[i]  = false; // shared reference; we don't own
                    // Keep the facet's refs_ bumped so it survives.
                    const_cast<facet*>(other.imp_->table[i])->refs_++;
                }
            }
        }
        // Release the imp we inherited from the copy of 'other'.
        if (imp_ && imp_->release()) release_imp(imp_);
        imp_ = new_imp;
        // Install f.
        size_t fid = Facet::id.__get();
        imp_->install(fid, f);
        name_ = "*";
    }

    // locale::combine<Facet>(other): return a copy of *this with Facet from other.
    // Ported from: libc++ include/__locale line 92.
    template<class Facet>
    locale combine(const locale& other) const {
        if (!has_facet<Facet>(other))
            __builtin_trap(); // would throw runtime_error per standard
        return locale(*this, &const_cast<Facet&>(use_facet<Facet>(other)));
    }

    // --- observers ---

    string name() const { return name_; }

    bool operator==(const locale& other) const noexcept {
        // Both locales point to the same imp → equal.
        // Named locales (non-"*"): compare by name.
        // Unnamed ("*"): only equal if same imp.
        if (imp_ && other.imp_ && imp_ == other.imp_) return true;
        if (name_ == "*" || other.name_ == "*") return false;
        return name_ == other.name_;
    }
    bool operator!=(const locale& other) const noexcept { return !(*this == other); }

    // --- statics ---

    static const locale& classic() noexcept {
        static locale inst;  // default-constructed → "C"
        return inst;
    }
    static locale global(const locale& loc) {
        locale prev = global_locale();
        global_locale() = loc;
        return prev;
    }

    // use_facet / has_facet support: global static registry for classic facets.
    static const facet* __get_facet(size_t id) noexcept;
    static void __register_facet(size_t id, const facet* f) noexcept;

    // Per-locale lookup: checks this locale's injected table, then global registry.
    const facet* __lookup_facet(size_t id) const noexcept {
        if (imp_) {
            const facet* f = imp_->get(id);
            if (f) return f;
        }
        return __get_facet(id);
    }

private:
    string name_;
    imp*   imp_;   // nullptr for classic/named locales with no injected facets

    static locale& global_locale() {
        static locale g;
        return g;
    }
};

// locale::id counter definition — lives here (header-only, #pragma once / include guard)
inline size_t locale::id::counter = 0;

// Static facet registry (array indexed by id)
namespace detail {
    constexpr size_t max_facets = 64;
    inline const locale::facet* facet_registry[max_facets] = {};
} // namespace detail

inline const locale::facet* locale::__get_facet(size_t id) noexcept {
    if (id == 0 || id >= detail::max_facets) return nullptr;
    return detail::facet_registry[id];
}
inline void locale::__register_facet(size_t id, const locale::facet* f) noexcept {
    if (id == 0 || id >= detail::max_facets) return;
    detail::facet_registry[id] = f;
}

//===----------------------------------------------------------------------===//
// has_facet / use_facet
// Ported from: libc++ include/__locale lines 176-183.
// Extended to check per-locale injected table (locale::__lookup_facet) before
// falling back to the global static registry.
//===----------------------------------------------------------------------===//

template<class Facet>
bool has_facet(const locale& loc) noexcept {
    size_t id = Facet::id.__get();
    return loc.__lookup_facet(id) != nullptr;
}

template<class Facet>
const Facet& use_facet(const locale& loc) {
    size_t id = Facet::id.__get();
    const locale::facet* f = loc.__lookup_facet(id);
    if (!f) __builtin_trap(); // facet not installed — unreachable in well-formed code
    return static_cast<const Facet&>(*f);
}

//===----------------------------------------------------------------------===//
// codecvt_base
//===----------------------------------------------------------------------===//
class codecvt_base {
public:
    codecvt_base() = default;
    enum result { ok, partial, error, noconv };
};

//===----------------------------------------------------------------------===//
// codecvt<InternT, ExternT, StateT> — primary template (unimplemented)
//===----------------------------------------------------------------------===//
template<class InternT, class ExternT, class StateT>
class codecvt;

//===----------------------------------------------------------------------===//
// Internal UTF conversion helpers (header-only: must be inline, not static)
// Ported directly from libc++ src/locale.cpp, stripping leading-underscore names.
//===----------------------------------------------------------------------===//
namespace detail {

// UTF-16 (as uint16_t pairs) → UTF-8
inline codecvt_base::result utf16_to_utf8(
    const uint16_t* frm, const uint16_t* frm_end, const uint16_t*& frm_nxt,
    uint8_t* to, uint8_t* to_end, uint8_t*& to_nxt,
    unsigned long Maxcode = 0x10FFFF, int mode = 0)
{
    // mode bits: generate_header=2, little_endian=1, consume_header=4
    frm_nxt = frm; to_nxt = to;
    if (mode & 2) { // generate_header
        if (to_end - to_nxt < 3) return codecvt_base::partial;
        *to_nxt++ = 0xEF; *to_nxt++ = 0xBB; *to_nxt++ = 0xBF;
    }
    for (; frm_nxt < frm_end; ++frm_nxt) {
        uint16_t wc1 = *frm_nxt;
        if (wc1 > Maxcode) return codecvt_base::error;
        if (wc1 < 0x0080) {
            if (to_end - to_nxt < 1) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(wc1);
        } else if (wc1 < 0x0800) {
            if (to_end - to_nxt < 2) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(0xC0 | (wc1 >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc1 & 0x3F));
        } else if (wc1 < 0xD800) {
            if (to_end - to_nxt < 3) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(0xE0 | (wc1 >> 12));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((wc1 & 0x0FC0) >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc1 & 0x003F));
        } else if (wc1 < 0xDC00) {
            if (frm_end - frm_nxt < 2) return codecvt_base::partial;
            uint16_t wc2 = frm_nxt[1];
            if ((wc2 & 0xFC00) != 0xDC00) return codecvt_base::error;
            if (to_end - to_nxt < 4) return codecvt_base::partial;
            if (((((wc1 & 0x03C0UL) >> 6) + 1) << 16) + ((wc1 & 0x003FUL) << 10) + (wc2 & 0x03FF) > Maxcode)
                return codecvt_base::error;
            ++frm_nxt;
            uint8_t z = static_cast<uint8_t>(((wc1 & 0x03C0) >> 6) + 1);
            *to_nxt++ = static_cast<uint8_t>(0xF0 | (z >> 2));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((z & 0x03) << 4) | ((wc1 & 0x003C) >> 2));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((wc1 & 0x0003) << 4) | ((wc2 & 0x03C0) >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc2 & 0x003F));
        } else if (wc1 < 0xE000) {
            return codecvt_base::error;
        } else {
            if (to_end - to_nxt < 3) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(0xE0 | (wc1 >> 12));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((wc1 & 0x0FC0) >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc1 & 0x003F));
        }
    }
    return codecvt_base::ok;
}

// UTF-16 (as uint32_t, each holding a uint16_t value) → UTF-8
inline codecvt_base::result utf16_to_utf8(
    const uint32_t* frm, const uint32_t* frm_end, const uint32_t*& frm_nxt,
    uint8_t* to, uint8_t* to_end, uint8_t*& to_nxt,
    unsigned long Maxcode = 0x10FFFF, int mode = 0)
{
    frm_nxt = frm; to_nxt = to;
    if (mode & 2) {
        if (to_end - to_nxt < 3) return codecvt_base::partial;
        *to_nxt++ = 0xEF; *to_nxt++ = 0xBB; *to_nxt++ = 0xBF;
    }
    for (; frm_nxt < frm_end; ++frm_nxt) {
        uint16_t wc1 = static_cast<uint16_t>(*frm_nxt);
        if (wc1 > Maxcode) return codecvt_base::error;
        if (wc1 < 0x0080) {
            if (to_end - to_nxt < 1) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(wc1);
        } else if (wc1 < 0x0800) {
            if (to_end - to_nxt < 2) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(0xC0 | (wc1 >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc1 & 0x3F));
        } else if (wc1 < 0xD800) {
            if (to_end - to_nxt < 3) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(0xE0 | (wc1 >> 12));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((wc1 & 0x0FC0) >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc1 & 0x003F));
        } else if (wc1 < 0xDC00) {
            if (frm_end - frm_nxt < 2) return codecvt_base::partial;
            uint16_t wc2 = static_cast<uint16_t>(frm_nxt[1]);
            if ((wc2 & 0xFC00) != 0xDC00) return codecvt_base::error;
            if (to_end - to_nxt < 4) return codecvt_base::partial;
            if (((((wc1 & 0x03C0UL) >> 6) + 1) << 16) + ((wc1 & 0x003FUL) << 10) + (wc2 & 0x03FF) > Maxcode)
                return codecvt_base::error;
            ++frm_nxt;
            uint8_t z = static_cast<uint8_t>(((wc1 & 0x03C0) >> 6) + 1);
            *to_nxt++ = static_cast<uint8_t>(0xF0 | (z >> 2));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((z & 0x03) << 4) | ((wc1 & 0x003C) >> 2));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((wc1 & 0x0003) << 4) | ((wc2 & 0x03C0) >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc2 & 0x003F));
        } else if (wc1 < 0xE000) {
            return codecvt_base::error;
        } else {
            if (to_end - to_nxt < 3) return codecvt_base::partial;
            *to_nxt++ = static_cast<uint8_t>(0xE0 | (wc1 >> 12));
            *to_nxt++ = static_cast<uint8_t>(0x80 | ((wc1 & 0x0FC0) >> 6));
            *to_nxt++ = static_cast<uint8_t>(0x80 | (wc1 & 0x003F));
        }
    }
    return codecvt_base::ok;
}

// UTF-8 → UTF-16 (output as uint16_t)
inline codecvt_base::result utf8_to_utf16(
    const uint8_t* frm, const uint8_t* frm_end, const uint8_t*& frm_nxt,
    uint16_t* to, uint16_t* to_end, uint16_t*& to_nxt,
    unsigned long Maxcode = 0x10FFFF, int mode = 0)
{
    frm_nxt = frm; to_nxt = to;
    if (mode & 4) { // consume_header
        if (frm_end - frm_nxt >= 3 && frm_nxt[0] == 0xEF && frm_nxt[1] == 0xBB && frm_nxt[2] == 0xBF)
            frm_nxt += 3;
    }
    for (; frm_nxt < frm_end && to_nxt < to_end; ++to_nxt) {
        uint8_t c1 = *frm_nxt;
        if (c1 > Maxcode) return codecvt_base::error;
        if (c1 < 0x80) {
            *to_nxt = static_cast<uint16_t>(c1); ++frm_nxt;
        } else if (c1 < 0xC2) {
            return codecvt_base::error;
        } else if (c1 < 0xE0) {
            if (frm_end - frm_nxt < 2) return codecvt_base::partial;
            uint8_t c2 = frm_nxt[1];
            if ((c2 & 0xC0) != 0x80) return codecvt_base::error;
            uint16_t t = static_cast<uint16_t>(((c1 & 0x1F) << 6) | (c2 & 0x3F));
            if (t > Maxcode) return codecvt_base::error;
            *to_nxt = t; frm_nxt += 2;
        } else if (c1 < 0xF0) {
            if (frm_end - frm_nxt < 2) return codecvt_base::partial;
            uint8_t c2 = frm_nxt[1];
            switch (c1) {
            case 0xE0: if ((c2 & 0xE0) != 0xA0) return codecvt_base::error; break;
            case 0xED: if ((c2 & 0xE0) != 0x80) return codecvt_base::error; break;
            default:   if ((c2 & 0xC0) != 0x80) return codecvt_base::error; break;
            }
            if (frm_end - frm_nxt < 3) return codecvt_base::partial;
            uint8_t c3 = frm_nxt[2];
            if ((c3 & 0xC0) != 0x80) return codecvt_base::error;
            uint16_t t = static_cast<uint16_t>(((c1 & 0x0F) << 12) | ((c2 & 0x3F) << 6) | (c3 & 0x3F));
            if (t > Maxcode) return codecvt_base::error;
            *to_nxt = t; frm_nxt += 3;
        } else if (c1 < 0xF5) {
            if (frm_end - frm_nxt < 2) return codecvt_base::partial;
            uint8_t c2 = frm_nxt[1];
            switch (c1) {
            case 0xF0: if (!(0x90 <= c2 && c2 <= 0xBF)) return codecvt_base::error; break;
            case 0xF4: if ((c2 & 0xF0) != 0x80) return codecvt_base::error; break;
            default:   if ((c2 & 0xC0) != 0x80) return codecvt_base::error; break;
            }
            if (frm_end - frm_nxt < 3) return codecvt_base::partial;
