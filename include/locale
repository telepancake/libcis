//===----------------------------------------------------------------------===//
// numpunct_byname<CharT> — pulls decimal_point/thousands_sep/grouping from the
// named locale's lconv (via uselocale, since glibc has no localeconv_l).
// Ported from libc++ src/locale.cpp numpunct_byname::__init.
//===----------------------------------------------------------------------===//
template<class CharT> class numpunct_byname;

template<>
class numpunct_byname<char> : public numpunct<char> {
    char dp_ = '.', ts_ = ',';
    string grp_;
public:
    typedef char char_type;
    typedef string string_type;
    explicit numpunct_byname(const char* nm, size_t refs = 0) : numpunct<char>(refs) { init(nm); }
    explicit numpunct_byname(const string& nm, size_t refs = 0) : numpunct<char>(refs) { init(nm.c_str()); }
protected:
    ~numpunct_byname() override {}
    char do_decimal_point() const override { return dp_; }
    char do_thousands_sep() const override { return ts_; }
    string do_grouping() const override { return grp_; }
private:
    void init(const char* nm) {
        if (__builtin_strcmp(nm, "C") == 0) return;
        ::locale_t l = detail::make_locale(nm);
        detail::scoped_uselocale guard(l);
        struct lconv* lc = ::localeconv();
        // Narrow a possibly-multibyte separator to one char (U+202F -> ' '),
        // keeping the default when no single-char form exists (libc++ parity).
        detail::mb_to_char(dp_, lc->decimal_point);
        detail::mb_to_char(ts_, lc->thousands_sep);
        grp_ = lc->grouping;
        ::freelocale(l);
    }
};

template<>
class numpunct_byname<wchar_t> : public numpunct<wchar_t> {
    wchar_t dp_ = L'.', ts_ = L',';
    string grp_;
public:
    typedef wchar_t char_type;
    typedef wstring string_type;
    explicit numpunct_byname(const char* nm, size_t refs = 0) : numpunct<wchar_t>(refs) { init(nm); }
    explicit numpunct_byname(const string& nm, size_t refs = 0) : numpunct<wchar_t>(refs) { init(nm.c_str()); }
protected:
    ~numpunct_byname() override {}
    wchar_t do_decimal_point() const override { return dp_; }
    wchar_t do_thousands_sep() const override { return ts_; }
    string do_grouping() const override { return grp_; }
private:
    void init(const char* nm) {
        if (__builtin_strcmp(nm, "C") == 0) return;
        ::locale_t l = detail::make_locale(nm);
        detail::scoped_uselocale guard(l);
        struct lconv* lc = ::localeconv();
        // Decode the full multibyte sequence (the separator may be e.g. U+202F in
        // fr_FR.UTF-8), not just the first byte, using the imbued locale's encoding.
        auto decode = [](const char* s, wchar_t dflt) -> wchar_t {
            if (!s || !s[0]) return dflt;
            wchar_t wc; mbstate_t st{};
            size_t n = ::mbrtowc(&wc, s, __builtin_strlen(s), &st);
            return (n == (size_t)-1 || n == (size_t)-2 || n == 0) ? (wchar_t)(unsigned char)s[0] : wc;
        };
        dp_ = decode(lc->decimal_point, dp_);
        ts_ = decode(lc->thousands_sep, ts_);
        grp_ = lc->grouping;
        ::freelocale(l);
    }
};


