struct num_put_base {
protected:
  static void format_int(char* fmtp, const char* len, bool signd, detail::ios_fmtflags flags) {
    if ((flags & detail::ios_showpos) && (flags & detail::ios_basefield) != detail::ios_oct &&
        (flags & detail::ios_basefield) != detail::ios_hex && signd)
      *fmtp++ = '+';
    if (flags & detail::ios_showbase)
      *fmtp++ = '#';
    while (*len)
      *fmtp++ = *len++;
    if ((flags & detail::ios_basefield) == detail::ios_oct)
      *fmtp = 'o';
    else if ((flags & detail::ios_basefield) == detail::ios_hex) {
      if (flags & detail::ios_uppercase)
        *fmtp = 'X';
      else
        *fmtp = 'x';
    } else if (signd)
      *fmtp = 'd';
    else
      *fmtp = 'u';
  }

  static bool format_float(char* fmtp, const char* len, detail::ios_fmtflags flags) {
    bool specify_precision = true;
    if (flags & detail::ios_showpos)
      *fmtp++ = '+';
    if (flags & detail::ios_showpoint)
      *fmtp++ = '#';
    detail::ios_fmtflags floatfield = flags & detail::ios_floatfield;
    bool uppercase                = (flags & detail::ios_uppercase) != 0;
    if (floatfield == (detail::ios_fixed | detail::ios_scientific))
      specify_precision = false;
    else {
      *fmtp++ = '.';
      *fmtp++ = '*';
    }
    while (*len)
      *fmtp++ = *len++;
    if (floatfield == detail::ios_fixed) {
      if (uppercase)
        *fmtp = 'F';
      else
        *fmtp = 'f';
    } else if (floatfield == detail::ios_scientific) {
      if (uppercase)
        *fmtp = 'E';
      else
        *fmtp = 'e';
    } else if (floatfield == (detail::ios_fixed | detail::ios_scientific)) {
      if (uppercase)
        *fmtp = 'A';
      else
        *fmtp = 'a';
    } else {
      if (uppercase)
        *fmtp = 'G';
      else
        *fmtp = 'g';
    }
    return specify_precision;
  }

  template <class IosBase>
  static char* identify_padding(char* nb, char* ne, const IosBase& iob) {
    switch (iob.flags() & detail::ios_adjustfield) {
    case detail::ios_internal:
      if (nb[0] == '-' || nb[0] == '+')
        return nb + 1;
      if (ne - nb >= 2 && nb[0] == '0' && (nb[1] == 'x' || nb[1] == 'X'))
        return nb + 2;
      break;
    case detail::ios_left:
      return ne;
    case detail::ios_right:
    default:
      break;
    }
    return nb;
  }
};

