template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_white_space(
    iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  for (; b != e && ct.is(ctype_base::space, *b); ++b)
    ;
