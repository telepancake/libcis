// time_get primitives

template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_weekdayname(
    int& w, iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  const string_type* wk = this->weeks();
  ptrdiff_t i           = detail::scan_keyword(b, e, wk, wk + 14, ct, err, false) - wk;
  if (i < 14)
    w = i % 7;
}

template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_monthname(
    int& m, iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  const string_type* month = this->months();
  ptrdiff_t i              = detail::scan_keyword(b, e, month, month + 24, ct, err, false) - month;
  if (i < 24)
    m = i % 12;
}

template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_day(
    int& d, iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  int t = detail::get_up_to_n_digits(b, e, err, ct, 2);
  if (!(err & detail::ios_failbit) && 1 <= t && t <= 31)
    d = t;
  else
    err |= detail::ios_failbit;
}

template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_month(
    int& m, iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  int t = detail::get_up_to_n_digits(b, e, err, ct, 2) - 1;
  if (!(err & detail::ios_failbit) && 0 <= t && t <= 11)
    m = t;
  else
    err |= detail::ios_failbit;
}

template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_year(
    int& y, iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  int t = detail::get_up_to_n_digits(b, e, err, ct, 4);
  if (!(err & detail::ios_failbit)) {
    if (t < 69)
      t += 2000;
    else if (69 <= t && t <= 99)
      t += 1900;
    y = t - 1900;
  }
}

template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_year4(
    int& y, iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  int t = detail::get_up_to_n_digits(b, e, err, ct, 4);
  if (!(err & detail::ios_failbit))
