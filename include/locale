template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_am_pm(
    int& h, iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  const string_type* ap = this->am_pm();
  if (ap[0].size() + ap[1].size() == 0) {
    err |= detail::ios_failbit;
    return;
  }
  ptrdiff_t i = detail::scan_keyword(b, e, ap, ap + 2, ct, err, false) - ap;
  if (i == 0 && h == 12)
    h = 0;
  else if (i == 1 && h < 12)
    h += 12;
}

template <class CharT, class InputIterator>
void time_get<CharT, InputIterator>::get_percent(
    iter_type& b, iter_type e, detail::ios_iostate& err, const ctype<char_type>& ct) const {
  if (b == e) {
    err |= detail::ios_eofbit | detail::ios_failbit;
    return;
  }
  if (ct.narrow(*b, 0) != '%')
    err |= detail::ios_failbit;
  else if (++b == e)
    err |= detail::ios_eofbit;
}

// time_get end primitives

template <class CharT, class InputIterator>
InputIterator time_get<CharT, InputIterator>::get(
    iter_type b,
    iter_type e,
    ios_base& iob,
    detail::ios_iostate& err,
    tm* t,
    const char_type* fmtb,
    const char_type* fmte) const {
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(iob.getloc());
  err                        = detail::ios_goodbit;
  while (fmtb != fmte && err == detail::ios_goodbit) {
    if (b == e) {
      err = detail::ios_failbit;
      break;
    }
    if (ct.narrow(*fmtb, 0) == '%') {
      if (++fmtb == fmte) {
        err = detail::ios_failbit;
        break;
      }
      char cmd = ct.narrow(*fmtb, 0);
      char opt = '\0';
      if (cmd == 'E' || cmd == '0') {
        if (++fmtb == fmte) {
          err = detail::ios_failbit;
          break;
        }
        opt = cmd;
        cmd = ct.narrow(*fmtb, 0);
      }
      b = do_get(b, e, iob, err, t, cmd, opt);
      ++fmtb;
    } else if (ct.is(ctype_base::space, *fmtb)) {
      for (++fmtb; fmtb != fmte && ct.is(ctype_base::space, *fmtb); ++fmtb)
        ;
      for (; b != e && ct.is(ctype_base::space, *b); ++b)
        ;
    } else if (ct.toupper(*b) == ct.toupper(*fmtb)) {
      ++b;
      ++fmtb;
    } else {
      // libcis: glibc's strptime is lenient about literal separators that are
      // absent from the input — e.g. zh_CN D_FMT "%Y年%m月%d日" parses
      // "2009年0610" (the 月 between month and day is simply omitted).  libc++'s
      // strict form would set failbit here; instead we skip the unmatched
      // format literal and keep parsing.  Whitespace and '%' directives are
      // handled by the branches above, so only true literal separators reach
      // this point; skipping them matches the glibc behaviour the byname
      // time_get tests (get_date / get_date_wide) expect.
      ++fmtb;
    }
  }
  if (b == e)
    err |= detail::ios_eofbit;
  return b;
}

