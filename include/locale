template<class CharT> class ctype;

template<>
class ctype<char> : public locale::facet, public ctype_base {
public:
    typedef char char_type;
    static locale::id id;

    static constexpr size_t table_size = 256;

    explicit ctype(const mask* tab = nullptr, bool del = false, size_t refs = 0)
        : locale::facet(refs), tab_(tab ? tab : classic_table()), del_(del) {}

    const mask* table() const noexcept { return tab_; }
    static const mask* classic_table() noexcept {
        static mask t[table_size];
        static bool init = false;
        if (!init) {
            for (int i = 0; i < (int)table_size; ++i) t[i] = classify((char)i);
            init = true;
        }
        return t;
    }

    ~ctype() override {
        if (del_ && tab_) delete[] tab_;
    }

    bool is(mask m, char c) const {
        return do_is(m, c);
    }
    const char* is(const char* lo, const char* hi, mask* vec) const {
        return do_is(lo, hi, vec);
    }
    const char* scan_is(mask m, const char* lo, const char* hi) const {
        return do_scan_is(m, lo, hi);
    }
    const char* scan_not(mask m, const char* lo, const char* hi) const {
        return do_scan_not(m, lo, hi);
    }
    char toupper(char c) const { return do_toupper(c); }
    const char* toupper(char* lo, const char* hi) const { return do_toupper(lo, hi); }
    char tolower(char c) const { return do_tolower(c); }
    const char* tolower(char* lo, const char* hi) const { return do_tolower(lo, hi); }
    char widen(char c) const { return do_widen(c); }
    const char* widen(const char* lo, const char* hi, char* to) const { return do_widen(lo, hi, to); }
    char narrow(char c, char dfault) const { return do_narrow(c, dfault); }
    const char* narrow(const char* lo, const char* hi, char dfault, char* to) const {
        return do_narrow(lo, hi, dfault, to);
    }

protected:
    virtual bool do_is(mask m, char c) const {
        return (classify(c) & m) != 0;
    }
    virtual const char* do_is(const char* lo, const char* hi, mask* vec) const {
        for (const char* p = lo; p != hi; ++p, ++vec)
            *vec = classify(*p);
        return hi;
    }
    virtual const char* do_scan_is(mask m, const char* lo, const char* hi) const {
        for (; lo != hi && !do_is(m, *lo); ++lo) {}
        return lo;
    }
    virtual const char* do_scan_not(mask m, const char* lo, const char* hi) const {
        for (; lo != hi && do_is(m, *lo); ++lo) {}
        return lo;
    }
    virtual char do_toupper(char c) const {
        return (char)::toupper((unsigned char)c);
    }
    virtual const char* do_toupper(char* lo, const char* hi) const {
        for (; lo != hi; ++lo) *lo = do_toupper(*lo);
        return hi;
    }
    virtual char do_tolower(char c) const {
        return (char)::tolower((unsigned char)c);
    }
    virtual const char* do_tolower(char* lo, const char* hi) const {
        for (; lo != hi; ++lo) *lo = do_tolower(*lo);
        return hi;
    }
    virtual char do_widen(char c) const { return c; }
    virtual const char* do_widen(const char* lo, const char* hi, char* to) const {
        for (; lo != hi; ++lo, ++to) *to = *lo;
        return hi;
    }
    virtual char do_narrow(char c, char /*dfault*/) const { return c; }
    virtual const char* do_narrow(const char* lo, const char* hi, char /*dfault*/, char* to) const {
        for (; lo != hi; ++lo, ++to) *to = *lo;
        return hi;
    }

private:
    static mask classify(char c) {
        unsigned char u = (unsigned char)c;
        mask m = 0;
        if (::isspace(u))  m |= space;
        if (::isprint(u))  m |= print;
        if (::iscntrl(u))  m |= cntrl;
        if (::isupper(u))  m |= upper;
        if (::islower(u))  m |= lower;
        if (::isalpha(u))  m |= alpha;
        if (::isdigit(u))  m |= digit;
        if (::ispunct(u))  m |= punct;
        if (::isxdigit(u)) m |= xdigit;
        if (::isblank(u))  m |= blank;
        return m;
    }

    const mask* tab_;
    bool del_;
};

