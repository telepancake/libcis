            uint8_t c2 = frm_nxt[1], c3 = frm_nxt[2];
            switch (c1) {
            case 0xE0: if ((c2 & 0xE0) != 0xA0) return static_cast<int>(frm_nxt - frm); break;
            case 0xED: if ((c2 & 0xE0) != 0x80) return static_cast<int>(frm_nxt - frm); break;
            default:   if ((c2 & 0xC0) != 0x80) return static_cast<int>(frm_nxt - frm); break;
