template <class CharT, class InputIterator>
InputIterator time_get<CharT, InputIterator>::do_get(
    iter_type b, iter_type e, ios_base& iob, detail::ios_iostate& err, tm* t, char fmt, char) const {
  err                        = detail::ios_goodbit;
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(iob.getloc());
  switch (fmt) {
  case 'a':
  case 'A':
    get_weekdayname(t->tm_wday, b, e, err, ct);
    break;
  case 'b':
  case 'B':
  case 'h':
    get_monthname(t->tm_mon, b, e, err, ct);
    break;
  case 'c': {
    const string_type& fm = this->c();
    b                     = get(b, e, iob, err, t, fm.data(), fm.data() + fm.size());
  } break;
  case 'd':
  case 'e':
    get_day(t->tm_mday, b, e, err, ct);
    break;
  case 'D': {
    const char_type fm[] = {'%', 'm', '/', '%', 'd', '/', '%', 'y'};
    b                    = get(b, e, iob, err, t, fm, fm + sizeof(fm) / sizeof(fm[0]));
  } break;
  case 'F': {
    const char_type fm[] = {'%', 'Y', '-', '%', 'm', '-', '%', 'd'};
    b                    = get(b, e, iob, err, t, fm, fm + sizeof(fm) / sizeof(fm[0]));
  } break;
  case 'H':
    get_hour(t->tm_hour, b, e, err, ct);
    break;
  case 'I':
    get_12_hour(t->tm_hour, b, e, err, ct);
    break;
  case 'j':
    get_day_year_num(t->tm_yday, b, e, err, ct);
    break;
  case 'm':
    get_month(t->tm_mon, b, e, err, ct);
    break;
  case 'M':
    get_minute(t->tm_min, b, e, err, ct);
    break;
  case 'n':
  case 't':
    get_white_space(b, e, err, ct);
    break;
  case 'p':
    get_am_pm(t->tm_hour, b, e, err, ct);
    break;
  case 'r': {
    const char_type fm[] = {'%', 'I', ':', '%', 'M', ':', '%', 'S', ' ', '%', 'p'};
    b                    = get(b, e, iob, err, t, fm, fm + sizeof(fm) / sizeof(fm[0]));
  } break;
  case 'R': {
    const char_type fm[] = {'%', 'H', ':', '%', 'M'};
    b                    = get(b, e, iob, err, t, fm, fm + sizeof(fm) / sizeof(fm[0]));
  } break;
  case 'S':
    get_second(t->tm_sec, b, e, err, ct);
    break;
  case 'T': {
    const char_type fm[] = {'%', 'H', ':', '%', 'M', ':', '%', 'S'};
    b                    = get(b, e, iob, err, t, fm, fm + sizeof(fm) / sizeof(fm[0]));
  } break;
  case 'w':
    get_weekday(t->tm_wday, b, e, err, ct);
    break;
  case 'x':
    return do_get_date(b, e, iob, err, t);
  case 'X': {
    const string_type& fm = this->X();
    b                     = get(b, e, iob, err, t, fm.data(), fm.data() + fm.size());
  } break;
  case 'y':
    get_year(t->tm_year, b, e, err, ct);
    break;
  case 'Y':
    get_year4(t->tm_year, b, e, err, ct);
    break;
  case '%':
    get_percent(b, e, err, ct);
    break;
  default:
    err |= detail::ios_failbit;
  }
  return b;
}

// time_get_byname<CharT,InputIterator>  (libc++ include/locale ~2004-2032)
// See header comment: byname uses the classic "C" storage; only date order
// is overridden (to mdy, the libc++ default for unanalyzed locales).
template <class CharT, class InputIterator = istreambuf_iterator<CharT> >
class time_get_byname : public time_get<CharT, InputIterator> {
public:
  typedef time_base::dateorder dateorder;
  typedef InputIterator iter_type;
  typedef CharT char_type;
  typedef basic_string<char_type> string_type;

  explicit time_get_byname(const char* nm, size_t refs = 0)
      : time_get<CharT, InputIterator>(refs) { init(nm); }
  explicit time_get_byname(const string& nm, size_t refs = 0)
      : time_get<CharT, InputIterator>(refs) { init(nm.c_str()); }

protected:
  ~time_get_byname() override {}

  // Storage overrides: locale-specific names/formats from nl_langinfo_l.
  const string_type* weeks() const override { return weeks_; }
  const string_type* months() const override { return months_; }
  const string_type* am_pm() const override { return am_pm_; }
  const string_type& c() const override { return c_; }
  const string_type& r() const override { return r_; }
  const string_type& x() const override { return x_; }
  const string_type& X() const override { return X_; }
  dateorder do_date_order() const override { return date_order_; }

private:
  string_type weeks_[14];
  string_type months_[24];
  string_type am_pm_[2];
  string_type c_, r_, x_, X_;
  dateorder date_order_ = time_base::mdy;

  // Convert a (possibly multibyte/UTF-8) nl_langinfo string to CharT, using
  // the named locale's encoding (so wchar_t gets real code points, not bytes).
  static string_type widen_str(const char* s, ::locale_t l) {
    string_type r;
    if (!s) return r;
    if constexpr (sizeof(CharT) == 1) {
      for (; *s; ++s) r.push_back(static_cast<CharT>(static_cast<unsigned char>(*s)));
    } else {
      detail::scoped_uselocale guard(l);
      ::mbstate_t st{};
      const char* p = s;
      size_t n = ::mbsrtowcs(nullptr, &p, 0, &st);
      if (n == (size_t)-1) { // fall back to byte copy
        for (const char* q = s; *q; ++q) r.push_back(static_cast<CharT>(static_cast<unsigned char>(*q)));
        return r;
      }
      wchar_t buf[256];
      ::mbstate_t st2{};
      p = s;
      size_t got = ::mbsrtowcs(buf, &p, n < 256 ? n : 255, &st2);
      for (size_t i = 0; i < got; ++i) r.push_back(static_cast<CharT>(buf[i]));
    }
    return r;
  }

  void init(const char* nm) {
    ::locale_t l = detail::make_locale(nm);
    // weeks: [0..6] full (Sunday..Saturday), [7..13] abbreviated
    static const int dayfull[7] = {DAY_1,DAY_2,DAY_3,DAY_4,DAY_5,DAY_6,DAY_7};
    static const int dayabbr[7] = {ABDAY_1,ABDAY_2,ABDAY_3,ABDAY_4,ABDAY_5,ABDAY_6,ABDAY_7};
    for (int i = 0; i < 7; ++i) {
      weeks_[i]     = widen_str(::nl_langinfo_l(dayfull[i], l), l);
      weeks_[i + 7] = widen_str(::nl_langinfo_l(dayabbr[i], l), l);
    }
    static const int monfull[12] = {MON_1,MON_2,MON_3,MON_4,MON_5,MON_6,MON_7,MON_8,MON_9,MON_10,MON_11,MON_12};
    static const int monabbr[12] = {ABMON_1,ABMON_2,ABMON_3,ABMON_4,ABMON_5,ABMON_6,ABMON_7,ABMON_8,ABMON_9,ABMON_10,ABMON_11,ABMON_12};
    for (int i = 0; i < 12; ++i) {
      months_[i]      = widen_str(::nl_langinfo_l(monfull[i], l), l);
      months_[i + 12] = widen_str(::nl_langinfo_l(monabbr[i], l), l);
    }
    am_pm_[0] = widen_str(::nl_langinfo_l(AM_STR, l), l);
    am_pm_[1] = widen_str(::nl_langinfo_l(PM_STR, l), l);
    c_ = widen_str(::nl_langinfo_l(D_T_FMT, l), l);
    r_ = widen_str(::nl_langinfo_l(T_FMT_AMPM, l), l);
    x_ = widen_str(::nl_langinfo_l(D_FMT, l), l);
    X_ = widen_str(::nl_langinfo_l(T_FMT, l), l);
    // Derive date order from D_FMT (look for first of d/m/y).
    {
      const char* f = ::nl_langinfo_l(D_FMT, l);
      char order[3]; int n = 0;
      for (const char* p = f; *p && n < 3; ++p) {
        if (*p != '%') continue;
        ++p;
        if (*p == 'd' || *p == 'e') order[n++] = 'd';
        else if (*p == 'm') order[n++] = 'm';
        else if (*p == 'y' || *p == 'Y') order[n++] = 'y';
      }
      if (n == 3) {
        if (order[0]=='d'&&order[1]=='m'&&order[2]=='y') date_order_ = time_base::dmy;
        else if (order[0]=='m'&&order[1]=='d'&&order[2]=='y') date_order_ = time_base::mdy;
        else if (order[0]=='y'&&order[1]=='m'&&order[2]=='d') date_order_ = time_base::ymd;
        else if (order[0]=='y'&&order[1]=='d'&&order[2]=='m') date_order_ = time_base::ydm;
      }
    }
    ::freelocale(l);
  }
};


// __time_put  (libc++ include/locale ~2039-2051; src/locale.cpp ~5045-5065)
namespace detail {

class time_put_base {
  ::locale_t loc_;

protected:
  time_put_base() : loc_((::locale_t)0) {}
  time_put_base(const char* nm) : loc_(detail::make_locale(nm)) {}
  time_put_base(const string& nm) : loc_(detail::make_locale(nm.c_str())) {}
  ~time_put_base() {
    if (loc_ != (::locale_t)0)
      ::freelocale(loc_);
  }

  void do_put(char* nb, char*& ne, const tm* t, char fmt, char mod) const {
    char f[] = {'%', fmt, mod, 0};
    if (mod != 0) {
      char tmp = f[1];
      f[1]     = f[2];
      f[2]     = tmp;
    }
    size_t n;
    if (loc_ != (::locale_t)0)
      n = ::strftime_l(nb, static_cast<size_t>(ne - nb), f, t, loc_);
    else
      n = ::strftime(nb, static_cast<size_t>(ne - nb), f, t);
    ne = nb + n;
  }

  void do_put(wchar_t* wb, wchar_t*& we, const tm* t, char fmt, char mod) const {
    char nar[100];
    char* ne = nar + 100;
    do_put(nar, ne, t, fmt, mod);
    mbstate_t mb     = mbstate_t();
    const char* nb   = nar;
    // Decode under loc_'s encoding (strftime_l produced bytes in that codeset,
    // e.g. UTF-8 month names); the C global locale may be "C" and would fail.
    size_t j;
    if (loc_ != (::locale_t)0) {
      detail::scoped_uselocale g(loc_);
      j = ::mbsrtowcs(wb, &nb, static_cast<size_t>(we - wb), &mb);
    } else {
      j = ::mbsrtowcs(wb, &nb, static_cast<size_t>(we - wb), &mb);
    }
    if (j == size_t(-1))
      __builtin_trap();
    we = wb + j;
  }
};

} // namespace detail

// time_put<CharT,OutputIterator>  (libc++ include/locale ~2053-2121)
template <class CharT, class OutputIterator = ostreambuf_iterator<CharT> >
class time_put : public locale::facet, private detail::time_put_base {
public:
  typedef CharT char_type;
  typedef OutputIterator iter_type;

  explicit time_put(size_t refs = 0) : locale::facet(refs) {}

  iter_type put(iter_type s, ios_base& iob, char_type fl, const tm* t, const char_type* pb, const char_type* pe) const;

  iter_type put(iter_type s, ios_base& iob, char_type fl, const tm* t, char fmt, char mod = 0) const {
    return do_put(s, iob, fl, t, fmt, mod);
  }

  static locale::id id;

protected:
  ~time_put() override {}
  virtual iter_type do_put(iter_type s, ios_base&, char_type, const tm* t, char fmt, char mod) const;

  explicit time_put(const char* nm, size_t refs) : locale::facet(refs), detail::time_put_base(nm) {}
  explicit time_put(const string& nm, size_t refs) : locale::facet(refs), detail::time_put_base(nm) {}
};

template <class CharT, class OutputIterator>
OutputIterator time_put<CharT, OutputIterator>::put(
    iter_type s, ios_base& iob, char_type fl, const tm* t, const char_type* pb, const char_type* pe) const {
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(iob.getloc());
  for (; pb != pe; ++pb) {
    if (ct.narrow(*pb, 0) == '%') {
      if (++pb == pe) {
        *s++ = pb[-1];
        break;
      }
      char mod = 0;
      char fmt = ct.narrow(*pb, 0);
      if (fmt == 'E' || fmt == 'O') {
        if (++pb == pe) {
          *s++ = pb[-2];
          *s++ = pb[-1];
          break;
        }
        mod = fmt;
        fmt = ct.narrow(*pb, 0);
      }
      s = do_put(s, iob, fl, t, fmt, mod);
    } else
      *s++ = *pb;
  }
  return s;
}

template <class CharT, class OutputIterator>
OutputIterator time_put<CharT, OutputIterator>::do_put(
    iter_type s, ios_base&, char_type, const tm* t, char fmt, char mod) const {
  char_type nar[100];
  char_type* nb = nar;
  char_type* ne = nb + 100;
  detail::time_put_base::do_put(nb, ne, t, fmt, mod);
  return std::copy(nb, ne, s);
}

