// UTF-8 → UCS-2 (uint16_t, no surrogates allowed)
inline codecvt_base::result utf8_to_ucs2(
    const uint8_t* frm, const uint8_t* frm_end, const uint8_t*& frm_nxt,
    uint16_t* to, uint16_t* to_end, uint16_t*& to_nxt,
    unsigned long Maxcode = 0x10FFFF, int mode = 0)
{
