// Out-of-line locale methods that depend on the byname facets defined above.
//===----------------------------------------------------------------------===//

// Placeholder category installers — filled in as money/time/messages facets
// are added.  Until then the classic facets (global registry) serve these
// categories for named locales.
// __install_monetary/time/messages are defined in src/support.cpp (where
// ios_base is complete): constructing the byname facets instantiates their
// virtual do_get/do_put bodies, which reference a complete std::ios_base that
// <locale> cannot see (the <ios>/<locale> include cycle).  Declarations only here.

// Build (or extend) this locale's imp with byname facets for `name` covering
// `cat`, inheriting other categories from `base` (or classic if base==nullptr).
inline void locale::__build_named(const char* name, category cat, const locale* base) {
    // Start from a fresh imp; copy base's per-locale overrides if present.
    imp* ni = new imp();
    ni->has_names = true;
    // Seed cat_names from base (or classic "C").
    const char* base_cat[6];
    for (int i = 0; i < 6; ++i) {
        if (base && base->imp_ && base->imp_->has_names)
            ni->cat_names[i] = base->imp_->cat_names[i];
        else if (base)
            ni->cat_names[i] = base->name_ == "*" ? "*" : base->name_;
        else
            ni->cat_names[i] = "C";
        base_cat[i] = nullptr;
    }
    // Copy facet overrides from base imp (shared, not owned).
    if (base && base->imp_) {
        for (size_t i = 0; i < imp::max_facets; ++i) {
            if (base->imp_->table[i]) {
                ni->table[i] = base->imp_->table[i];
                ni->owns[i]  = false;
                const_cast<facet*>(base->imp_->table[i])->refs_++;
            }
        }
    }
    string nm = name;
    bool isC = (nm == "C");
    // Install byname facets for the requested categories.
    auto inst = [&](size_t id, facet* f) { ni->install(id, f); };
    if (cat & collate) {
        ni->cat_names[0] = nm;
        if (!isC) {
            inst(std::collate<char>::id.__get(),    new collate_byname<char>(nm));
            inst(std::collate<wchar_t>::id.__get(), new collate_byname<wchar_t>(nm));
        }
    }
    if (cat & ctype) {
        ni->cat_names[1] = nm;
        if (!isC) {
            inst(std::ctype<char>::id.__get(),    new ctype_byname<char>(nm));
            inst(std::ctype<wchar_t>::id.__get(), new ctype_byname<wchar_t>(nm));
        }
    }
    if (cat & monetary) {
        ni->cat_names[2] = nm;
        __install_monetary(ni, nm.c_str(), isC);
    }
    if (cat & numeric) {
        ni->cat_names[3] = nm;
        if (!isC) {
            inst(std::numpunct<char>::id.__get(),    new numpunct_byname<char>(nm));
            inst(std::numpunct<wchar_t>::id.__get(), new numpunct_byname<wchar_t>(nm));
        }
    }
    if (cat & time) {
        ni->cat_names[4] = nm;
        __install_time(ni, nm.c_str(), isC);
    }
    if (cat & messages) {
        ni->cat_names[5] = nm;
        __install_messages(ni, nm.c_str(), isC);
    }
    // Replace our inherited imp with the new one.
    if (imp_ && imp_->release()) release_imp(imp_);
    imp_ = ni;
    name_ = __compose_name(ni->cat_names);
}

// Get the 6 per-category names of a locale.
inline void locale::__category_names(const locale& loc, string out[6]) {
    if (loc.imp_ && loc.imp_->has_names) {
        for (int i = 0; i < 6; ++i) out[i] = loc.imp_->cat_names[i];
    } else {
        string n = loc.name_;
        for (int i = 0; i < 6; ++i) out[i] = n;
    }
}

// Copy the facets belonging to `cat` from `src` into `ni` (shared, not owned).
inline void locale::__copy_category_facets(imp* ni, const locale& src, category cat) {
    // Enumerate the facet ids per category.
    auto cp = [&](size_t id) {
        const facet* f = src.__lookup_facet(id);
        if (!f) return;
        ni->table[id] = f; ni->owns[id] = false;
        const_cast<facet*>(f)->refs_++;
    };
    if (cat & collate) { cp(std::collate<char>::id.__get()); cp(std::collate<wchar_t>::id.__get()); }
    if (cat & ctype) {
        cp(std::ctype<char>::id.__get()); cp(std::ctype<wchar_t>::id.__get());
        cp(std::codecvt<char, char, mbstate_t>::id.__get());
        cp(std::codecvt<wchar_t, char, mbstate_t>::id.__get());
        cp(std::codecvt<char16_t, char, mbstate_t>::id.__get());
        cp(std::codecvt<char32_t, char, mbstate_t>::id.__get());
    }
    if (cat & numeric) { cp(std::numpunct<char>::id.__get()); cp(std::numpunct<wchar_t>::id.__get()); }
    // monetary/time/messages facets copied once those facets exist (TODO).
}

// Compose the POSIX-style locale name from per-category names.
inline string locale::__compose_name(const string* cn) {
    // If any category is "*" the whole locale is unnamed.
    for (int i = 0; i < 6; ++i) if (cn[i] == "*") return "*";
    bool same = true;
    for (int i = 1; i < 6; ++i) if (cn[i] != cn[0]) { same = false; break; }
    if (same) return cn[0];
    // LC_CTYPE order per glibc/libc++: collate? libc++ uses fixed order.
    static const char* lbl[6] = {
        "LC_COLLATE=", "LC_CTYPE=", "LC_MONETARY=", "LC_NUMERIC=", "LC_TIME=", "LC_MESSAGES="
    };
    string r;
    for (int i = 0; i < 6; ++i) {
        r += lbl[i]; r += cn[i]; r += ';';
    }
    if (!r.empty()) r.pop_back();
    return r;
}

inline string locale::name() const {
    if (imp_ && imp_->has_names) return __compose_name(imp_->cat_names);
    return name_;
}

// locale(other, one, cats): replace the cats categories of `other` with the
// corresponding facets and category-names of `one`.
inline locale::locale(const locale& other, const locale& one, category cat)
    : locale(other) {
    imp* ni = new imp();
    ni->has_names = true;
    // Seed from `other` (names + facet overrides).
    string oc[6], onec[6];
    __category_names(other, oc);
    __category_names(one, onec);
    for (int i = 0; i < 6; ++i) ni->cat_names[i] = oc[i];
    // copy other's facet overrides
    if (other.imp_) {
        for (size_t i = 0; i < imp::max_facets; ++i)
            if (other.imp_->table[i]) {
                ni->table[i] = other.imp_->table[i]; ni->owns[i] = false;
                const_cast<facet*>(other.imp_->table[i])->refs_++;
            }
    }
    // For each selected category, take facets+name from `one`.
    if (cat != none) {
        static const category cats[6] = { collate, ctype, monetary, numeric, time, messages };
        for (int i = 0; i < 6; ++i) {
            if (!(cat & cats[i])) continue;
            ni->cat_names[i] = onec[i];
            __copy_category_facets(ni, one, cats[i]);
        }
    }
    if (imp_ && imp_->release()) release_imp(imp_);
    imp_ = ni;
    // [locale.cons]p3: the result is named only if BOTH operands are named.
    if (other.name() == "*" || one.name() == "*") {
        ni->has_names = false;   // name() will fall back to name_
        name_ = "*";
    } else {
        name_ = __compose_name(ni->cat_names);
    }
}

