        : byte_err_string_(std::move(wc.byte_err_string_)),
          wide_err_string_(std::move(wc.wide_err_string_)),
          cvtptr_(wc.cvtptr_), cvtstate_(wc.cvtstate_), cvtcount_(wc.cvtcount_) {
        wc.cvtptr_ = nullptr;
    }
