            uint16_t t = static_cast<uint16_t>(((c1 & 0x0F) << 12) | ((c2 & 0x3F) << 6) | (c3 & 0x3F));
            if (t > Maxcode) return codecvt_base::error;
            *to_nxt = t; frm_nxt += 3;
