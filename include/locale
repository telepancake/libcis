template <class T>
T num_get_signed_integral(const char* a, const char* a_end, detail::ios_iostate& err, int base) {
  if (a != a_end) {
    typename remove_reference<decltype(errno)>::type save_errno = errno;
    errno                                                       = 0;
    char* p2;
    long long ll = std::strtoll(a, &p2, base);
    typename remove_reference<decltype(errno)>::type current_errno = errno;
    if (current_errno == 0)
      errno = save_errno;
    if (p2 != a_end) {
      err = detail::ios_failbit;
      return 0;
    } else if (current_errno == ERANGE || ll < numeric_limits<T>::min() || numeric_limits<T>::max() < ll) {
      err = detail::ios_failbit;
      if (ll > 0)
        return numeric_limits<T>::max();
      else
        return numeric_limits<T>::min();
    }
    return static_cast<T>(ll);
  }
  err = detail::ios_failbit;
  return 0;
}

template <class T>
T num_get_unsigned_integral(const char* a, const char* a_end, detail::ios_iostate& err, int base) {
  if (a != a_end) {
    const bool negate = *a == '-';
    if (negate && ++a == a_end) {
      err = detail::ios_failbit;
      return 0;
    }
    typename remove_reference<decltype(errno)>::type save_errno = errno;
    errno                                                       = 0;
    char* p2;
    unsigned long long ll = std::strtoull(a, &p2, base);
    typename remove_reference<decltype(errno)>::type current_errno = errno;
    if (current_errno == 0)
      errno = save_errno;
    if (p2 != a_end) {
      err = detail::ios_failbit;
      return 0;
    } else if (current_errno == ERANGE || numeric_limits<T>::max() < ll) {
      err = detail::ios_failbit;
      return numeric_limits<T>::max();
    }
    T res = static_cast<T>(ll);
    if (negate)
      res = -res;
    return res;
  }
  err = detail::ios_failbit;
  return 0;
}

template <class T>
T do_strtod(const char* a, char** p2);
template <>
inline float do_strtod<float>(const char* a, char** p2) { return std::strtof(a, p2); }
template <>
inline double do_strtod<double>(const char* a, char** p2) { return std::strtod(a, p2); }
template <>
inline long double do_strtod<long double>(const char* a, char** p2) { return std::strtold(a, p2); }

template <class T>
T num_get_float(const char* a, const char* a_end, detail::ios_iostate& err) {
  if (a != a_end) {
    typename remove_reference<decltype(errno)>::type save_errno = errno;
    errno                                                       = 0;
