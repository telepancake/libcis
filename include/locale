      sn  = mp.positive_sign();
    }
    dp  = mp.decimal_point();
    ts  = mp.thousands_sep();
    grp = mp.grouping();
    sym = mp.curr_symbol();
    fd  = mp.frac_digits();
  } else {
    const moneypunct<char_type, false>& mp = std::use_facet<moneypunct<char_type, false> >(loc);
    if (neg) {
      pat = mp.neg_format();
      sn  = mp.negative_sign();
    } else {
      pat = mp.pos_format();
      sn  = mp.positive_sign();
    }
    dp  = mp.decimal_point();
    ts  = mp.thousands_sep();
    grp = mp.grouping();
    sym = mp.curr_symbol();
    fd  = mp.frac_digits();
  }
}

template <class CharT>
void money_put_base<CharT>::format(
    char_type* mb,
    char_type*& mi,
    char_type*& me,
    detail::ios_fmtflags flags,
    const char_type* db,
    const char_type* de,
    const ctype<char_type>& ct,
    bool neg,
    const money_base::pattern& pat,
    char_type dp,
    char_type ts,
    const string& grp,
    const string_type& sym,
    const string_type& sn,
    int fd) {
  me = mb;
  for (char p : pat.field) {
    switch (p) {
    case money_base::none:
      mi = me;
      break;
    case money_base::space:
      mi    = me;
      *me++ = ct.widen(' ');
      break;
    case money_base::sign:
      if (!sn.empty())
        *me++ = sn[0];
      break;
    case money_base::symbol:
      if (!sym.empty() && (flags & detail::ios_showbase))
        me = std::copy(sym.begin(), sym.end(), me);
      break;
    case money_base::value: {
      char_type* t = me;
      if (neg)
        ++db;
      const char_type* d;
      for (d = db; d < de; ++d)
        if (!ct.is(ctype_base::digit, *d))
          break;
      if (fd > 0) {
        int f;
        for (f = fd; d > db && f > 0; --f)
          *me++ = *--d;
        char_type z = f > 0 ? ct.widen('0') : char_type();
        for (; f > 0; --f)
          *me++ = z;
        *me++ = dp;
      }
      if (d == db) {
        *me++ = ct.widen('0');
      } else {
        unsigned ng = 0;
        unsigned ig = 0;
        unsigned gl = grp.empty() ? numeric_limits<unsigned>::max() : static_cast<unsigned>(grp[ig]);
        while (d != db) {
          if (ng == gl) {
            *me++ = ts;
            ng    = 0;
            if (++ig < grp.size())
              gl = grp[ig] == numeric_limits<char>::max()
                       ? numeric_limits<unsigned>::max()
                       : static_cast<unsigned>(grp[ig]);
          }
          *me++ = *--d;
          ++ng;
        }
      }
      std::reverse(t, me);
    } break;
    }
  }
  if (sn.size() > 1)
    me = std::copy(sn.begin() + 1, sn.end(), me);
  if ((flags & detail::ios_adjustfield) == detail::ios_left)
    mi = me;
  else if ((flags & detail::ios_adjustfield) != detail::ios_internal)
    mi = mb;
}

template <class CharT, class OutputIterator = ostreambuf_iterator<CharT> >
class money_put : public locale::facet, private money_put_base<CharT> {
public:
  typedef CharT char_type;
  typedef OutputIterator iter_type;
  typedef basic_string<char_type> string_type;

  explicit money_put(size_t refs = 0) : locale::facet(refs) {}

  iter_type put(iter_type s, bool intl, ios_base& iob, char_type fl, long double units) const {
    return do_put(s, intl, iob, fl, units);
  }

  iter_type put(iter_type s, bool intl, ios_base& iob, char_type fl, const string_type& digits) const {
    return do_put(s, intl, iob, fl, digits);
  }

  static locale::id id;

protected:
  ~money_put() override {}

  virtual iter_type do_put(iter_type s, bool intl, ios_base& iob, char_type fl, long double units) const;
  virtual iter_type do_put(iter_type s, bool intl, ios_base& iob, char_type fl, const string_type& digits) const;
};

template <class CharT, class OutputIterator>
locale::id money_put<CharT, OutputIterator>::id;

template <class CharT, class OutputIterator>
OutputIterator money_put<CharT, OutputIterator>::do_put(
    iter_type s, bool intl, ios_base& iob, char_type fl, long double units) const {
  const size_t bs = 100;
  char buf[bs];
  char* bb = buf;
  char_type digits[bs];
  char_type* db = digits;
  int n         = snprintf(bb, bs, "%.0Lf", units);
  unique_ptr<char, void (*)(void*)> hn(nullptr, free);
  unique_ptr<char_type, void (*)(void*)> hd(0, free);
  if (static_cast<size_t>(n) > bs - 1) {
    hn.reset((char*)malloc(static_cast<size_t>(n) + 1));
    if (hn.get() == nullptr)
      __builtin_trap();
    bb = hn.get();
    snprintf(bb, static_cast<size_t>(n) + 1, "%.0Lf", units);
    hd.reset((char_type*)malloc(static_cast<size_t>(n) * sizeof(char_type)));
    if (hd == nullptr)
      __builtin_trap();
    db = hd.get();
  }
  locale loc                 = iob.getloc();
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(loc);
  ct.widen(bb, bb + n, db);
  bool neg = n > 0 && bb[0] == '-';
  money_base::pattern pat;
  char_type dp;
  char_type ts;
  string grp;
  string_type sym;
  string_type sn;
  int fd;
  this->gather_info(intl, neg, loc, pat, dp, ts, grp, sym, sn, fd);
  char_type mbuf[bs];
  char_type* mb = mbuf;
  unique_ptr<char_type, void (*)(void*)> hw(0, free);
  size_t exn = n > fd ? (static_cast<size_t>(n) - static_cast<size_t>(fd)) * 2 + sn.size() + sym.size() +
                            static_cast<size_t>(fd) + 1
                      : sn.size() + sym.size() + static_cast<size_t>(fd) + 2;
  if (exn > bs) {
    hw.reset((char_type*)malloc(exn * sizeof(char_type)));
    mb = hw.get();
    if (mb == 0)
      __builtin_trap();
  }
  char_type* mi;
  char_type* me;
  this->format(mb, mi, me, iob.flags(), db, db + n, ct, neg, pat, dp, ts, grp, sym, sn, fd);
  return detail::money_pad_and_output(s, mb, mi, me, iob, fl);
}

template <class CharT, class OutputIterator>
OutputIterator money_put<CharT, OutputIterator>::do_put(
    iter_type s, bool intl, ios_base& iob, char_type fl, const string_type& digits) const {
  locale loc                 = iob.getloc();
  const ctype<char_type>& ct = std::use_facet<ctype<char_type> >(loc);
  bool neg                   = digits.size() > 0 && digits[0] == ct.widen('-');
  money_base::pattern pat;
  char_type dp;
  char_type ts;
  string grp;
  string_type sym;
  string_type sn;
  int fd;
  this->gather_info(intl, neg, loc, pat, dp, ts, grp, sym, sn, fd);
  char_type mbuf[100];
  char_type* mb = mbuf;
  unique_ptr<char_type, void (*)(void*)> h(0, free);
  size_t exn =
      static_cast<int>(digits.size()) > fd
          ? (digits.size() - static_cast<size_t>(fd)) * 2 + sn.size() + sym.size() + static_cast<size_t>(fd) + 1
          : sn.size() + sym.size() + static_cast<size_t>(fd) + 2;
  if (exn > 100) {
    h.reset((char_type*)malloc(exn * sizeof(char_type)));
    mb = h.get();
    if (mb == 0)
      __builtin_trap();
  }
  char_type* mi;
  char_type* me;
  this->format(
      mb, mi, me, iob.flags(), digits.data(), digits.data() + digits.size(), ct, neg, pat, dp, ts, grp, sym, sn, fd);
  return detail::money_pad_and_output(s, mb, mi, me, iob, fl);
}


//=== time_get / time_put / messages (ported fragment) ===

// ===========================================================================
// time_get / time_put / messages facets — libcis port
//
// Ported mechanically from LLVM libc++ (release/20.x):
//   include/locale:
//     __scan_keyword                              : ~257-370
//     __get_up_to_n_digits                        : ~1407-1432
//     time_base                                   : ~1434-1437
//     __time_get_c_storage<CharT> (decl)          : ~1440-1485
//     time_get<CharT,InputIterator> + primitives  : ~1487-1936
//     __time_get_storage / time_get_byname        : ~1943-2037
//     __time_put / time_put / time_put_byname     : ~2039-2145
//     messages_base / messages / messages_byname  : ~2975-3075
//   src/locale.cpp:
//     __time_get_c_storage<char>/<wchar_t> classic "C" data : ~4228-4441
//     __time_put::__do_put (strftime)             : ~5045-5065
//
// Conventions applied (CONVENTIONS.md):
//   - all leading/trailing underscores stripped
//   - _LIBCPP_* macros deleted; _NOEXCEPT->noexcept; _VSTD::->std::
//   - internal helpers live in `namespace detail`
//   - -fno-exceptions: __throw_bad_alloc()/__throw_runtime_error() -> __builtin_trap()
//   - discarded comma exprs guarded with (void) (as in libc++)
//
// Out-of-line static `id` definitions are at the bottom of this fragment.
//
// Deviations from libc++ (and why):
//   - __time_get_storage / __time_get (nl_langinfo-based byname *data*) is NOT
//     ported: it requires libc++'s private __locale nl_langinfo plumbing that
//     libcis does not expose. time_get_byname therefore inherits the classic
//     "C" storage from time_get/__time_get_c_storage and overrides only
//     do_date_order() to return time_base::mdy. Date PARSING for byname locales
//     thus uses the "C" names. Faithful parsing machinery (do_get*/get/helpers)
//     is ported in full.
//   - __time_put::__do_put: classic facet uses strftime() on the C locale;
//     byname uses strftime_l(...) with detail::make_locale(name), per task.
//     The wchar_t __do_put path is implemented inline via mbsrtowcs (libc++
//     src/locale.cpp:5054), trapping on conversion failure.
//   - messages: the classic trivial facet (do_open returns -1, do_get returns
//     dflt, do_close no-op), matching libc++'s !_LIBCPP_HAS_CATOPEN path.
// ===========================================================================

namespace detail {

// NOTE: detail::scan_keyword already exists in libcis <locale>; reused, not redefined.

// __get_up_to_n_digits  (libc++ include/locale ~1407-1432)
template <class CharT, class InputIterator>
int get_up_to_n_digits(
    InputIterator& b, InputIterator e, detail::ios_iostate& err, const ctype<CharT>& ct, int n) {
  // Precondition:  n >= 1
  if (b == e) {
    err |= detail::ios_eofbit | detail::ios_failbit;
    return 0;
  }
  // get first digit
  CharT c = *b;
  if (!ct.is(ctype_base::digit, c)) {
    err |= detail::ios_failbit;
    return 0;
  }
  int r = ct.narrow(c, 0) - '0';
  for (++b, (void)--n; b != e && n > 0; ++b, (void)--n) {
    // get next digit
    c = *b;
    if (!ct.is(ctype_base::digit, c))
      return r;
    r = r * 10 + ct.narrow(c, 0) - '0';
  }
  if (b == e)
    err |= detail::ios_eofbit;
  return r;
}

} // namespace detail

