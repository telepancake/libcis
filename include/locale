~codecvt() override = default;

protected:

    virtual result do_out(state_type&, const intern_type* frm, const intern_type*,
                          const intern_type*& frm_nxt, extern_type* to, extern_type*,
                          extern_type*& to_nxt) const {
        frm_nxt = frm; to_nxt = to; return noconv;
    }
    virtual result do_in(state_type&, const extern_type* frm, const extern_type*,
                         const extern_type*& frm_nxt, intern_type* to, intern_type*,
                         intern_type*& to_nxt) const {
        frm_nxt = frm; to_nxt = to; return noconv;
    }
