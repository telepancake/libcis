template<class CharT> class numpunct;

template<>
class numpunct<char> : public locale::facet {
public:
    typedef char char_type;
    static locale::id id;

    explicit numpunct(size_t refs = 0) : locale::facet(refs) {}

    typedef string string_type;

    char decimal_point()  const { return do_decimal_point(); }
    char thousands_sep()  const { return do_thousands_sep(); }
    string grouping()     const { return do_grouping(); }
    string truename()     const { return do_truename(); }
    string falsename()    const { return do_falsename(); }

protected:
    virtual char do_decimal_point() const { return '.'; }
    virtual char do_thousands_sep() const { return ','; }
    // "C" locale: empty grouping = no grouping; "true"/"false".
    virtual string do_grouping()  const { return string(); }
    virtual string do_truename()  const { return string("true"); }
    virtual string do_falsename() const { return string("false"); }
};

inline locale::id numpunct<char>::id;

