    const locale& loc,
    money_base::pattern& pat,
    char_type& dp,
    char_type& ts,
    string& grp,
    string_type& sym,
    string_type& sn,
    int& fd) {
  if (intl) {
    const moneypunct<char_type, true>& mp = std::use_facet<moneypunct<char_type, true> >(loc);
    if (neg) {
      pat = mp.neg_format();
      sn  = mp.negative_sign();
