      buf.resize(2 * buf.size());
      buf.resize(buf.capacity());
      a     = &buf[0];
      a_end = a + tmp;
    }
    if (this->stage2_int_loop(*b, base, a, a_end, dc, thousands_sep, grouping, g, g_end, atoms))
      break;
  }
  buf.resize(a_end - a);
  if (std::sscanf(buf.c_str(), "%p", &v) != 1)
    err = detail::ios_failbit;
  if (b == e)
    err |= detail::ios_eofbit;
  return b;
}

