// <any> — type-erased value container (no-RTTI variant)
// Mechanically ported from libc++ include/any.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Type identity for any_cast is performed via a per-type static int address
// (value_type_id<T>::id, in <bits/value_ops.h>) instead of typeid(). This is
// the no-RTTI path: type comparison uses pointer identity rather than the
// RTTI runtime.
//
// any::type() is OMITTED — it returns a type_info reference which requires
// RTTI. The member traps on call.
//
// bad_any_cast: kept as a type deriving from std::exception. Under
// -fno-exceptions a failed any_cast (value form) calls __builtin_trap()
// instead of throwing.
//
// Type erasure layer (stage 2 of the cores design, notes/cores-design.md §6):
// the per-T SmallHandler/LargeHandler with an Action-enum switch is gone.
// Each any holds a `const detail::value_ops*` instead of a HandleFuncPtr, and
// the five lifecycle modifiers (reset / copy ctor / move ctor / swap /
// any_cast pointer form) call the matching slot on the vocab table directly.
// See bits/value_ops.h for the small-vs-large storage convention the slots
// follow.
#pragma once

#include <type_traits>
#include <utility>
#include <new>
#include <typeinfo>   // type_info (for any::type()'s signature)
#include <initializer_list>
#include <functional>
#include <exception>
#include <bits/value_ops.h>

namespace std {

//===----------------------------------------------------------------------===//
// bad_any_cast
//===----------------------------------------------------------------------===//

class bad_any_cast : public exception {
public:
    bad_any_cast() noexcept                              = default;
    bad_any_cast(const bad_any_cast&) noexcept           = default;
    bad_any_cast& operator=(const bad_any_cast&) noexcept = default;
    ~bad_any_cast() noexcept override                    = default;
    [[nodiscard]] const char* what() const noexcept override {
        return "bad_any_cast";
    }
};

// Under -fno-exceptions: trap instead of throwing bad_any_cast.
[[noreturn]] inline void throw_bad_any_cast() noexcept {
    // Would throw bad_any_cast() under -fexceptions.
    __builtin_trap();
}

// Helper: detect in_place_type_t specialisations (needed before any class).
namespace any_imp {
    template<class T> struct is_inplace_type      : false_type {};
    template<class T> struct is_inplace_type<in_place_type_t<T>> : true_type {};
} // namespace any_imp

template<class T>
struct is_specialization_of_in_place_type
    : any_imp::is_inplace_type<remove_cvref_t<T>> {};

// Forward declarations
class any;

template<class V> add_pointer_t<add_const_t<V>> any_cast(const any*) noexcept;
template<class V> add_pointer_t<V>               any_cast(any*) noexcept;

//===----------------------------------------------------------------------===//
// any
//===----------------------------------------------------------------------===//
//
// Layout: three storage words (the Storage union — used inline for "small" T
// and as a single ptr for "large" T) plus one `const value_ops*` vocab
// pointer. Identical to the pre-stage-2 layout; HandleFuncPtr -> value_ops*
// is a name + type change at this slot, not a layout change.
//
// The small/large policy is the value_ops's: a T qualifies for inline storage
// iff `detail::value_is_small<T>` (size + alignment fit, noexcept move ctor).
// The vocab table records this in its `flags & vf_is_small`, and any_cast
// reads that bit to pick `&s_` (small) vs `s_.ptr` (large) when returning
// the stored object's address.

class any {
public:
    // --- construct / destruct ---
    constexpr any() noexcept : v_(nullptr) {}

    any(const any& other) : v_(nullptr) {
        if (other.v_) {
            other.v_->copy_construct(&s_, &other.s_);
            v_ = other.v_;
        }
    }

    any(any&& other) noexcept : v_(nullptr) {
        if (other.v_) {
            other.v_->move_construct(&s_, &other.s_);
            v_       = other.v_;
            other.v_ = nullptr;
        }
    }

    template<class V,
             class T = decay_t<V>,
             class = enable_if_t<!is_same_v<T, any> &&
                                 !is_specialization_of_in_place_type<V>::value &&
                                 is_copy_constructible_v<T>>>
    any(V&& v) : v_(nullptr) {
        create<T>(std::forward<V>(v));
    }

    template<class V, class... Args,
             class T = decay_t<V>,
             class = enable_if_t<is_constructible_v<T, Args...> &&
                                 is_copy_constructible_v<T>>>
    explicit any(in_place_type_t<V>, Args&&... args) : v_(nullptr) {
        create<T>(std::forward<Args>(args)...);
    }

    template<class V, class U, class... Args,
             class T = decay_t<V>,
             class = enable_if_t<is_constructible_v<T, initializer_list<U>&, Args...> &&
                                 is_copy_constructible_v<T>>>
    explicit any(in_place_type_t<V>, initializer_list<U> il, Args&&... args) : v_(nullptr) {
        create<T>(il, std::forward<Args>(args)...);
    }

    ~any() { reset(); }

    // --- assignments ---
    any& operator=(const any& rhs) {
        any(rhs).swap(*this);
        return *this;
    }

    any& operator=(any&& rhs) noexcept {
        any(move(rhs)).swap(*this);
        return *this;
    }

    template<class V,
             class T = decay_t<V>,
             class = enable_if_t<!is_same_v<T, any> && is_copy_constructible_v<T>>>
    any& operator=(V&& rhs) {
        any(std::forward<V>(rhs)).swap(*this);
        return *this;
    }

    // --- modifiers ---
    template<class V, class... Args,
             class T = decay_t<V>,
             class = enable_if_t<is_constructible_v<T, Args...> &&
                                 is_copy_constructible_v<T>>>
    T& emplace(Args&&... args) {
        reset();
        return create<T>(std::forward<Args>(args)...);
    }

    template<class V, class U, class... Args,
             class T = decay_t<V>,
             class = enable_if_t<is_constructible_v<T, initializer_list<U>&, Args...> &&
                                 is_copy_constructible_v<T>>>
    T& emplace(initializer_list<U> il, Args&&... args) {
        reset();
        return create<T>(il, std::forward<Args>(args)...);
    }

    void reset() noexcept {
        if (v_) {
            v_->destroy(&s_);
            v_ = nullptr;
        }
    }

    void swap(any& rhs) noexcept {
        if (this == &rhs) return;
        if (v_ && rhs.v_) {
            // Three-step swap via a temporary, exactly as the previous
            // handler-based implementation did. Each move_construct call
            // also tears down its source half (the small leaf runs the
            // source dtor; the large leaf nulls the source ptr).
            any tmp;
            rhs.v_->move_construct(&tmp.s_, &rhs.s_);
            tmp.v_ = rhs.v_;
            rhs.v_ = nullptr;
            this->v_->move_construct(&rhs.s_, &this->s_);
            rhs.v_ = this->v_;
            this->v_ = nullptr;
            tmp.v_->move_construct(&this->s_, &tmp.s_);
            this->v_ = tmp.v_;
            tmp.v_ = nullptr;
        } else if (v_) {
            this->v_->move_construct(&rhs.s_, &this->s_);
            rhs.v_ = this->v_;
            this->v_ = nullptr;
        } else if (rhs.v_) {
            rhs.v_->move_construct(&this->s_, &rhs.s_);
            this->v_ = rhs.v_;
            rhs.v_ = nullptr;
        }
    }

    // --- observers ---
    [[nodiscard]] bool has_value() const noexcept { return v_ != nullptr; }

    // type() exists for the API surface ([any.observers]): the transferred
    // tests excise every evaluated use (rtti untestable on target) but still
    // check its declaration via unevaluated contexts (ASSERT_NOEXCEPT).
    // Under -fno-rtti there is no typeid to return, so calling it traps —
    // same convention as the library's other would-throw paths.
    [[nodiscard]] const type_info& type() const noexcept {
        __builtin_trap();   // would return typeid(T); impossible without RTTI
    }

private:
    // Storage: three ptr-sized slots, picked up as either the inline buffer
    // (small T) or a single owning pointer (large T). Layout pinned by
    // value_ops's small/large policy (bits/value_ops.h).
    union Storage {
        constexpr Storage() : ptr(nullptr) {}
        void* ptr;
        alignas(detail::value_small_alignment) char buf[detail::value_small_size];
    };

    // create<T>(args...) — emplace a freshly-constructed T (either inline at
    // &s_ or on the heap with s_.ptr pointing at it) and install the per-T
    // value_ops. Mirrors the SmallHandler::create / LargeHandler::create
    // split from before, but the small/large branch is on a constexpr
    // predicate (no Handler conditional_t alias).
    template<class T, class... Args>
    T& create(Args&&... args) {
        T* p;
        if constexpr (detail::value_is_small<T>) {
            p = ::new (static_cast<void*>(&s_.buf)) T(std::forward<Args>(args)...);
        } else {
            p = new T(std::forward<Args>(args)...);
            s_.ptr = p;
        }
        v_ = &detail::value_ops_for<T>;
        return *p;
    }

    template<class V> friend add_pointer_t<add_const_t<V>> any_cast(const any*) noexcept;
    template<class V> friend add_pointer_t<V>               any_cast(any*) noexcept;

    // Vocab pointer — the per-T value_ops table. Null when empty.
    const detail::value_ops* v_ = nullptr;
    Storage                  s_;
};

//===----------------------------------------------------------------------===//
// Non-member functions
//===----------------------------------------------------------------------===//

inline void swap(any& x, any& y) noexcept { x.swap(y); }

template<class T, class... Args>
[[nodiscard]] inline any make_any(Args&&... args) {
    return any(in_place_type<T>, std::forward<Args>(args)...);
}

template<class T, class U, class... Args>
[[nodiscard]] inline any make_any(initializer_list<U> il, Args&&... args) {
    return any(in_place_type<T>, il, std::forward<Args>(args)...);
}

// Pointer forms — return nullptr on type mismatch (no-throw, no RTTI needed).
//
// The type check is `a->v_->type_id == &detail::value_type_id<V>::id`. When
// it matches, the stored object's address is `&a->s_` for a small T (the
// inline buffer is the object) and `a->s_.ptr` for a large T (the storage
// holds the heap pointer); `v_->flags & vf_is_small` picks the right one.
template<class V>
[[nodiscard]] inline add_pointer_t<V> any_cast(any* a) noexcept {
    static_assert(!is_void_v<V>,      "V may not be void");
    static_assert(!is_reference_v<V>, "V may not be a reference");
    // Strip cv on the lookup key: a stored Type matches a lookup of `Type
    // const`, `Type const volatile`, etc. (Matches the prior get_fallback_
    // typeid<V> behaviour, which did remove_cv_t<remove_reference_t<V>>.)
    using Key = remove_cv_t<V>;
    if (a && a->v_ && a->v_->type_id == &detail::value_type_id<Key>::id) {
        void* p = (a->v_->flags & detail::vf_is_small)
                      ? static_cast<void*>(&a->s_)
                      : a->s_.ptr;
        // An any can never store a function type, but any_cast<void()> must
        // still compile and yield nullptr: static_cast from void* to a
        // function pointer is ill-formed, so dispatch like libc++'s
        // __pointer_or_func_cast instead of casting unconditionally.
        if constexpr (is_function_v<V>)
            return nullptr;
        else
            return static_cast<add_pointer_t<V>>(p);
    }
    return nullptr;
}

template<class V>
[[nodiscard]] inline add_pointer_t<add_const_t<V>> any_cast(const any* a) noexcept {
    return any_cast<V>(const_cast<any*>(a));
}

// Value forms — trap on mismatch (no exceptions).
template<class V>
[[nodiscard]] inline V any_cast(const any& a) {
    using R = remove_cvref_t<V>;
    static_assert(is_constructible_v<V, const R&>,
                  "V must be constructible from const R&");
    const R* p = any_cast<R>(&a);
    if (!p) throw_bad_any_cast();
    return static_cast<V>(*p);
}

template<class V>
[[nodiscard]] inline V any_cast(any& a) {
    using R = remove_cvref_t<V>;
    static_assert(is_constructible_v<V, R&>,
                  "V must be constructible from R&");
    R* p = any_cast<R>(&a);
    if (!p) throw_bad_any_cast();
    return static_cast<V>(*p);
}

template<class V>
[[nodiscard]] inline V any_cast(any&& a) {
    using R = remove_cvref_t<V>;
    static_assert(is_constructible_v<V, R>,
                  "V must be constructible from R");
    R* p = any_cast<R>(&a);
    if (!p) throw_bad_any_cast();
    return static_cast<V>(move(*p));
}

} // namespace std
