//===----------------------------------------------------------------------===//
// is_function (is_function.h)
// __is_function NOT in gcc-10.2.
// Standard trick: T is a function iff const T is NOT const (functions can't
// be const-qualified) AND T is not a reference.
//===----------------------------------------------------------------------===//
template<class T>
inline constexpr bool is_function_v = !is_const_v<const T> && !is_reference_v<T>;
template<class T>
struct is_function : bool_constant<is_function_v<T>> {};

