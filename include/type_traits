// is_nothrow_destructible (is_nothrow_destructible.h)
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T> constexpr bool compute_is_nothrow_destructible() {
        if constexpr (is_lvalue_reference_v<T> || is_rvalue_reference_v<T>)
            return true;
        else if constexpr (is_destructible_v<T>)
            return noexcept(declval<T&>().~T());
        else
            return false;
    }
}

