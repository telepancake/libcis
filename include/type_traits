//===----------------------------------------------------------------------===//
// Nothrow constructible (is_nothrow_constructible.h)
// __is_nothrow_constructible NOT in gcc-10.2 — use noexcept expressions.
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T, class... Args>
    constexpr bool compute_is_nothrow_constructible() {
        if constexpr (is_constructible_v<T, Args...>) {
            if constexpr (sizeof...(Args) == 0)
                return noexcept(T());
            else
                return noexcept(T(declval<Args>()...));
        } else {
            return false;
        }
    }
}

template<class T, class... Args>
inline constexpr bool is_nothrow_constructible_v =
    detail::compute_is_nothrow_constructible<T, Args...>();

