//===----------------------------------------------------------------------===//
namespace detail {
    template<class T> inline constexpr bool is_mem_ptr_base = false;
    template<class T, class C> inline constexpr bool is_mem_ptr_base<T C::*> = true;

    template<class T> inline constexpr bool is_mem_fn_ptr_base = false;
    template<class T, class C>
    inline constexpr bool is_mem_fn_ptr_base<T C::*> = is_function_v<T>;
}
template<class T>
inline constexpr bool is_member_pointer_v = detail::is_mem_ptr_base<remove_cv_t<T>>;
template<class T>
struct is_member_pointer : bool_constant<is_member_pointer_v<T>> {};

