//===----------------------------------------------------------------------===//
// is_destructible (is_destructible.h)
// __is_destructible NOT in gcc-10.2.
//===----------------------------------------------------------------------===//
namespace detail {
    // Concept: T's destructor is well-formed and callable.
    template<class T>
    concept destructor_wellformed = requires(T& t) { t.~T(); };

    template<class T> constexpr bool compute_is_destructible() {
        if constexpr (is_reference_v<T>)
            return true;
        else if constexpr (is_void_v<T> || is_function_v<T> || is_unbounded_array_v<T>)
            return false;
        else
            // For scalar types, classes, and bounded arrays: check the element type.
            return destructor_wellformed<remove_all_extents_t<T>>;
    }
}

template<class T>
inline constexpr bool is_destructible_v = detail::compute_is_destructible<T>();
template<class T>
struct is_destructible : bool_constant<is_destructible_v<T>> {};

