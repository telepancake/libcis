struct is_trivially_move_assignable
    : bool_constant<is_trivially_move_assignable_v<T>> {};

//===----------------------------------------------------------------------===//
// is_trivially_destructible (is_trivially_destructible.h)
// __has_trivial_destructor available in gcc-10.2
//===----------------------------------------------------------------------===//
template<class T>
inline constexpr bool is_trivially_destructible_v =
    is_destructible_v<T> && __has_trivial_destructor(T);
template<class T>
struct is_trivially_destructible
    : bool_constant<is_trivially_destructible_v<T>> {};

//===----------------------------------------------------------------------===//
// Nothrow constructible (is_nothrow_constructible.h)
// __is_nothrow_constructible NOT in gcc-10.2 — use noexcept expressions.
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T, class... Args>
    constexpr bool compute_is_nothrow_constructible() {
        if constexpr (is_constructible_v<T, Args...>) {
            if constexpr (sizeof...(Args) == 0)
                return noexcept(T());
            else
                return noexcept(T(declval<Args>()...));
        } else {
            return false;
        }
    }
}

template<class T, class... Args>
inline constexpr bool is_nothrow_constructible_v =
    detail::compute_is_nothrow_constructible<T, Args...>();

template<class T, class... Args>
struct is_nothrow_constructible
    : bool_constant<is_nothrow_constructible_v<T, Args...>> {};

template<class T>
inline constexpr bool is_nothrow_default_constructible_v =
    is_nothrow_constructible_v<T>;
template<class T>
struct is_nothrow_default_constructible
    : bool_constant<is_nothrow_default_constructible_v<T>> {};

template<class T>
inline constexpr bool is_nothrow_copy_constructible_v =
    is_nothrow_constructible_v<T, add_lvalue_reference_t<const T>>;
template<class T>
struct is_nothrow_copy_constructible
    : bool_constant<is_nothrow_copy_constructible_v<T>> {};

template<class T>
inline constexpr bool is_nothrow_move_constructible_v =
    is_nothrow_constructible_v<T, add_rvalue_reference_t<T>>;
template<class T>
struct is_nothrow_move_constructible
    : bool_constant<is_nothrow_move_constructible_v<T>> {};

//===----------------------------------------------------------------------===//
// Nothrow assignable (is_nothrow_assignable.h)
// __is_nothrow_assignable NOT in gcc-10.2.
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T, class Arg>
    constexpr bool compute_is_nothrow_assignable() {
        if constexpr (is_assignable_v<T, Arg>)
            return noexcept(declval<T>() = declval<Arg>());
        else
            return false;
    }
}
template<class T, class Arg>
inline constexpr bool is_nothrow_assignable_v =
    detail::compute_is_nothrow_assignable<T, Arg>();
template<class T, class Arg>
struct is_nothrow_assignable
    : bool_constant<is_nothrow_assignable_v<T, Arg>> {};

template<class T>
inline constexpr bool is_nothrow_copy_assignable_v =
    is_nothrow_assignable_v<add_lvalue_reference_t<T>,
                             add_lvalue_reference_t<const T>>;
template<class T>
struct is_nothrow_copy_assignable
    : bool_constant<is_nothrow_copy_assignable_v<T>> {};

template<class T>
inline constexpr bool is_nothrow_move_assignable_v =
    is_nothrow_assignable_v<add_lvalue_reference_t<T>, add_rvalue_reference_t<T>>;
template<class T>
struct is_nothrow_move_assignable
    : bool_constant<is_nothrow_move_assignable_v<T>> {};

//===----------------------------------------------------------------------===//
// is_nothrow_destructible (is_nothrow_destructible.h)
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T> constexpr bool compute_is_nothrow_destructible() {
        if constexpr (is_lvalue_reference_v<T> || is_rvalue_reference_v<T>)
            return true;
        else if constexpr (is_destructible_v<T>)
            return noexcept(declval<T&>().~T());
        else
            return false;
    }
}

template<class T>
inline constexpr bool is_nothrow_destructible_v =
    detail::compute_is_nothrow_destructible<T>();
// Arrays: delegate to element type (specialise the _v since compute can't
// easily recurse to the element type generically)
template<class T, size_t N>
inline constexpr bool is_nothrow_destructible_v<T[N]> =
    is_nothrow_destructible_v<T>;

template<class T>
struct is_nothrow_destructible
    : bool_constant<is_nothrow_destructible_v<T>> {};

//===----------------------------------------------------------------------===//
// is_convertible (is_convertible.h)
// __is_convertible NOT in gcc-10.2.
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T> void convert_test(T) noexcept;

    template<class From, class To, class = void>
    inline constexpr bool is_convertible_impl = false;
    template<class From, class To>
    inline constexpr bool is_convertible_impl<
        From, To,
        void_t<decltype(convert_test<To>(declval<From>()))>> = true;
}

template<class From, class To>
inline constexpr bool is_convertible_v =
    (is_void_v<From> && is_void_v<To>) ||
    (!is_void_v<To> && detail::is_convertible_impl<From, To>);
template<class From, class To>
struct is_convertible : bool_constant<is_convertible_v<From, To>> {};

//===----------------------------------------------------------------------===//
// is_nothrow_convertible (C++20)
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T> void nothrow_convert_test(T) noexcept;

    template<class From, class To>
    constexpr bool compute_is_nothrow_convertible() {
        if constexpr (is_void_v<From> && is_void_v<To>)
            return true;
        else if constexpr (!is_void_v<To> && is_convertible_impl<From, To>)
            return noexcept(nothrow_convert_test<To>(declval<From>()));
        else
            return false;
    }
}
template<class From, class To>
inline constexpr bool is_nothrow_convertible_v =
    detail::compute_is_nothrow_convertible<From, To>();
template<class From, class To>
struct is_nothrow_convertible : bool_constant<is_nothrow_convertible_v<From, To>> {};

