template<class T>
inline constexpr bool is_scoped_enum_v =
    is_enum_v<T> && !is_convertible_v<T, int>;
template<class T>
struct is_scoped_enum : bool_constant<is_scoped_enum_v<T>> {};

//===----------------------------------------------------------------------===//
// underlying_type (underlying_type.h)
// __underlying_type available in gcc-10.2
// Only well-formed for enum types; inherits no ::type for non-enums
// (matches standard: "shall not be instantiated for non-enum types").
//===----------------------------------------------------------------------===//
template<class T> struct underlying_type {};
template<class T> requires is_enum_v<T>
struct underlying_type<T> { using type = __underlying_type(T); };
template<class T>
using underlying_type_t = typename underlying_type<T>::type;

