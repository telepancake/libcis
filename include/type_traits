//===----------------------------------------------------------------------===//
// is_signed, is_unsigned (is_signed.h, is_unsigned.h)
// __is_signed, __is_unsigned NOT in gcc-10.2.
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T> constexpr bool compute_is_signed() {
        if constexpr (is_arithmetic_v<T>) return T(-1) < T(0);
        else return false;
    }
    template<class T> constexpr bool compute_is_unsigned() {
        if constexpr (is_integral_v<T>) return T(0) < T(-1);
        else return false;
    }
}
template<class T>
inline constexpr bool is_signed_v = detail::compute_is_signed<T>();
template<class T>
struct is_signed : bool_constant<is_signed_v<T>> {};

template<class T>
inline constexpr bool is_unsigned_v = detail::compute_is_unsigned<T>();
template<class T>
struct is_unsigned : bool_constant<is_unsigned_v<T>> {};

