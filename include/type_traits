//===----------------------------------------------------------------------===//
// type_list + find_first (internal helpers for make_signed/make_unsigned)
//===----------------------------------------------------------------------===//
namespace detail {
    template<class... Types> struct type_list {};

    template<class>            struct type_list_head;
    template<class H, class... T>
    struct type_list_head<type_list<H, T...>> { using type = H; };

    template<class List, size_t Size,
             bool = Size <= sizeof(typename type_list_head<List>::type)>
    struct find_first;
    template<class H, class... T, size_t S>
    struct find_first<type_list<H, T...>, S, true>  { using type = H; };
    template<class H, class... T, size_t S>
    struct find_first<type_list<H, T...>, S, false> {
        using type = typename find_first<type_list<T...>, S>::type;
    };
}

//===----------------------------------------------------------------------===//
// copy_cv (copy_cv.h — internal helper)
//===----------------------------------------------------------------------===//
namespace detail {
    template<class From>       struct copy_cv_sel { template<class T> using apply = T; };
    template<class From>       struct copy_cv_sel<const From> {
        template<class T> using apply = const T; };
    template<class From>       struct copy_cv_sel<volatile From> {
        template<class T> using apply = volatile T; };
    template<class From>       struct copy_cv_sel<const volatile From> {
        template<class T> using apply = const volatile T; };
    template<class From, class To>
    using copy_cv_t = typename copy_cv_sel<From>::template apply<To>;
}

//===----------------------------------------------------------------------===//
// copy_cvref (copy_cvref.h — internal helper for common_reference)
// XREF(A) = a unary alias template T such that T<U> is U with A's cv+ref quals.
//===----------------------------------------------------------------------===//
namespace detail {
    // copy_cvref: apply From's cv AND reference qualifiers to To.
    template<class From>
    struct copy_cvref_sel {
        template<class To> using apply = copy_cv_t<From, To>;
    };
    template<class From>
    struct copy_cvref_sel<From&> {
        template<class To> using apply = add_lvalue_reference_t<copy_cv_t<From, To>>;
    };
    template<class From>
    struct copy_cvref_sel<From&&> {
        template<class To> using apply = add_rvalue_reference_t<copy_cv_t<From, To>>;
    };
    template<class From, class To>
    using copy_cvref_t = typename copy_cvref_sel<From>::template apply<To>;
}

//===----------------------------------------------------------------------===//
// make_signed, make_unsigned (make_signed.h, make_unsigned.h)
// __make_signed, __make_unsigned NOT in gcc-10.2.
//===----------------------------------------------------------------------===//
namespace detail {
    using signed_types   = type_list<signed char, short, int, long, long long, __int128>;
    using unsigned_types = type_list<unsigned char, unsigned short, unsigned int,
                                     unsigned long, unsigned long long, unsigned __int128>;

    template<class T, bool = is_integral_v<T> || is_enum_v<T>>
    struct make_signed_base {};
    template<class T>
    struct make_signed_base<T, true> {
        using type = typename find_first<signed_types, sizeof(T)>::type;
    };
    template<> struct make_signed_base<bool, true>               {};
    template<> struct make_signed_base<signed short, true>       { using type = short; };
    template<> struct make_signed_base<unsigned short, true>     { using type = short; };
    template<> struct make_signed_base<signed int, true>         { using type = int; };
    template<> struct make_signed_base<unsigned int, true>       { using type = int; };
    template<> struct make_signed_base<signed long, true>        { using type = long; };
    template<> struct make_signed_base<unsigned long, true>      { using type = long; };
    template<> struct make_signed_base<signed long long, true>   { using type = long long; };
    template<> struct make_signed_base<unsigned long long, true> { using type = long long; };
    template<> struct make_signed_base<__int128, true>           { using type = __int128; };
    template<> struct make_signed_base<unsigned __int128, true>  { using type = __int128; };

    template<class T, bool = is_integral_v<T> || is_enum_v<T>>
    struct make_unsigned_base {};
    template<class T>
    struct make_unsigned_base<T, true> {
        using type = typename find_first<unsigned_types, sizeof(T)>::type;
    };
    template<> struct make_unsigned_base<bool, true>               {};
    template<> struct make_unsigned_base<signed short, true>       { using type = unsigned short; };
    template<> struct make_unsigned_base<unsigned short, true>     { using type = unsigned short; };
    template<> struct make_unsigned_base<signed int, true>         { using type = unsigned int; };
    template<> struct make_unsigned_base<unsigned int, true>       { using type = unsigned int; };
    template<> struct make_unsigned_base<signed long, true>        { using type = unsigned long; };
    template<> struct make_unsigned_base<unsigned long, true>      { using type = unsigned long; };
    template<> struct make_unsigned_base<signed long long, true>   { using type = unsigned long long; };
    template<> struct make_unsigned_base<unsigned long long, true> { using type = unsigned long long; };
    template<> struct make_unsigned_base<__int128, true>           { using type = unsigned __int128; };
    template<> struct make_unsigned_base<unsigned __int128, true>  { using type = unsigned __int128; };
}

template<class T>
struct make_signed {
    using type = detail::copy_cv_t<T,
        typename detail::make_signed_base<remove_cv_t<T>>::type>;
};
template<class T> using make_signed_t = typename make_signed<T>::type;

template<class T>
struct make_unsigned {
    using type = detail::copy_cv_t<T,
        typename detail::make_unsigned_base<remove_cv_t<T>>::type>;
