//===----------------------------------------------------------------------===//
// is_nothrow_convertible (C++20)
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T> void nothrow_convert_test(T) noexcept;

    template<class From, class To>
    constexpr bool compute_is_nothrow_convertible() {
        if constexpr (is_void_v<From> && is_void_v<To>)
            return true;
        else if constexpr (!is_void_v<To> && is_convertible_impl<From, To>)
            return noexcept(nothrow_convert_test<To>(declval<From>()));
        else
            return false;
    }
}
template<class From, class To>
inline constexpr bool is_nothrow_convertible_v =
    detail::compute_is_nothrow_convertible<From, To>();
template<class From, class To>
