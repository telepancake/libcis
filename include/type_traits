    template<> inline constexpr bool is_integral_base<char>               = true;
    template<> inline constexpr bool is_integral_base<signed char>        = true;
    template<> inline constexpr bool is_integral_base<unsigned char>      = true;
    template<> inline constexpr bool is_integral_base<wchar_t>            = true;
    template<> inline constexpr bool is_integral_base<char8_t>            = true;
    template<> inline constexpr bool is_integral_base<char16_t>           = true;
    template<> inline constexpr bool is_integral_base<char32_t>           = true;
    template<> inline constexpr bool is_integral_base<short>              = true;
    template<> inline constexpr bool is_integral_base<unsigned short>     = true;
    template<> inline constexpr bool is_integral_base<int>                = true;
    template<> inline constexpr bool is_integral_base<unsigned int>       = true;
    template<> inline constexpr bool is_integral_base<long>               = true;
    template<> inline constexpr bool is_integral_base<unsigned long>      = true;
    template<> inline constexpr bool is_integral_base<long long>          = true;
    template<> inline constexpr bool is_integral_base<unsigned long long> = true;
    template<> inline constexpr bool is_integral_base<__int128>           = true;
    template<> inline constexpr bool is_integral_base<unsigned __int128>  = true;
}
template<class T>
inline constexpr bool is_integral_v = detail::is_integral_base<remove_cv_t<T>>;
template<class T>
struct is_integral : bool_constant<is_integral_v<T>> {};

