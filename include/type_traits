template<class T>
inline constexpr bool is_void_v = is_same_v<remove_cv_t<T>, void>;
template<class T>
struct is_void : bool_constant<is_void_v<T>> {};

//===----------------------------------------------------------------------===//
// is_null_pointer (is_null_pointer.h)
