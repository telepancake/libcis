template<class T>           struct rank : integral_constant<size_t, 0> {};
template<class T>           struct rank<T[]>    : integral_constant<size_t, rank<T>::value + 1> {};
template<class T, size_t N> struct rank<T[N]>   : integral_constant<size_t, rank<T>::value + 1> {};
template<class T>
inline constexpr size_t rank_v = rank<T>::value;

template<class T, unsigned I = 0>
struct extent : integral_constant<size_t, 0> {};
template<class T>
struct extent<T[], 0>           : integral_constant<size_t, 0> {};
template<class T, unsigned I>
struct extent<T[], I>           : integral_constant<size_t, extent<T, I-1>::value> {};
template<class T, size_t N>
struct extent<T[N], 0>          : integral_constant<size_t, N> {};
template<class T, size_t N, unsigned I>
struct extent<T[N], I>          : integral_constant<size_t, extent<T, I-1>::value> {};
template<class T, unsigned I = 0>
inline constexpr size_t extent_v = extent<T, I>::value;

