// <clocale> -- C locale functions in namespace std.
// Mechanically ported from libc++ include/clocale.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Includes <locale.h> (reachable via the system include path even with
// -nostdinc++) and re-exports lconv, setlocale, and localeconv into namespace
// std.
// The macros (LC_ALL, LC_COLLATE, LC_CTYPE, LC_MONETARY, LC_NUMERIC, LC_TIME,
// NULL) remain in the global namespace as provided by <locale.h>; the standard
// only requires them there.
#pragma once

// glibc declarations must keep DEFAULT visibility no matter where this
// wrapper is first included from: io headers wrap their bodies in
// `#pragma GCC visibility push(hidden)` (libstdc++-ABI isolation), and a
// libc prototype first seen inside such a region becomes a hidden symbol
// the linker then cannot resolve against libc (e.g. strtod via <sstream>).
#pragma GCC visibility push(default)
#include <locale.h>
#pragma GCC visibility pop

namespace std {

using ::lconv;
using ::setlocale;
using ::localeconv;

} // namespace std
