// ---------- Floating-point ----------
namespace fmt_detail {
template<class T, class CharT>
struct float_fmt_base {
    fmt_spec::parsed_specs specs_;

    template<class ParseCtx>
    constexpr typename ParseCtx::iterator parse(ParseCtx& pc) {
        dummy_ctx d;
        auto it = parse_specs<CharT>(pc, d, fmt_spec::fields_float, specs_);
        // Set default precision for explicit format specs
        switch (specs_.type_) {
        case fmt_spec::type::scientific_lower:
        case fmt_spec::type::scientific_upper:
        case fmt_spec::type::fixed_lower:
        case fmt_spec::type::fixed_upper:
        case fmt_spec::type::general_lower:
        case fmt_spec::type::general_upper:
            if (!specs_.has_precision()) specs_.prec = 6;
            break;
        default: break;
        }
        pc.advance_to(it);
        return it;
    }

    template<class FmtCtx>
    typename FmtCtx::iterator format(T value, FmtCtx& ctx) const {
        return format_float<CharT>(value, ctx, specs_);
    }
};
