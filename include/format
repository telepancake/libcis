// ---------- Pointers ----------
template<class C>
struct formatter<const void*, C> {
    fmt_spec::parsed_specs specs_;

    template<class ParseCtx>
    constexpr typename ParseCtx::iterator parse(ParseCtx& pc) {
        fmt_detail::dummy_ctx d;
        auto it = fmt_detail::parse_specs<C>(pc, d, fmt_spec::fields_pointer, specs_);
        pc.advance_to(it);
        return it;
    }

    template<class FmtCtx>
    typename FmtCtx::iterator format(const void* p, FmtCtx& ctx) const {
        char buf[32];
        int n = std::snprintf(buf, sizeof(buf), "%p", p);
        basic_string_view<char> sv{buf, static_cast<size_t>(n)};
        fmt_spec::parsed_specs s = specs_;
        if (s.align == fmt_spec::alignment::default_) s.align = fmt_spec::alignment::right;
        auto out = ctx.out();
        if constexpr (is_same_v<C, char>) {
            ctx.advance_to(fmt_detail::write_padded(sv, out, s));
        } else {
            basic_string<C> ws; ws.reserve(static_cast<size_t>(n));
            for (char c : sv) ws.push_back(static_cast<C>(c));
            ctx.advance_to(fmt_detail::write_padded(basic_string_view<C>{ws.data(),ws.size()}, out, s));
        }
        return ctx.out();
    }
};

