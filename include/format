// ---------- Strings ----------
namespace fmt_detail {
template<class CharT>
struct str_fmt_base {
    fmt_spec::parsed_specs specs_;

    template<class ParseCtx>
    constexpr typename ParseCtx::iterator parse(ParseCtx& pc) {
        dummy_ctx d;
        auto it = parse_specs<CharT>(pc, d, fmt_spec::fields_string, specs_);
        pc.advance_to(it);
        return it;
    }

    template<class FmtCtx>
    typename FmtCtx::iterator format_sv(basic_string_view<CharT> sv, FmtCtx& ctx) const {
        fmt_spec::parsed_specs s = specs_;
        if (s.align == fmt_spec::alignment::default_)
            s.align = fmt_spec::alignment::left;
        if (s.has_precision() && static_cast<int32_t>(sv.size()) > s.prec)
            sv = sv.substr(0, static_cast<size_t>(s.prec));
        auto out = ctx.out();
        ctx.advance_to(write_padded(sv, out, s));
        return ctx.out();
    }
};
