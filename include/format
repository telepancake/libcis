// ============================================================
// 16. Core vformat engine
// ============================================================

namespace fmt_detail {

// dispatch_format_arg: format one argument using its stored type.
// We use a manual switch on arg_kind rather than a generic lambda to avoid
// the "use before deduction of auto" problem in gcc-10.
template<class FmtCtx, class ParseCtx>
void dispatch_format_arg(basic_format_arg<FmtCtx>& arg,
                          ParseCtx& pc, FmtCtx& ctx, bool has_spec) {
    using CharT = typename FmtCtx::char_type;
    using K = fmt_arg_kind;

    auto do_fmt = [&](auto val) {
        using ArgT = decltype(val);
        if constexpr (!is_same_v<ArgT, monostate> &&
                      !is_same_v<ArgT, typename basic_format_arg<FmtCtx>::handle>) {
            formatter<ArgT, CharT> f;
            if (has_spec) pc.advance_to(f.parse(pc));
            ctx.advance_to(f.format(val, ctx));
        }
    };

    switch (arg.kind_) {
    case K::none:
        throw_format_error("The argument index value is too large");
    case K::boolean:
        do_fmt(arg.val_.b); break;
    case K::char_t:
        do_fmt(arg.val_.ch); break;
    case K::int_:
        do_fmt(arg.val_.i); break;
    case K::long_long:
        do_fmt(arg.val_.ll); break;
    case K::uint_:
        do_fmt(arg.val_.u); break;
    case K::ullong:
        do_fmt(arg.val_.ull); break;
    case K::float_:
        do_fmt(arg.val_.f); break;
    case K::double_:
        do_fmt(arg.val_.d); break;
    case K::ldouble:
        do_fmt(arg.val_.ld); break;
    case K::cstring:
        do_fmt(arg.val_.cs); break;
    case K::strview:
        do_fmt(arg.val_.sv); break;
    case K::ptr:
        do_fmt(arg.val_.p); break;
    case K::handle: {
        typename basic_format_arg<FmtCtx>::handle h{arg.val_.hd};
        h.format(pc, ctx);
        break;
    }
    }
}

template<class ParseCtx, class FmtCtx>
typename FmtCtx::iterator vformat_to_impl(ParseCtx& pc, FmtCtx& ctx) {
    using CharT = typename ParseCtx::char_type;
    auto begin   = pc.begin();
    auto end     = pc.end();
    auto out_it  = ctx.out();

    while (begin != end) {
        switch (*begin) {
        case CharT('{'): {
            ++begin;
            if (begin == end)
                throw_format_error("The format string terminates at a '{'");

            if (*begin == CharT('{')) {
                *out_it++ = CharT('{');
                ++begin;
                continue;
            }

            // replacement field: parse arg-id
            ctx.advance_to(std::move(out_it));
            auto r = parse_arg_id(begin, end, pc);
            begin = r.last;
            if (begin == end)
                throw_format_error("The argument index should end with a ':' or a '}'");

            bool has_spec = (*begin == CharT(':'));
            if (has_spec)
                pc.advance_to(begin + 1);
            else
                pc.advance_to(begin);  // points at '}'

            auto the_arg = ctx.arg(r.value);
            dispatch_format_arg(the_arg, pc, ctx, has_spec);

            begin = pc.begin();
            if (begin == end || *begin != CharT('}'))
                throw_format_error("The replacement field misses a terminating '}'");
            ++begin;
            out_it = ctx.out();
            continue;
        }
        case CharT('}'): {
            ++begin;
            if (begin == end || *begin != CharT('}'))
                throw_format_error("The format string contains an invalid escape sequence");
            *out_it++ = CharT('}');
            ++begin;
            continue;
        }
        default:
            *out_it++ = *begin++;
            continue;
        }
    }
    return out_it;
}

} // namespace fmt_detail

// ============================================================
// 17. Public API
// ============================================================

// vformat_to
template<class Out>
Out vformat_to(Out out, string_view fmt,
               basic_format_args<basic_format_context<Out, char>> args) {
    basic_format_context<Out, char> ctx{std::move(out), args};
    basic_format_parse_context<char> pc{fmt, args.size()};
    return fmt_detail::vformat_to_impl(pc, ctx);
}

// vformat (builds result in a string)
[[nodiscard]] inline string vformat(string_view fmt, format_args args) {
    string result;
    vformat_to(back_inserter(result), fmt, args);
    return result;
}

// format
template<class... Args>
[[nodiscard]] string format(format_string<Args...> fmt, Args&&... args) {
    return vformat(fmt.get(), make_format_args(args...));
}

// format_to
template<class Out, class... Args>
Out format_to(Out out, format_string<Args...> fmt, Args&&... args) {
    auto store = make_format_args<basic_format_context<Out,char>>(args...);
    basic_format_args<basic_format_context<Out,char>> fargs{store};
    return vformat_to(std::move(out), fmt.get(), fargs);
}

// ============================================================
// 18. format_to_n
// ============================================================

// State block for counted_out — held by pointer so copies share state.
namespace fmt_detail {

template<class Out>
struct counted_out_state {
    Out                    out;       // current write position
    iter_difference_t<Out> remaining; // capacity left
    iter_difference_t<Out> total;     // total chars requested
};

// counted_out holds a pointer to shared state so copies are assignable
// and mutations propagate correctly through the *it++ = v idiom.
template<class Out>
struct counted_out {
    counted_out_state<Out>* state; // pointer — NO reference member (assignable!)

    using iterator_category = output_iterator_tag;
    using value_type        = void;
    using difference_type   = iter_difference_t<Out>;
    using pointer           = void;
    using reference         = void;

    counted_out& operator=(typename iterator_traits<Out>::value_type v) {
        if (state->remaining > 0) {
            *(state->out)++ = v;
            --(state->remaining);
        }
        ++(state->total);
        return *this;
    }
    counted_out& operator*()     { return *this; }
    counted_out& operator++()    { return *this; }
    counted_out  operator++(int) { return *this; }
};

} // namespace fmt_detail

template<class Out, class... Args>
format_to_n_result<Out>
format_to_n(Out out, iter_difference_t<Out> n,
            format_string<Args...> fmt, Args&&... args) {
    using COut  = fmt_detail::counted_out<Out>;
    using State = fmt_detail::counted_out_state<Out>;

    State state{std::move(out), n, 0};

    auto store = make_format_args<basic_format_context<COut,char>>(args...);
    basic_format_args<basic_format_context<COut,char>> fargs{store};

    COut cit{&state};
    basic_format_context<COut, char> ctx{std::move(cit), fargs};
    basic_format_parse_context<char> pc{fmt.get(), fargs.size()};
    fmt_detail::vformat_to_impl(pc, ctx);
    return {std::move(state.out), state.total};
}

// ============================================================
// 19. formatted_size
// ============================================================

namespace fmt_detail {

struct counting_out {
    size_t* count; // pointer — keeps the iterator copy-assignable

    using iterator_category = output_iterator_tag;
    using value_type        = void;
    using difference_type   = ptrdiff_t;
    using pointer           = void;
    using reference         = void;

    counting_out& operator=(char)  { ++(*count); return *this; }
    counting_out& operator*()      { return *this; }
    counting_out& operator++()     { return *this; }
    counting_out  operator++(int)  { return *this; }
};

} // namespace fmt_detail

template<class... Args>
[[nodiscard]] size_t formatted_size(format_string<Args...> fmt, Args&&... args) {
    size_t count = 0;
    using CO = fmt_detail::counting_out;
    auto store = make_format_args<basic_format_context<CO,char>>(args...);
    basic_format_args<basic_format_context<CO,char>> fargs{store};

    CO cit{&count};
    basic_format_context<CO, char> ctx{std::move(cit), fargs};
    basic_format_parse_context<char> pc{fmt.get(), fargs.size()};
    fmt_detail::vformat_to_impl(pc, ctx);
    return count;
}

} // namespace std
