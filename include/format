// DEVIATION: libcis <charconv> has no floating-point to_chars (libc++
// implements it in src/ via Ryu).  These helpers emulate the exact to_chars
// semantics the formatter needs on top of snprintf, using a
// shortest-round-trip digit search for the precision-less forms.

template <class Fp>
int fp_snprintf(char* buf, size_t size, const char* spec, int precision, Fp value) {
  if (precision < 0)
    return std::snprintf(buf, size, spec, value);
  return std::snprintf(buf, size, spec, precision, value);
}

template <class Fp>
Fp fp_parse(const char* s) {
  if constexpr (same_as<Fp, float>)
    return strtof(s, nullptr);
  else if constexpr (same_as<Fp, double>)
    return strtod(s, nullptr);
  else
    return strtold(s, nullptr);
}

// Renders value with %.{prec}Le style conversion conv into buf, returns length.
template <class Fp>
int fp_print(char* buf, size_t size, char conv, int precision, Fp value) {
  char spec[8];
  int i     = 0;
  spec[i++] = '%';
  if (precision >= 0) {
    spec[i++] = '.';
    spec[i++] = '*';
  }
  if constexpr (same_as<Fp, long double>)
    spec[i++] = 'L';
  spec[i++] = conv;
  spec[i]   = '\0';
  return fmtops::fp_snprintf(buf, size, spec, precision, value);
}

// Shortest scientific digits that round-trip: returns digit string (no radix
// point), decimal exponent, sign.
template <class Fp>
struct fp_shortest_result {
  char digits[64];
  int num_digits;
  int exp10;
  bool negative;
};

template <class Fp>
fp_shortest_result<Fp> fp_shortest(Fp value) {
  fp_shortest_result<Fp> result;
  char buf[128];
  int max_digits = numeric_limits<Fp>::max_digits10;
  int len        = 0;
  for (int prec = 0; prec < max_digits; ++prec) {
    len = fmtops::fp_print(buf, sizeof(buf), 'e', prec, value);
    if (fmtops::fp_parse<Fp>(buf) == value)
      break;
  }
  // parse [-]d[.ddd]e±dd
  const char* p   = buf;
  result.negative = (*p == '-');
  if (result.negative)
    ++p;
  int n              = 0;
  result.digits[n++] = *p++;
  if (*p == '.') {
    ++p;
    while (*p != 'e')
      result.digits[n++] = *p++;
  }
  // strip trailing zeros (snprintf %.Ne keeps them; shortest search makes the
  // last requested digit significant, but a smaller precision may already have
  // round-tripped with trailing zeros when crossing powers of ten).
  while (n > 1 && result.digits[n - 1] == '0')
    --n;
  result.num_digits = n;
  ++p; // 'e'
  result.exp10 = static_cast<int>(std::strtol(p, nullptr, 10));
  (void)len;
  return result;
}

inline char* fp_write_exponent(char* out, int exp10, char exp_char) {
  *out++ = exp_char;
  if (exp10 < 0) {
    *out++ = '-';
    exp10  = -exp10;
  } else
    *out++ = '+';
  char tmp[8];
  int i = 0;
  do {
    tmp[i++] = static_cast<char>('0' + exp10 % 10);
    exp10 /= 10;
  } while (exp10);
  while (i < 2)
    tmp[i++] = '0';
  while (i)
    *out++ = tmp[--i];
  return out;
}

// Writes the shortest fixed representation of digits/exp10 (no trailing zeros).
inline char* fp_write_fixed_shortest(char* out, const char* digits, int n, int exp10) {
  if (exp10 >= 0) {
    int int_digits = exp10 + 1;
    for (int i = 0; i < int_digits; ++i)
      *out++ = i < n ? digits[i] : '0';
    if (n > int_digits) {
      *out++ = '.';
      for (int i = int_digits; i < n; ++i)
        *out++ = digits[i];
    }
  } else {
    *out++ = '0';
    *out++ = '.';
    for (int i = 0; i < -exp10 - 1; ++i)
      *out++ = '0';
    for (int i = 0; i < n; ++i)
      *out++ = digits[i];
  }
  return out;
}

// Writes the shortest scientific representation d[.ddd]e±dd.
inline char* fp_write_scientific_shortest(char* out, const char* digits, int n, int exp10) {
  *out++ = digits[0];
  if (n > 1) {
    *out++ = '.';
    for (int i = 1; i < n; ++i)
      *out++ = digits[i];
  }
  return fmtops::fp_write_exponent(out, exp10, 'e');
}

template <class Fp>
bool fp_special(char* first, char** out, Fp value) {
  if (std::isnan(value)) {
    char* p = first;
    if (std::signbit(value))
      *p++ = '-';
    std::memcpy(p, "nan", 3);
    *out = p + 3;
    return true;
  }
  if (std::isinf(value)) {
    char* p = first;
    if (std::signbit(value))
      *p++ = '-';
    std::memcpy(p, "inf", 3);
    *out = p + 3;
    return true;
  }
  return false;
}

// to_chars(first, last, value) — shortest, fixed/scientific whichever shorter,
// ties go to fixed.
template <floating_point Fp>
to_chars_result fp_to_chars(char* first, char* last, Fp value) {
  char* end;
  if (fmtops::fp_special(first, &end, value))
    return {end, errc(0)};
  auto r   = fmtops::fp_shortest(value);
  char* p  = first;
  if (r.negative)
    *p++ = '-';
  // length of fixed: see fp_write_fixed_shortest layout
  int fixed_len;
  if (r.exp10 >= 0)
    fixed_len = std::max(r.exp10 + 1, r.num_digits) + (r.num_digits > r.exp10 + 1 ? 1 : 0);
  else
    fixed_len = 2 + (-r.exp10 - 1) + r.num_digits;
  int exp_digits     = r.exp10 <= -100 || r.exp10 >= 100 ? 3 : 2;
  int scientific_len = r.num_digits + (r.num_digits > 1 ? 1 : 0) + 2 + exp_digits;
  if (fixed_len <= scientific_len)
    p = fmtops::fp_write_fixed_shortest(p, r.digits, r.num_digits, r.exp10);
  else
    p = fmtops::fp_write_scientific_shortest(p, r.digits, r.num_digits, r.exp10);
  return {p, errc(0)};
}

// to_chars(first, last, value, fmt) — shortest round-trip in the given format.
template <floating_point Fp>
to_chars_result fp_to_chars(char* first, char* last, Fp value, chars_format fmt) {
  char* end;
  if (fmtops::fp_special(first, &end, value))
    return {end, errc(0)};
  if (fmt == chars_format::hex) {
    // %La is shortest-exact; drop the "0x" prefix.
    char buf[160];
    int len  = fmtops::fp_print(buf, sizeof(buf), 'a', -1, value);
    char* p  = first;
    const char* s = buf;
    if (*s == '-') {
      *p++ = '-';
      ++s;
    }
    s += 2; // "0x"
    std::memcpy(p, s, static_cast<size_t>(len - (s - buf)));
    return {p + (len - (s - buf)), errc(0)};
  }
  auto r  = fmtops::fp_shortest(value);
  char* p = first;
  if (r.negative)
    *p++ = '-';
  switch (fmt) {
  case chars_format::fixed:
    p = fmtops::fp_write_fixed_shortest(p, r.digits, r.num_digits, r.exp10);
    break;
  case chars_format::scientific:
    p = fmtops::fp_write_scientific_shortest(p, r.digits, r.num_digits, r.exp10);
    break;
  default: { // general: printf %g selection with shortest digits
    if (r.exp10 >= -5 && r.exp10 < r.num_digits + 4)
      ; // heuristic unused; standard %g rule below
    int P = r.num_digits;
    int X = r.exp10;
    if (X >= -4 && X < std::max(P, 1))
      p = fmtops::fp_write_fixed_shortest(p, r.digits, r.num_digits, r.exp10);
    else
      p = fmtops::fp_write_scientific_shortest(p, r.digits, r.num_digits, r.exp10);
    break;
  }
  }
  return {p, errc(0)};
}

// to_chars(first, last, value, fmt, precision) — printf-style.
template <floating_point Fp>
to_chars_result fp_to_chars(char* first, char* last, Fp value, chars_format fmt, int precision) {
  char* end;
  if (fmtops::fp_special(first, &end, value))
    return {end, errc(0)};
  char conv;
  switch (fmt) {
  case chars_format::fixed:
    conv = 'f';
    break;
  case chars_format::scientific:
    conv = 'e';
    break;
  case chars_format::hex:
    conv = 'a';
    break;
  default:
    conv = 'g';
    break;
  }
  // %g would strip trailing zeros only with no '#'; to_chars(general,
  // precision) also strips them, so plain %g matches.
  char buf[1024];
  char* heap = nullptr;
  char* s    = buf;
  int len    = fmtops::fp_print(buf, sizeof(buf), conv, precision, value);
  FMT_ASSERT(len >= 0, "snprintf failure");
  if (static_cast<size_t>(len) >= sizeof(buf)) {
    heap = new char[static_cast<size_t>(len) + 1];
    s    = heap;
    fmtops::fp_print(s, static_cast<size_t>(len) + 1, conv, precision, value);
  }
  const char* q = s;
  char* p       = first;
  if (*q == '-')
    *p++ = *q++;
  if (conv == 'a' && q[0] == '0' && (q[1] == 'x' || q[1] == 'X'))
    q += 2;
  size_t body = static_cast<size_t>(len - (q - s));
  FMT_ASSERT(p + body <= last, "buffer too small");
  std::memcpy(p, q, body);
  p += body;
  delete[] heap;
  return {p, errc(0)};
}

