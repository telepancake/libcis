class format_error : public runtime_error {
public:
  explicit format_error(const string& s) : runtime_error(s) {}
  explicit format_error(const char* s) : runtime_error(s) {}
  format_error(const format_error&)            = default;
  format_error& operator=(const format_error&) = default;
  
  ~format_error() noexcept override = default;
};


[[noreturn]] inline void throw_format_error(const char* s) {
  // -fno-exceptions: report and trap.
  __builtin_printf("format_error: %s\n", s);
  __builtin_trap();
}


