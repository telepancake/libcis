// <format> — std::format and friends.
// Mechanically ported from libc++ include/format and include/__format/*.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Deviations from the standard / libc++:
//  - format_error never throws; errors call __builtin_trap().
//  - Floating-point formatting uses snprintf (not std::to_chars for fp),
//    because gcc-10's <charconv> only covers integers.
//  - basic_format_string consteval validation is relaxed (gcc-10 consteval
//    support is limited). Runtime checking still applies.
//  - No locale / wide-char support.  No chrono/range/tuple formatters.
#pragma once

#include <string>
#include <string_view>
#include <type_traits>
#include <concepts>
#include <charconv>
#include <cstdint>
#include <array>
#include <vector>
#include <iterator>
#include <cmath>
#include <cstdio>
#include <stdexcept>
#include <variant>  // monostate

namespace std {

// ============================================================
// 1. format_error
// ============================================================

class format_error : public runtime_error {
public:
    explicit format_error(const string& s) : runtime_error(s.c_str()) {}
    explicit format_error(const char*   s) : runtime_error(s) {}
    format_error(const format_error&)            = default;
    format_error& operator=(const format_error&) = default;
    ~format_error() noexcept override = default;
};

[[noreturn]] inline void throw_format_error(const char* msg) {
    __builtin_printf("format_error: %s\n", msg);
    __builtin_trap();
}

// ============================================================
// 2. formatter primary template (disabled)
// ============================================================

template<class Tp, class CharT = char>
struct formatter {
    formatter()  = delete;
    ~formatter() = delete;
};

// ============================================================
// 3. basic_format_parse_context
// ============================================================

template<class CharT>
class basic_format_parse_context {
public:
    using char_type      = CharT;
    using const_iterator = typename basic_string_view<CharT>::const_iterator;
    using iterator       = const_iterator;

    constexpr explicit basic_format_parse_context(
            basic_string_view<CharT> fmt, size_t num_args = 0) noexcept
        : begin_(fmt.begin()), end_(fmt.end()),
          indexing_(unknown_), next_arg_id_(0), num_args_(num_args) {}

    basic_format_parse_context(const basic_format_parse_context&)            = delete;
    basic_format_parse_context& operator=(const basic_format_parse_context&) = delete;

    [[nodiscard]] constexpr const_iterator begin() const noexcept { return begin_; }
    [[nodiscard]] constexpr const_iterator end()   const noexcept { return end_;   }
    constexpr void advance_to(const_iterator it) { begin_ = it; }

    constexpr size_t next_arg_id() {
        if (indexing_ == manual_)
            throw_format_error("Using automatic argument numbering in manual argument numbering mode");
        if (indexing_ == unknown_)
            indexing_ = automatic_;
        return next_arg_id_++;
    }

    constexpr void check_arg_id(size_t id) {
        if (indexing_ == automatic_)
            throw_format_error("Using manual argument numbering in automatic argument numbering mode");
        if (indexing_ == unknown_)
            indexing_ = manual_;
        (void)id;
    }

private:
    iterator begin_;
    iterator end_;
    enum Indexing { unknown_, manual_, automatic_ };
    Indexing indexing_;
    size_t   next_arg_id_;
    size_t   num_args_;
};

using format_parse_context = basic_format_parse_context<char>;

// ============================================================
// 4. format_spec enums & parsed_specs
// ============================================================

namespace fmt_spec {

enum class alignment : uint8_t {
    default_, left, center, right, zero_padding
};
enum class sign : uint8_t {
    default_, minus, plus, space
};
enum class type : uint8_t {
    default_ = 0,
    string_,
    binary_lower, binary_upper,
    octal,
    decimal,
    hex_lower, hex_upper,
    pointer_lower, pointer_upper,
    char_,
    hexfloat_lower, hexfloat_upper,
    scientific_lower, scientific_upper,
    fixed_lower, fixed_upper,
    general_lower, general_upper,
};

struct fill_t {
    char data[4] = {' '};
};

struct parsed_specs {
    alignment  align = alignment::default_;
    sign       sign_ = sign::default_;
    bool       alt   = false;
    type       type_ = type::default_;
    int32_t    width = 0;
    int32_t    prec  = -1;
    fill_t     fill;

    bool has_width()     const { return width > 0; }
    bool has_precision() const { return prec  >= 0; }
};

struct fields {
    bool sign         = false;
    bool alt          = false;
    bool zero_pad     = false;
    bool precision    = false;
    bool locale       = false;
    bool type_field   = false;
};

inline constexpr fields fields_bool     = {false,false,false,false,true,true};
inline constexpr fields fields_integral = {true, true, true, false,true,true};
inline constexpr fields fields_float    = {true, true, true, true, true,true};
inline constexpr fields fields_string   = {false,false,false,true, false,true};
inline constexpr fields fields_pointer  = {false,false,true, false,false,true};

} // namespace fmt_spec

// ============================================================
// 5. basic_format_arg / basic_format_args
// ============================================================

// The arg_kind enum — shared representation
enum class fmt_arg_kind : uint8_t {
    none,
    boolean, char_t,
    int_, long_long, uint_, ullong,
    float_, double_, ldouble,
    cstring, strview, ptr, handle
};

// basic_format_arg<Context> carries one format argument.
// The handle stores a Context-specific function pointer so it can call
// formatter<T,CharT>::format without knowing T at this layer.
template<class Context>
class basic_format_arg {
    using CharT = typename Context::char_type;
public:
    struct handle_data {
        const void* ptr;
        void (*fn)(basic_format_parse_context<CharT>&, Context&, const void*);
    };

    class handle {
        handle_data& d_;
    public:
        explicit handle(handle_data& d) noexcept : d_(d) {}
        void format(basic_format_parse_context<CharT>& pc, Context& ctx) const {
            d_.fn(pc, ctx, d_.ptr);
        }
    };

    // Internal storage — left public so helpers can access without friend complications
    union storage {
        bool                     b;
        CharT                    ch;
        int                      i;
        unsigned                 u;
        long long                ll;
        unsigned long long       ull;
        float                    f;
        double                   d;
        long double              ld;
        const CharT*             cs;
        basic_string_view<CharT> sv;
        const void*              p;
        handle_data              hd;

        storage() noexcept : i(0) {}
    };

    fmt_arg_kind kind_ = fmt_arg_kind::none;
    storage      val_;

    basic_format_arg() noexcept = default;
    explicit operator bool() const noexcept { return kind_ != fmt_arg_kind::none; }

    // Construction helpers
    static basic_format_arg make(bool v)                    noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::boolean; a.val_.b=v; return a; }
    static basic_format_arg make(CharT v)                   noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::char_t;  a.val_.ch=v; return a; }
    static basic_format_arg make(int v)                     noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::int_;    a.val_.i=v; return a; }
    static basic_format_arg make(unsigned v)                noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::uint_;   a.val_.u=v; return a; }
    static basic_format_arg make(long long v)               noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::long_long; a.val_.ll=v; return a; }
    static basic_format_arg make(unsigned long long v)      noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::ullong;  a.val_.ull=v; return a; }
    static basic_format_arg make(float v)                   noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::float_;  a.val_.f=v; return a; }
    static basic_format_arg make(double v)                  noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::double_; a.val_.d=v; return a; }
    static basic_format_arg make(long double v)             noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::ldouble; a.val_.ld=v; return a; }
    static basic_format_arg make(const CharT* v)            noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::cstring; a.val_.cs=v; return a; }
    static basic_format_arg make(basic_string_view<CharT> v)noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::strview; a.val_.sv=v; return a; }
    static basic_format_arg make(const void* v)             noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::ptr;    a.val_.p=v; return a; }
    static basic_format_arg make_handle(handle_data hd)     noexcept { basic_format_arg a; a.kind_=fmt_arg_kind::handle;  a.val_.hd=hd; return a; }
};

// visit_format_arg_impl — dispatches to visitor based on stored type
template<class Visitor, class Context>
decltype(auto) visit_format_arg_impl(Visitor&& vis, basic_format_arg<Context> arg) {
    using K = fmt_arg_kind;
    switch (arg.kind_) {
    case K::none:     return std::forward<Visitor>(vis)(monostate{});
    case K::boolean:  return std::forward<Visitor>(vis)(arg.val_.b);
    case K::char_t:   return std::forward<Visitor>(vis)(arg.val_.ch);
    case K::int_:     return std::forward<Visitor>(vis)(arg.val_.i);
    case K::long_long:return std::forward<Visitor>(vis)(arg.val_.ll);
    case K::uint_:    return std::forward<Visitor>(vis)(arg.val_.u);
    case K::ullong:   return std::forward<Visitor>(vis)(arg.val_.ull);
    case K::float_:   return std::forward<Visitor>(vis)(arg.val_.f);
    case K::double_:  return std::forward<Visitor>(vis)(arg.val_.d);
    case K::ldouble:  return std::forward<Visitor>(vis)(arg.val_.ld);
    case K::cstring:  return std::forward<Visitor>(vis)(arg.val_.cs);
    case K::strview:  return std::forward<Visitor>(vis)(arg.val_.sv);
    case K::ptr:      return std::forward<Visitor>(vis)(arg.val_.p);
    case K::handle:
        return std::forward<Visitor>(vis)(
            typename basic_format_arg<Context>::handle{arg.val_.hd});
    }
    __builtin_trap();
}

// Public visit_format_arg (deprecated in C++26 but still provided)
template<class Visitor, class Context>
decltype(auto) visit_format_arg(Visitor&& vis, basic_format_arg<Context> arg) {
    return visit_format_arg_impl(std::forward<Visitor>(vis), arg);
}

// ============================================================
// 6. determine_arg_kind + make_basic_format_arg
// ============================================================

namespace fmt_detail {

// Helper to check if D is a string-like type (has value_type + data/size)
// without triggering hard errors for non-class types.
template<class D, class CharT>
inline constexpr bool is_string_like_v = false;

template<class D, class CharT>
    requires requires { typename D::value_type; } &&
             is_same_v<typename D::value_type, CharT>
inline constexpr bool is_string_like_v<D, CharT> = true;

// Map a decayed type to its arg_kind.
// IMPORTANT: char arrays (char[N] / const char[N]) must be handled as cstring
// via decay_t before reaching the handle fallthrough.
template<class Context, class D>
constexpr fmt_arg_kind determine_kind() {
    using CharT = typename Context::char_type;
    // D is already decay_t<T>
    if constexpr (is_same_v<D, bool>)            return fmt_arg_kind::boolean;
    else if constexpr (is_same_v<D, CharT>)      return fmt_arg_kind::char_t;
    else if constexpr (is_same_v<D, float>)      return fmt_arg_kind::float_;
    else if constexpr (is_same_v<D, double>)     return fmt_arg_kind::double_;
    else if constexpr (is_same_v<D, long double>) return fmt_arg_kind::ldouble;
    // char pointer (incl. decayed char array)
    else if constexpr (is_same_v<D, const CharT*> || is_same_v<D, CharT*>)
        return fmt_arg_kind::cstring;
    // void pointer / nullptr_t
    else if constexpr (is_same_v<D, nullptr_t> ||
                       is_same_v<D, void*> ||
                       is_same_v<D, const void*>)
        return fmt_arg_kind::ptr;
    // string / string_view that share the context char_type
    else if constexpr (is_string_like_v<D, CharT>)
        return fmt_arg_kind::strview;
    else if constexpr (signed_integral<D>) {
        if constexpr (sizeof(D) <= sizeof(int))         return fmt_arg_kind::int_;
        else                                            return fmt_arg_kind::long_long;
    }
    else if constexpr (unsigned_integral<D>) {
        if constexpr (sizeof(D) <= sizeof(unsigned))    return fmt_arg_kind::uint_;
        else                                            return fmt_arg_kind::ullong;
    }
    else
        return fmt_arg_kind::handle;
}

} // namespace fmt_detail

// make_basic_format_arg<Context>(v) — creates a basic_format_arg<Context> for v.
// T is the unqualified type as stored; D = decay_t<T>.
template<class Context, class T>
basic_format_arg<Context> make_basic_format_arg(T& v) noexcept {
    using D     = decay_t<T>;
    using CharT = typename Context::char_type;
    using Arg   = basic_format_arg<Context>;

    constexpr fmt_arg_kind k = fmt_detail::determine_kind<Context, D>();

    if constexpr (k == fmt_arg_kind::char_t)
        return Arg::make(static_cast<CharT>(v));
    else if constexpr (k == fmt_arg_kind::int_)
        return Arg::make(static_cast<int>(v));
    else if constexpr (k == fmt_arg_kind::long_long)
        return Arg::make(static_cast<long long>(v));
    else if constexpr (k == fmt_arg_kind::uint_)
        return Arg::make(static_cast<unsigned>(v));
    else if constexpr (k == fmt_arg_kind::ullong)
        return Arg::make(static_cast<unsigned long long>(v));
    else if constexpr (k == fmt_arg_kind::strview) {
        // D has .data()/.size() — safe because this branch is only taken for string-like D
        const CharT* p2 = v.data();
        size_t       s2 = v.size();
        return Arg::make(basic_string_view<CharT>{p2, s2});
    }
    else if constexpr (k == fmt_arg_kind::ptr)
        return Arg::make(static_cast<const void*>(
            // nullptr_t doesn't convert to const void* directly
            []<class U>(U x) -> const void* {
                if constexpr (is_same_v<U, nullptr_t>) return nullptr;
                else return static_cast<const void*>(x);
            }(v)));
    else if constexpr (k == fmt_arg_kind::handle) {
        typename Arg::handle_data hd{
            std::addressof(v),
            [](basic_format_parse_context<CharT>& pc, Context& ctx, const void* p) {
                using Dp = remove_const_t<T>;
                typename Context::template formatter_type<Dp> f;
                pc.advance_to(f.parse(pc));
                ctx.advance_to(f.format(*const_cast<Dp*>(static_cast<const Dp*>(p)), ctx));
            }
        };
        return Arg::make_handle(hd);
    }
    else
        return Arg::make(v); // boolean, float, double, ldouble, cstring
}

// ============================================================
// 7. format_arg_store + basic_format_args
// ============================================================

// Type-erased format_args that works for any Context.
// We store basic_format_arg<Context> directly.
// format_arg_store is a temporary created by make_format_args; it keeps
// the args alive.  basic_format_args just holds a pointer + size.

template<class Context, class... Args>
struct format_arg_store {
    static constexpr size_t N = sizeof...(Args);
    basic_format_arg<Context> storage[N == 0 ? 1 : N];
    size_t count = N;

    format_arg_store(Args&... as) noexcept {
        size_t i = 0;
        ((storage[i++] = make_basic_format_arg<Context>(as)), ...);
    }
};

template<class Context>
class basic_format_args {
    const basic_format_arg<Context>* data_ = nullptr;
    size_t size_                            = 0;
public:
    basic_format_args() noexcept = default;

    template<class... Args>
    basic_format_args(const format_arg_store<Context, Args...>& store) noexcept
        : data_(store.storage), size_(store.count) {}

    [[nodiscard]] basic_format_arg<Context> get(size_t id) const noexcept {
        if (id >= size_) return {};
        return data_[id];
    }
    [[nodiscard]] size_t size() const noexcept { return size_; }
};

// ============================================================
// 8. basic_format_context
// ============================================================

template<class Out, class CharT>
class basic_format_context {
    Out out_;
    basic_format_args<basic_format_context> args_;
public:
    using iterator  = Out;
    using char_type = CharT;

    template<class Tp>
    using formatter_type = formatter<Tp, CharT>;

    explicit basic_format_context(Out out,
                                  basic_format_args<basic_format_context> args)
        : out_(std::move(out)), args_(args) {}

    basic_format_context(const basic_format_context&)            = delete;
    basic_format_context& operator=(const basic_format_context&) = delete;

    [[nodiscard]] basic_format_arg<basic_format_context> arg(size_t id) const noexcept {
        return args_.get(id);
    }

    [[nodiscard]] Out out() { return std::move(out_); }
    void advance_to(Out it) { out_ = std::move(it); }
};

// format_context = Context with back_insert_iterator<string>
using format_context = basic_format_context<back_insert_iterator<string>, char>;
// Convenient alias
using format_args = basic_format_args<format_context>;

