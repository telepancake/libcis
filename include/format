namespace fmt_detail {

// Width/prec arg substitution
template<class Context>
int32_t substitute_arg_id(basic_format_arg<Context> arg) {
    return visit_format_arg_impl([](auto v) -> int32_t {
        using T = remove_cvref_t<decltype(v)>;
        if constexpr (is_same_v<T, int>)               return v;
        if constexpr (is_same_v<T, unsigned>)          return static_cast<int32_t>(v);
        if constexpr (is_same_v<T, long long>)         return static_cast<int32_t>(v);
        if constexpr (is_same_v<T, unsigned long long>) return static_cast<int32_t>(v);
        throw_format_error("Replacement argument isn't a standard signed or unsigned integer type");
        return 0;
    }, arg);
}

// Number parser
template<class It>
struct parse_number_result { It last; uint32_t value; };

template<class It>
constexpr parse_number_result<It> parse_number(It begin, It end) {
    using CharT = typename iterator_traits<It>::value_type;
    It bound = (end - begin > 9) ? begin + 9 : end;
    uint32_t value = static_cast<uint32_t>(*begin - CharT('0'));
    while (++begin != bound) {
        if (*begin < CharT('0') || *begin > CharT('9'))
            return {begin, value};
        value = value * 10u + static_cast<uint32_t>(*begin - CharT('0'));
    }
    if (begin != end && *begin >= CharT('0') && *begin <= CharT('9')) {
        uint64_t v2 = uint64_t(value) * 10 + static_cast<uint32_t>(*begin++ - CharT('0'));
        if (v2 > uint32_t(INT32_MAX) ||
            (begin != end && *begin >= CharT('0') && *begin <= CharT('9')))
            throw_format_error("The numeric value of the format specifier is too large");
        value = static_cast<uint32_t>(v2);
    }
    return {begin, value};
}

template<class It, class ParseCtx>
constexpr parse_number_result<It> parse_arg_id(It begin, It end, ParseCtx& ctx) {
    using CharT = typename iterator_traits<It>::value_type;
    switch (*begin) {
    case CharT('0'): {
        ctx.check_arg_id(0);
        return {++begin, 0};
    }
    case CharT(':'):
    case CharT('}'): {
        uint32_t v = static_cast<uint32_t>(ctx.next_arg_id());
        return {begin, v};
    }
    default:
        if (*begin < CharT('0') || *begin > CharT('9'))
            throw_format_error("The argument index starts with an invalid character");
        auto r = parse_number(begin, end);
        ctx.check_arg_id(r.value);
        return r;
    }
}

// parse_specs: parse a std-format-spec into parsed_specs.
// Returns iterator past consumed chars (should be at '}').
template<class CharT, class ParseCtx, class FmtCtx>
typename ParseCtx::iterator
parse_specs(ParseCtx& pc, FmtCtx& ctx, fmt_spec::fields f,
            fmt_spec::parsed_specs& out) {
    auto begin = pc.begin();
    auto end   = pc.end();

    if (begin == end || *begin == CharT('}'))
        return begin;

    // fill + align detection
    auto is_align = [](CharT c, fmt_spec::alignment& al) -> bool {
        switch (c) {
        case CharT('<'): al = fmt_spec::alignment::left;   return true;
        case CharT('^'): al = fmt_spec::alignment::center; return true;
        case CharT('>'): al = fmt_spec::alignment::right;  return true;
        }
        return false;
    };

    if (begin + 1 != end && is_align(*(begin+1), out.align)) {
        if (*begin == CharT('{'))
            throw_format_error("The fill option contains an invalid value");
        out.fill.data[0] = static_cast<char>(*begin);
        begin += 2;
    } else if (is_align(*begin, out.align)) {
        ++begin;
    }
    if (begin == end || *begin == CharT('}')) return begin;

    // sign
    if (f.sign) {
        switch (*begin) {
        case CharT('-'): out.sign_ = fmt_spec::sign::minus;  ++begin; break;
        case CharT('+'): out.sign_ = fmt_spec::sign::plus;   ++begin; break;
        case CharT(' '): out.sign_ = fmt_spec::sign::space;  ++begin; break;
        default: break;
        }
        if (begin == end || *begin == CharT('}')) return begin;
    }

    // alternate form
    if (f.alt && *begin == CharT('#')) {
        out.alt = true; ++begin;
        if (begin == end || *begin == CharT('}')) return begin;
    }

    // zero-padding
    if (f.zero_pad && *begin == CharT('0')) {
        if (out.align == fmt_spec::alignment::default_)
            out.align = fmt_spec::alignment::zero_padding;
        ++begin;
        if (begin == end || *begin == CharT('}')) return begin;
    }

    // width
    bool     width_as_arg = false;
    uint32_t width_arg_id = 0;
    if (*begin == CharT('{')) {
        ++begin;
        auto r = parse_arg_id(begin, end, pc);
        if (r.last == end || *r.last != CharT('}'))
            throw_format_error("The argument index is invalid");
        ++r.last;
        width_as_arg = true;
        width_arg_id = r.value;
        begin = r.last;
    } else if (*begin >= CharT('1') && *begin <= CharT('9')) {
        auto r = parse_number(begin, end);
        out.width = static_cast<int32_t>(r.value);
        begin = r.last;
    }
    if (begin == end || *begin == CharT('}')) {
        if (width_as_arg) out.width = substitute_arg_id(ctx.arg(width_arg_id));
        return begin;
    }

    // precision
    bool     prec_as_arg = false;
    uint32_t prec_arg_id = 0;
    if (f.precision && *begin == CharT('.')) {
        ++begin;
        if (begin == end)
            throw_format_error("End of input while parsing format specifier precision");
        if (*begin == CharT('{')) {
            ++begin;
            auto r = parse_arg_id(begin, end, pc);
            if (r.last == end || *r.last != CharT('}'))
                throw_format_error("The argument index is invalid");
            ++r.last;
            prec_as_arg = true;
            prec_arg_id = r.value;
            begin = r.last;
        } else if (*begin >= CharT('0') && *begin <= CharT('9')) {
            auto r = parse_number(begin, end);
            out.prec = static_cast<int32_t>(r.value);
            begin = r.last;
        } else {
            throw_format_error("The precision option does not contain a value or an argument index");
        }
        if (begin == end || *begin == CharT('}')) {
            if (width_as_arg) out.width = substitute_arg_id(ctx.arg(width_arg_id));
            if (prec_as_arg)  out.prec  = substitute_arg_id(ctx.arg(prec_arg_id));
            return begin;
        }
    }

    // locale L (skip — no locale support)
    if (f.locale && *begin == CharT('L')) {
        ++begin;
        if (begin == end || *begin == CharT('}')) {
            if (width_as_arg) out.width = substitute_arg_id(ctx.arg(width_arg_id));
            if (prec_as_arg)  out.prec  = substitute_arg_id(ctx.arg(prec_arg_id));
            return begin;
        }
    }

    // type
    if (f.type_field) {
        switch (static_cast<char>(*begin)) {
        case 'A': out.type_ = fmt_spec::type::hexfloat_upper;   ++begin; break;
        case 'B': out.type_ = fmt_spec::type::binary_upper;     ++begin; break;
        case 'E': out.type_ = fmt_spec::type::scientific_upper; ++begin; break;
        case 'F': out.type_ = fmt_spec::type::fixed_upper;      ++begin; break;
        case 'G': out.type_ = fmt_spec::type::general_upper;    ++begin; break;
        case 'X': out.type_ = fmt_spec::type::hex_upper;        ++begin; break;
        case 'a': out.type_ = fmt_spec::type::hexfloat_lower;   ++begin; break;
        case 'b': out.type_ = fmt_spec::type::binary_lower;     ++begin; break;
        case 'c': out.type_ = fmt_spec::type::char_;            ++begin; break;
        case 'd': out.type_ = fmt_spec::type::decimal;          ++begin; break;
        case 'e': out.type_ = fmt_spec::type::scientific_lower; ++begin; break;
        case 'f': out.type_ = fmt_spec::type::fixed_lower;      ++begin; break;
        case 'g': out.type_ = fmt_spec::type::general_lower;    ++begin; break;
        case 'o': out.type_ = fmt_spec::type::octal;            ++begin; break;
        case 'p': out.type_ = fmt_spec::type::pointer_lower;    ++begin; break;
        case 'P': out.type_ = fmt_spec::type::pointer_upper;    ++begin; break;
        case 's': out.type_ = fmt_spec::type::string_;          ++begin; break;
        case 'x': out.type_ = fmt_spec::type::hex_lower;        ++begin; break;
        default:  break;
        }
    }

    // resolve dynamic width/prec
    if (width_as_arg) out.width = substitute_arg_id(ctx.arg(width_arg_id));
    if (prec_as_arg)  out.prec  = substitute_arg_id(ctx.arg(prec_arg_id));

    return begin;
}

// ============================================================
// 13. Output helpers
// ============================================================

struct padding { size_t before; size_t after; };

inline padding calc_padding(size_t sz, size_t w, fmt_spec::alignment align) {
    size_t fill = w - sz;
    switch (align) {
    case fmt_spec::alignment::left:   return {0, fill};
    case fmt_spec::alignment::center: { size_t b = fill/2; return {b, fill-b}; }
    default:                          return {fill, 0};  // right / zero
    }
}

template<class CharT, class Out>
Out write_padded(basic_string_view<CharT> sv, Out out,
                 const fmt_spec::parsed_specs& specs) {
    auto sz  = static_cast<int32_t>(sv.size());
    CharT fc = static_cast<CharT>(specs.fill.data[0]);

    if (!specs.has_width() || sz >= specs.width) {
        for (CharT c : sv) *out++ = c;
        return out;
    }
    auto p = calc_padding(static_cast<size_t>(sz),
                          static_cast<size_t>(specs.width), specs.align);
    for (size_t i = 0; i < p.before; ++i) *out++ = fc;
    for (CharT c : sv)                     *out++ = c;
    for (size_t i = 0; i < p.after;  ++i) *out++ = fc;
    return out;
}

// Integer writer: sign_prefix (e.g. "-0x") + digits, with width/alignment.
template<class CharT, class Out>
Out write_int(const char* sp, size_t sp_len,
              const char* digs, size_t d_len,
              Out out, const fmt_spec::parsed_specs& specs, bool upper = false) {
    size_t total = sp_len + d_len;
    CharT  fc    = static_cast<CharT>(specs.fill.data[0]);

    if (specs.align == fmt_spec::alignment::zero_padding &&
        specs.has_width() && total < static_cast<size_t>(specs.width)) {
        // sign/prefix, then zeros, then digits
        for (size_t i = 0; i < sp_len; ++i) *out++ = static_cast<CharT>(sp[i]);
        size_t zeros = static_cast<size_t>(specs.width) - total;
        for (size_t i = 0; i < zeros; ++i)  *out++ = CharT('0');
        for (size_t i = 0; i < d_len; ++i) {
            char c = digs[i];
            if (upper && c >= 'a' && c <= 'f') c = static_cast<char>(c - 'a' + 'A');
            *out++ = static_cast<CharT>(c);
        }
        return out;
    }

    // Combine into stack buffer
    char buf[128];
    size_t pos = 0;
    for (size_t i = 0; i < sp_len; ++i) buf[pos++] = sp[i];
    for (size_t i = 0; i < d_len;  ++i) {
        char c = digs[i];
        if (upper && c >= 'a' && c <= 'f') c = static_cast<char>(c - 'a' + 'A');
        buf[pos++] = c;
    }

    if (!specs.has_width() || static_cast<int32_t>(pos) >= specs.width) {
        for (size_t i = 0; i < pos; ++i) *out++ = static_cast<CharT>(buf[i]);
        return out;
    }

    fmt_spec::alignment eff = specs.align == fmt_spec::alignment::default_
                               ? fmt_spec::alignment::right : specs.align;
    auto p = calc_padding(pos, static_cast<size_t>(specs.width), eff);
    for (size_t i = 0; i < p.before; ++i) *out++ = fc;
    for (size_t i = 0; i < pos;      ++i) *out++ = static_cast<CharT>(buf[i]);
    for (size_t i = 0; i < p.after;  ++i) *out++ = fc;
    return out;
}

// Integer formatting (both signed/unsigned).
template<class CharT, class T, class FmtCtx>
typename FmtCtx::iterator format_integer(T value, FmtCtx& ctx,
                                          const fmt_spec::parsed_specs& specs) {
    using namespace fmt_spec;

    // Char display type
    if (specs.type_ == type::char_) {
        CharT cv = static_cast<CharT>(value);
        parsed_specs cs = specs;
        if (cs.align == alignment::default_) cs.align = alignment::left;
        auto out = ctx.out();
        ctx.advance_to(write_padded(basic_string_view<CharT>{&cv, 1}, out, cs));
        return ctx.out();
    }

    int base = 10;
    const char* alt_prefix = nullptr;
    bool upper = false;

    switch (specs.type_) {
    case type::binary_lower:  base=2;  if(specs.alt) alt_prefix="0b"; break;
    case type::binary_upper:  base=2;  if(specs.alt) alt_prefix="0B"; break;
    case type::octal:         base=8;  if(specs.alt) alt_prefix="0";  break;
    case type::default_:
    case type::decimal:       base=10; break;
    case type::hex_lower:     base=16; if(specs.alt) alt_prefix="0x"; break;
    case type::hex_upper:     base=16; if(specs.alt) alt_prefix="0X"; upper=true; break;
    default: throw_format_error("Invalid integer type specifier");
    }

    // Extract sign + magnitude
    bool negative = false;
    using UT = make_unsigned_t<T>;
    UT uval;
    if constexpr (is_signed_v<T>) {
        negative = (value < 0);
        uval = negative ? static_cast<UT>(UT(0) - static_cast<UT>(value))
                        : static_cast<UT>(value);
    } else {
        uval = static_cast<UT>(value);
    }

    // Build sign+prefix string
    char sp[8]; size_t sp_len = 0;
    if (negative) {
        sp[sp_len++] = '-';
    } else {
        if      (specs.sign_ == sign::plus)  sp[sp_len++] = '+';
        else if (specs.sign_ == sign::space) sp[sp_len++] = ' ';
    }
    // Octal special: no "0" prefix if value==0
    bool do_alt_prefix = specs.alt && !(specs.type_ == type::octal && uval == 0);
    if (do_alt_prefix && alt_prefix) {
        const char* p = alt_prefix;
        while (*p) sp[sp_len++] = *p++;
    }

    char digs[72];
    auto r = std::to_chars(digs, digs + sizeof(digs), uval, base);
    if (r.ec != std::errc{}) __builtin_trap();
    size_t d_len = static_cast<size_t>(r.ptr - digs);

    auto out = ctx.out();
    ctx.advance_to(write_int<CharT>(sp, sp_len, digs, d_len, out, specs, upper));
    return ctx.out();
}

// Floating-point formatting via snprintf (gcc-10 has no fp to_chars).
// DEVIATION: uses snprintf rather than std::to_chars for floating-point.
template<class CharT, class T, class FmtCtx>
typename FmtCtx::iterator format_float(T value, FmtCtx& ctx,
                                        const fmt_spec::parsed_specs& specs) {
    using namespace fmt_spec;

    // Build printf format string
    char fmt_buf[32]; int fi = 0;
    fmt_buf[fi++] = '%';
    switch (specs.sign_) {
    case sign::plus:  fmt_buf[fi++] = '+'; break;
    case sign::space: fmt_buf[fi++] = ' '; break;
    default: break;
    }
    if (specs.alt) fmt_buf[fi++] = '#';

    if (specs.has_precision()) {
        fmt_buf[fi++] = '.';
        int p = specs.prec;
        if (p >= 100) { fmt_buf[fi++] = static_cast<char>('0'+p/100); p%=100; }
        if (p >=  10) { fmt_buf[fi++] = static_cast<char>('0'+p/10);  p%=10;  }
        fmt_buf[fi++] = static_cast<char>('0'+p);
    }

    if constexpr (is_same_v<T, long double>) fmt_buf[fi++] = 'L';

    char conv = 'g';
    switch (specs.type_) {
    case type::default_:           conv = 'g';                   break;
    case type::scientific_lower:   conv = 'e';                   break;
    case type::scientific_upper:   conv = 'E';                   break;
    case type::fixed_lower:        conv = 'f';                   break;
    case type::fixed_upper:        conv = 'F';                   break;
    case type::general_lower:      conv = 'g';                   break;
    case type::general_upper:      conv = 'G';                   break;
    case type::hexfloat_lower:     conv = 'a';                   break;
    case type::hexfloat_upper:     conv = 'A';                   break;
    default: throw_format_error("Invalid float type specifier");
    }
    fmt_buf[fi++] = conv;
    fmt_buf[fi]   = '\0';

    char tmp[512]; int n;
    if constexpr (is_same_v<T, long double>)
        n = std::snprintf(tmp, sizeof(tmp), fmt_buf, value);
    else
        n = std::snprintf(tmp, sizeof(tmp), fmt_buf, static_cast<double>(value));

    if (n < 0 || static_cast<size_t>(n) >= sizeof(tmp))
        throw_format_error("Float formatting buffer overflow");

    basic_string_view<char> sv{tmp, static_cast<size_t>(n)};
    auto out = ctx.out();

    // zero-padding: sign/prefix then zeros
    if (specs.align == alignment::zero_padding &&
        specs.has_width() && static_cast<int32_t>(sv.size()) < specs.width) {
        size_t sig_end = 0;
        if (sv.size() > 0 && (sv[0]=='+' || sv[0]=='-' || sv[0]==' '))
            sig_end = 1;
        size_t zeros = static_cast<size_t>(specs.width) - sv.size();
        for (size_t i = 0; i < sig_end; ++i) *out++ = static_cast<CharT>(sv[i]);
        for (size_t i = 0; i < zeros;   ++i) *out++ = CharT('0');
        for (size_t i = sig_end; i < sv.size(); ++i) *out++ = static_cast<CharT>(sv[i]);
    } else {
        parsed_specs ps2 = specs;
        if (ps2.align == alignment::default_) ps2.align = alignment::right;
        if constexpr (is_same_v<CharT, char>) {
            out = write_padded(sv, out, ps2);
        } else {
            basic_string<CharT> ws;
            ws.reserve(sv.size());
            for (char c : sv) ws.push_back(static_cast<CharT>(c));
            out = write_padded(basic_string_view<CharT>{ws.data(), ws.size()}, out, ps2);
        }
    }
    ctx.advance_to(out);
    return ctx.out();
}

