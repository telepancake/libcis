template <class CharT>
constexpr void process_parsed_integer(parser<CharT>& parser, const char* id) {
  switch (parser.type_) {
  case format_spec::type::default_:
  case format_spec::type::binary_lower_case:
  case format_spec::type::binary_upper_case:
  case format_spec::type::octal:
  case format_spec::type::decimal:
  case format_spec::type::hexadecimal_lower_case:
  case format_spec::type::hexadecimal_upper_case:
    break;

