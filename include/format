struct formatter_pointer {
public:
  template <class ParseContext>
  constexpr typename ParseContext::iterator parse(ParseContext& ctx) {
    typename ParseContext::iterator result = parser_.parse(ctx, format_spec::fields_pointer);
    format_spec::process_display_type_pointer(parser_.type_, "a pointer");
    return result;
  }

  template <class FormatContext>
  typename FormatContext::iterator format(const void* ptr, FormatContext& ctx) const {
    format_spec::parsed_specifications<CharT> specs = parser_.get_parsed_std_specifications(ctx);
    specs.std_.alternate_form_                       = true;
    specs.std_.type_ =
        specs.std_.type_ == format_spec::type::pointer_upper_case
            ? format_spec::type::hexadecimal_upper_case
            : format_spec::type::hexadecimal_lower_case;

    return fmtops::format_integer(reinterpret_cast<uintptr_t>(ptr), ctx, specs);
  }

  format_spec::parser<CharT> parser_;
};

