  optional<std::locale> loc_;

  template <class OtherOutIt, class OtherCharT>
  friend basic_format_context<OtherOutIt, OtherCharT> __format_context_create(
      OtherOutIt, basic_format_args<basic_format_context<OtherOutIt, OtherCharT>>, optional<std::locale>&&);

