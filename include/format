          return static_cast<Context*>(c)->arg(id).visit(std::move(visitor));
#  else
          
          return std::visit_format_arg_internal(std::move(visitor), static_cast<Context*>(c)->arg(id));
          
#  endif // LIBCPP_STD_VER >= 26 && LIBCPP_HAS_EXPLICIT_THIS_PARAMETER
        }) {
  }

  basic_format_arg<basic_format_context> arg(size_t id) const noexcept {
    return arg_(ctx_, id);
  }
  std::locale locale() { return loc_(ctx_); }
  iterator out() { return std::move(out_it_); }
  void advance_to(iterator it) { out_it_ = std::move(it); }

private:
  iterator out_it_;

  std::locale (*loc_)(void* ctx);

  void* ctx_;
  basic_format_arg<basic_format_context> (*arg_)(void* ctx, size_t id);
