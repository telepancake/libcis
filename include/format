// ---------- bool ----------
template<class CharT>
struct formatter<bool, CharT> {
    fmt_spec::parsed_specs specs_;

    template<class ParseCtx>
    constexpr typename ParseCtx::iterator parse(ParseCtx& pc) {
        fmt_detail::dummy_ctx d;
        auto it = fmt_detail::parse_specs<CharT>(pc, d,
                      fmt_spec::fields_bool, specs_);
        pc.advance_to(it);
        return it;
    }

    template<class FmtCtx>
    typename FmtCtx::iterator format(bool value, FmtCtx& ctx) const {
        using t = fmt_spec::type;
        fmt_spec::parsed_specs s = specs_;
        // Resolve dynamic width from ctx
        // (static parse already happened, dynamic arg-id was resolved in parse_specs)

        if (s.type_ != t::default_ && s.type_ != t::string_) {
            // format as integer
            formatter<unsigned, CharT> fi; fi.specs_ = s;
            return fi.format(static_cast<unsigned>(value), ctx);
        }
        // String
        if (s.align == fmt_spec::alignment::default_)
            s.align = fmt_spec::alignment::left;
        basic_string_view<CharT> sv;
        if constexpr (is_same_v<CharT, char>)
            sv = value ? basic_string_view<CharT>{"true",4}
                       : basic_string_view<CharT>{"false",5};
        auto out = ctx.out();
        ctx.advance_to(fmt_detail::write_padded(sv, out, s));
        return ctx.out();
    }
};

// ---------- CharT (char) ----------
template<class CharT>
struct formatter<CharT, CharT> {
    fmt_spec::parsed_specs specs_;

    template<class ParseCtx>
    constexpr typename ParseCtx::iterator parse(ParseCtx& pc) {
        fmt_detail::dummy_ctx d;
        auto it = fmt_detail::parse_specs<CharT>(pc, d,
                      fmt_spec::fields_bool, specs_);
        pc.advance_to(it);
        return it;
    }

    template<class FmtCtx>
    typename FmtCtx::iterator format(CharT value, FmtCtx& ctx) const {
        fmt_spec::parsed_specs s = specs_;
        using t = fmt_spec::type;
        if (s.type_ != t::default_ && s.type_ != t::char_) {
            formatter<int, CharT> fi; fi.specs_ = s;
            return fi.format(static_cast<int>(value), ctx);
        }
        if (s.align == fmt_spec::alignment::default_)
            s.align = fmt_spec::alignment::left;
        auto out = ctx.out();
        ctx.advance_to(fmt_detail::write_padded(basic_string_view<CharT>{&value,1}, out, s));
        return ctx.out();
    }
};

