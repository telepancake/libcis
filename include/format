// This function is not user observable, so it can directly use the non-standard
// types of the "variant". See arg_t for more details.
template <class Visitor, class Context>
decltype(auto) visit_format_arg_internal(Visitor&& vis, basic_format_arg<Context> arg) {
  switch (arg.type_) {
  case fmt::arg_t::none:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.monostate_);
  case fmt::arg_t::boolean:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.boolean_);
  case fmt::arg_t::char_type:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.char_type_);
  case fmt::arg_t::int_:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.int_);
  case fmt::arg_t::long_long:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.long_long_);
  case fmt::arg_t::i128:
    __builtin_unreachable();
  case fmt::arg_t::unsigned_:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.unsigned_);
  case fmt::arg_t::unsigned_long_long:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.unsigned_long_long_);
  case fmt::arg_t::u128:
    __builtin_unreachable();
  case fmt::arg_t::float_:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.float_);
  case fmt::arg_t::double_:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.double_);
  case fmt::arg_t::long_double:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.long_double_);
  case fmt::arg_t::const_char_type_ptr:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.const_char_type_ptr_);
  case fmt::arg_t::string_view:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.string_view_);
  case fmt::arg_t::ptr:
    return std::invoke(std::forward<Visitor>(vis), arg.value_.ptr_);
  case fmt::arg_t::handle:
    return std::invoke(
        std::forward<Visitor>(vis), typename basic_format_arg<Context>::handle{arg.value_.handle_});
  }

  __builtin_unreachable();
}

