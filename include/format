  void advance_to(iterator it) { out_it_ = std::move(it); }

private:
  iterator out_it_;
  basic_format_args<basic_format_context> args_;

  // The Standard doesn't specify how the locale is stored.
  // [format.context]/6
  // std::locale locale();
