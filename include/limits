// <limits> -- numeric_limits and related types.
// Mechanically ported from libc++ include/limits (self-contained, no __limits/ subdir).
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Builtins used:
//   __CHAR_BIT__, __FLT_RADIX__
//   __FLT_MANT_DIG__, __FLT_DIG__, __FLT_EPSILON__, __FLT_MIN__, __FLT_MAX__,
//   __FLT_DENORM_MIN__, __FLT_MIN_EXP__, __FLT_MIN_10_EXP__,
//   __FLT_MAX_EXP__, __FLT_MAX_10_EXP__
//   __DBL_MANT_DIG__, __DBL_DIG__, __DBL_EPSILON__, __DBL_MIN__, __DBL_MAX__,
//   __DBL_DENORM_MIN__, __DBL_MIN_EXP__, __DBL_MIN_10_EXP__,
//   __DBL_MAX_EXP__, __DBL_MAX_10_EXP__
//   __LDBL_MANT_DIG__, __LDBL_DIG__, __LDBL_EPSILON__, __LDBL_MIN__, __LDBL_MAX__,
//   __LDBL_DENORM_MIN__, __LDBL_MIN_EXP__, __LDBL_MIN_10_EXP__,
//   __LDBL_MAX_EXP__, __LDBL_MAX_10_EXP__
//   __builtin_huge_valf, __builtin_nanf, __builtin_nansf  (float)
//   __builtin_huge_val,  __builtin_nan,  __builtin_nans   (double)
//   __builtin_huge_vall, __builtin_nanl, __builtin_nansl  (long double)
//
// NOTE: __builtin_popcountg is gcc-13+; we use sizeof(T)*__CHAR_BIT__-is_signed
//       to compute `digits` for integer types (exact for all standard types).
#pragma once

#include <type_traits>

namespace std {

//===----------------------------------------------------------------------===//
// float_round_style, float_denorm_style
//===----------------------------------------------------------------------===//
enum float_round_style {
    round_indeterminate       = -1,
    round_toward_zero         =  0,
    round_to_nearest          =  1,
    round_toward_infinity     =  2,
    round_toward_neg_infinity =  3
};

enum float_denorm_style {
    denorm_indeterminate = -1,
    denorm_absent        =  0,
    denorm_present       =  1
};

//===----------------------------------------------------------------------===//
// numeric_limits_base — unspecialized (non-arithmetic types)
//===----------------------------------------------------------------------===//
template<class T, bool = is_arithmetic_v<T>>
class numeric_limits_base {
protected:
    using type = T;

    static constexpr bool is_specialized = false;
    [[nodiscard]] static constexpr type min()     noexcept { return type(); }
    [[nodiscard]] static constexpr type max()     noexcept { return type(); }
    [[nodiscard]] static constexpr type lowest()  noexcept { return type(); }

    static constexpr int  digits       = 0;
    static constexpr int  digits10     = 0;
    static constexpr int  max_digits10 = 0;
    static constexpr bool is_signed    = false;
    static constexpr bool is_integer   = false;
    static constexpr bool is_exact     = false;
    static constexpr int  radix        = 0;
    [[nodiscard]] static constexpr type epsilon()     noexcept { return type(); }
    [[nodiscard]] static constexpr type round_error() noexcept { return type(); }

    static constexpr int min_exponent   = 0;
    static constexpr int min_exponent10 = 0;
    static constexpr int max_exponent   = 0;
    static constexpr int max_exponent10 = 0;

    static constexpr bool has_infinity     = false;
    static constexpr bool has_quiet_NaN    = false;
    static constexpr bool has_signaling_NaN = false;
    static constexpr float_denorm_style has_denorm = denorm_absent;
    static constexpr bool has_denorm_loss  = false;
    [[nodiscard]] static constexpr type infinity()     noexcept { return type(); }
    [[nodiscard]] static constexpr type quiet_NaN()    noexcept { return type(); }
    [[nodiscard]] static constexpr type signaling_NaN() noexcept { return type(); }
    [[nodiscard]] static constexpr type denorm_min()   noexcept { return type(); }

    static constexpr bool is_iec559  = false;
    static constexpr bool is_bounded = false;
    static constexpr bool is_modulo  = false;

    static constexpr bool traps           = false;
    static constexpr bool tinyness_before = false;
    static constexpr float_round_style round_style = round_toward_zero;
};

//===----------------------------------------------------------------------===//
// numeric_limits_base — arithmetic (integer) specialization
// Uses sizeof(T)*__CHAR_BIT__ - is_signed for digits (exact for standard types;
// __builtin_popcountg is gcc-13+ only).
//===----------------------------------------------------------------------===//
template<class T>
class numeric_limits_base<T, true> {
protected:
    using type = T;

    static constexpr bool is_specialized = true;
    static constexpr bool is_signed      = type(-1) < type(0);
    static constexpr int  digits         =
        static_cast<int>(sizeof(type) * __CHAR_BIT__) - (is_signed ? 1 : 0);
    // digits10 = floor(digits * log10(2)); 1936274/6432163 is a convergent.
    static constexpr int  digits10       = static_cast<int>((digits * 1936274LL) / 6432163);
    static constexpr int  max_digits10   = 0;
    static constexpr type min_val        = is_signed ? type(type(1) << digits) : type(0);
    static constexpr type max_val        = is_signed ? type(type(~type(0)) ^ min_val) : type(~type(0));
    [[nodiscard]] static constexpr type min()    noexcept { return min_val; }
    [[nodiscard]] static constexpr type max()    noexcept { return max_val; }
    [[nodiscard]] static constexpr type lowest() noexcept { return min(); }

    static constexpr bool is_integer = true;
    static constexpr bool is_exact   = true;
    static constexpr int  radix      = 2;
    [[nodiscard]] static constexpr type epsilon()     noexcept { return type(0); }
    [[nodiscard]] static constexpr type round_error() noexcept { return type(0); }

    static constexpr int min_exponent   = 0;
    static constexpr int min_exponent10 = 0;
    static constexpr int max_exponent   = 0;
    static constexpr int max_exponent10 = 0;

    static constexpr bool has_infinity      = false;
    static constexpr bool has_quiet_NaN     = false;
    static constexpr bool has_signaling_NaN = false;
    static constexpr float_denorm_style has_denorm = denorm_absent;
    static constexpr bool has_denorm_loss   = false;
    [[nodiscard]] static constexpr type infinity()      noexcept { return type(0); }
    [[nodiscard]] static constexpr type quiet_NaN()     noexcept { return type(0); }
    [[nodiscard]] static constexpr type signaling_NaN() noexcept { return type(0); }
    [[nodiscard]] static constexpr type denorm_min()    noexcept { return type(0); }

    static constexpr bool is_iec559  = false;
    static constexpr bool is_bounded = true;
    static constexpr bool is_modulo  = !is_signed;

#if defined(__i386__) || defined(__x86_64__) || defined(__wasm__)
    static constexpr bool traps = __is_same(decltype(+type(0)), type);
#else
    static constexpr bool traps = false;
#endif
    static constexpr bool tinyness_before          = false;
    static constexpr float_round_style round_style = round_toward_zero;
};

