//===----------------------------------------------------------------------===//
// numeric_limits — public face, inherits from numeric_limits_base
//===----------------------------------------------------------------------===//
template<class T>
class numeric_limits : private numeric_limits_base<T> {
    using base = numeric_limits_base<T>;
    using type = typename base::type;
public:
    static inline constexpr bool is_specialized = base::is_specialized;
    [[nodiscard]] static constexpr type min()    noexcept { return base::min(); }
    [[nodiscard]] static constexpr type max()    noexcept { return base::max(); }
    [[nodiscard]] static constexpr type lowest() noexcept { return base::lowest(); }

    static inline constexpr int  digits       = base::digits;
    static inline constexpr int  digits10     = base::digits10;
    static inline constexpr int  max_digits10 = base::max_digits10;
    static inline constexpr bool is_signed    = base::is_signed;
    static inline constexpr bool is_integer   = base::is_integer;
    static inline constexpr bool is_exact     = base::is_exact;
    static inline constexpr int  radix        = base::radix;
    [[nodiscard]] static constexpr type epsilon()     noexcept { return base::epsilon(); }
    [[nodiscard]] static constexpr type round_error() noexcept { return base::round_error(); }

    static inline constexpr int min_exponent   = base::min_exponent;
    static inline constexpr int min_exponent10 = base::min_exponent10;
    static inline constexpr int max_exponent   = base::max_exponent;
    static inline constexpr int max_exponent10 = base::max_exponent10;

    static inline constexpr bool has_infinity      = base::has_infinity;
    static inline constexpr bool has_quiet_NaN     = base::has_quiet_NaN;
    static inline constexpr bool has_signaling_NaN = base::has_signaling_NaN;
    static inline constexpr float_denorm_style has_denorm = base::has_denorm;
    static inline constexpr bool has_denorm_loss   = base::has_denorm_loss;
    [[nodiscard]] static constexpr type infinity()      noexcept { return base::infinity(); }
    [[nodiscard]] static constexpr type quiet_NaN()     noexcept { return base::quiet_NaN(); }
    [[nodiscard]] static constexpr type signaling_NaN() noexcept { return base::signaling_NaN(); }
    [[nodiscard]] static constexpr type denorm_min()    noexcept { return base::denorm_min(); }

    static inline constexpr bool is_iec559  = base::is_iec559;
    static inline constexpr bool is_bounded = base::is_bounded;
    static inline constexpr bool is_modulo  = base::is_modulo;

    static inline constexpr bool traps           = base::traps;
    static inline constexpr bool tinyness_before = base::tinyness_before;
    static inline constexpr float_round_style round_style = base::round_style;
};

// CV-qualified specializations just inherit the unqualified one.
template<class T> class numeric_limits<const T>          : public numeric_limits<T> {};
template<class T> class numeric_limits<volatile T>       : public numeric_limits<T> {};
template<class T> class numeric_limits<const volatile T> : public numeric_limits<T> {};

} // namespace std
