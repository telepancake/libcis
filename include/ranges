namespace ranges {

namespace transform_detail {
    template<bool Const, class View>
    using maybe_const = conditional_t<Const, const View, View>;

    template<class View>
    struct transform_iter_concept { using type = input_iterator_tag; };
    template<random_access_range View>
    struct transform_iter_concept<View> { using type = random_access_iterator_tag; };
    template<bidirectional_range View>
    struct transform_iter_concept<View> { using type = bidirectional_iterator_tag; };
    template<forward_range View>
    struct transform_iter_concept<View> { using type = forward_iterator_tag; };

    template<class View, class Fn>
    struct transform_iter_cat_base {};
    template<forward_range View, class Fn>
    struct transform_iter_cat_base<View, Fn> {
        using Cat = typename iterator_traits<iterator_t<View>>::iterator_category;
        using iterator_category =
            conditional_t<is_reference_v<invoke_result_t<Fn&, range_reference_t<View>>>,
                conditional_t<derived_from<Cat, contiguous_iterator_tag>,
                              random_access_iterator_tag,
                              Cat>,
                input_iterator_tag>;
    };
} // namespace transform_detail

template<input_range View, copy_constructible Fn>
    requires view<View> && is_object_v<Fn> &&
             regular_invocable<Fn&, range_reference_t<View>> &&
             requires { typename type_identity<invoke_result_t<Fn&, range_reference_t<View>>&>; }
class transform_view : public view_interface<transform_view<View, Fn>> {
    template<bool Const>
    class iterator;
    template<bool Const>
    class sentinel;

    [[no_unique_address]] movable_box<Fn> func_;
    [[no_unique_address]] View base_ = View();

public:
    transform_view()
        requires default_initializable<View> && default_initializable<Fn>
    = default;
    constexpr transform_view(View base, Fn func)
        : func_(in_place, move(func)), base_(move(base)) {}

    constexpr View base() const& requires copy_constructible<View> { return base_; }
    constexpr View base() && { return move(base_); }

    constexpr iterator<false> begin() { return {*this, ranges::begin(base_)}; }
    constexpr iterator<true> begin() const
        requires range<const View> &&
                 regular_invocable<const Fn&, range_reference_t<const View>>
    { return {*this, ranges::begin(base_)}; }

    constexpr sentinel<false> end() { return sentinel<false>(ranges::end(base_)); }
    constexpr iterator<false> end() requires common_range<View> {
        return {*this, ranges::end(base_)};
    }
    constexpr sentinel<true> end() const
        requires range<const View> &&
                 regular_invocable<const Fn&, range_reference_t<const View>>
    { return sentinel<true>(ranges::end(base_)); }
    constexpr iterator<true> end() const
        requires common_range<const View> &&
                 regular_invocable<const Fn&, range_reference_t<const View>>
    { return {*this, ranges::end(base_)}; }

    constexpr auto size() requires sized_range<View> { return ranges::size(base_); }
    constexpr auto size() const requires sized_range<const View> { return ranges::size(base_); }
};

template<class Range, class Fn>
transform_view(Range&&, Fn) -> transform_view<views::all_t<Range>, Fn>;

template<input_range View, copy_constructible Fn>
    requires view<View> && is_object_v<Fn> &&
             regular_invocable<Fn&, range_reference_t<View>> &&
             requires { typename type_identity<invoke_result_t<Fn&, range_reference_t<View>>&>; }
template<bool Const>
class transform_view<View, Fn>::iterator
    : public transform_detail::transform_iter_cat_base<
        transform_detail::maybe_const<Const, View>,
        transform_detail::maybe_const<Const, Fn>>
{
    using Parent = transform_detail::maybe_const<Const, transform_view>;
    using Base   = transform_detail::maybe_const<Const, View>;
    Parent* parent_ = nullptr;

    template<bool>
    friend class transform_view<View, Fn>::iterator;
    template<bool>
    friend class transform_view<View, Fn>::sentinel;
public:
    iterator_t<Base> current_ = iterator_t<Base>();
    using iterator_concept = typename transform_detail::transform_iter_concept<View>::type;
    using value_type = remove_cvref_t<invoke_result_t<transform_detail::maybe_const<Const, Fn>&,
                                                       range_reference_t<Base>>>;
    using difference_type = range_difference_t<Base>;

    iterator()
        requires default_initializable<iterator_t<Base>>
    = default;
    constexpr iterator(Parent& parent, iterator_t<Base> current)
        : parent_(addressof(parent)), current_(move(current)) {}
    constexpr iterator(iterator<!Const> i)
        requires Const && convertible_to<iterator_t<View>, iterator_t<Base>>
        : parent_(i.parent_), current_(move(i.current_)) {}

    constexpr const iterator_t<Base>& base() const& noexcept { return current_; }
    constexpr iterator_t<Base> base() && { return move(current_); }

    constexpr decltype(auto) operator*() const
        noexcept(noexcept(invoke(*parent_->func_, *current_))) {
        return invoke(*parent_->func_, *current_);
    }

    constexpr iterator& operator++() { ++current_; return *this; }
    constexpr void operator++(int) { ++current_; }
    constexpr iterator operator++(int) requires forward_range<Base> {
        auto tmp = *this; ++*this; return tmp;
    }
    constexpr iterator& operator--() requires bidirectional_range<Base> {
        --current_; return *this;
    }
    constexpr iterator operator--(int) requires bidirectional_range<Base> {
        auto tmp = *this; --*this; return tmp;
    }
    constexpr iterator& operator+=(difference_type n) requires random_access_range<Base> {
        current_ += n; return *this;
    }
    constexpr iterator& operator-=(difference_type n) requires random_access_range<Base> {
        current_ -= n; return *this;
    }
    constexpr decltype(auto) operator[](difference_type n) const
        noexcept(noexcept(invoke(*parent_->func_, current_[n])))
        requires random_access_range<Base>
    { return invoke(*parent_->func_, current_[n]); }

    friend constexpr bool operator==(const iterator& x, const iterator& y)
        requires equality_comparable<iterator_t<Base>>
    { return x.current_ == y.current_; }
    friend constexpr bool operator<(const iterator& x, const iterator& y)
        requires random_access_range<Base>
    { return x.current_ < y.current_; }
    friend constexpr bool operator>(const iterator& x, const iterator& y)
        requires random_access_range<Base>
    { return x.current_ > y.current_; }
    friend constexpr bool operator<=(const iterator& x, const iterator& y)
        requires random_access_range<Base>
    { return x.current_ <= y.current_; }
    friend constexpr bool operator>=(const iterator& x, const iterator& y)
        requires random_access_range<Base>
    { return x.current_ >= y.current_; }
    friend constexpr auto operator<=>(const iterator& x, const iterator& y)
        requires random_access_range<Base> && three_way_comparable<iterator_t<Base>>
    { return x.current_ <=> y.current_; }

    friend constexpr iterator operator+(iterator i, difference_type n)
        requires random_access_range<Base>
    { return {*i.parent_, i.current_ + n}; }
    friend constexpr iterator operator+(difference_type n, iterator i)
        requires random_access_range<Base>
    { return {*i.parent_, i.current_ + n}; }
    friend constexpr iterator operator-(iterator i, difference_type n)
        requires random_access_range<Base>
    { return {*i.parent_, i.current_ - n}; }
    friend constexpr difference_type operator-(const iterator& x, const iterator& y)
        requires sized_sentinel_for<iterator_t<Base>, iterator_t<Base>>
    { return x.current_ - y.current_; }
};

template<input_range View, copy_constructible Fn>
    requires view<View> && is_object_v<Fn> &&
             regular_invocable<Fn&, range_reference_t<View>> &&
             requires { typename type_identity<invoke_result_t<Fn&, range_reference_t<View>>&>; }
template<bool Const>
class transform_view<View, Fn>::sentinel {
    using Base   = transform_detail::maybe_const<Const, View>;
    sentinel_t<Base> end_ = sentinel_t<Base>();

    template<bool>
    friend class transform_view<View, Fn>::iterator;
    template<bool>
