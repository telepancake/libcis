namespace ranges {

template<input_range View, indirect_unary_predicate<iterator_t<View>> Pred>
    requires view<View> && is_object_v<Pred>
class filter_view : public view_interface<filter_view<View, Pred>> {
    [[no_unique_address]] View base_ = View();
    [[no_unique_address]] movable_box<Pred> pred_;

    // cache begin() for forward ranges
    static constexpr bool use_cache = forward_range<View>;
    using Cache = conditional_t<use_cache, non_propagating_cache<iterator_t<View>>, empty_cache>;
    [[no_unique_address]] Cache cached_begin_ = Cache();

    class iterator;
    class sentinel;

public:
    filter_view()
        requires default_initializable<View> && default_initializable<Pred>
    = default;
    constexpr filter_view(View base, Pred pred)
        : base_(move(base)), pred_(in_place, move(pred)) {}

    constexpr View base() const& requires copy_constructible<View> { return base_; }
    constexpr View base() && { return move(base_); }
    constexpr const Pred& pred() const { return *pred_; }

    constexpr iterator begin() {
        if constexpr (use_cache) {
            if (!cached_begin_.has_value()) {
                auto it = ranges::begin(base_);
                while (it != ranges::end(base_) && !invoke(*pred_, *it)) ++it;
                cached_begin_.emplace(it);
            }
            return {*this, *cached_begin_};
        } else {
            auto it = ranges::begin(base_);
            while (it != ranges::end(base_) && !invoke(*pred_, *it)) ++it;
            return {*this, it};
        }
    }
    constexpr auto end() {
        if constexpr (common_range<View>)
            return iterator{*this, ranges::end(base_)};
        else
            return sentinel{*this};
    }
};

template<class Range, class Pred>
filter_view(Range&&, Pred) -> filter_view<views::all_t<Range>, Pred>;

template<class View>
struct filter_iter_cat {};
template<forward_range View>
struct filter_iter_cat<View> {
    using Cat = typename iterator_traits<iterator_t<View>>::iterator_category;
    using iterator_category =
        conditional_t<derived_from<Cat, bidirectional_iterator_tag>,
                      bidirectional_iterator_tag,
        conditional_t<derived_from<Cat, forward_iterator_tag>,
                      forward_iterator_tag,
                      Cat>>;
};

template<input_range View, indirect_unary_predicate<iterator_t<View>> Pred>
    requires view<View> && is_object_v<Pred>
class filter_view<View, Pred>::iterator : public filter_iter_cat<View> {
public:
    [[no_unique_address]] iterator_t<View> current_ = iterator_t<View>();
    [[no_unique_address]] filter_view* parent_ = nullptr;

    using iterator_concept =
        conditional_t<bidirectional_range<View>, bidirectional_iterator_tag,
        conditional_t<forward_range<View>, forward_iterator_tag,
        input_iterator_tag>>;
    using value_type = range_value_t<View>;
    using difference_type = range_difference_t<View>;

    iterator()
        requires default_initializable<iterator_t<View>>
    = default;
    constexpr iterator(filter_view& parent, iterator_t<View> current)
        : current_(move(current)), parent_(addressof(parent)) {}

    [[nodiscard]] constexpr const iterator_t<View>& base() const& noexcept { return current_; }
    [[nodiscard]] constexpr iterator_t<View> base() && { return move(current_); }
    [[nodiscard]] constexpr range_reference_t<View> operator*() const { return *current_; }
    constexpr iterator_t<View> operator->() const
        requires requires(iterator_t<View> i) { i.operator->(); } && copyable<iterator_t<View>>
    { return current_; }

    constexpr iterator& operator++() {
        ++current_;
        while (current_ != ranges::end(parent_->base_) && !invoke(*parent_->pred_, *current_))
            ++current_;
        return *this;
    }
    constexpr void operator++(int) { ++*this; }
    constexpr iterator operator++(int) requires forward_range<View> {
        auto tmp = *this; ++*this; return tmp;
    }
    constexpr iterator& operator--() requires bidirectional_range<View> {
        do { --current_; } while (!invoke(*parent_->pred_, *current_));
        return *this;
    }
    constexpr iterator operator--(int) requires bidirectional_range<View> {
        auto tmp = *this; --*this; return tmp;
    }

    friend constexpr bool operator==(const iterator& x, const iterator& y)
        requires equality_comparable<iterator_t<View>>
    { return x.current_ == y.current_; }

    friend constexpr range_rvalue_reference_t<View>
    iter_move(const iterator& it) noexcept(noexcept(ranges::iter_move(it.current_))) {
        return ranges::iter_move(it.current_);
    }
    friend constexpr void iter_swap(const iterator& x, const iterator& y)
        noexcept(noexcept(ranges::iter_swap(x.current_, y.current_)))
        requires indirectly_swappable<iterator_t<View>>
    { ranges::iter_swap(x.current_, y.current_); }
};

template<input_range View, indirect_unary_predicate<iterator_t<View>> Pred>
    requires view<View> && is_object_v<Pred>
class filter_view<View, Pred>::sentinel {
public:
    sentinel_t<View> end_ = sentinel_t<View>();
    sentinel() = default;
    constexpr explicit sentinel(filter_view& parent) : end_(ranges::end(parent.base_)) {}
    [[nodiscard]] constexpr sentinel_t<View> base() const { return end_; }
    friend constexpr bool operator==(const iterator& x, const sentinel& y) {
        return x.current_ == y.end_;
    }
};

template<class View, class Pred>
inline constexpr bool enable_view<filter_view<View, Pred>> = true;

