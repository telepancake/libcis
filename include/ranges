//===----------------------------------------------------------------------===//
// Range adaptor closure infrastructure + operator|
//===----------------------------------------------------------------------===//

namespace ranges {

template<class T>
    requires is_class_v<T> && same_as<T, remove_cv_t<T>>
struct range_adaptor_closure_base {};

// pipeable: wraps a function as a range_adaptor_closure
template<class Fn>
struct pipeable : Fn, range_adaptor_closure_base<pipeable<Fn>> {
    constexpr explicit pipeable(Fn&& f) : Fn(move(f)) {}
};

template<class T>
T derived_from_range_adaptor_closure(range_adaptor_closure_base<T>*);

template<class T>
concept range_adaptor_closure_type =
    !ranges::range<remove_cvref_t<T>> &&
    requires {
        { derived_from_range_adaptor_closure((remove_cvref_t<T>*)nullptr) }
            -> same_as<remove_cvref_t<T>>;
    };

// range | closure
template<ranges::range Range, range_adaptor_closure_type Closure>
    requires invocable<Closure, Range>
[[nodiscard]] constexpr decltype(auto)
operator|(Range&& range, Closure&& closure)
    noexcept(is_nothrow_invocable_v<Closure, Range>)
{
    return invoke(forward<Closure>(closure), forward<Range>(range));
}

// closure1 | closure2  -> composed closure
template<range_adaptor_closure_type C1, range_adaptor_closure_type C2>
    requires constructible_from<decay_t<C1>, C1> && constructible_from<decay_t<C2>, C2>
[[nodiscard]] constexpr auto operator|(C1&& c1, C2&& c2)
    noexcept(is_nothrow_constructible_v<decay_t<C1>, C1> &&
             is_nothrow_constructible_v<decay_t<C2>, C2>)
{
    // return a closure that applies c1 then c2
    return pipeable([c1_ = forward<C1>(c1), c2_ = forward<C2>(c2)](auto&& range) mutable
        -> decltype(auto) {
        return invoke(c2_, invoke(c1_, forward<decltype(range)>(range)));
    });
}

// bind_back helper (simplified: bind last N args)
namespace bind_back_detail {
    template<class Fn, class... BoundArgs>
    struct bind_back_fn : range_adaptor_closure_base<bind_back_fn<Fn, BoundArgs...>> {
        Fn fn_;
        tuple<BoundArgs...> bound_;

        // Explicit constructor to avoid aggregate-init issues with base class
        constexpr bind_back_fn(Fn f, tuple<BoundArgs...> b)
            : fn_(move(f)), bound_(move(b)) {}

        template<class Range>
        constexpr decltype(auto) operator()(Range&& range) & {
            return apply([&](auto&... args) -> decltype(auto) {
                return invoke(fn_, forward<Range>(range), args...);
            }, bound_);
        }
        template<class Range>
        constexpr decltype(auto) operator()(Range&& range) const& {
            return apply([&](const auto&... args) -> decltype(auto) {
                return invoke(fn_, forward<Range>(range), args...);
            }, bound_);
        }
        template<class Range>
        constexpr decltype(auto) operator()(Range&& range) && {
            return apply([&](auto&&... args) -> decltype(auto) {
                return invoke(move(fn_), forward<Range>(range), move(args)...);
            }, move(bound_));
        }
    };
} // namespace bind_back_detail

template<class Fn, class... Args>
constexpr auto bind_back(Fn&& fn, Args&&... args) {
    return bind_back_detail::bind_back_fn<decay_t<Fn>, decay_t<Args>...>{
        decay_t<Fn>(forward<Fn>(fn)),
        tuple<decay_t<Args>...>(forward<Args>(args)...)
    };
}

} // namespace ranges

