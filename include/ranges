    }
    template<bool OtherConst>
        requires sized_sentinel_for<sentinel_t<Base>,
                                    iterator_t<transform_detail::maybe_const<OtherConst, View>>>
    friend constexpr range_difference_t<transform_detail::maybe_const<OtherConst, View>>
    operator-(const sentinel& x, const iterator<OtherConst>& y) {
