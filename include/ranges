// <ranges> — C++20 ranges library.
// Mechanically ported from libc++ include/__ranges/*.h
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Deferred (not yet implemented):
//   views::split, views::lazy_split  (complex parser views)
//   istream_view / basic_istream_view (needs <istream>)
//   ranges:: algorithm overloads (separate effort)
//   join_view / views::join (deferred — complex inner-range bookkeeping)
//   views::elements / keys / values (deferred — needs tuple machinery)
//   views::common (deferred — needs common_iterator which needs variant)
//
// Provided:
//   CPOs: begin/end/cbegin/cend/rbegin/rend/crbegin/crend/size/ssize/empty/data/cdata
//   Concepts: range, borrowed_range, sized_range, input/output/forward/bidirectional/
//             random_access/contiguous/common/viewable_range, view, enable_view,
//             enable_borrowed_range, view_base, simple_view (internal)
//   Associated types: iterator_t, sentinel_t, range_difference_t, range_size_t,
//                     range_value_t, range_reference_t, range_rvalue_reference_t,
//                     borrowed_iterator_t, borrowed_subrange_t, dangling
//   view_interface, subrange (+ subrange_kind)
//   Views: empty_view, single_view, iota_view, ref_view, owning_view
//   Adaptors: views::all, views::filter, views::transform, views::take,
//             views::take_while, views::drop, views::drop_while,
//             views::reverse, views::iota, views::single, views::empty, views::counted
//   ranges::advance, ranges::distance, ranges::next, ranges::prev CPOs

#pragma once

#include <type_traits>
#include <concepts>
#include <iterator>
#include <optional>
#include <utility>
#include <cstddef>
#include <initializer_list>
#include <functional>

namespace std {

//===----------------------------------------------------------------------===//
// Helpers used throughout <ranges>
//===----------------------------------------------------------------------===//

namespace ranges {

// Exposition-only: enable_borrowed_range (forward-declared, specialised later)
template<class>
inline constexpr bool enable_borrowed_range = false;

// disable_sized_range
template<class>
inline constexpr bool disable_sized_range = false;

// view_base (empty tag struct for opting into view)
struct view_base {};

// Forward-declare view_interface so enable_view can detect it
template<class Derived>
    requires is_class_v<Derived> && same_as<Derived, remove_cv_t<Derived>>
class view_interface;

// Helper: function that exists only if T derives from some view_interface<Y>
// (not view_interface<Y> itself)
template<class Op, class Yp>
    requires(!same_as<Op, view_interface<Yp>>)
void is_derived_from_view_interface_fn(view_interface<Yp>*);

// enable_view: true if T derives from view_base, or from some view_interface<Y>
// This matches the C++20 standard (and libc++ implementation).
template<class T>
inline constexpr bool enable_view =
    derived_from<T, view_base> ||
    requires { is_derived_from_view_interface_fn<remove_cv_t<T>>((remove_cv_t<T>*)nullptr); };

} // namespace ranges

//===----------------------------------------------------------------------===//
// [range.access] — range access CPOs
// Note: <iterator> already provides std:: (non-ranges) begin/end/...
// Here we define the ranges:: CPO versions with borrowed_range enforcement.
//===----------------------------------------------------------------------===//

namespace ranges {

// can_borrow: lvalue reference or enable_borrowed_range<remove_cvref_t<T>>
namespace access_detail {
    template<class T>
    concept can_borrow =
        is_lvalue_reference_v<T> ||
        enable_borrowed_range<remove_cvref_t<T>>;

    template<class T>
    concept class_or_enum = is_class_v<T> || is_union_v<T> || is_enum_v<T>;
} // namespace access_detail

// ---- ranges::begin ----
namespace begin_detail {
void begin() = delete; // poison pill

template<class T>
concept member_begin =
    access_detail::can_borrow<T> &&
    requires(T&& t) {
        { t.begin() } -> input_or_output_iterator;
    };

template<class T>
concept adl_begin =
    !member_begin<T> &&
    access_detail::can_borrow<T> &&
    access_detail::class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) {
        { begin(t) } -> input_or_output_iterator;
    };

struct begin_fn {
    // raw array (lvalue)
    template<class T, size_t N>
    [[nodiscard]] constexpr T* operator()(T (&arr)[N]) const noexcept {
        return arr + 0;
    }
    // member .begin()
    template<class T>
        requires member_begin<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.begin()))
        -> decltype(t.begin()) {
        return t.begin();
    }
    // ADL begin(t)
    template<class T>
        requires adl_begin<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(begin(t)))
        -> decltype(begin(t)) {
        return begin(t);
    }
};
} // namespace begin_detail

inline namespace cpo {
    inline constexpr auto begin = begin_detail::begin_fn{};
} // namespace cpo

// iterator_t (needed by end CPO)
template<class R>
using iterator_t = decltype(ranges::begin(declval<R&>()));

// ---- ranges::end ----
namespace end_detail {
void end() = delete; // poison pill

template<class T>
concept member_end =
    access_detail::can_borrow<T> &&
    requires(T&& t) {
        typename iterator_t<T>;
        { t.end() } -> sentinel_for<iterator_t<T>>;
    };

template<class T>
concept adl_end =
    !member_end<T> &&
    access_detail::can_borrow<T> &&
    access_detail::class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) {
        typename iterator_t<T>;
        { end(t) } -> sentinel_for<iterator_t<T>>;
    };

struct end_fn {
    template<class T, size_t N>
    [[nodiscard]] constexpr T* operator()(T (&arr)[N]) const noexcept {
        return arr + N;
    }
    template<class T>
        requires member_end<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.end()))
        -> decltype(t.end()) {
        return t.end();
    }
    template<class T>
        requires adl_end<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(end(t)))
        -> decltype(end(t)) {
        return end(t);
    }
};
} // namespace end_detail

inline namespace cpo {
    inline constexpr auto end = end_detail::end_fn{};
} // namespace cpo

// ---- ranges::cbegin / cend ----
namespace cbegin_detail {
struct cbegin_fn {
    template<class T>
        requires is_lvalue_reference_v<T&&>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(ranges::begin(static_cast<const remove_reference_t<T>&>(t))))
        -> decltype(ranges::begin(static_cast<const remove_reference_t<T>&>(t))) {
        return ranges::begin(static_cast<const remove_reference_t<T>&>(t));
    }
    template<class T>
        requires is_rvalue_reference_v<T&&>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(ranges::begin(static_cast<const T&&>(t))))
        -> decltype(ranges::begin(static_cast<const T&&>(t))) {
        return ranges::begin(static_cast<const T&&>(t));
    }
};
} // namespace cbegin_detail

namespace cend_detail {
struct cend_fn {
    template<class T>
        requires is_lvalue_reference_v<T&&>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(ranges::end(static_cast<const remove_reference_t<T>&>(t))))
        -> decltype(ranges::end(static_cast<const remove_reference_t<T>&>(t))) {
        return ranges::end(static_cast<const remove_reference_t<T>&>(t));
    }
    template<class T>
        requires is_rvalue_reference_v<T&&>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(ranges::end(static_cast<const T&&>(t))))
        -> decltype(ranges::end(static_cast<const T&&>(t))) {
