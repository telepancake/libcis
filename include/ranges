template<view View>
class drop_view : public view_interface<drop_view<View>> {
    static constexpr bool use_cache =
        forward_range<View> && !(random_access_range<View> && sized_range<View>);
    using Cache = conditional_t<use_cache, non_propagating_cache<iterator_t<View>>, empty_cache>;
    [[no_unique_address]] Cache cached_begin_ = Cache();
    range_difference_t<View> count_ = 0;
    [[no_unique_address]] View base_ = View();

public:
    drop_view()
        requires default_initializable<View>
    = default;
    constexpr drop_view(View base, range_difference_t<View> count)
        : count_(count), base_(move(base)) {}

    constexpr View base() const& requires copy_constructible<View> { return base_; }
    constexpr View base() && { return move(base_); }

    constexpr auto begin()
        requires(!(simple_view<View> && random_access_range<const View> &&
                   sized_range<const View>))
    {
        if constexpr (random_access_range<View> && sized_range<View>) {
            auto sz = static_cast<range_difference_t<View>>(ranges::size(base_));
            auto offset = count_ < sz ? count_ : sz;
            return ranges::begin(base_) + offset;
        }
        if constexpr (use_cache) {
            if (cached_begin_.has_value()) return *cached_begin_;
        }
        auto it = ranges::next(ranges::begin(base_), count_, ranges::end(base_));
        if constexpr (use_cache) cached_begin_.emplace(it);
        return it;
    }
    constexpr auto begin() const
        requires random_access_range<const View> && sized_range<const View>
    {
        auto sz = static_cast<range_difference_t<const View>>(ranges::size(base_));
        auto offset = count_ < sz ? count_ : sz;
        return ranges::begin(base_) + offset;
    }

    constexpr auto end() requires(!simple_view<View>) { return ranges::end(base_); }
    constexpr auto end() const requires range<const View> { return ranges::end(base_); }

    constexpr auto size() requires sized_range<View> {
        const auto s = ranges::size(base_);
        const auto c = static_cast<decltype(s)>(count_);
        return s < c ? decltype(s){0} : s - c;
    }
    constexpr auto size() const requires sized_range<const View> {
        const auto s = ranges::size(base_);
        const auto c = static_cast<decltype(s)>(count_);
        return s < c ? decltype(s){0} : s - c;
    }
};

