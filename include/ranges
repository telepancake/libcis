template<view View>
class take_view : public view_interface<take_view<View>> {
    [[no_unique_address]] View base_ = View();
    range_difference_t<View> count_ = 0;

    template<bool Const>
    class sentinel;

public:
    take_view()
        requires default_initializable<View>
    = default;
    constexpr take_view(View base, range_difference_t<View> count)
        : base_(move(base)), count_(count) {}

    constexpr View base() const& requires copy_constructible<View> { return base_; }
    constexpr View base() && { return move(base_); }

    constexpr auto begin()
        requires(!simple_view<View>)
    {
        if constexpr (sized_range<View>) {
            if constexpr (random_access_range<View>)
                return ranges::begin(base_);
            else
                return counted_iterator(ranges::begin(base_),
                    static_cast<range_difference_t<View>>(size()));
        } else {
            return counted_iterator(ranges::begin(base_), count_);
        }
    }
    constexpr auto begin() const requires range<const View> {
        if constexpr (sized_range<const View>) {
            if constexpr (random_access_range<const View>)
                return ranges::begin(base_);
            else
                return counted_iterator(ranges::begin(base_),
                    static_cast<range_difference_t<const View>>(size()));
        } else {
            return counted_iterator(ranges::begin(base_), count_);
        }
    }

    constexpr auto end()
        requires(!simple_view<View>)
    {
        if constexpr (sized_range<View>) {
            if constexpr (random_access_range<View>)
                return ranges::begin(base_) + static_cast<range_difference_t<View>>(size());
            else
                return default_sentinel;
        } else {
            return sentinel<false>{ranges::end(base_)};
        }
    }
    constexpr auto end() const requires range<const View> {
        if constexpr (sized_range<const View>) {
            if constexpr (random_access_range<const View>)
                return ranges::begin(base_) + static_cast<range_difference_t<const View>>(size());
            else
                return default_sentinel;
        } else {
            return sentinel<true>{ranges::end(base_)};
        }
    }

    constexpr auto size() requires sized_range<View> {
        auto n = ranges::size(base_);
        auto c = static_cast<decltype(n)>(count_);
        return n < c ? n : c;
    }
    constexpr auto size() const requires sized_range<const View> {
        auto n = ranges::size(base_);
        auto c = static_cast<decltype(n)>(count_);
        return n < c ? n : c;
    }
};

template<view View>
template<bool Const>
class take_view<View>::sentinel {
    using Base = conditional_t<Const, const View, View>;
    using CIter = counted_iterator<iterator_t<conditional_t<Const, const View, View>>>;
    [[no_unique_address]] sentinel_t<Base> end_ = sentinel_t<Base>();

    template<bool>
    friend class take_view<View>::sentinel;
public:
    sentinel() = default;
    constexpr explicit sentinel(sentinel_t<Base> end) : end_(move(end)) {}
    constexpr sentinel(sentinel<!Const> s)
        requires Const && convertible_to<sentinel_t<View>, sentinel_t<Base>>
        : end_(move(s.end_)) {}
    [[nodiscard]] constexpr sentinel_t<Base> base() const { return end_; }

    friend constexpr bool operator==(const CIter& lhs, const sentinel& rhs) {
        return lhs.count() == 0 || lhs.base() == rhs.end_;
    }
    template<bool OtherConst = !Const>
        requires sentinel_for<sentinel_t<Base>,
                              iterator_t<conditional_t<OtherConst, const View, View>>>
    friend constexpr bool operator==(
        const counted_iterator<iterator_t<conditional_t<OtherConst, const View, View>>>& lhs,
        const sentinel& rhs)
    { return lhs.count() == 0 || lhs.base() == rhs.end_; }
};

