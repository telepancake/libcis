//===----------------------------------------------------------------------===//
// [range.range] — range concepts and associated types
//===----------------------------------------------------------------------===//

namespace ranges {

template<class T>
concept range = requires(T& t) {
    ranges::begin(t);
    ranges::end(t);
};

template<class T>
concept borrowed_range =
    range<T> &&
    (is_lvalue_reference_v<T> || enable_borrowed_range<remove_cvref_t<T>>);

template<range R>
using sentinel_t = decltype(ranges::end(declval<R&>()));

template<range R>
using range_difference_t = iter_difference_t<iterator_t<R>>;

template<range R>
using range_value_t = iter_value_t<iterator_t<R>>;

template<range R>
using range_reference_t = iter_reference_t<iterator_t<R>>;

template<range R>
using range_rvalue_reference_t = iter_rvalue_reference_t<iterator_t<R>>;

template<class T>
concept sized_range = range<T> && requires(T& t) { ranges::size(t); };

template<sized_range R>
using range_size_t = decltype(ranges::size(declval<R&>()));

template<class T>
concept view = range<T> && movable<T> && enable_view<T>;

// internal: simple_view
template<class R>
concept simple_view =
    view<R> && range<const R> &&
    same_as<iterator_t<R>, iterator_t<const R>> &&
    same_as<sentinel_t<R>, sentinel_t<const R>>;

template<class Rp, class T>
concept output_range = range<Rp> && output_iterator<iterator_t<Rp>, T>;

template<class T>
concept input_range = range<T> && input_iterator<iterator_t<T>>;

template<class T>
concept forward_range = input_range<T> && forward_iterator<iterator_t<T>>;

template<class T>
concept bidirectional_range = forward_range<T> && bidirectional_iterator<iterator_t<T>>;

template<class T>
concept random_access_range = bidirectional_range<T> && random_access_iterator<iterator_t<T>>;

template<class T>
concept contiguous_range =
    random_access_range<T> &&
    contiguous_iterator<iterator_t<T>> &&
    requires(T& t) {
        { ranges::data(t) } -> same_as<add_pointer_t<range_reference_t<T>>>;
    };

template<class T>
concept common_range = range<T> && same_as<iterator_t<T>, sentinel_t<T>>;

namespace detail {
    template<class T>
    inline constexpr bool is_std_initializer_list = false;
    template<class E>
    inline constexpr bool is_std_initializer_list<initializer_list<E>> = true;
} // namespace detail

template<class T>
concept viewable_range =
    range<T> &&
    ((view<remove_cvref_t<T>> && constructible_from<remove_cvref_t<T>, T>) ||
     (!view<remove_cvref_t<T>> &&
      (is_lvalue_reference_v<T> ||
       (movable<remove_reference_t<T>> &&
        !detail::is_std_initializer_list<remove_cvref_t<T>>))));

// dangling
struct dangling {
    dangling() = default;
    template<class... Args>
    constexpr dangling(Args&&...) noexcept {}
};

template<range R>
using borrowed_iterator_t = conditional_t<borrowed_range<R>, iterator_t<R>, dangling>;

} // namespace ranges

//===----------------------------------------------------------------------===//
// [range.prim.advance/distance/next/prev] — ranges:: algorithm utilities
//===----------------------------------------------------------------------===//

namespace ranges {

// ranges::advance
namespace advance_detail {
struct advance_fn {
    template<input_or_output_iterator I>
    constexpr void operator()(I& i, iter_difference_t<I> n) const {
        if constexpr (random_access_iterator<I>) {
            i += n;
        } else if constexpr (bidirectional_iterator<I>) {
            for (; n > 0; --n) ++i;
            for (; n < 0; ++n) --i;
        } else {
            for (; n > 0; --n) ++i;
        }
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    constexpr void operator()(I& i, S bound) const {
        if constexpr (assignable_from<I&, S>) {
            i = move(bound);
        } else if constexpr (sized_sentinel_for<S, I>) {
            (*this)(i, bound - i);
        } else {
            while (i != bound) ++i;
        }
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    constexpr iter_difference_t<I> operator()(I& i, iter_difference_t<I> n, S bound) const {
        if constexpr (sized_sentinel_for<S, I>) {
            auto dist = bound - i;
            if constexpr (bidirectional_iterator<I>) {
                if (n < 0) {
                    auto neg = -n;
                    if (static_cast<iter_difference_t<I>>(-dist) < neg) {
                        (*this)(i, bound);
                        return n - (bound - i);
                    }
                    (*this)(i, n);
                    return 0;
                }
            }
            if (dist < n) {
                (*this)(i, bound);
                return n - dist;
            }
            (*this)(i, n);
            return 0;
        } else {
            if constexpr (bidirectional_iterator<I>) {
                for (; n < 0 && i != bound; ++n) --i;
            }
            for (; n > 0 && i != bound; --n) ++i;
            return n;
        }
    }
};
} // namespace advance_detail

inline namespace cpo {
    inline constexpr auto advance = advance_detail::advance_fn{};
} // namespace cpo

// ranges::distance
namespace distance_detail {
struct distance_fn {
    template<input_or_output_iterator I, sentinel_for<I> S>
        requires (!sized_sentinel_for<S, I>)
    constexpr iter_difference_t<I> operator()(I first, S last) const {
        iter_difference_t<I> n = 0;
        while (first != last) { ++first; ++n; }
        return n;
    }
    template<input_or_output_iterator I, sized_sentinel_for<I> S>
    [[nodiscard]] constexpr iter_difference_t<I> operator()(I first, S last) const {
        return last - first;
    }
    template<range R>
    [[nodiscard]] constexpr range_difference_t<R> operator()(R&& r) const {
        if constexpr (sized_range<R>) {
            return static_cast<range_difference_t<R>>(ranges::size(r));
        } else {
            return (*this)(ranges::begin(r), ranges::end(r));
        }
    }
};
} // namespace distance_detail

inline namespace cpo {
    inline constexpr auto distance = distance_detail::distance_fn{};
} // namespace cpo

// ranges::next
namespace next_detail {
struct next_fn {
    template<input_or_output_iterator I>
    [[nodiscard]] constexpr I operator()(I i) const {
        ++i;
        return i;
    }
    template<input_or_output_iterator I>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n) const {
        ranges::advance(i, n);
        return i;
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    [[nodiscard]] constexpr I operator()(I i, S bound) const {
        ranges::advance(i, bound);
        return i;
    }
    template<input_or_output_iterator I, sentinel_for<I> S>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n, S bound) const {
        ranges::advance(i, n, bound);
        return i;
    }
};
} // namespace next_detail

inline namespace cpo {
    inline constexpr auto next = next_detail::next_fn{};
} // namespace cpo

// ranges::prev
namespace prev_detail {
struct prev_fn {
    template<bidirectional_iterator I>
    [[nodiscard]] constexpr I operator()(I i) const {
        --i;
        return i;
    }
    template<bidirectional_iterator I>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n) const {
        ranges::advance(i, -n);
        return i;
    }
    template<bidirectional_iterator I>
    [[nodiscard]] constexpr I operator()(I i, iter_difference_t<I> n, I bound) const {
        ranges::advance(i, -n, bound);
        return i;
    }
};
} // namespace prev_detail

inline namespace cpo {
    inline constexpr auto prev = prev_detail::prev_fn{};
} // namespace cpo

