    requires input_range<View> && is_object_v<Pred> &&
             indirect_unary_predicate<const Pred, iterator_t<View>>
class drop_while_view : public view_interface<drop_while_view<View, Pred>> {
    [[no_unique_address]] View base_ = View();
    [[no_unique_address]] movable_box<Pred> pred_;

    static constexpr bool use_cache = forward_range<View>;
    using Cache = conditional_t<use_cache, non_propagating_cache<iterator_t<View>>, empty_cache>;
    [[no_unique_address]] Cache cached_begin_ = Cache();

public:
    drop_while_view()
        requires default_initializable<View> && default_initializable<Pred>
    = default;
