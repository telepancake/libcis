// Internal: movable_box and non_propagating_cache
//===----------------------------------------------------------------------===//

namespace ranges {

// movable_box: wraps a copy_constructible type and makes it assignable
// Uses optional<T> as storage.
template<class T>
    requires copy_constructible<T> && is_object_v<T>
class movable_box {
    optional<T> val_;
public:
    template<class... Args>
        requires is_constructible_v<T, Args...>
    constexpr explicit movable_box(in_place_t, Args&&... args)
        noexcept(is_nothrow_constructible_v<T, Args...>)
        : val_(in_place, forward<Args>(args)...) {}

    constexpr movable_box()
        noexcept(is_nothrow_default_constructible_v<T>)
        requires default_initializable<T>
        : val_(in_place) {}

    movable_box(const movable_box&) = default;
    movable_box(movable_box&&) = default;

    constexpr movable_box& operator=(const movable_box& other)
        noexcept(is_nothrow_copy_constructible_v<T>)
    {
        if (this != addressof(other)) {
            if (other.has_value())
                val_.emplace(*other);
            else
                val_.reset();
        }
        return *this;
    }
    movable_box& operator=(movable_box&&) requires movable<T> = default;
    constexpr movable_box& operator=(movable_box&& other)
        noexcept(is_nothrow_move_constructible_v<T>)
    {
        if (this != addressof(other)) {
            if (other.has_value())
                val_.emplace(move(*other));
            else
                val_.reset();
        }
        return *this;
    }

    constexpr const T& operator*() const noexcept { return *val_; }
    constexpr T& operator*() noexcept { return *val_; }
    constexpr const T* operator->() const noexcept { return val_.operator->(); }
    constexpr T* operator->() noexcept { return val_.operator->(); }
    constexpr bool has_value() const noexcept { return val_.has_value(); }
};

// non_propagating_cache: optional that doesn't propagate on copy/move
template<class T>
    requires is_object_v<T>
class non_propagating_cache {
    struct from_tag {};
    struct fwd_tag {};
    struct wrapper {
        template<class... Args>
        constexpr explicit wrapper(fwd_tag, Args&&... args)
            : t_(forward<Args>(args)...) {}
        template<class Fn>
        constexpr explicit wrapper(from_tag, const Fn& f) : t_(f()) {}
        T t_;
    };
    optional<wrapper> val_ = nullopt;
public:
    non_propagating_cache() = default;
    constexpr non_propagating_cache(const non_propagating_cache&) noexcept : val_(nullopt) {}
    constexpr non_propagating_cache(non_propagating_cache&& other) noexcept : val_(nullopt) {
        other.val_.reset();
    }
    constexpr non_propagating_cache& operator=(const non_propagating_cache& other) noexcept {
        if (this != addressof(other)) val_.reset();
        return *this;
    }
    constexpr non_propagating_cache& operator=(non_propagating_cache&& other) noexcept {
        val_.reset(); other.val_.reset(); return *this;
    }
    constexpr T& operator*() { return val_->t_; }
    constexpr const T& operator*() const { return val_->t_; }
    constexpr bool has_value() const { return val_.has_value(); }
    template<class Fn>
    constexpr T& emplace_from(const Fn& f) {
        return val_.emplace(from_tag{}, f).t_;
    }
    template<class... Args>
    constexpr T& emplace(Args&&... args) {
        return val_.emplace(fwd_tag{}, forward<Args>(args)...).t_;
    }
};

