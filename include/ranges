// ---- ranges::size ----
namespace size_detail {
void size() = delete; // poison pill

template<class T>
concept integer_like_check = integral<remove_cvref_t<T>> && !same_as<bool, remove_cv_t<remove_reference_t<T>>>;

template<class T>
concept member_size =
    !disable_sized_range<remove_cvref_t<T>> &&
    requires(T&& t) {
        { t.size() } -> integer_like_check;
    };

template<class T>
concept adl_size =
    !disable_sized_range<remove_cvref_t<T>> &&
    !member_size<T> &&
    access_detail::class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) {
        { size(t) } -> integer_like_check;
    };

template<class T>
concept difference_size =
    !member_size<T> && !adl_size<T> &&
    access_detail::class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) {
        { ranges::begin(t) } -> forward_iterator;
        { ranges::end(t) } -> sized_sentinel_for<decltype(ranges::begin(declval<T>()))>;
    };

struct size_fn {
    template<class T, size_t N>
    [[nodiscard]] constexpr size_t operator()(T (&&)[N]) const noexcept { return N; }
    template<class T, size_t N>
    [[nodiscard]] constexpr size_t operator()(T (&)[N]) const noexcept { return N; }
    template<class T>
        requires member_size<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.size())) -> decltype(t.size()) {
        return t.size();
    }
    template<class T>
        requires adl_size<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(size(t))) -> decltype(size(t)) {
        return size(t);
    }
    template<class T>
        requires difference_size<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(ranges::end(t) - ranges::begin(t)))
        -> make_unsigned_t<decltype(ranges::end(t) - ranges::begin(t))> {
        return static_cast<make_unsigned_t<decltype(ranges::end(t) - ranges::begin(t))>>(
            ranges::end(t) - ranges::begin(t));
    }
};
} // namespace size_detail

inline namespace cpo {
    inline constexpr auto size = size_detail::size_fn{};
} // namespace cpo

// ---- ranges::ssize ----
namespace ssize_detail {
struct ssize_fn {
    template<class T>
        requires requires(T&& t) { ranges::size(t); }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(ranges::size(t)))
    {
        using D = common_type_t<ptrdiff_t, make_signed_t<decltype(ranges::size(t))>>;
        return static_cast<D>(ranges::size(t));
    }
};
} // namespace ssize_detail

inline namespace cpo {
    inline constexpr auto ssize = ssize_detail::ssize_fn{};
} // namespace cpo

// ---- ranges::empty ----
namespace empty_detail {
struct empty_fn {
    // member .empty()
    template<class T>
        requires requires(T&& t) { bool(t.empty()); }
    [[nodiscard]] constexpr bool operator()(T&& t) const
        noexcept(noexcept(bool(t.empty()))) {
        return bool(t.empty());
    }
    // via size == 0
    template<class T>
        requires (!requires(T&& t) { bool(t.empty()); }) &&
                 requires(T&& t) { ranges::size(t) == 0; }
    [[nodiscard]] constexpr bool operator()(T&& t) const
        noexcept(noexcept(ranges::size(t) == 0)) {
        return ranges::size(t) == 0;
    }
    // via begin == end (forward ranges only)
    template<class T>
        requires (!requires(T&& t) { bool(t.empty()); }) &&
                 (!requires(T&& t) { ranges::size(t) == 0; }) &&
                 requires(T&& t) {
                     { ranges::begin(t) } -> forward_iterator;
                     ranges::end(t);
                 }
    [[nodiscard]] constexpr bool operator()(T&& t) const
        noexcept(noexcept(ranges::begin(t) == ranges::end(t))) {
        return ranges::begin(t) == ranges::end(t);
    }
};
} // namespace empty_detail

inline namespace cpo {
    inline constexpr auto empty = empty_detail::empty_fn{};
} // namespace cpo

// ---- ranges::data / cdata ----
namespace data_detail {
struct data_fn {
    // member .data() that returns a pointer to object
    template<class T>
        requires access_detail::can_borrow<T> &&
                 requires(T&& t) {
                     t.data();
                     requires is_pointer_v<decltype(t.data())>;
                     requires is_object_v<remove_pointer_t<decltype(t.data())>>;
                 }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.data())) -> decltype(t.data()) {
        return t.data();
    }
    // fallback: begin() returns a contiguous_iterator -> to_address
    template<class T>
        requires access_detail::can_borrow<T> &&
                 (!requires(T&& t) {
                     t.data();
                     requires is_pointer_v<decltype(t.data())>;
                  }) &&
                 requires(T&& t) {
                     { ranges::begin(t) } -> contiguous_iterator;
                 }
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(to_address(ranges::begin(t)))) {
        return to_address(ranges::begin(t));
    }
};
} // namespace data_detail

inline namespace cpo {
    inline constexpr auto data = data_detail::data_fn{};
} // namespace cpo

