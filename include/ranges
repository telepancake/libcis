namespace split_detail {
struct split_fn {
    template<class Range, class Pattern>
    [[nodiscard]] constexpr auto operator()(Range&& range, Pattern&& pattern) const
        noexcept(noexcept(ranges::split_view(forward<Range>(range), forward<Pattern>(pattern))))
        -> decltype(ranges::split_view(forward<Range>(range), forward<Pattern>(pattern)))
    { return ranges::split_view(forward<Range>(range), forward<Pattern>(pattern)); }

    template<class Pattern>
        requires constructible_from<decay_t<Pattern>, Pattern>
    [[nodiscard]] constexpr auto operator()(Pattern&& pattern) const
        noexcept(is_nothrow_constructible_v<decay_t<Pattern>, Pattern>)
