//===----------------------------------------------------------------------===//
// [range.view.interface] — view_interface
//===----------------------------------------------------------------------===//

namespace ranges {

template<class Derived>
    requires is_class_v<Derived> && same_as<Derived, remove_cv_t<Derived>>
class view_interface {
    constexpr Derived& derived() noexcept {
        static_assert(derived_from<Derived, view_interface>);
        return static_cast<Derived&>(*this);
    }
    constexpr const Derived& derived() const noexcept {
        static_assert(derived_from<Derived, view_interface>);
        return static_cast<const Derived&>(*this);
    }

public:
    template<class D = Derived>
    [[nodiscard]] constexpr bool empty()
        requires sized_range<D> || forward_range<D>
    {
        if constexpr (sized_range<D>)
            return ranges::size(derived()) == 0;
        else
            return ranges::begin(derived()) == ranges::end(derived());
    }
    template<class D = Derived>
    [[nodiscard]] constexpr bool empty() const
        requires sized_range<const D> || forward_range<const D>
    {
        if constexpr (sized_range<const D>)
            return ranges::size(derived()) == 0;
        else
            return ranges::begin(derived()) == ranges::end(derived());
    }

    template<class D = Derived>
    constexpr explicit operator bool()
        requires requires(D& t) { ranges::empty(t); }
    {
        return !ranges::empty(derived());
    }
    template<class D = Derived>
    constexpr explicit operator bool() const
        requires requires(const D& t) { ranges::empty(t); }
    {
        return !ranges::empty(derived());
    }

    template<class D = Derived>
    [[nodiscard]] constexpr auto data()
        requires contiguous_iterator<iterator_t<D>>
    {
        return to_address(ranges::begin(derived()));
    }
    template<class D = Derived>
    [[nodiscard]] constexpr auto data() const
        requires range<const D> && contiguous_iterator<iterator_t<const D>>
    {
        return to_address(ranges::begin(derived()));
    }

    template<class D = Derived>
    [[nodiscard]] constexpr auto size()
        requires forward_range<D> && sized_sentinel_for<sentinel_t<D>, iterator_t<D>>
    {
        return static_cast<make_unsigned_t<iter_difference_t<iterator_t<D>>>>(
            ranges::end(derived()) - ranges::begin(derived()));
    }
    template<class D = Derived>
    [[nodiscard]] constexpr auto size() const
        requires forward_range<const D> &&
                 sized_sentinel_for<sentinel_t<const D>, iterator_t<const D>>
    {
        return static_cast<make_unsigned_t<iter_difference_t<iterator_t<const D>>>>(
            ranges::end(derived()) - ranges::begin(derived()));
    }

    template<class D = Derived>
    [[nodiscard]] constexpr decltype(auto) front()
        requires forward_range<D>
    {
        return *ranges::begin(derived());
    }
    template<class D = Derived>
    [[nodiscard]] constexpr decltype(auto) front() const
        requires forward_range<const D>
    {
        return *ranges::begin(derived());
    }

    template<class D = Derived>
    [[nodiscard]] constexpr decltype(auto) back()
        requires bidirectional_range<D> && common_range<D>
    {
        return *ranges::prev(ranges::end(derived()));
    }
    template<class D = Derived>
    [[nodiscard]] constexpr decltype(auto) back() const
        requires bidirectional_range<const D> && common_range<const D>
    {
        return *ranges::prev(ranges::end(derived()));
    }

    template<random_access_range RARange = Derived>
    [[nodiscard]] constexpr decltype(auto) operator[](range_difference_t<RARange> n) {
        return ranges::begin(derived())[n];
    }
    template<random_access_range RARange = const Derived>
    [[nodiscard]] constexpr decltype(auto) operator[](range_difference_t<RARange> n) const {
        return ranges::begin(derived())[n];
    }
};

} // namespace ranges

//===----------------------------------------------------------------------===//
// [range.subrange] — subrange
//===----------------------------------------------------------------------===//

namespace ranges {

enum class subrange_kind : bool { unsized, sized };

// subrange forward declaration for tuple_size/element specialisation below
template<input_or_output_iterator Iter,
         sentinel_for<Iter> Sent = Iter,
         subrange_kind Kind = sized_sentinel_for<Sent, Iter>
                              ? subrange_kind::sized : subrange_kind::unsized>
    requires(Kind == subrange_kind::sized || !sized_sentinel_for<Sent, Iter>)
class subrange;

// borrowed_subrange_t
template<range R>
using borrowed_subrange_t = conditional_t<borrowed_range<R>,
                                          subrange<iterator_t<R>>,
                                          dangling>;

// pair-like concept helpers
namespace subrange_detail {
    template<class T>
    concept pair_like =
        !is_reference_v<T> &&
        requires(T t) {
            typename tuple_size<T>::type;
            requires derived_from<tuple_size<T>, integral_constant<size_t, 2>>;
            typename tuple_element_t<0, remove_const_t<T>>;
            typename tuple_element_t<1, remove_const_t<T>>;
            { get<0>(t) } -> convertible_to<const tuple_element_t<0, T>&>;
            { get<1>(t) } -> convertible_to<const tuple_element_t<1, T>&>;
        };

    template<class T>
    concept pair_like_no_subrange =
        pair_like<T> && !requires { typename T::is_subrange; };

    template<class From, class To>
    concept uses_nonqualification_pointer_conversion =
        is_pointer_v<From> && is_pointer_v<To> &&
        !convertible_to<remove_pointer_t<From>(*)[], remove_pointer_t<To>(*)[]>;

    template<class From, class To>
    concept convertible_to_non_slicing =
        convertible_to<From, To> &&
        !uses_nonqualification_pointer_conversion<decay_t<From>, decay_t<To>>;

    template<class Pair, class Iter, class Sent>
    concept pair_like_convertible_from =
        !range<Pair> && pair_like_no_subrange<Pair> &&
        constructible_from<Pair, Iter, Sent> &&
        convertible_to_non_slicing<Iter, tuple_element_t<0, Pair>> &&
        convertible_to<Sent, tuple_element_t<1, Pair>>;
} // namespace subrange_detail

template<input_or_output_iterator Iter,
         sentinel_for<Iter> Sent,
         subrange_kind Kind>
    requires(Kind == subrange_kind::sized || !sized_sentinel_for<Sent, Iter>)
class subrange : public view_interface<subrange<Iter, Sent, Kind>> {
public:
    static constexpr bool store_size =
        (Kind == subrange_kind::sized && !sized_sentinel_for<Sent, Iter>);

private:
    struct empty_size {
        constexpr empty_size(auto) noexcept {}
    };
    using SizeT = conditional_t<store_size,
                                make_unsigned_t<iter_difference_t<Iter>>,
                                empty_size>;

    [[no_unique_address]] Iter begin_ = Iter();
    [[no_unique_address]] Sent end_   = Sent();
    [[no_unique_address]] SizeT size_ = 0;

public:
    subrange()
        requires default_initializable<Iter>
    = default;

    // (iter, sent) — when size not stored
    constexpr subrange(subrange_detail::convertible_to_non_slicing<Iter> auto iter, Sent sent)
        requires(!store_size)
        : begin_(move(iter)), end_(move(sent)) {}

    // (iter, sent, n) — when Kind == sized
    constexpr subrange(subrange_detail::convertible_to_non_slicing<Iter> auto iter,
                       Sent sent,
                       make_unsigned_t<iter_difference_t<Iter>> n)
        requires(Kind == subrange_kind::sized)
        : begin_(move(iter)), end_(move(sent)), size_(n) {}

    // from range (no-size version)
    template<class Range>
        requires borrowed_range<Range> &&
                 subrange_detail::convertible_to_non_slicing<iterator_t<Range>, Iter> &&
                 convertible_to<sentinel_t<Range>, Sent> &&
                 (!same_as<remove_cvref_t<Range>, subrange>)
    constexpr subrange(Range&& r)
        requires(!store_size)
        : subrange(ranges::begin(r), ranges::end(r)) {}

    // from range (size version — sized_range)
    template<class Range>
        requires borrowed_range<Range> &&
                 subrange_detail::convertible_to_non_slicing<iterator_t<Range>, Iter> &&
                 convertible_to<sentinel_t<Range>, Sent> &&
                 (!same_as<remove_cvref_t<Range>, subrange>) &&
                 store_size && sized_range<Range>
    constexpr subrange(Range&& r)
        : subrange(r, ranges::size(r)) {}

    // from range (size version — explicit)
    template<borrowed_range Range>
        requires subrange_detail::convertible_to_non_slicing<iterator_t<Range>, Iter> &&
                 convertible_to<sentinel_t<Range>, Sent>
    constexpr subrange(Range&& r, make_unsigned_t<iter_difference_t<Iter>> n)
        requires(Kind == subrange_kind::sized)
        : subrange(ranges::begin(r), ranges::end(r), n) {}

    // pair-like conversion
    template<subrange_detail::pair_like_convertible_from<const Iter&, const Sent&> Pair>
    constexpr operator Pair() const {
        return Pair(begin_, end_);
    }

    [[nodiscard]] constexpr Iter begin() const requires copyable<Iter> { return begin_; }
    [[nodiscard]] constexpr Iter begin() requires(!copyable<Iter>) { return move(begin_); }
    [[nodiscard]] constexpr Sent end() const { return end_; }
    [[nodiscard]] constexpr bool empty() const { return begin_ == end_; }

    [[nodiscard]] constexpr make_unsigned_t<iter_difference_t<Iter>> size() const
        requires(Kind == subrange_kind::sized)
    {
        if constexpr (store_size)
            return size_;
        else
            return static_cast<make_unsigned_t<iter_difference_t<Iter>>>(end_ - begin_);
    }

    [[nodiscard]] constexpr subrange next(iter_difference_t<Iter> n = 1) const&
        requires forward_iterator<Iter>
    {
        auto tmp = *this;
        tmp.advance(n);
        return tmp;
    }
    [[nodiscard]] constexpr subrange next(iter_difference_t<Iter> n = 1) && {
        advance(n);
        return move(*this);
    }
    [[nodiscard]] constexpr subrange prev(iter_difference_t<Iter> n = 1) const
        requires bidirectional_iterator<Iter>
    {
        auto tmp = *this;
        tmp.advance(-n);
        return tmp;
    }
    constexpr subrange& advance(iter_difference_t<Iter> n) {
        if constexpr (bidirectional_iterator<Iter>) {
            if (n < 0) {
                ranges::advance(begin_, n);
                if constexpr (store_size)
                    size_ += static_cast<make_unsigned_t<iter_difference_t<Iter>>>(-n);
                return *this;
            }
        }
        auto d = n - ranges::advance(begin_, n, end_);
        if constexpr (store_size)
            size_ -= static_cast<make_unsigned_t<iter_difference_t<Iter>>>(d);
        return *this;
    }

    // Mark this as a subrange to exclude from pair_like_no_subrange
    using is_subrange = void;
};

// Deduction guides
template<input_or_output_iterator Iter, sentinel_for<Iter> Sent>
subrange(Iter, Sent) -> subrange<Iter, Sent>;

template<input_or_output_iterator Iter, sentinel_for<Iter> Sent>
subrange(Iter, Sent, make_unsigned_t<iter_difference_t<Iter>>)
    -> subrange<Iter, Sent, subrange_kind::sized>;

template<borrowed_range Range>
subrange(Range&&)
    -> subrange<iterator_t<Range>, sentinel_t<Range>,
                (sized_range<Range> || sized_sentinel_for<sentinel_t<Range>, iterator_t<Range>>)
                ? subrange_kind::sized : subrange_kind::unsized>;

template<borrowed_range Range>
subrange(Range&&, make_unsigned_t<range_difference_t<Range>>)
    -> subrange<iterator_t<Range>, sentinel_t<Range>, subrange_kind::sized>;

// get<> for subrange
template<size_t Index, class Iter, class Sent, subrange_kind Kind>
    requires((Index == 0 && copyable<Iter>) || Index == 1)
[[nodiscard]] constexpr auto get(const subrange<Iter, Sent, Kind>& sr) {
    if constexpr (Index == 0) return sr.begin();
    else return sr.end();
}
template<size_t Index, class Iter, class Sent, subrange_kind Kind>
    requires(Index < 2)
[[nodiscard]] constexpr auto get(subrange<Iter, Sent, Kind>&& sr) {
    if constexpr (Index == 0) return sr.begin();
    else return sr.end();
}

template<class Iter, class Sent, subrange_kind Kind>
inline constexpr bool enable_borrowed_range<subrange<Iter, Sent, Kind>> = true;

} // namespace ranges

// tuple_size / tuple_element for subrange
template<class Iter, class Sent, ranges::subrange_kind Kind>
struct tuple_size<ranges::subrange<Iter, Sent, Kind>>
    : integral_constant<size_t, 2> {};

template<class Iter, class Sent, ranges::subrange_kind Kind>
struct tuple_element<0, ranges::subrange<Iter, Sent, Kind>> { using type = Iter; };

template<class Iter, class Sent, ranges::subrange_kind Kind>
struct tuple_element<1, ranges::subrange<Iter, Sent, Kind>> { using type = Sent; };

template<class Iter, class Sent, ranges::subrange_kind Kind>
struct tuple_element<0, const ranges::subrange<Iter, Sent, Kind>> { using type = Iter; };

template<class Iter, class Sent, ranges::subrange_kind Kind>
struct tuple_element<1, const ranges::subrange<Iter, Sent, Kind>> { using type = Sent; };

