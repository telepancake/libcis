// ---- ranges::rbegin / rend ----
namespace rbegin_detail {
void rbegin() = delete;

template<class T>
concept member_rbegin =
    access_detail::can_borrow<T> &&
    requires(T&& t) {
        { t.rbegin() } -> input_or_output_iterator;
    };

template<class T>
concept adl_rbegin =
    !member_rbegin<T> &&
    access_detail::can_borrow<T> &&
    access_detail::class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) {
        { rbegin(t) } -> input_or_output_iterator;
    };

template<class T>
concept rev_begin =
    !member_rbegin<T> && !adl_rbegin<T> &&
    access_detail::can_borrow<T> &&
    requires(T&& t) {
        { ranges::begin(t) } -> bidirectional_iterator;
        { ranges::end(t) }   -> same_as<decltype(ranges::begin(t))>;
    };

struct rbegin_fn {
    template<class T>
        requires member_rbegin<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.rbegin()))
        -> decltype(t.rbegin()) {
        return t.rbegin();
    }
    template<class T>
        requires adl_rbegin<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(rbegin(t)))
        -> decltype(rbegin(t)) {
        return rbegin(t);
    }
    template<class T>
        requires rev_begin<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(make_reverse_iterator(ranges::end(t)))) {
        return make_reverse_iterator(ranges::end(t));
    }
};
} // namespace rbegin_detail

namespace rend_detail {
void rend() = delete;

template<class T>
concept member_rend =
    access_detail::can_borrow<T> &&
    requires(T&& t) {
        { t.rend() } -> sentinel_for<decltype(declval<rbegin_detail::rbegin_fn>()(t))>;
    };

template<class T>
concept adl_rend =
    !member_rend<T> &&
    access_detail::can_borrow<T> &&
    access_detail::class_or_enum<remove_cvref_t<T>> &&
    requires(T&& t) {
        { rend(t) } -> sentinel_for<decltype(declval<rbegin_detail::rbegin_fn>()(t))>;
    };

template<class T>
concept rev_end =
    !member_rend<T> && !adl_rend<T> &&
    access_detail::can_borrow<T> &&
    requires(T&& t) {
        { ranges::begin(t) } -> bidirectional_iterator;
        { ranges::end(t) }   -> same_as<decltype(ranges::begin(t))>;
    };

struct rend_fn {
    template<class T>
        requires member_rend<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(t.rend()))
        -> decltype(t.rend()) {
        return t.rend();
    }
    template<class T>
        requires adl_rend<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(rend(t)))
        -> decltype(rend(t)) {
        return rend(t);
    }
    template<class T>
        requires rev_end<T>
    [[nodiscard]] constexpr auto operator()(T&& t) const
        noexcept(noexcept(make_reverse_iterator(ranges::begin(t)))) {
        return make_reverse_iterator(ranges::begin(t));
    }
};
} // namespace rend_detail

inline namespace cpo {
    inline constexpr auto rbegin = rbegin_detail::rbegin_fn{};
    inline constexpr auto rend   = rend_detail::rend_fn{};
} // namespace cpo (rbegin/rend)

