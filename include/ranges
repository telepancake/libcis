//===----------------------------------------------------------------------===//
// [range.iota] — iota_view
//===----------------------------------------------------------------------===//

namespace ranges {

namespace iota_detail {
    template<class T>
    concept decrementable = incrementable<T> && requires(T t) {
        { --t } -> same_as<T&>;
        { t-- } -> same_as<T>;
    };

    template<class T>
    concept advanceable =
        decrementable<T> && totally_ordered<T> &&
        requires(T i, const T j, const iter_difference_t<T> n) {
            { i += n } -> same_as<T&>;
            { i -= n } -> same_as<T&>;
            T(j + n);
            T(n + j);
            T(j - n);
            { j - j } -> convertible_to<iter_difference_t<T>>;
        };

    template<class T>
    struct get_iota_diff {
        using type = iter_difference_t<T>;
    };
    template<class T>
        requires (integral<T> && sizeof(iter_difference_t<T>) <= sizeof(T))
    struct get_iota_diff<T> {
        // use a wider signed type
        using type = conditional_t<sizeof(T) < sizeof(short), short,
                     conditional_t<sizeof(T) < sizeof(int), int,
                     conditional_t<sizeof(T) < sizeof(long), long, long long>>>;
    };
    template<class T>
    using iota_diff_t = typename get_iota_diff<T>::type;

    template<class T>
    struct iota_iter_category {};
    template<incrementable T>
    struct iota_iter_category<T> { using iterator_category = input_iterator_tag; };
} // namespace iota_detail

template<weakly_incrementable Start,
         semiregular BoundSentinel = unreachable_sentinel_t>
    requires std::detail::weakly_equality_comparable_with<Start, BoundSentinel> && copyable<Start>
class iota_view : public view_interface<iota_view<Start, BoundSentinel>> {
    struct iterator : public iota_detail::iota_iter_category<Start> {
        friend class iota_view;
        using iterator_concept =
            conditional_t<iota_detail::advanceable<Start>, random_access_iterator_tag,
            conditional_t<iota_detail::decrementable<Start>, bidirectional_iterator_tag,
            conditional_t<incrementable<Start>, forward_iterator_tag,
            input_iterator_tag>>>;
        using value_type = Start;
        using difference_type = iota_detail::iota_diff_t<Start>;

        Start value_ = Start();

        iterator()
            requires default_initializable<Start>
        = default;
        constexpr explicit iterator(Start v) : value_(move(v)) {}

        [[nodiscard]] constexpr Start operator*() const
            noexcept(is_nothrow_copy_constructible_v<Start>) {
            return value_;
        }
        constexpr iterator& operator++() { ++value_; return *this; }
        constexpr void operator++(int) { ++*this; }
        constexpr iterator operator++(int) requires incrementable<Start> {
            auto tmp = *this; ++*this; return tmp;
        }
        constexpr iterator& operator--() requires iota_detail::decrementable<Start> {
            --value_; return *this;
        }
        constexpr iterator operator--(int) requires iota_detail::decrementable<Start> {
            auto tmp = *this; --*this; return tmp;
        }
        constexpr iterator& operator+=(difference_type n)
            requires iota_detail::advanceable<Start>
        {
            value_ += n; return *this;
        }
        constexpr iterator& operator-=(difference_type n)
            requires iota_detail::advanceable<Start>
        {
            value_ -= n; return *this;
        }
        [[nodiscard]] constexpr Start operator[](difference_type n) const
            requires iota_detail::advanceable<Start>
        {
            return Start(value_ + n);
        }
        friend constexpr bool operator==(const iterator& x, const iterator& y)
            requires equality_comparable<Start>
        {
            return x.value_ == y.value_;
        }
        friend constexpr bool operator<(const iterator& x, const iterator& y)
            requires totally_ordered<Start>
        { return x.value_ < y.value_; }
        friend constexpr bool operator>(const iterator& x, const iterator& y)
            requires totally_ordered<Start>
        { return y < x; }
        friend constexpr bool operator<=(const iterator& x, const iterator& y)
            requires totally_ordered<Start>
        { return !(y < x); }
        friend constexpr bool operator>=(const iterator& x, const iterator& y)
            requires totally_ordered<Start>
        { return !(x < y); }
        friend constexpr auto operator<=>(const iterator& x, const iterator& y)
            requires totally_ordered<Start> && three_way_comparable<Start>
        { return x.value_ <=> y.value_; }
        friend constexpr iterator operator+(iterator i, difference_type n)
            requires iota_detail::advanceable<Start>
        { i += n; return i; }
        friend constexpr iterator operator+(difference_type n, iterator i)
            requires iota_detail::advanceable<Start>
        { return i + n; }
        friend constexpr iterator operator-(iterator i, difference_type n)
            requires iota_detail::advanceable<Start>
        { i -= n; return i; }
        friend constexpr difference_type operator-(const iterator& x, const iterator& y)
            requires iota_detail::advanceable<Start>
        {
            if constexpr (integral<Start>) {
                if constexpr (is_signed_v<Start>)
                    return difference_type(difference_type(x.value_) - difference_type(y.value_));
                if (y.value_ > x.value_)
                    return difference_type(-difference_type(y.value_ - x.value_));
                return difference_type(x.value_ - y.value_);
            }
            return x.value_ - y.value_;
        }
    };

    struct sentinel {
        friend class iota_view;
        BoundSentinel bound_ = BoundSentinel();
        sentinel() = default;
        constexpr explicit sentinel(BoundSentinel b) : bound_(move(b)) {}
        friend constexpr bool operator==(const iterator& x, const sentinel& y) {
            return x.value_ == y.bound_;
        }
        friend constexpr iter_difference_t<Start>
        operator-(const iterator& x, const sentinel& y)
            requires sized_sentinel_for<BoundSentinel, Start>
        { return x.value_ - y.bound_; }
        friend constexpr iter_difference_t<Start>
        operator-(const sentinel& x, const iterator& y)
            requires sized_sentinel_for<BoundSentinel, Start>
        { return -(y - x); }
    };

    Start value_ = Start();
    BoundSentinel bound_ = BoundSentinel();

public:
    iota_view()
        requires default_initializable<Start>
    = default;
    constexpr explicit iota_view(Start value) : value_(move(value)) {}
    constexpr iota_view(type_identity_t<Start> value, type_identity_t<BoundSentinel> bound)
        : value_(move(value)), bound_(move(bound)) {}

    [[nodiscard]] constexpr iterator begin() const { return iterator{value_}; }

    // When Start == BoundSentinel, end() returns an iterator (common range).
    // Otherwise, when BoundSentinel is unreachable_sentinel_t, returns unreachable_sentinel.
    // Otherwise, returns a sentinel.
    [[nodiscard]] constexpr auto end() const {
        if constexpr (same_as<Start, BoundSentinel>)
            return iterator{bound_};
        else if constexpr (same_as<BoundSentinel, unreachable_sentinel_t>)
            return unreachable_sentinel;
        else
            return sentinel{bound_};
    }
    [[nodiscard]] constexpr bool empty() const { return value_ == bound_; }
    [[nodiscard]] constexpr auto size() const
        requires (same_as<Start, BoundSentinel> && iota_detail::advanceable<Start>) ||
                 (integral<Start> && integral<BoundSentinel>) ||
                 sized_sentinel_for<BoundSentinel, Start>
    {
        if constexpr (integral<Start> && integral<BoundSentinel>) {
            return (value_ < 0)
                ? (bound_ < 0
                   ? make_unsigned_t<Start>(-value_) - make_unsigned_t<Start>(-bound_)
                   : make_unsigned_t<Start>(bound_) + make_unsigned_t<Start>(-value_))
                : make_unsigned_t<Start>(bound_) - make_unsigned_t<Start>(value_);
        } else {
            return static_cast<make_unsigned_t<iter_difference_t<Start>>>(bound_ - value_);
        }
    }
};

template<class Start, class BoundSentinel>
iota_view(Start, BoundSentinel) -> iota_view<Start, BoundSentinel>;

template<class Start, class BoundSentinel>
inline constexpr bool enable_borrowed_range<iota_view<Start, BoundSentinel>> = true;

template<class Start, class BoundSentinel>
inline constexpr bool enable_view<iota_view<Start, BoundSentinel>> = true;

