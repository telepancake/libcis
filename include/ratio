using hecto = ratio<100LL, 1LL>;
using kilo  = ratio<1000LL, 1LL>;
using mega  = ratio<1000000LL, 1LL>;
using giga  = ratio<1000000000LL, 1LL>;
using tera  = ratio<1000000000000LL, 1LL>;
