//===----------------------------------------------------------------------===//
// String-search helpers (ported from libc++ __string/char_traits.h).
// These are used by basic_string_view's find/rfind/find_*_of methods.
// Names stripped of leading underscores per CONVENTIONS.
//===----------------------------------------------------------------------===//

// str_find_char: find single char
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find(const CharT* p, SizeT sz, CharT c, SizeT pos) noexcept {
    if (pos > sz) return Npos;
    const CharT* r = Traits::find(p + pos, sz - pos, c);
    if (r == nullptr) return Npos;
    return static_cast<SizeT>(r - p);
}

// search_substring: find first occurrence of [first2,last2) in [first1,last1)
template<class CharT, class Traits>
constexpr const CharT*
search_substring(const CharT* first1, const CharT* last1,
                 const CharT* first2, const CharT* last2) noexcept {
    const ptrdiff_t len2 = last2 - first2;
    if (len2 == 0) return first1;

    ptrdiff_t len1 = last1 - first1;
    if (len1 < len2) return last1;

    CharT f2 = *first2;
    while (true) {
        len1 = last1 - first1;
        if (len1 < len2) return last1;
        first1 = Traits::find(first1, static_cast<size_t>(len1 - len2 + 1), f2);
        if (first1 == nullptr) return last1;
        if (Traits::compare(first1, first2, static_cast<size_t>(len2)) == 0)
            return first1;
        ++first1;
    }
}

// str_find_substr: find substring
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find(const CharT* p, SizeT sz,
         const CharT* s, SizeT pos, SizeT n) noexcept {
    if (pos > sz) return Npos;
    if (n == 0) return pos;
    const CharT* r = search_substring<CharT, Traits>(p + pos, p + sz, s, s + n);
    if (r == p + sz) return Npos;
    return static_cast<SizeT>(r - p);
}

// str_rfind_char
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_rfind(const CharT* p, SizeT sz, CharT c, SizeT pos) noexcept {
    if (sz < 1) return Npos;
    SizeT end = (pos < sz) ? pos + 1 : sz;
    for (const CharT* ps = p + end; ps != p;) {
        if (Traits::eq(*--ps, c))
            return static_cast<SizeT>(ps - p);
    }
    return Npos;
}

// str_rfind_substr
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_rfind(const CharT* p, SizeT sz,
          const CharT* s, SizeT pos, SizeT n) noexcept {
    SizeT end = detail::sv_min(pos, sz);
    // if n <= sz-end, shift end forward by n; otherwise end = sz
    if (n <= sz - end) end += n;
    else end = sz;
    const CharT* search_end = p + end;
    // find_end_classic: scan backwards for n-char match
    if (n == 0) return static_cast<SizeT>(search_end - p);
    // search backwards
    while (search_end != p) {
        --search_end;
        // try match at search_end
        if (Traits::eq(*search_end, s[0])) {
            // check if there's enough room
            if (static_cast<SizeT>(p + end - search_end) >= n &&
                Traits::compare(search_end, s, n) == 0)
                return static_cast<SizeT>(search_end - p);
        }
    }
    return Npos;
}

// str_find_first_of
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find_first_of(const CharT* p, SizeT sz,
                  const CharT* s, SizeT pos, SizeT n) noexcept {
    if (pos >= sz || n == 0) return Npos;
    for (const CharT* ps = p + pos; ps != p + sz; ++ps) {
        if (Traits::find(s, n, *ps) != nullptr)
            return static_cast<SizeT>(ps - p);
    }
    return Npos;
}

// str_find_last_of
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find_last_of(const CharT* p, SizeT sz,
                 const CharT* s, SizeT pos, SizeT n) noexcept {
    if (n == 0) return Npos;
    SizeT end = (pos < sz) ? pos + 1 : sz;
    for (const CharT* ps = p + end; ps != p;) {
        if (Traits::find(s, n, *--ps) != nullptr)
            return static_cast<SizeT>(ps - p);
    }
    return Npos;
}

// str_find_first_not_of (substring set)
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find_first_not_of(const CharT* p, SizeT sz,
                      const CharT* s, SizeT pos, SizeT n) noexcept {
    if (pos < sz) {
        for (const CharT* ps = p + pos; ps != p + sz; ++ps) {
            if (Traits::find(s, n, *ps) == nullptr)
                return static_cast<SizeT>(ps - p);
        }
    }
    return Npos;
}

// str_find_first_not_of (single char)
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find_first_not_of(const CharT* p, SizeT sz, CharT c, SizeT pos) noexcept {
    if (pos < sz) {
        for (const CharT* ps = p + pos; ps != p + sz; ++ps) {
            if (!Traits::eq(*ps, c))
                return static_cast<SizeT>(ps - p);
        }
    }
    return Npos;
}

// str_find_last_not_of (substring set)
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find_last_not_of(const CharT* p, SizeT sz,
                     const CharT* s, SizeT pos, SizeT n) noexcept {
    SizeT end = (pos < sz) ? pos + 1 : sz;
    for (const CharT* ps = p + end; ps != p;) {
        if (Traits::find(s, n, *--ps) == nullptr)
            return static_cast<SizeT>(ps - p);
    }
    return Npos;
}

// str_find_last_not_of (single char)
template<class CharT, class SizeT, class Traits, SizeT Npos>
constexpr SizeT
str_find_last_not_of(const CharT* p, SizeT sz, CharT c, SizeT pos) noexcept {
    SizeT end = (pos < sz) ? pos + 1 : sz;
    for (const CharT* ps = p + end; ps != p;) {
        if (!Traits::eq(*--ps, c))
            return static_cast<SizeT>(ps - p);
    }
    return Npos;
}

//===----------------------------------------------------------------------===//
// basic_string_view
// Ported from libc++ include/string_view.
//
// Iterator: plain const pointer (no ABI-bounded / wrap variants).
// substr: out_of_range replaced with __builtin_trap() (no exceptions).
// at:     same.
// copy:   same.
// Hash specialisations: deferred.
//===----------------------------------------------------------------------===//

template<class CharT, class Traits = char_traits<CharT>>
class basic_string_view {
public:
    // types
    using traits_type            = Traits;
    using value_type             = CharT;
    using pointer                = CharT*;
    using const_pointer          = const CharT*;
    using reference              = CharT&;
    using const_reference        = const CharT&;
    using const_iterator         = const CharT*;
    using iterator               = const_iterator;
    using const_reverse_iterator = std::reverse_iterator<const_iterator>;
    using reverse_iterator       = const_reverse_iterator;
    using size_type              = size_t;
    using difference_type        = ptrdiff_t;

    static constexpr size_type npos = size_type(-1);

    static_assert(!is_array_v<value_type>,
        "Character type of basic_string_view must not be an array");
    static_assert(is_standard_layout_v<value_type>,
        "Character type of basic_string_view must be standard-layout");
    static_assert(is_trivially_copyable_v<value_type>,
        "Character type of basic_string_view must be trivially copyable");
    static_assert(is_same_v<CharT, typename traits_type::char_type>,
        "traits_type::char_type must be the same type as CharT");

    // [string.view.cons]
    constexpr basic_string_view() noexcept : data_(nullptr), size_(0) {}

    basic_string_view(const basic_string_view&) noexcept = default;
    basic_string_view& operator=(const basic_string_view&) noexcept = default;

    constexpr basic_string_view(const CharT* s, size_type len) noexcept
        : data_(s), size_(len) {}

    constexpr basic_string_view(const CharT* s)
        : data_(s), size_(traits_type::length(s)) {}

    // C++20: iterator-pair constructor
    template<class It, class End>
        requires (is_same_v<typename iterator_traits<It>::value_type, CharT> &&
                  !is_convertible_v<End, size_type>)
    constexpr basic_string_view(It begin, End end)
        : data_(begin), size_(static_cast<size_type>(end - begin)) {}

    // [string.view.iterators]
    [[nodiscard]] constexpr const_iterator begin()  const noexcept { return data_; }
    [[nodiscard]] constexpr const_iterator end()    const noexcept { return data_ + size_; }
    [[nodiscard]] constexpr const_iterator cbegin() const noexcept { return data_; }
    [[nodiscard]] constexpr const_iterator cend()   const noexcept { return data_ + size_; }

    [[nodiscard]] constexpr const_reverse_iterator rbegin()  const noexcept {
        return const_reverse_iterator(cend());
    }
    [[nodiscard]] constexpr const_reverse_iterator rend()    const noexcept {
        return const_reverse_iterator(cbegin());
    }
    [[nodiscard]] constexpr const_reverse_iterator crbegin() const noexcept {
        return const_reverse_iterator(cend());
    }
    [[nodiscard]] constexpr const_reverse_iterator crend()   const noexcept {
        return const_reverse_iterator(cbegin());
    }

    // [string.view.capacity]
    [[nodiscard]] constexpr size_type size()     const noexcept { return size_; }
    [[nodiscard]] constexpr size_type length()   const noexcept { return size_; }
    [[nodiscard]] constexpr size_type max_size() const noexcept {
        return numeric_limits<size_type>::max() / sizeof(value_type);
    }
    [[nodiscard]] constexpr bool empty() const noexcept { return size_ == 0; }

    // [string.view.access]
    [[nodiscard]] constexpr const_reference operator[](size_type pos) const noexcept {
        return data_[pos];
    }

    // at: out_of_range -> __builtin_trap (no exceptions in this build)
    [[nodiscard]] constexpr const_reference at(size_type pos) const {
        if (pos >= size_) __builtin_trap(); // would throw out_of_range
        return data_[pos];
    }

    [[nodiscard]] constexpr const_reference front() const noexcept { return data_[0]; }
    [[nodiscard]] constexpr const_reference back()  const noexcept { return data_[size_ - 1]; }
    [[nodiscard]] constexpr const_pointer   data()  const noexcept { return data_; }

    // [string.view.modifiers]
    constexpr void remove_prefix(size_type n) noexcept {
        data_ += n;
        size_ -= n;
    }
    constexpr void remove_suffix(size_type n) noexcept {
        size_ -= n;
    }
    constexpr void swap(basic_string_view& other) noexcept {
        const value_type* p = data_;
        data_       = other.data_;
        other.data_ = p;
        size_type sz = size_;
        size_       = other.size_;
        other.size_ = sz;
    }

    // copy: out_of_range -> __builtin_trap
    constexpr size_type copy(CharT* s, size_type n, size_type pos = 0) const {
        if (pos > size_) __builtin_trap(); // would throw out_of_range
        size_type rlen = detail::sv_min(n, size_ - pos);
        traits_type::copy(s, data_ + pos, rlen);
        return rlen;
    }

    // substr: out_of_range -> __builtin_trap
    [[nodiscard]] constexpr basic_string_view
    substr(size_type pos = 0, size_type n = npos) const {
        if (pos > size_) __builtin_trap(); // would throw out_of_range
        return basic_string_view(data_ + pos, detail::sv_min(n, size_ - pos));
    }

    // compare
    [[nodiscard]] constexpr int compare(basic_string_view sv) const noexcept {
        size_type rlen = detail::sv_min(size_, sv.size_);
        int ret = traits_type::compare(data_, sv.data_, rlen);
        if (ret == 0) {
            if (size_ < sv.size_) ret = -1;
            else if (size_ > sv.size_) ret = 1;
        }
        return ret;
    }
    [[nodiscard]] constexpr int
    compare(size_type pos1, size_type n1, basic_string_view sv) const {
        return substr(pos1, n1).compare(sv);
    }
    [[nodiscard]] constexpr int
    compare(size_type pos1, size_type n1,
            basic_string_view sv, size_type pos2, size_type n2) const {
        return substr(pos1, n1).compare(sv.substr(pos2, n2));
    }
    [[nodiscard]] constexpr int compare(const CharT* s) const noexcept {
        return compare(basic_string_view(s));
    }
    [[nodiscard]] constexpr int
    compare(size_type pos1, size_type n1, const CharT* s) const {
        return substr(pos1, n1).compare(basic_string_view(s));
    }
    [[nodiscard]] constexpr int
    compare(size_type pos1, size_type n1, const CharT* s, size_type n2) const {
        return substr(pos1, n1).compare(basic_string_view(s, n2));
    }

    // starts_with / ends_with / contains (C++20/23)
    [[nodiscard]] constexpr bool starts_with(basic_string_view sv) const noexcept {
        return size_ >= sv.size_ && compare(0, sv.size_, sv) == 0;
    }
    [[nodiscard]] constexpr bool starts_with(value_type c) const noexcept {
        return !empty() && traits_type::eq(front(), c);
    }
    [[nodiscard]] constexpr bool starts_with(const value_type* s) const noexcept {
        return starts_with(basic_string_view(s));
    }

    [[nodiscard]] constexpr bool ends_with(basic_string_view sv) const noexcept {
        return size_ >= sv.size_ && compare(size_ - sv.size_, npos, sv) == 0;
    }
    [[nodiscard]] constexpr bool ends_with(value_type c) const noexcept {
        return !empty() && traits_type::eq(back(), c);
    }
    [[nodiscard]] constexpr bool ends_with(const value_type* s) const noexcept {
        return ends_with(basic_string_view(s));
    }

    [[nodiscard]] constexpr bool contains(basic_string_view sv) const noexcept {
        return find(sv) != npos;
    }
    [[nodiscard]] constexpr bool contains(value_type c) const noexcept {
        return find(c) != npos;
    }
    [[nodiscard]] constexpr bool contains(const value_type* s) const noexcept {
        return find(s) != npos;
    }

    // find
    [[nodiscard]] constexpr size_type
    find(basic_string_view s, size_type pos = 0) const noexcept {
        return str_find<value_type, size_type, traits_type, npos>(
            data_, size_, s.data_, pos, s.size_);
    }
    [[nodiscard]] constexpr size_type
    find(CharT c, size_type pos = 0) const noexcept {
        return str_find<value_type, size_type, traits_type, npos>(
            data_, size_, c, pos);
    }
    [[nodiscard]] constexpr size_type
    find(const CharT* s, size_type pos, size_type n) const noexcept {
        return str_find<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, n);
    }
    [[nodiscard]] constexpr size_type
    find(const CharT* s, size_type pos = 0) const noexcept {
        return str_find<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, traits_type::length(s));
    }

    // rfind
    [[nodiscard]] constexpr size_type
    rfind(basic_string_view s, size_type pos = npos) const noexcept {
        return str_rfind<value_type, size_type, traits_type, npos>(
            data_, size_, s.data_, pos, s.size_);
    }
    [[nodiscard]] constexpr size_type
    rfind(CharT c, size_type pos = npos) const noexcept {
        return str_rfind<value_type, size_type, traits_type, npos>(
            data_, size_, c, pos);
    }
    [[nodiscard]] constexpr size_type
    rfind(const CharT* s, size_type pos, size_type n) const noexcept {
        return str_rfind<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, n);
    }
    [[nodiscard]] constexpr size_type
    rfind(const CharT* s, size_type pos = npos) const noexcept {
        return str_rfind<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, traits_type::length(s));
    }

    // find_first_of
    [[nodiscard]] constexpr size_type
    find_first_of(basic_string_view s, size_type pos = 0) const noexcept {
        return str_find_first_of<value_type, size_type, traits_type, npos>(
            data_, size_, s.data_, pos, s.size_);
    }
    [[nodiscard]] constexpr size_type
    find_first_of(CharT c, size_type pos = 0) const noexcept {
        return find(c, pos);
    }
    [[nodiscard]] constexpr size_type
    find_first_of(const CharT* s, size_type pos, size_type n) const noexcept {
        return str_find_first_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, n);
    }
    [[nodiscard]] constexpr size_type
    find_first_of(const CharT* s, size_type pos = 0) const noexcept {
        return str_find_first_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, traits_type::length(s));
    }

    // find_last_of
    [[nodiscard]] constexpr size_type
    find_last_of(basic_string_view s, size_type pos = npos) const noexcept {
        return str_find_last_of<value_type, size_type, traits_type, npos>(
            data_, size_, s.data_, pos, s.size_);
    }
    [[nodiscard]] constexpr size_type
    find_last_of(CharT c, size_type pos = npos) const noexcept {
        return rfind(c, pos);
    }
    [[nodiscard]] constexpr size_type
    find_last_of(const CharT* s, size_type pos, size_type n) const noexcept {
        return str_find_last_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, n);
    }
    [[nodiscard]] constexpr size_type
    find_last_of(const CharT* s, size_type pos = npos) const noexcept {
        return str_find_last_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, traits_type::length(s));
    }

    // find_first_not_of
    [[nodiscard]] constexpr size_type
    find_first_not_of(basic_string_view s, size_type pos = 0) const noexcept {
        return str_find_first_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, s.data_, pos, s.size_);
    }
    [[nodiscard]] constexpr size_type
    find_first_not_of(CharT c, size_type pos = 0) const noexcept {
        return str_find_first_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, c, pos);
    }
    [[nodiscard]] constexpr size_type
    find_first_not_of(const CharT* s, size_type pos, size_type n) const noexcept {
        return str_find_first_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, n);
    }
    [[nodiscard]] constexpr size_type
    find_first_not_of(const CharT* s, size_type pos = 0) const noexcept {
        return str_find_first_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, traits_type::length(s));
    }

    // find_last_not_of
    [[nodiscard]] constexpr size_type
    find_last_not_of(basic_string_view s, size_type pos = npos) const noexcept {
        return str_find_last_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, s.data_, pos, s.size_);
    }
    [[nodiscard]] constexpr size_type
    find_last_not_of(CharT c, size_type pos = npos) const noexcept {
        return str_find_last_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, c, pos);
    }
    [[nodiscard]] constexpr size_type
    find_last_not_of(const CharT* s, size_type pos, size_type n) const noexcept {
        return str_find_last_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, n);
    }
    [[nodiscard]] constexpr size_type
    find_last_not_of(const CharT* s, size_type pos = npos) const noexcept {
        return str_find_last_not_of<value_type, size_type, traits_type, npos>(
            data_, size_, s, pos, traits_type::length(s));
    }

private:
    const value_type* data_;
    size_type         size_;
};

