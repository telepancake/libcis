// <string_view> — basic_string_view + char_traits.
// Mechanically ported from libc++ include/string_view +
//   include/__string/char_traits.h
//   include/__string/constexpr_c_functions.h (relevant parts)
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// char_traits builtin audit (probed against gcc-10.2):
//   CONSTEXPR-OK  : __builtin_memcmp, __builtin_strlen, __builtin_memchr
//                   (char* cast from void* also works in constexpr)
//   NOT CONSTEXPR : __builtin_memcpy, __builtin_memmove  → hand-written loops
//   NOT PRESENT   : __builtin_char_memchr, __builtin_wmemcmp,
//                   __builtin_wcslen, __builtin_wmemchr
//   wchar_t / char16_t / char32_t : hand-written constexpr loops throughout
//
// substr / out_of_range: exceptions are disabled (-fno-exceptions).
//   Out-of-range on substr/at/copy calls __builtin_trap() instead.
//
// Hash specialisations: deferred — needs <functional> (not yet ported).
//   The specialisations are not provided here; add them when <functional>
//   is available.
//
// char_traits lives here (not in bits/) so that <string> can
//   #include <string_view> to reuse it.
#pragma once

#include <type_traits>
#include <compare>
#include <iterator>
#include <limits>
#include <cstdio>   // EOF
#include <cwchar>   // WEOF, wint_t, mbstate_t

namespace std {

//===----------------------------------------------------------------------===//
// Internal helper: constexpr min (avoids <algorithm> dependency)
//===----------------------------------------------------------------------===//
namespace detail {
    template<class T>
    constexpr T sv_min(T a, T b) noexcept { return a < b ? a : b; }
} // namespace detail

//===----------------------------------------------------------------------===//
// char_traits — primary template (intentionally incomplete; specialisations
//   below supply the actual definitions)
//===----------------------------------------------------------------------===//

template<class CharT>
struct char_traits;

//===----------------------------------------------------------------------===//
// char_traits<char>
// Ported from libc++ __string/char_traits.h specialisation for char.
//
// compare:  constexpr loop (gcc-10 __builtin_memcmp IS constexpr; used here)
// length:   constexpr loop (gcc-10 __builtin_strlen IS constexpr, but the
//           libc++ note says "GCC doesn't support __builtin_strlen for
//           heap-allocated memory during CE"; safe loop used instead)
// find:     __builtin_memchr IS constexpr in gcc-10 (probed); used directly
// copy/move/assign(array): hand-written constexpr loops (__builtin_memcpy /
//           __builtin_memmove are NOT constexpr in gcc-10)
//===----------------------------------------------------------------------===//

template<>
struct char_traits<char> {
    using char_type  = char;
    using int_type   = int;
    using off_type   = long;          // streamoff equivalent, avoids <iosfwd>
    using pos_type   = long;          // streampos equivalent
    using state_type = mbstate_t;
    using comparison_category = strong_ordering;

    static constexpr void assign(char_type& c1, const char_type& c2) noexcept {
        c1 = c2;
    }

    [[nodiscard]] static constexpr bool eq(char_type c1, char_type c2) noexcept {
        return c1 == c2;
    }

    [[nodiscard]] static constexpr bool lt(char_type c1, char_type c2) noexcept {
        return (unsigned char)c1 < (unsigned char)c2;
    }

    // __builtin_memcmp IS constexpr in gcc-10 (probed).
    // char may be signed, so we compare via lt() in the constexpr path to
    // ensure unsigned-char semantics (matching libc++ non-clang path).
    [[nodiscard]] static constexpr int
    compare(const char_type* lhs, const char_type* rhs, size_t count) noexcept {
        if (__builtin_is_constant_evaluated()) {
            for (size_t i = 0; i < count; ++i) {
                if (lt(lhs[i], rhs[i])) return -1;
                if (lt(rhs[i], lhs[i])) return  1;
            }
            return 0;
        }
        return __builtin_memcmp(lhs, rhs, count);
    }

    [[nodiscard]] static constexpr size_t length(const char_type* s) noexcept {
        // Hand-written loop: safe in constexpr on gcc-10.
        size_t i = 0;
        for (; s[i] != '\0'; ++i) {}
        return i;
    }

    [[nodiscard]] static constexpr const char_type*
    find(const char_type* s, size_t n, const char_type& a) noexcept {
        if (__builtin_is_constant_evaluated()) {
            for (size_t i = 0; i < n; ++i) {
                if (eq(s[i], a)) return s + i;
            }
            return nullptr;
        }
        return static_cast<const char_type*>(__builtin_memchr(s, (unsigned char)a, n));
    }

    // move: overlapping-safe copy (no constexpr __builtin_memmove in gcc-10)
    static constexpr char_type*
    move(char_type* s1, const char_type* s2, size_t n) noexcept {
        if (__builtin_is_constant_evaluated()) {
            if (s1 < s2 || s1 >= s2 + n) {
                for (size_t i = 0; i < n; ++i) s1[i] = s2[i];
            } else {
                for (size_t i = n; i > 0; --i) s1[i-1] = s2[i-1];
            }
            return s1;
        }
        __builtin_memmove(s1, s2, n);
        return s1;
    }

    // copy: non-overlapping
    static constexpr char_type*
    copy(char_type* s1, const char_type* s2, size_t n) noexcept {
        if (__builtin_is_constant_evaluated()) {
            for (size_t i = 0; i < n; ++i) s1[i] = s2[i];
            return s1;
        }
        __builtin_memcpy(s1, s2, n);
        return s1;
    }

    // assign(array)
    static constexpr char_type*
    assign(char_type* s, size_t n, char_type a) noexcept {
        for (size_t i = 0; i < n; ++i) s[i] = a;
        return s;
    }

    [[nodiscard]] static constexpr int_type not_eof(int_type c) noexcept {
        return eq_int_type(c, eof()) ? ~eof() : c;
    }
    [[nodiscard]] static constexpr char_type to_char_type(int_type c) noexcept {
        return char_type(c);
    }
    [[nodiscard]] static constexpr int_type to_int_type(char_type c) noexcept {
        return int_type((unsigned char)c);
    }
    [[nodiscard]] static constexpr bool eq_int_type(int_type c1, int_type c2) noexcept {
        return c1 == c2;
    }
    [[nodiscard]] static constexpr int_type eof() noexcept {
        return int_type(EOF);
    }
};

//===----------------------------------------------------------------------===//
// char_traits_base — shared CRTP-less base for wchar_t / char8_t /
//   char16_t / char32_t (mirrors __char_traits_base in libc++)
// Template parameters: CharT, IntT, EOFVal
//===----------------------------------------------------------------------===//

template<class CharT, class IntT, IntT EOFVal>
struct char_traits_base {
    using char_type  = CharT;
    using int_type   = IntT;
    using off_type   = long;
    using pos_type   = long;
    using state_type = mbstate_t;
    using comparison_category = strong_ordering;

    static constexpr void
    assign(char_type& lhs, const char_type& rhs) noexcept { lhs = rhs; }

    [[nodiscard]] static constexpr bool eq(char_type lhs, char_type rhs) noexcept {
        return lhs == rhs;
    }
    [[nodiscard]] static constexpr bool lt(char_type lhs, char_type rhs) noexcept {
        return lhs < rhs;
    }

    // move
    static constexpr char_type*
    move(char_type* dest, const char_type* src, size_t n) noexcept {
        if (__builtin_is_constant_evaluated()) {
            if (dest < src || dest >= src + n) {
                for (size_t i = 0; i < n; ++i) dest[i] = src[i];
            } else {
                for (size_t i = n; i > 0; --i) dest[i-1] = src[i-1];
            }
            return dest;
        }
        __builtin_memmove(dest, src, n * sizeof(char_type));
        return dest;
    }

    // copy
    static constexpr char_type*
    copy(char_type* dest, const char_type* src, size_t n) noexcept {
        if (__builtin_is_constant_evaluated()) {
            for (size_t i = 0; i < n; ++i) dest[i] = src[i];
            return dest;
        }
        __builtin_memcpy(dest, src, n * sizeof(char_type));
        return dest;
    }

    // assign(array)
    static constexpr char_type*
    assign(char_type* str, size_t n, char_type fill_char) noexcept {
        for (size_t i = 0; i < n; ++i) str[i] = fill_char;
        return str;
    }

    [[nodiscard]] static constexpr char_type to_char_type(int_type c) noexcept {
        return char_type(c);
    }
    [[nodiscard]] static constexpr int_type to_int_type(char_type c) noexcept {
        return int_type(c);
    }
    [[nodiscard]] static constexpr bool eq_int_type(int_type lhs, int_type rhs) noexcept {
        return lhs == rhs;
    }
    [[nodiscard]] static constexpr int_type eof() noexcept { return EOFVal; }
    [[nodiscard]] static constexpr int_type not_eof(int_type c) noexcept {
        return eq_int_type(c, eof()) ? static_cast<int_type>(~eof()) : c;
    }
};

//===----------------------------------------------------------------------===//
// char_traits<wchar_t>
// All constexpr operations use hand-written loops (no gcc-10 wide builtins).
//===----------------------------------------------------------------------===//

template<>
struct char_traits<wchar_t>
    : char_traits_base<wchar_t, wint_t, static_cast<wint_t>(WEOF)> {

    [[nodiscard]] static constexpr int
    compare(const char_type* s1, const char_type* s2, size_t n) noexcept {
        for (size_t i = 0; i < n; ++i) {
            if (lt(s1[i], s2[i])) return -1;
            if (lt(s2[i], s1[i])) return  1;
        }
        return 0;
    }

    [[nodiscard]] static constexpr size_t length(const char_type* s) noexcept {
        size_t i = 0;
        for (; !eq(s[i], char_type(0)); ++i) {}
        return i;
    }

    [[nodiscard]] static constexpr const char_type*
    find(const char_type* s, size_t n, const char_type& a) noexcept {
        for (size_t i = 0; i < n; ++i) {
            if (eq(s[i], a)) return s + i;
        }
        return nullptr;
    }
};

//===----------------------------------------------------------------------===//
// char_traits<char8_t>
// compare/length/find via hand-written loops or __builtin_memchr (same-byte).
//===----------------------------------------------------------------------===//

template<>
struct char_traits<char8_t>
    : char_traits_base<char8_t, unsigned int, static_cast<unsigned int>(EOF)> {

    [[nodiscard]] static constexpr int
    compare(const char8_t* s1, const char8_t* s2, size_t n) noexcept {
        if (__builtin_is_constant_evaluated()) {
            for (size_t i = 0; i < n; ++i) {
                if (s1[i] < s2[i]) return -1;
                if (s2[i] < s1[i]) return  1;
            }
            return 0;
        }
        return __builtin_memcmp(s1, s2, n);
    }

    [[nodiscard]] static constexpr size_t length(const char8_t* s) noexcept {
        size_t i = 0;
        for (; s[i] != char8_t(0); ++i) {}
        return i;
    }

    [[nodiscard]] static constexpr const char8_t*
    find(const char8_t* s, size_t n, const char8_t& a) noexcept {
        if (__builtin_is_constant_evaluated()) {
            for (size_t i = 0; i < n; ++i) {
                if (s[i] == a) return s + i;
            }
            return nullptr;
        }
        return static_cast<const char8_t*>(__builtin_memchr(s, (unsigned char)a, n));
    }
};

