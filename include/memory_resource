// __memory/allocator_arg_t.h: __user_alloc_construct_impl.
// The dispatch constant detail::uses_alloc_ctor lives in <tuple>.
namespace detail {

template <class T, class Allocator, class... Args>
inline void user_alloc_construct_impl(integral_constant<int, 0>, T* storage, const Allocator&, Args&&... args) {
  ::new ((void*)storage) T(std::forward<Args>(args)...);
}

template <class T, class Allocator, class... Args>
inline void user_alloc_construct_impl(integral_constant<int, 1>, T* storage, const Allocator& a, Args&&... args) {
  ::new ((void*)storage) T(allocator_arg, a, std::forward<Args>(args)...);
}

template <class T, class Allocator, class... Args>
inline void user_alloc_construct_impl(integral_constant<int, 2>, T* storage, const Allocator& a, Args&&... args) {
  ::new ((void*)storage) T(std::forward<Args>(args)..., a);
}

} // namespace detail

