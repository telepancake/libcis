// <barrier> -- barrier synchronization primitive.
// Mechanically ported from libc++ include/barrier.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// Algorithm note: uses a simple "central barrier" (flat counter + phase token)
// rather than libc++'s tree barrier.  Semantics are identical; throughput on
// many-core machines is lower, but correctness and ABI simplicity are better
// for this embedded use-case.

#include <atomic>
#include <cstdint>
#include <limits>
#include <cstddef>
#include <type_traits>

namespace std {

// Default no-op completion function.
struct empty_completion {
    void operator()() noexcept {}
};

template<class CompletionFunction = empty_completion>
class barrier {
public:
    // arrival_token is a phase tag; odd = waiting for this phase to close.
    using arrival_token = uint32_t;

    [[nodiscard]] static constexpr ptrdiff_t max() noexcept {
        return numeric_limits<ptrdiff_t>::max();
    }

    constexpr explicit barrier(ptrdiff_t count,
                               CompletionFunction f = CompletionFunction()) noexcept
        : expected(count),
          current(count),
          phase(0),
          completion(static_cast<CompletionFunction&&>(f)) {}

    ~barrier() = default;
    barrier(const barrier&)            = delete;
    barrier& operator=(const barrier&) = delete;

    // Decrement the arrival count by `update`.  Returns a token for the current
    // phase that can be passed to wait().
    [[nodiscard]] arrival_token arrive(ptrdiff_t update = 1) noexcept {
        arrival_token old_phase = phase.load(memory_order_relaxed);
        ptrdiff_t prev = current.fetch_sub(update, memory_order_acq_rel);
        if (prev == update) {
            // Last arrival: run completion, reset counter, advance phase.
            completion();
            current.store(expected.load(memory_order_relaxed),
                          memory_order_relaxed);
            // Advance phase by 1 so waiters whose token != new phase wake.
            phase.fetch_add(1, memory_order_release);
            phase.notify_all();
        }
        return old_phase;
    }

    // Block until the phase associated with `arrival` has completed.
    void wait(arrival_token&& arrival) const noexcept {
        while (true) {
            arrival_token cur = phase.load(memory_order_acquire);
            if (cur != arrival)
                return;
            phase.wait(arrival, memory_order_acquire);
        }
    }

    void arrive_and_wait() noexcept {
        wait(arrive());
    }

    // Drop this thread's slot from future phases.
    void arrive_and_drop() noexcept {
        // Decrement the expected count so future phases need one fewer arrival.
        expected.fetch_sub(1, memory_order_relaxed);
        (void)arrive(1);
    }

private:
    atomic<ptrdiff_t>   expected;
    atomic<ptrdiff_t>   current;
    atomic<arrival_token> phase;
    CompletionFunction  completion;
};

} // namespace std
