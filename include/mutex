//===----------------------------------------------------------------------===//
// lock_guard (from __mutex/lock_guard.h)
//===----------------------------------------------------------------------===//

template <class Mutex>
class lock_guard {
public:
    using mutex_type = Mutex;
private:
    mutex_type& m_;
public:
    explicit lock_guard(mutex_type& m) : m_(m) { m_.lock(); }
    lock_guard(mutex_type& m, adopt_lock_t) : m_(m) {}
    ~lock_guard() { m_.unlock(); }

    lock_guard(const lock_guard&)            = delete;
    lock_guard& operator=(const lock_guard&) = delete;
};

//===----------------------------------------------------------------------===//
// unique_lock (from __mutex/unique_lock.h)
//===----------------------------------------------------------------------===//

template <class Mutex>
class unique_lock {
public:
    using mutex_type = Mutex;
private:
    mutex_type* m_;
    bool owns_;
public:
    unique_lock() noexcept : m_(nullptr), owns_(false) {}

    explicit unique_lock(mutex_type& m) : m_(addressof(m)), owns_(true) {
        m_->lock();
    }

    unique_lock(mutex_type& m, defer_lock_t) noexcept
        : m_(addressof(m)), owns_(false) {}

    unique_lock(mutex_type& m, try_to_lock_t)
        : m_(addressof(m)), owns_(m.try_lock()) {}

    unique_lock(mutex_type& m, adopt_lock_t)
        : m_(addressof(m)), owns_(true) {}

    template <class Clock, class Duration>
    unique_lock(mutex_type& m, const chrono::time_point<Clock, Duration>& t)
        : m_(addressof(m)), owns_(m.try_lock_until(t)) {}

    template <class Rep, class Period>
    unique_lock(mutex_type& m, const chrono::duration<Rep, Period>& d)
        : m_(addressof(m)), owns_(m.try_lock_for(d)) {}

    ~unique_lock() {
        if (owns_) m_->unlock();
    }

    unique_lock(const unique_lock&)            = delete;
    unique_lock& operator=(const unique_lock&) = delete;

    unique_lock(unique_lock&& u) noexcept : m_(u.m_), owns_(u.owns_) {
        u.m_    = nullptr;
        u.owns_ = false;
    }

    unique_lock& operator=(unique_lock&& u) noexcept {
        if (this != addressof(u))
            unique_lock(std::move(u)).swap(*this);
        return *this;
    }

    void lock() {
        if (m_ == nullptr) __builtin_trap(); // null mutex
        if (owns_) __builtin_trap();          // already locked
        m_->lock();
        owns_ = true;
    }

    bool try_lock() {
        if (m_ == nullptr) __builtin_trap();
        if (owns_) __builtin_trap();
        owns_ = m_->try_lock();
        return owns_;
    }

    template <class Rep, class Period>
    bool try_lock_for(const chrono::duration<Rep, Period>& d) {
        if (m_ == nullptr) __builtin_trap();
        if (owns_) __builtin_trap();
        owns_ = m_->try_lock_for(d);
        return owns_;
    }

    template <class Clock, class Duration>
    bool try_lock_until(const chrono::time_point<Clock, Duration>& t) {
        if (m_ == nullptr) __builtin_trap();
        if (owns_) __builtin_trap();
        owns_ = m_->try_lock_until(t);
        return owns_;
    }

    void unlock() {
        if (!owns_) __builtin_trap(); // not locked
        m_->unlock();
        owns_ = false;
    }

    void swap(unique_lock& u) noexcept {
        std::swap(m_, u.m_);
        std::swap(owns_, u.owns_);
    }

    mutex_type* release() noexcept {
        mutex_type* m = m_;
        m_    = nullptr;
        owns_ = false;
        return m;
    }

    bool owns_lock() const noexcept { return owns_; }
    explicit operator bool() const noexcept { return owns_; }
    mutex_type* mutex() const noexcept { return m_; }
};

template <class Mutex>
inline void swap(unique_lock<Mutex>& x, unique_lock<Mutex>& y) noexcept {
    x.swap(y);
}

//===----------------------------------------------------------------------===//
// try_lock / lock (variadic, from libc++ mutex)
//===----------------------------------------------------------------------===//

template <class L0, class L1>
[[nodiscard]] int try_lock(L0& l0, L1& l1) {
    unique_lock<L0> u0(l0, try_to_lock_t{});
    if (u0.owns_lock()) {
        if (l1.try_lock()) {
            u0.release();
            return -1;
        } else {
            return 1;
        }
    }
    return 0;
}

template <class L0, class L1, class L2, class... L3>
[[nodiscard]] int try_lock(L0& l0, L1& l1, L2& l2, L3&... l3) {
    int r = 0;
    unique_lock<L0> u0(l0, try_to_lock);
    if (u0.owns_lock()) {
        r = std::try_lock(l1, l2, l3...);
        if (r == -1)
            u0.release();
        else
            ++r;
    }
    return r;
}

template <class L0, class L1>
void lock(L0& l0, L1& l1) {
    while (true) {
        {
            unique_lock<L0> u0(l0);
            if (l1.try_lock()) {
                u0.release();
                break;
            }
        }
        sched_yield();
        {
            unique_lock<L1> u1(l1);
            if (l0.try_lock()) {
                u1.release();
                break;
            }
        }
        sched_yield();
    }
}

// lock_first — internal helper for variadic lock
template <class L0, class L1, class L2, class... L3>
void lock_first(int i, L0& l0, L1& l1, L2& l2, L3&... l3) {
    while (true) {
        switch (i) {
        case 0: {
            unique_lock<L0> u0(l0);
            i = std::try_lock(l1, l2, l3...);
            if (i == -1) { u0.release(); return; }
        }
            ++i;
            sched_yield();
            break;
        case 1: {
            unique_lock<L1> u1(l1);
            i = std::try_lock(l2, l3..., l0);
            if (i == -1) { u1.release(); return; }
        }
            if (i == static_cast<int>(sizeof...(L3)) + 1)
                i = 0;
            else
                i += 2;
            sched_yield();
            break;
        default:
            std::lock_first(i - 2, l2, l3..., l0, l1);
            return;
        }
    }
}

template <class L0, class L1, class L2, class... L3>
void lock(L0& l0, L1& l1, L2& l2, L3&... l3) {
    std::lock_first(0, l0, l1, l2, l3...);
}

//===----------------------------------------------------------------------===//
// scoped_lock (C++17, from libc++ mutex)
//===----------------------------------------------------------------------===//

template <class... Mutexes>
class scoped_lock;

template <>
class scoped_lock<> {
public:
    explicit scoped_lock() {}
    explicit scoped_lock(adopt_lock_t) {}
    ~scoped_lock() = default;
    scoped_lock(const scoped_lock&)            = delete;
    scoped_lock& operator=(const scoped_lock&) = delete;
};

template <class Mutex>
class scoped_lock<Mutex> {
public:
    using mutex_type = Mutex;
private:
    mutex_type& m_;
public:
    explicit scoped_lock(mutex_type& m) : m_(m) { m_.lock(); }
    ~scoped_lock() { m_.unlock(); }
    explicit scoped_lock(adopt_lock_t, mutex_type& m) : m_(m) {}
    scoped_lock(const scoped_lock&)            = delete;
    scoped_lock& operator=(const scoped_lock&) = delete;
};

template <class... MArgs>
class scoped_lock {
    static_assert(sizeof...(MArgs) > 1, "At least 2 lock types required");
    using MutexTuple = tuple<MArgs&...>;
public:
    explicit scoped_lock(MArgs&... margs) : t_(margs...) {
        std::lock(margs...);
    }
    scoped_lock(adopt_lock_t, MArgs&... margs) : t_(margs...) {}
    ~scoped_lock() { unlock_unpack(make_index_sequence<sizeof...(MArgs)>(), t_); }
    scoped_lock(const scoped_lock&)            = delete;
    scoped_lock& operator=(const scoped_lock&) = delete;
private:
    template <size_t... Idx>
    static void unlock_unpack(index_sequence<Idx...>, MutexTuple& mt) {
        (get<Idx>(mt).unlock(), ...);
    }
    MutexTuple t_;
};

//===----------------------------------------------------------------------===//
// timed_mutex (from libc++ mutex — implemented via mutex + condition_variable)
// NOTE: condition_variable is defined in <condition_variable> which includes
// <mutex>, so we cannot #include it here.  We forward-declare only; the timed
// operations are defined AFTER the full condition_variable definition.
// For a fully-self-contained single-TU build we include condition_variable
// here at the bottom via a deferred include trick.  Instead we inline the
// implementation directly using pthread_cond_t so we have no circular dep.
//===----------------------------------------------------------------------===//

class timed_mutex {
    pthread_mutex_t pm_  = PTHREAD_MUTEX_INITIALIZER;
    pthread_cond_t  pc_  = PTHREAD_COND_INITIALIZER;
    bool locked_ = false;
public:
    timed_mutex() = default;
    ~timed_mutex() {
        pthread_cond_destroy(&pc_);
        pthread_mutex_destroy(&pm_);
    }
    timed_mutex(const timed_mutex&)            = delete;
    timed_mutex& operator=(const timed_mutex&) = delete;

    void lock() {
        pthread_mutex_lock(&pm_);
        while (locked_)
            pthread_cond_wait(&pc_, &pm_);
        locked_ = true;
        pthread_mutex_unlock(&pm_);
    }

    bool try_lock() noexcept {
        pthread_mutex_lock(&pm_);
        bool got = !locked_;
        if (got) locked_ = true;
        pthread_mutex_unlock(&pm_);
        return got;
    }

    template <class Rep, class Period>
    bool try_lock_for(const chrono::duration<Rep, Period>& rel) {
        return try_lock_until(chrono::steady_clock::now() + rel);
    }

    template <class Clock, class Duration>
    bool try_lock_until(const chrono::time_point<Clock, Duration>& abs) {
        using namespace chrono;
        // Convert abs_time to system_clock nanoseconds for pthread_cond_timedwait
        auto abs_ns = time_point_cast<nanoseconds>(
            system_clock::now() + duration_cast<nanoseconds>(abs - Clock::now()));
        auto ns_count = abs_ns.time_since_epoch().count();
        struct timespec ts;
        ts.tv_sec  = static_cast<time_t>(ns_count / 1000000000LL);
        ts.tv_nsec = static_cast<long>(ns_count % 1000000000LL);
        if (ts.tv_nsec < 0) { ts.tv_nsec += 1000000000LL; --ts.tv_sec; }

        pthread_mutex_lock(&pm_);
        bool got = false;
        while (locked_) {
            int r = pthread_cond_timedwait(&pc_, &pm_, &ts);
            if (r == ETIMEDOUT) {
                got = false;
                goto done;
            }
        }
        got = true;
        locked_ = true;
    done:
        pthread_mutex_unlock(&pm_);
        return got;
    }

    void unlock() noexcept {
        pthread_mutex_lock(&pm_);
        locked_ = false;
        pthread_mutex_unlock(&pm_);
        pthread_cond_signal(&pc_);
    }
};

//===----------------------------------------------------------------------===//
// recursive_timed_mutex (from libc++ mutex)
//===----------------------------------------------------------------------===//

class recursive_timed_mutex {
    pthread_mutex_t pm_   = PTHREAD_MUTEX_INITIALIZER;
    pthread_cond_t  pc_   = PTHREAD_COND_INITIALIZER;
    size_t count_ = 0;
    pthread_t owner_{};
public:
    recursive_timed_mutex() = default;
    ~recursive_timed_mutex() {
        pthread_cond_destroy(&pc_);
        pthread_mutex_destroy(&pm_);
    }
    recursive_timed_mutex(const recursive_timed_mutex&)            = delete;
    recursive_timed_mutex& operator=(const recursive_timed_mutex&) = delete;

    void lock() {
        pthread_t self = pthread_self();
        pthread_mutex_lock(&pm_);
        if (count_ != 0 && pthread_equal(owner_, self)) {
            if (count_ == numeric_limits<size_t>::max()) { pthread_mutex_unlock(&pm_); __builtin_trap(); }
            ++count_;
            pthread_mutex_unlock(&pm_);
            return;
        }
        while (count_ != 0)
            pthread_cond_wait(&pc_, &pm_);
        count_ = 1;
        owner_ = self;
        pthread_mutex_unlock(&pm_);
    }

    bool try_lock() noexcept {
        pthread_t self = pthread_self();
        pthread_mutex_lock(&pm_);
        bool got = false;
        if (count_ == 0) {
            count_ = 1; owner_ = self; got = true;
        } else if (pthread_equal(owner_, self)) {
            if (count_ < numeric_limits<size_t>::max()) { ++count_; got = true; }
        }
        pthread_mutex_unlock(&pm_);
        return got;
    }

    template <class Rep, class Period>
    bool try_lock_for(const chrono::duration<Rep, Period>& rel) {
        return try_lock_until(chrono::steady_clock::now() + rel);
    }

    template <class Clock, class Duration>
    bool try_lock_until(const chrono::time_point<Clock, Duration>& abs) {
        using namespace chrono;
        pthread_t self = pthread_self();
        pthread_mutex_lock(&pm_);
        if (count_ != 0 && pthread_equal(owner_, self)) {
            if (count_ < numeric_limits<size_t>::max()) {
                ++count_;
                pthread_mutex_unlock(&pm_);
                return true;
            }
            pthread_mutex_unlock(&pm_);
            return false;
        }

        auto abs_ns = time_point_cast<nanoseconds>(
            system_clock::now() + duration_cast<nanoseconds>(abs - Clock::now()));
        auto ns_count = abs_ns.time_since_epoch().count();
        struct timespec ts;
        ts.tv_sec  = static_cast<time_t>(ns_count / 1000000000LL);
        ts.tv_nsec = static_cast<long>(ns_count % 1000000000LL);
        if (ts.tv_nsec < 0) { ts.tv_nsec += 1000000000LL; --ts.tv_sec; }

        bool got = false;
        while (count_ != 0) {
            int r = pthread_cond_timedwait(&pc_, &pm_, &ts);
            if (r == ETIMEDOUT) goto done;
        }
        count_ = 1;
        owner_ = self;
        got = true;
    done:
        pthread_mutex_unlock(&pm_);
        return got;
    }

    void unlock() noexcept {
        pthread_mutex_lock(&pm_);
        if (--count_ == 0)
            pthread_cond_signal(&pc_);
        pthread_mutex_unlock(&pm_);
    }
};

//===----------------------------------------------------------------------===//
// once_flag / call_once (from __mutex/once_flag.h)
// Uses pthread_once internally via an atomic state.
//===----------------------------------------------------------------------===//

struct once_flag {
    constexpr once_flag() noexcept : state_(0) {}
    once_flag(const once_flag&)            = delete;
    once_flag& operator=(const once_flag&) = delete;

    using state_type = unsigned long;
    static constexpr state_type unset    = 0;
    static constexpr state_type pending  = 1;
    static constexpr state_type complete = ~state_type(0);

private:
    state_type state_;

    template <class Callable, class... Args>
    friend void call_once(once_flag&, Callable&&, Args&&...);
};

// Proxy: wraps (callable, args...) tuple so pthread_once-style void(*)(void*) can call it
template <class Fp>
void call_once_proxy(void* vp) {
    auto* p = static_cast<Fp*>(vp);
    (*p)();
}

// Internal driver: uses an atomic acquire-load fast path; falls back to pthread_mutex
// for the slow path (double-checked, like __call_once in libc++).
namespace detail {

inline pthread_mutex_t& once_mutex() {
    static pthread_mutex_t m = PTHREAD_MUTEX_INITIALIZER;
    return m;
}
inline pthread_cond_t& once_cond() {
    static pthread_cond_t c = PTHREAD_COND_INITIALIZER;
    return c;
}

inline void call_once_impl(once_flag::state_type& state, void* fp, void (*proxy)(void*)) {
    pthread_mutex_lock(&once_mutex());
    while (true) {
        // reload under lock
        once_flag::state_type s = __atomic_load_n(&state, __ATOMIC_ACQUIRE);
        if (s == once_flag::complete) {
            pthread_mutex_unlock(&once_mutex());
            return;
        }
        if (s == once_flag::unset) {
            __atomic_store_n(&state, once_flag::pending, __ATOMIC_RELAXED);
            pthread_mutex_unlock(&once_mutex());
            // call the function — if it traps/aborts, state stays pending (correct)
            proxy(fp);
            pthread_mutex_lock(&once_mutex());
            __atomic_store_n(&state, once_flag::complete, __ATOMIC_RELEASE);
            pthread_cond_broadcast(&once_cond());
            pthread_mutex_unlock(&once_mutex());
            return;
        }
        // pending — another thread is running the function; wait
        pthread_cond_wait(&once_cond(), &once_mutex());
    }
}

} // namespace detail

template <class Callable, class... Args>
inline void call_once(once_flag& flag, Callable&& func, Args&&... args) {
    if (__atomic_load_n(&flag.state_, __ATOMIC_ACQUIRE) != once_flag::complete) {
        // Pack callable + args into a tuple, then invoke via index sequence.
        using Tuple = tuple<Callable&&, Args&&...>;
        Tuple f(forward<Callable>(func), forward<Args>(args)...);
        auto invoke_all = [&f]() {
            [&f]<size_t... I>(index_sequence<I...>) {
                // Call: get<0>(f)(get<1>(f), get<2>(f), ...)
                get<0>(std::move(f))(get<I+1>(std::move(f))...);
            }(make_index_sequence<sizeof...(Args)>{});
        };
        using InvokeFn = decltype(invoke_all);
        detail::call_once_impl(flag.state_,
                               static_cast<void*>(addressof(invoke_all)),
                               &call_once_proxy<InvokeFn>);
    }
}

} // namespace std
