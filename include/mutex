//===----------------------------------------------------------------------===//
// Tag types (from __mutex/tag_types.h)
//===----------------------------------------------------------------------===//

struct defer_lock_t  { explicit defer_lock_t()  = default; };
struct try_to_lock_t { explicit try_to_lock_t() = default; };
struct adopt_lock_t  { explicit adopt_lock_t()  = default; };

inline constexpr defer_lock_t  defer_lock{};
inline constexpr try_to_lock_t try_to_lock{};
inline constexpr adopt_lock_t  adopt_lock{};

//===----------------------------------------------------------------------===//
// mutex (from __mutex/mutex.h)
// Wraps pthread_mutex_t.  On primitive failure -> __builtin_trap() (no exceptions).
//===----------------------------------------------------------------------===//

class mutex {
    pthread_mutex_t m_ = PTHREAD_MUTEX_INITIALIZER;
public:
    constexpr mutex() noexcept = default;
    ~mutex() noexcept { pthread_mutex_destroy(&m_); }

    mutex(const mutex&)            = delete;
    mutex& operator=(const mutex&) = delete;

    void lock() {
        int ec = pthread_mutex_lock(&m_);
        if (ec != 0) __builtin_trap(); // would be system_error
    }

    bool try_lock() noexcept {
        return pthread_mutex_trylock(&m_) == 0;
    }

    void unlock() noexcept {
        pthread_mutex_unlock(&m_);
    }

    using native_handle_type = pthread_mutex_t*;
    native_handle_type native_handle() { return &m_; }
};

//===----------------------------------------------------------------------===//
// recursive_mutex (from libc++ mutex)
//===----------------------------------------------------------------------===//

class recursive_mutex {
    pthread_mutex_t m_;
public:
    recursive_mutex() {
        pthread_mutexattr_t attr;
        pthread_mutexattr_init(&attr);
        pthread_mutexattr_settype(&attr, PTHREAD_MUTEX_RECURSIVE);
        int ec = pthread_mutex_init(&m_, &attr);
        pthread_mutexattr_destroy(&attr);
        if (ec != 0) __builtin_trap();
    }
    ~recursive_mutex() noexcept { pthread_mutex_destroy(&m_); }

    recursive_mutex(const recursive_mutex&)            = delete;
    recursive_mutex& operator=(const recursive_mutex&) = delete;

    void lock() {
        int ec = pthread_mutex_lock(&m_);
        if (ec != 0) __builtin_trap();
    }

    bool try_lock() noexcept {
        return pthread_mutex_trylock(&m_) == 0;
    }

    void unlock() noexcept {
        pthread_mutex_unlock(&m_);
    }

    using native_handle_type = pthread_mutex_t*;
    native_handle_type native_handle() { return &m_; }
};

