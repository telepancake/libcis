template <class T>
template <class VE>
valarray<T>& valarray<T>::operator=(const val_expr<VE>& v) {
  size_t n = v.size();
  if (size() != n) resize(n);
  T* t = begin_;
  for (size_t i = 0; i != n; ++t, ++i)
    *t = T(v[i]);
  return *this;
}

