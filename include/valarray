#ifndef LIBCIS_VALARRAY
#define LIBCIS_VALARRAY

// valarray<T> and supporting classes.
// Ported from LLVM libc++ for g++-10.2 -std=gnu++20 -fno-exceptions -fno-rtti.
//
// ORDERING NOTE: valarray<T> must be fully defined BEFORE gslice/gslice_array/
// mask_array/indirect_array because those hold valarray<size_t> members.
// slice (plain struct, no valarray members) can come early.

