// ─── val_expr<ValExpr> ───────────────────────────────────────────────────────
template <class ValExpr>
class val_expr {
  using rm_ref = typename std::remove_reference<ValExpr>::type;
  ValExpr expr_;

public:
  using value_type  = typename rm_ref::value_type;
  using result_type = typename rm_ref::result_type;

  explicit val_expr(const rm_ref& e) : expr_(e) {}

  result_type operator[](size_t i) const { return expr_[i]; }

  val_expr<slice_expr<ValExpr>> operator[](slice s) const {
    using E = slice_expr<ValExpr>;
    return val_expr<E>(E(s, expr_));
  }

  val_expr<indirect_expr<ValExpr>> operator[](const valarray<size_t>& vs) const;
  val_expr<mask_expr<ValExpr>>     operator[](const valarray<bool>& vb) const;
  val_expr<indirect_expr<ValExpr>> operator[](const gslice& gs) const;

  val_expr<UnaryOp<unary_plus_op<value_type>,  ValExpr>> operator+() const {
    using Op = UnaryOp<unary_plus_op<value_type>, ValExpr>;
    return val_expr<Op>(Op(unary_plus_op<value_type>(), expr_));
  }
  val_expr<UnaryOp<negate_op<value_type>, ValExpr>> operator-() const {
    using Op = UnaryOp<negate_op<value_type>, ValExpr>;
    return val_expr<Op>(Op(negate_op<value_type>(), expr_));
  }
  val_expr<UnaryOp<bit_not_op<value_type>, ValExpr>> operator~() const {
    using Op = UnaryOp<bit_not_op<value_type>, ValExpr>;
    return val_expr<Op>(Op(bit_not_op<value_type>(), expr_));
  }
  val_expr<UnaryOp<logical_not_op<value_type>, ValExpr>> operator!() const {
    using Op = UnaryOp<logical_not_op<value_type>, ValExpr>;
    return val_expr<Op>(Op(logical_not_op<value_type>(), expr_));
  }

  operator valarray<result_type>() const;

  size_t size() const { return expr_.size(); }

  result_type sum() const {
    size_t n = expr_.size();
    result_type r = n ? expr_[0] : result_type();
    for (size_t i = 1; i < n; ++i) r += expr_[i];
    return r;
  }

  result_type min() const {
    size_t n = size();
    result_type r = n ? (*this)[0] : result_type();
    for (size_t i = 1; i < n; ++i) { auto x = expr_[i]; if (x < r) r = x; }
    return r;
  }

  result_type max() const {
    size_t n = size();
    result_type r = n ? (*this)[0] : result_type();
    for (size_t i = 1; i < n; ++i) { auto x = expr_[i]; if (r < x) r = x; }
    return r;
  }

  val_expr<shift_expr<ValExpr>>  shift(int i) const {
    return val_expr<shift_expr<ValExpr>>(shift_expr<ValExpr>(i, expr_));
  }
  val_expr<cshift_expr<ValExpr>> cshift(int i) const {
    return val_expr<cshift_expr<ValExpr>>(cshift_expr<ValExpr>(i, expr_));
  }

  val_expr<UnaryOp<apply_expr_op<value_type, value_type(*)(value_type)>, ValExpr>>
  apply(value_type f(value_type)) const {
    using Op = apply_expr_op<value_type, value_type(*)(value_type)>;
    using E  = UnaryOp<Op, ValExpr>;
    return val_expr<E>(E(Op(f), expr_));
  }

  val_expr<UnaryOp<apply_expr_op<value_type, value_type(*)(const value_type&)>, ValExpr>>
  apply(value_type f(const value_type&)) const {
    using Op = apply_expr_op<value_type, value_type(*)(const value_type&)>;
    using E  = UnaryOp<Op, ValExpr>;
    return val_expr<E>(E(Op(f), expr_));
  }
};

template <class ValExpr>
val_expr<ValExpr>::operator valarray<result_type>() const {
  valarray<result_type> r;
  size_t n = expr_.size();
  if (n) {
    r.begin_ = r.end_ = std::allocator<result_type>().allocate(n);
    for (size_t i = 0; i != n; ++r.end_, ++i)
      ::new (static_cast<void*>(r.end_)) result_type(expr_[i]);
  }
  return r;
}

// ─── Now define gslice (holds valarray<size_t> members — must come AFTER valarray) ─

class gslice {
  valarray<size_t> size_;
  valarray<size_t> stride_;
  valarray<size_t> d1_;  // flattened 1d indices

  void init(size_t start) {
    // Compute number of elements
    size_t n = 1;
    for (size_t i = 0; i < size_.size(); ++i) n *= size_[i];
    d1_.resize(n);
    size_t j = 0;
    // Fill via nested iteration
    // We compute index as a mixed-radix counter
    if (n == 0) return;
    valarray<size_t> counter(size_t(0), size_.size());
    size_t ndims = size_.size();
    for (size_t k = 0; k < n; ++k) {
      size_t idx = start;
      for (size_t d = 0; d < ndims; ++d)
        idx += counter[d] * stride_[d];
      d1_[k] = idx;
      // increment counter (mixed-radix)
      for (size_t d2 = ndims; d2-- > 0; ) {
        counter[d2]++;
        if (counter[d2] < size_[d2]) break;
        counter[d2] = 0;
      }
    }
    (void)j;
  }

public:
  gslice() {}

  gslice(size_t start, const valarray<size_t>& sz, const valarray<size_t>& st)
    : size_(sz), stride_(st) { init(start); }

  gslice(size_t start, valarray<size_t>&& sz, const valarray<size_t>& st)
    : size_(std::move(sz)), stride_(st) { init(start); }

  gslice(size_t start, const valarray<size_t>& sz, valarray<size_t>&& st)
    : size_(sz), stride_(std::move(st)) { init(start); }

  gslice(size_t start, valarray<size_t>&& sz, valarray<size_t>&& st)
    : size_(std::move(sz)), stride_(std::move(st)) { init(start); }

  [[nodiscard]] size_t           start()  const noexcept { return d1_.size() ? d1_[0] : 0; }
  [[nodiscard]] valarray<size_t> size()   const { return size_; }
  [[nodiscard]] valarray<size_t> stride() const { return stride_; }

  template <class> friend class gslice_array;
  template <class> friend class valarray;
  template <class> friend class val_expr;
};

// ─── slice_array<T> ──────────────────────────────────────────────────────────
template <class T>
class slice_array {
public:
  using value_type = T;

private:
  T*     vp_;
  size_t size_;
  size_t stride_;

  slice_array(const slice& sl, const valarray<T>& v)
    : vp_(const_cast<T*>(v.begin_ + sl.start())),
      size_(sl.size()), stride_(sl.stride()) {}

  template <class> friend class valarray;

public:
  slice_array(const slice_array&) = default;
  slice_array() = delete;

  const slice_array& operator=(const slice_array& sa) const {
    T* t = vp_;
    const T* s = sa.vp_;
    for (size_t n = size_; n; --n, t += stride_, s += sa.stride_)
      *t = *s;
    return *this;
  }

  void operator=(const T& x) const {
    T* t = vp_;
    for (size_t n = size_; n; --n, t += stride_)
      *t = x;
  }

  void operator=(const valarray<T>& va) const {
    T* t = vp_;
    for (size_t i = 0; i < va.size(); ++i, t += stride_)
      *t = va[i];
  }

  template <class E>
    requires is_val_expr<E>::value
  void operator=(const E& v) const {
    T* t = vp_;
    for (size_t i = 0; i < size_; ++i, t += stride_)
      *t = v[i];
  }

  template <class E> requires is_val_expr<E>::value
  void operator*= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t *= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator/= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t /= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator+= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t += v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator-= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t -= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator^= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t ^= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator&= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t &= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator|= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t |= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator<<=(const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t <<= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator>>=(const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t >>= v[i]; }
  template <class E> requires is_val_expr<E>::value
  void operator%= (const E& v) const { T* t=vp_; for(size_t i=0;i<size_;++i,t+=stride_) *t %= v[i]; }

  // .get(i) for use_member_get
  T get(size_t i) const { return vp_[i * stride_]; }
};

