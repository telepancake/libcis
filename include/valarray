namespace std {

// Forward declarations
template <class T> class valarray;
template <class T> class slice_array;
class gslice;
template <class T> class gslice_array;
template <class T> class mask_array;
template <class T> class indirect_array;

// begin/end forward decls
template <class T> T*       begin(valarray<T>& v);
template <class T> const T* begin(const valarray<T>& v);
template <class T> T*       end(valarray<T>& v);
template <class T> const T* end(const valarray<T>& v);

// ─── slice ───────────────────────────────────────────────────────────────────
class slice {
  size_t start_;
  size_t size_;
  size_t stride_;

public:
  slice() : start_(0), size_(0), stride_(0) {}
  slice(size_t start, size_t size, size_t stride)
    : start_(start), size_(size), stride_(stride) {}

  [[nodiscard]] size_t start()  const noexcept { return start_;  }
  [[nodiscard]] size_t size()   const noexcept { return size_;   }
  [[nodiscard]] size_t stride() const noexcept { return stride_; }

  friend bool operator==(const slice& x, const slice& y) noexcept {
    return x.start_ == y.start_ && x.size_ == y.size_ && x.stride_ == y.stride_;
  }
};

// ─── Expression-template helpers (need to be declared before valarray) ───────

template <class Op, class A0>
struct UnaryOp {
  using result_type = typename Op::result_type;
  using value_type  = typename std::decay<result_type>::type;
  Op op_;
  A0 a0_;
  UnaryOp(const Op& op, const A0& a0) : op_(op), a0_(a0) {}
  result_type operator[](size_t i) const { return op_(a0_[i]); }
  size_t size() const { return a0_.size(); }
};

template <class Op, class A0, class A1>
struct BinaryOp {
  using result_type = typename Op::result_type;
  using value_type  = typename std::decay<result_type>::type;
  Op op_;
  A0 a0_;
  A1 a1_;
  BinaryOp(const Op& op, const A0& a0, const A1& a1) : op_(op), a0_(a0), a1_(a1) {}
  result_type operator[](size_t i) const { return op_(a0_[i], a1_[i]); }
  size_t size() const { return a0_.size(); }
};

// Scalar expression wrapper
template <class T>
class scalar_expr {
public:
  using value_type  = T;
  using result_type = const T&;

private:
  const T& val_;
  size_t   size_;

public:
  explicit scalar_expr(const T& val, size_t s) : val_(val), size_(s) {}
  result_type operator[](size_t) const { return val_; }
  size_t size() const { return size_; }
};

