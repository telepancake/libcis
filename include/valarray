// We use a macro to reduce boilerplate for binary operators

#define VALARRAY_BINARY_OP(opname, functor)                                    \
template <class E1, class E2>                                                  \
  requires (is_val_expr<E1>::value && is_val_expr<E2>::value)                 \
inline val_expr<BinaryOp<functor<typename E1::value_type>, E1, E2>>           \
opname(const E1& x, const E2& y) {                                            \
  using VT = typename E1::value_type;                                          \
  using Op = BinaryOp<functor<VT>, E1, E2>;                                   \
  return val_expr<Op>(Op(functor<VT>(), x, y));                               \
}                                                                              \
template <class E>                                                             \
  requires is_val_expr<E>::value                                               \
inline val_expr<BinaryOp<functor<typename E::value_type>,                      \
                         E, scalar_expr<typename E::value_type>>>             \
opname(const E& x, const typename E::value_type& y) {                        \
  using VT = typename E::value_type;                                           \
  using Op = BinaryOp<functor<VT>, E, scalar_expr<VT>>;                       \
  return val_expr<Op>(Op(functor<VT>(), x, scalar_expr<VT>(y, x.size())));   \
}                                                                              \
template <class E>                                                             \
  requires is_val_expr<E>::value                                               \
inline val_expr<BinaryOp<functor<typename E::value_type>,                      \
                         scalar_expr<typename E::value_type>, E>>             \
opname(const typename E::value_type& x, const E& y) {                        \
  using VT = typename E::value_type;                                           \
  using Op = BinaryOp<functor<VT>, scalar_expr<VT>, E>;                       \
  return val_expr<Op>(Op(functor<VT>(), scalar_expr<VT>(x, y.size()), y));   \
}

