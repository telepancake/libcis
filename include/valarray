// shift/cshift/apply member bodies
template <class T>
valarray<T> valarray<T>::shift(int i) const {
  valarray<T> r;
  size_t n = size();
  if (n) {
    r.begin_ = r.end_ = std::allocator<T>().allocate(n);
    const T* sb;
    T *tb, *te;
    if (i >= 0) {
      i  = std::min(i, static_cast<int>(n));
      sb = begin_ + i;
      tb = r.begin_;
      te = r.begin_ + (n - i);
    } else {
      i  = std::min(-i, static_cast<int>(n));
      sb = begin_;
      tb = r.begin_ + i;
      te = r.begin_ + n;
    }
    for (; r.end_ != tb; ++r.end_)
      ::new (static_cast<void*>(r.end_)) T();
    for (; r.end_ != te; ++r.end_, ++sb)
      ::new (static_cast<void*>(r.end_)) T(*sb);
    for (te = r.begin_ + n; r.end_ != te; ++r.end_)
      ::new (static_cast<void*>(r.end_)) T();
  }
  return r;
}

template <class T>
valarray<T> valarray<T>::cshift(int i) const {
  valarray<T> r;
  size_t n = size();
  if (n) {
    r.begin_ = r.end_ = std::allocator<T>().allocate(n);
    i %= static_cast<int>(n);
    const T* m = (i >= 0) ? begin_ + i : end_ + i;
    for (const T* s = m; s != end_; ++r.end_, ++s)
      ::new (static_cast<void*>(r.end_)) T(*s);
    for (const T* s = begin_; s != m; ++r.end_, ++s)
      ::new (static_cast<void*>(r.end_)) T(*s);
  }
  return r;
}

template <class T>
valarray<T> valarray<T>::apply(T f(T)) const {
  valarray<T> r;
  size_t n = size();
  if (n) {
    r.begin_ = r.end_ = std::allocator<T>().allocate(n);
    for (const T* p = begin_; n; ++r.end_, ++p, --n)
      ::new (static_cast<void*>(r.end_)) T(f(*p));
  }
  return r;
}

template <class T>
valarray<T> valarray<T>::apply(T f(const T&)) const {
  valarray<T> r;
  size_t n = size();
  if (n) {
    r.begin_ = r.end_ = std::allocator<T>().allocate(n);
    for (const T* p = begin_; n; ++r.end_, ++p, --n)
      ::new (static_cast<void*>(r.end_)) T(f(*p));
  }
  return r;
}

