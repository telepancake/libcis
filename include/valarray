// is_val_expr trait
template <class E>
struct is_val_expr : std::false_type {};

template <class T>
struct is_val_expr<valarray<T>> : std::true_type {};

// val_expr template (lazy proxy) — forward declared, defined after valarray
template <class ValExpr>
class val_expr;

template <class E>
struct is_val_expr<val_expr<E>> : std::true_type {};

// Helper: use_member_get trait — tells __get() whether to call .get(i) or [i]
template <class E>
struct use_member_get : std::false_type {};
template <class T>
struct use_member_get<slice_array<T>>    : std::true_type {};
template <class T>
struct use_member_get<gslice_array<T>>   : std::true_type {};
template <class T>
struct use_member_get<mask_array<T>>     : std::true_type {};
template <class T>
struct use_member_get<indirect_array<T>> : std::true_type {};

template <class E>
  requires (!use_member_get<E>::value)
inline typename E::value_type val_get(const E& v, size_t i) { return v[i]; }

template <class E>
  requires use_member_get<E>::value
inline typename E::value_type val_get(const E& v, size_t i) { return v.get(i); }

// Slice expression (lazy read-only slice view)
template <class ValExpr>
class slice_expr {
  using rm_ref = typename std::remove_reference<ValExpr>::type;
public:
  using value_type  = typename rm_ref::value_type;
  using result_type = value_type;

private:
  ValExpr expr_;
  size_t  start_;
  size_t  size_;
  size_t  stride_;

  slice_expr(const slice& sl, const rm_ref& e)
    : expr_(e), start_(sl.start()), size_(sl.size()), stride_(sl.stride()) {}

public:
  result_type operator[](size_t i) const { return expr_[start_ + i * stride_]; }
  size_t size() const { return size_; }

  template <class> friend class val_expr;
  template <class> friend class valarray;
};

// mask_expr / indirect_expr — forward declared body after valarray
template <class ValExpr>
class mask_expr;

template <class ValExpr>
class indirect_expr;

// shift_expr / cshift_expr
template <class ValExpr>
class shift_expr {
  using rm_ref = typename std::remove_reference<ValExpr>::type;
public:
  using value_type  = typename rm_ref::value_type;
  using result_type = value_type;

private:
  ValExpr   expr_;
  size_t    sz_;
  ptrdiff_t ul_;
  ptrdiff_t sn_;
  ptrdiff_t n_;
  static const ptrdiff_t Np = static_cast<ptrdiff_t>(sizeof(ptrdiff_t) * __CHAR_BIT__ - 1);

  shift_expr(int n, const rm_ref& e) : expr_(e), sz_(e.size()), n_(n) {
    ptrdiff_t neg_n = static_cast<ptrdiff_t>(n_ >> Np);
    sn_ = neg_n | static_cast<ptrdiff_t>(static_cast<size_t>(-n_) >> Np);
    ul_ = ((sz_ - n_) & ~neg_n) | ((n_ + 1) & neg_n);
  }

public:
  result_type operator[](size_t j) const {
    ptrdiff_t i = static_cast<ptrdiff_t>(j);
    ptrdiff_t m = (sn_ * i - ul_) >> Np;
    return (expr_[(i + n_) & m] & m) | (value_type() & ~m);
  }
  size_t size() const { return sz_; }

  template <class> friend class val_expr;
};

template <class ValExpr>
class cshift_expr {
  using rm_ref = typename std::remove_reference<ValExpr>::type;
public:
  using value_type  = typename rm_ref::value_type;
  using result_type = value_type;

private:
  ValExpr expr_;
  size_t  sz_;
  size_t  m_;
  size_t  o1_;
  size_t  o2_;

  cshift_expr(int n, const rm_ref& e) : expr_(e), sz_(e.size()) {
    n %= static_cast<int>(sz_);
    if (n >= 0) { m_ = sz_ - n; o1_ = n; o2_ = n - sz_; }
    else        { m_ = -n;      o1_ = n + sz_; o2_ = n; }
  }

public:
  result_type operator[](size_t i) const {
    return (i < m_) ? expr_[i + o1_] : expr_[i + o2_];
  }
  size_t size() const { return sz_; }

  template <class> friend class val_expr;
};

// ─── valarray<T> ─────────────────────────────────────────────────────────────
// MUST be fully defined before gslice, gslice_array, mask_array, indirect_array
// because those hold valarray<size_t> members.

template <class T>
class valarray {
public:
  using value_type  = T;
  using result_type = T;

private:
  T* begin_;
  T* end_;

  void clear(size_t capacity) {
    if (begin_ != nullptr) {
      while (end_ != begin_)
        (--end_)->~T();
      std::allocator<T>().deallocate(begin_, capacity);
      begin_ = end_ = nullptr;
    }
  }

  valarray& assign_range(const T* f, const T* l) {
    size_t n = static_cast<size_t>(l - f);
    if (size() != n) {
      clear(size());
      begin_ = std::allocator<T>().allocate(n);
      end_   = begin_ + n;
      std::uninitialized_copy(f, l, begin_);
    } else {
      std::copy(f, l, begin_);
    }
    return *this;
  }

public:
  // construct/destroy
  valarray() : begin_(nullptr), end_(nullptr) {}

  explicit valarray(size_t n) : begin_(nullptr), end_(nullptr) {
    if (n) {
      begin_ = end_ = std::allocator<T>().allocate(n);
      for (size_t left = n; left; --left, ++end_)
        ::new (static_cast<void*>(end_)) T();
    }
  }

  valarray(const T& x, size_t n) : begin_(nullptr), end_(nullptr) {
    resize(n, x);
  }

  valarray(const T* p, size_t n) : begin_(nullptr), end_(nullptr) {
    if (n) {
      begin_ = end_ = std::allocator<T>().allocate(n);
      for (size_t left = n; left; ++end_, ++p, --left)
        ::new (static_cast<void*>(end_)) T(*p);
    }
  }

  valarray(const valarray& v) : begin_(nullptr), end_(nullptr) {
    if (v.size()) {
      begin_ = end_ = std::allocator<T>().allocate(v.size());
      for (const T* p = v.begin_; p != v.end_; ++end_, ++p)
        ::new (static_cast<void*>(end_)) T(*p);
    }
  }

  valarray(valarray&& v) noexcept : begin_(v.begin_), end_(v.end_) {
    v.begin_ = v.end_ = nullptr;
  }

  valarray(std::initializer_list<T> il) : begin_(nullptr), end_(nullptr) {
    const size_t n = il.size();
    if (n) {
      begin_ = end_ = std::allocator<T>().allocate(n);
      for (const T* p = il.begin(); p != il.end(); ++end_, ++p)
        ::new (static_cast<void*>(end_)) T(*p);
    }
  }

  valarray(const slice_array<T>& sa);
  valarray(const gslice_array<T>& ga);
  valarray(const mask_array<T>& ma);
  valarray(const indirect_array<T>& ia);

  ~valarray() { clear(size()); }

  // assignment
  valarray& operator=(const valarray& v) {
    if (this != std::addressof(v))
      return assign_range(v.begin_, v.end_);
    return *this;
  }

  valarray& operator=(valarray&& v) noexcept {
    clear(size());
    begin_   = v.begin_;
    end_     = v.end_;
    v.begin_ = v.end_ = nullptr;
    return *this;
  }

  valarray& operator=(std::initializer_list<T> il) {
    return assign_range(il.begin(), il.end());
  }

  valarray& operator=(const T& x) {
    std::fill(begin_, end_, x);
    return *this;
  }

  valarray& operator=(const slice_array<T>& sa);
  valarray& operator=(const gslice_array<T>& ga);
  valarray& operator=(const mask_array<T>& ma);
  valarray& operator=(const indirect_array<T>& ia);

  template <class VE>
  valarray& operator=(const val_expr<VE>& v);

  // element access
  [[nodiscard]] const T& operator[](size_t i) const { return begin_[i]; }
  [[nodiscard]] T&       operator[](size_t i)       { return begin_[i]; }

  // subset operations — return types
  [[nodiscard]] val_expr<slice_expr<const valarray&>>   operator[](slice s) const;
  [[nodiscard]] slice_array<T>                          operator[](slice s);

  [[nodiscard]] val_expr<indirect_expr<const valarray&>> operator[](const gslice& gs) const;
  [[nodiscard]] gslice_array<T>                          operator[](const gslice& gs);

  [[nodiscard]] val_expr<mask_expr<const valarray&>>     operator[](const valarray<bool>& vb) const;
  [[nodiscard]] mask_array<T>                            operator[](const valarray<bool>& vb);

  [[nodiscard]] val_expr<indirect_expr<const valarray&>> operator[](const valarray<size_t>& vs) const;
  [[nodiscard]] indirect_array<T>                        operator[](const valarray<size_t>& vs);

  [[nodiscard]] val_expr<indirect_expr<const valarray&>> operator[](valarray<size_t>&& vs) const;
  [[nodiscard]] indirect_array<T>                        operator[](valarray<size_t>&& vs);

  // unary operators
  val_expr<UnaryOp<unary_plus_op<T>, const valarray&>>  operator+() const;
  val_expr<UnaryOp<negate_op<T>,     const valarray&>>  operator-() const;
  val_expr<UnaryOp<bit_not_op<T>,    const valarray&>>  operator~() const;
  val_expr<UnaryOp<logical_not_op<T>,const valarray&>>  operator!() const;

  // computed assignment (scalar)
  valarray& operator*= (const T& x) { for (T* p=begin_;p!=end_;++p) *p *= x; return *this; }
  valarray& operator/= (const T& x) { for (T* p=begin_;p!=end_;++p) *p /= x; return *this; }
  valarray& operator%= (const T& x) { for (T* p=begin_;p!=end_;++p) *p %= x; return *this; }
  valarray& operator+= (const T& x) { for (T* p=begin_;p!=end_;++p) *p += x; return *this; }
  valarray& operator-= (const T& x) { for (T* p=begin_;p!=end_;++p) *p -= x; return *this; }
  valarray& operator^= (const T& x) { for (T* p=begin_;p!=end_;++p) *p ^= x; return *this; }
  valarray& operator&= (const T& x) { for (T* p=begin_;p!=end_;++p) *p &= x; return *this; }
  valarray& operator|= (const T& x) { for (T* p=begin_;p!=end_;++p) *p |= x; return *this; }
  valarray& operator<<=(const T& x) { for (T* p=begin_;p!=end_;++p) *p <<= x; return *this; }
  valarray& operator>>=(const T& x) { for (T* p=begin_;p!=end_;++p) *p >>= x; return *this; }

  // computed assignment (val_expr)
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator*=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t *= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator/=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t /= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator%=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t %= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator+=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t += val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator-=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t -= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator^=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t ^= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator|=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t |= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator&=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t &= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator<<=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t <<= val_get(v,i); return *this; }
  template <class E>
    requires is_val_expr<E>::value
  valarray& operator>>=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t >>= val_get(v,i); return *this; }

  // computed assignment (proxy array types: slice_array, gslice_array, mask_array, indirect_array)
  template <class E>
    requires use_member_get<E>::value
  valarray& operator*=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t *= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator/=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t /= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator%=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t %= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator+=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t += val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator-=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t -= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator^=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t ^= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator|=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t |= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator&=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t &= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator<<=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t <<= val_get(v,i); return *this; }
  template <class E>
    requires use_member_get<E>::value
  valarray& operator>>=(const E& v) { size_t i=0; for (T* t=begin_;t!=end_;++t,++i) *t >>= val_get(v,i); return *this; }

  // member functions
  void swap(valarray& v) noexcept {
    std::swap(begin_, v.begin_);
    std::swap(end_, v.end_);
  }

  [[nodiscard]] size_t size() const noexcept {
    return static_cast<size_t>(end_ - begin_);
  }

  [[nodiscard]] T sum() const {
    if (begin_ == end_) return T();
    T r = *begin_;
    for (const T* p = begin_ + 1; p != end_; ++p)
      r += *p;
    return r;
  }

  [[nodiscard]] T min() const {
    if (begin_ == end_) return T();
    return *std::min_element(begin_, end_);
  }

  [[nodiscard]] T max() const {
    if (begin_ == end_) return T();
    return *std::max_element(begin_, end_);
  }

  [[nodiscard]] valarray shift(int i) const;
  [[nodiscard]] valarray cshift(int i) const;
  [[nodiscard]] valarray apply(T f(T)) const;
  [[nodiscard]] valarray apply(T f(const T&)) const;

  void resize(size_t n, T x = T()) {
    clear(size());
    if (n) {
      begin_ = end_ = std::allocator<T>().allocate(n);
      for (size_t left = n; left; --left, ++end_)
        ::new (static_cast<void*>(end_)) T(x);
    }
  }

private:
  template <class> friend class valarray;
  template <class> friend class slice_array;
  template <class> friend class gslice_array;
  template <class> friend class mask_array;
  template <class> friend class indirect_array;
  template <class> friend class mask_expr;
  template <class> friend class indirect_expr;
  template <class> friend class val_expr;

  template <class U> friend U*       begin(valarray<U>& v);
  template <class U> friend const U* begin(const valarray<U>& v);
  template <class U> friend U*       end(valarray<U>& v);
  template <class U> friend const U* end(const valarray<U>& v);
};

