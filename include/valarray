// ─── valarray member bodies that depend on the complete helper types ──────────

template <class T>
valarray<T>::valarray(const slice_array<T>& sa) : begin_(nullptr), end_(nullptr) {
  const size_t n = sa.size_;
  if (n) {
    begin_ = end_ = std::allocator<T>().allocate(n);
    const T* p = sa.vp_;
    for (size_t left = n; left; ++end_, p += sa.stride_, --left)
      ::new (static_cast<void*>(end_)) T(*p);
  }
}

template <class T>
valarray<T>::valarray(const gslice_array<T>& ga) : begin_(nullptr), end_(nullptr) {
  const size_t n = ga.d1_.size();
  if (n) {
    begin_ = end_ = std::allocator<T>().allocate(n);
    for (size_t i = 0; i < n; ++i, ++end_)
      ::new (static_cast<void*>(end_)) T(ga.vp_[ga.d1_[i]]);
  }
}

template <class T>
valarray<T>::valarray(const mask_array<T>& ma) : begin_(nullptr), end_(nullptr) {
  const size_t n = ma.d1_.size();
  if (n) {
    begin_ = end_ = std::allocator<T>().allocate(n);
    for (size_t i = 0; i < n; ++i, ++end_)
      ::new (static_cast<void*>(end_)) T(ma.vp_[ma.d1_[i]]);
  }
}

template <class T>
valarray<T>::valarray(const indirect_array<T>& ia) : begin_(nullptr), end_(nullptr) {
  const size_t n = ia.d1_.size();
  if (n) {
    begin_ = end_ = std::allocator<T>().allocate(n);
    for (size_t i = 0; i < n; ++i, ++end_)
      ::new (static_cast<void*>(end_)) T(ia.vp_[ia.d1_[i]]);
  }
}

template <class T>
valarray<T>& valarray<T>::operator=(const slice_array<T>& sa) {
  T* t = begin_;
  const T* s = sa.vp_;
  for (size_t n = sa.size_; n; --n, s += sa.stride_, ++t)
    *t = *s;
  return *this;
}

template <class T>
valarray<T>& valarray<T>::operator=(const gslice_array<T>& ga) {
  T* t = begin_;
  for (size_t i = 0; i < ga.d1_.size(); ++i, ++t)
    *t = ga.vp_[ga.d1_[i]];
  return *this;
}

