class underflow_error : public runtime_error {
public:
    explicit underflow_error(const char* msg) : runtime_error(msg) {}
    underflow_error(const underflow_error&) noexcept            = default;
    underflow_error& operator=(const underflow_error&) noexcept = default;
    ~underflow_error() noexcept override {}
};

//===----------------------------------------------------------------------===//
// Internal trap helpers (replaces the libc++ __throw_xxx functions which use
// throw; under -fno-exceptions we call __builtin_trap() instead).
// These are inline so that containers can call them as "will not return" paths.
//===----------------------------------------------------------------------===//
[[noreturn]] inline void throw_logic_error(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_domain_error(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_invalid_argument(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_length_error(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_out_of_range(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_runtime_error(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_range_error(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_overflow_error(const char* msg) {
    (void)msg;
    __builtin_trap();
}
[[noreturn]] inline void throw_underflow_error(const char* msg) {
    (void)msg;
    __builtin_trap();
}

} // namespace std
