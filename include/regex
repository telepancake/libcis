template <class _CharT>
class match_any_but_newline : public owns_one_state<_CharT> {
  typedef owns_one_state<_CharT> base;

public:
  typedef std::renfaState<_CharT> renfaState;

   match_any_but_newline(renfaNode<_CharT>* s) : base(s) {}

  void exec(renfaState&) const override;
};

template <>
 void match_any_but_newline<char>::exec(renfaState&) const;
template <>
 void match_any_but_newline<wchar_t>::exec(renfaState&) const;

template <>
inline void match_any_but_newline<char>::exec(renfaState& s) const {
  if (s.current_ != s.last_) {
    switch (*s.current_) {
    case '\r':
    case '\n':
      s.do_   = renfaState::reject;
      s.node_ = nullptr;
      break;
    default:
      s.do_ = renfaState::accept_and_consume;
      ++s.current_;
      s.node_ = this->first();
      break;
    }
  } else {
    s.do_   = renfaState::reject;
    s.node_ = nullptr;
  }
}

template <>
inline void match_any_but_newline<wchar_t>::exec(renfaState& s) const {
  if (s.current_ != s.last_) {
    switch (*s.current_) {
    case '\r':
    case '\n':
    case 0x2028:
    case 0x2029:
      s.do_   = renfaState::reject;
      s.node_ = nullptr;
      break;
    default:
      s.do_ = renfaState::accept_and_consume;
      ++s.current_;
      s.node_ = this->first();
      break;
    }
  } else {
    s.do_   = renfaState::reject;
    s.node_ = nullptr;
  }
}

