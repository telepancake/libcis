// back_ref

template <class _CharT>
class back_ref : public owns_one_state<_CharT> {
  typedef owns_one_state<_CharT> base;

  unsigned mexp_;

public:
  typedef std::renfaState<_CharT> renfaState;

   explicit back_ref(unsigned mexp, renfaNode<_CharT>* s) : base(s), mexp_(mexp) {}

   virtual void exec(renfaState&) const;
};

template <class _CharT>
void back_ref<_CharT>::exec(renfaState& s) const {
  if (mexp_ > s.sub_matches_.size())
    throw_regex_error<regex_constants::error_backref>();
  sub_match<const _CharT*>& sm = s.sub_matches_[mexp_ - 1];
  if (sm.matched) {
    ptrdiff_t len = sm.second - sm.first;
    if (s.last_ - s.current_ >= len && std::equal(sm.first, sm.second, s.current_)) {
      s.do_ = renfaState::accept_but_not_consume;
      s.current_ += len;
      s.node_ = this->first();
    } else {
      s.do_   = renfaState::reject;
      s.node_ = nullptr;
    }
  } else {
    s.do_   = renfaState::reject;
    s.node_ = nullptr;
  }
}

