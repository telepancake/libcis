//
// char_class_type  = ctype_base::mask  (same type as libc++ non-Bionic/Newlib)
// regex_word       = detail::regex_word_bit (0x0400, free bit in libcis mask)
//                    renamed from libc++'s __regex_word per CONVENTIONS.
// Private members renamed (no underscores):
//   __loc_ → loc_,  __ct_ → ct_,  __col_ → col_,  __init() → init()
//   __transform_primary()  → transform_primary_impl()
//   __lookup_collatename() → lookup_collatename_impl()
//   __lookup_classname()   → lookup_classname_impl()
//   __regex_traits_value() → traits_value()
// ---------------------------------------------------------------------------
template<class CharT>
struct regex_traits {
public:
    typedef CharT                    char_type;
    typedef basic_string<char_type>  string_type;
    typedef locale                   locale_type;
    typedef ctype_base::mask         char_class_type;

    // regex_word: a mask bit that does not overlap any ctype_base class bit.
    // (libc++ calls this __regex_word; renamed per CONVENTIONS.)
    static const char_class_type regex_word = detail::regex_word_bit;

private:
    locale_type              loc_;
    const ctype<char_type>*  ct_;
    const collate<char_type>* col_;

public:
    regex_traits() { init(); }

    static size_t length(const char_type* p) {
        return char_traits<char_type>::length(p);
    }
    char_type translate(char_type c) const { return c; }
    char_type translate_nocase(char_type c) const {
        return ct_->tolower(c);
    }

    template<class ForwardIter>
    string_type transform(ForwardIter f, ForwardIter l) const {
        string_type s(f, l);
        return col_->transform(s.data(), s.data() + s.size());
    }

    template<class ForwardIter>
    string_type transform_primary(ForwardIter f, ForwardIter l) const {
        return transform_primary_impl(f, l, char_type());
    }

    template<class ForwardIter>
    string_type lookup_collatename(ForwardIter f, ForwardIter l) const {
        return lookup_collatename_impl(f, l, char_type());
    }

    template<class ForwardIter>
    char_class_type lookup_classname(ForwardIter f, ForwardIter l,
                                     bool icase = false) const {
        return lookup_classname_impl(f, l, icase, char_type());
    }

    bool isctype(char_type c, char_class_type m) const {
        if (ct_->is(m, c)) return true;
        return (c == '_' && (m & regex_word));
    }

    int value(char_type ch, int radix) const {
        return traits_value(ch, radix);
    }

    locale_type imbue(locale_type l) {
        locale r = loc_;
        loc_ = l;
        init();
        return r;
    }

    locale_type getloc() const { return loc_; }

private:
    // Default collate instance for when collate<CharT> is not in the locale.
    // Subclass to make construction/destruction accessible in this context.
    // (libc++ deviation: libcis's <locale> omits collate; we fall back here.)
    struct default_collate : collate<char_type> {
        default_collate() : collate<char_type>(1) {} // refs=1 → never freed
        ~default_collate() override {}
    };

    void init() {
        ct_  = addressof(use_facet<ctype<char_type>>(loc_));
        // collate<CharT> is intentionally omitted from libcis's classic locale
        // registry.  Fall back to a static default instance (the default
        // do_transform() returns the string unchanged — correct for "C" locale).
        if (has_facet<collate<char_type>>(loc_))
            col_ = addressof(use_facet<collate<char_type>>(loc_));
        else {
            static default_collate s_col;
            col_ = addressof(s_col);
        }
    }

    // transform_primary — char overload (libc++ include/regex lines 1128–1144)
    template<class ForwardIter>
    string_type transform_primary_impl(ForwardIter f, ForwardIter l, char) const {
        const string_type s(f, l);
        string_type d = col_->transform(s.data(), s.data() + s.size());
        switch (d.size()) {
        case 1:  break;
        case 12: d[11] = d[3]; break;
        default: d.clear(); break;
        }
        return d;
    }

    // transform_primary — wchar_t overload (libc++ include/regex lines 1149–1164)
    template<class ForwardIter>
    string_type transform_primary_impl(ForwardIter f, ForwardIter l, wchar_t) const {
        const string_type s(f, l);
        string_type d = col_->transform(s.data(), s.data() + s.size());
        switch (d.size()) {
        case 1: break;
        case 3: d[2] = d[0]; break;
        default: d.clear(); break;
        }
        return d;
    }

    // lookup_collatename — char overload (libc++ include/regex lines 1173–1188)
    template<class ForwardIter>
    string_type lookup_collatename_impl(ForwardIter f, ForwardIter l, char) const {
        string_type s(f, l);
        string_type r;
        if (!s.empty()) {
            r = detail::get_collation_name(s.c_str());
