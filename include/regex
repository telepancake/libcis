template <class _CharT>
void l_anchor_multiline<_CharT>::exec(renfaState& s) const {
  if (s.at_first_ && s.current_ == s.first_ && !(s.flags_ & regex_constants::match_not_bol)) {
    s.do_   = renfaState::accept_but_not_consume;
    s.node_ = this->first();
  } else if (multiline_ && !s.at_first_ && is_eol(*std::prev(s.current_))) {
    s.do_   = renfaState::accept_but_not_consume;
    s.node_ = this->first();
  } else {
    s.do_   = renfaState::reject;
    s.node_ = nullptr;
