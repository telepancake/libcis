// The regex_word bit: a separate bit not in ctype_base for libcis.
// libcis ctype_base::mask is unsigned short; bits 0–9 used (0x0001–0x0200).
// We use bit 10 (0x0400) for regex_word.
inline constexpr ctype_base::mask regex_word_bit =
