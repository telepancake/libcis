inline constexpr size_t classnames_size() { return 15; }

// get_classname (libc++ src/regex.cpp lines 341–354)
inline ctype_base::mask get_classname(const char* s, bool icase) {
    struct cmp {
        bool operator()(const classname_entry& x, const char* y) const {
            return ::strcmp(x.elem, y) < 0;
        }
    };
    const classname_entry* b = classnames_data();
    const classname_entry* e = b + classnames_size();
    const classname_entry* i = lower_bound(b, e, s, cmp{});
    ctype_base::mask r = 0;
    if (i != e && ::strcmp(s, i->elem) == 0) {
        r = i->mask;
        if (r == regex_word_bit) {
            // "w" → alnum | upper | lower | regex_word_bit
            // (libc++ src/regex.cpp line 347: r |= ctype_base::alnum|upper|lower)
            r = static_cast<ctype_base::mask>(
                r | ctype_base::alnum | ctype_base::upper | ctype_base::lower);
        } else if (icase) {
            if (r & (ctype_base::lower | ctype_base::upper))
                r = static_cast<ctype_base::mask>(r | ctype_base::alpha);
        }
    }
    return r;
}

