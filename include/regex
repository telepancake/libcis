// get_collation_name (libc++ src/regex.cpp lines 333–339)
inline string get_collation_name(const char* s) {
    struct cmp {
        bool operator()(const collatename_entry& x, const char* y) const {
            return ::strcmp(x.elem, y) < 0;
        }
    };
    // Count entries up to null sentinel; cached in static local.
    static const size_t N = [] {
        size_t n = 0;
        const collatename_entry* p = collatenames_data();
        while (p[n].elem) ++n;
        return n;
    }();
    const collatename_entry* b = collatenames_data();
    const collatename_entry* e = b + N;
    const collatename_entry* i = lower_bound(b, e, s, cmp{});
    string r;
    if (i != e && ::strcmp(s, i->elem) == 0)
        r = char(i->ch);
    return r;
}

