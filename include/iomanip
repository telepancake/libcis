// <iomanip> — I/O manipulators: setw, setprecision, setfill, setbase,
//             setiosflags, resetiosflags, quoted,
//             get_money, put_money, get_time, put_time.
// Mechanically ported from libc++ include/iomanip.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
//
// get_money/put_money use the money_get/money_put facets and
// get_time/put_time use the time_get/time_put facets from <locale>.
#pragma once

// Hide all our symbols to prevent ABI conflict with libstdc++ shared library.
#pragma GCC visibility push(hidden)

#include <ios>       // ios_base, basic_ios, noskipws
#include <istream>   // basic_istream
#include <ostream>   // basic_ostream
#include <locale>    // money_get/put, time_get/put, use_facet
#include <string>    // basic_string
#include <string_view> // basic_string_view

namespace std {

//===----------------------------------------------------------------------===//
// resetiosflags
//===----------------------------------------------------------------------===//
class iom_resetiosflags {
    ios_base::fmtflags mask_;
public:
    explicit iom_resetiosflags(ios_base::fmtflags m) : mask_(m) {}

    template<class CharT, class Traits>
    friend basic_ostream<CharT, Traits>&
    operator<<(basic_ostream<CharT, Traits>& os, const iom_resetiosflags& x) {
        os.unsetf(x.mask_); return os;
    }
    template<class CharT, class Traits>
    friend basic_istream<CharT, Traits>&
    operator>>(basic_istream<CharT, Traits>& is, const iom_resetiosflags& x) {
        is.unsetf(x.mask_); return is;
    }
};

inline iom_resetiosflags resetiosflags(ios_base::fmtflags mask) {
    return iom_resetiosflags(mask);
}

