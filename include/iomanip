//===----------------------------------------------------------------------===//
// quoted — std::quoted (C++14)
//===----------------------------------------------------------------------===//

namespace detail {

// Output: write delim + escaped content + delim into os
template<class CharT, class Traits>
basic_ostream<CharT, Traits>&
quoted_output(basic_ostream<CharT, Traits>& os,
              const CharT* first, const CharT* last,
              CharT delim, CharT escape)
{
    basic_string<CharT, Traits> buf;
    buf.push_back(delim);
    for (; first != last; ++first) {
        if (Traits::eq(*first, escape) || Traits::eq(*first, delim))
            buf.push_back(escape);
        buf.push_back(*first);
    }
    buf.push_back(delim);
    return detail::put_character_sequence(os, buf.data(), buf.size());
}

// Input: read delimited (possibly escaped) string from is into string
template<class CharT, class Traits, class Str>
basic_istream<CharT, Traits>&
quoted_input(basic_istream<CharT, Traits>& is, Str& str,
             CharT delim, CharT escape)
{
    str.clear();
    CharT c;
    is >> c;
    if (is.fail())
        return is;
    if (!Traits::eq(c, delim)) {
        // no delimiter — read the whole word
        is.putback(c);
        is >> str;
        return is;
    }
    // Read until closing delim, handling escape
    ios_base& (*noskipws_fn)(ios_base&) = noskipws;
    auto saved_flags = is.flags();
    noskipws_fn(is);
    while (true) {
        is >> c;
        if (is.fail()) break;
        if (Traits::eq(c, escape)) {
            is >> c;
            if (is.fail()) break;
        } else if (Traits::eq(c, delim)) {
            break;
        }
        str.push_back(c);
    }
    is.flags(saved_flags);
    return is;
}

} // namespace detail

// Proxy for output-only (const CharT* or const string&)
template<class CharT, class Traits = void>
struct quoted_output_proxy {
    const CharT* first_;
    const CharT* last_;
    CharT delim_;
    CharT escape_;

    explicit quoted_output_proxy(const CharT* f, const CharT* l,
                                 CharT d, CharT e)
        : first_(f), last_(l), delim_(d), escape_(e) {}

    template<class T2,
             class = enable_if_t<is_same_v<Traits, void> || is_same_v<Traits, T2>>>
    friend basic_ostream<CharT, T2>&
    operator<<(basic_ostream<CharT, T2>& os, const quoted_output_proxy& p) {
        return detail::quoted_output(os, p.first_, p.last_, p.delim_, p.escape_);
    }
};

// Proxy for mutable string& (both input and output)
template<class CharT, class Traits, class Allocator>
struct quoted_proxy {
    basic_string<CharT, Traits, Allocator>& str_;
    CharT delim_;
    CharT escape_;

    explicit quoted_proxy(basic_string<CharT, Traits, Allocator>& s,
                          CharT d, CharT e)
        : str_(s), delim_(d), escape_(e) {}

    friend basic_ostream<CharT, Traits>&
    operator<<(basic_ostream<CharT, Traits>& os, const quoted_proxy& p) {
        return detail::quoted_output(os, p.str_.data(),
                                     p.str_.data() + p.str_.size(),
                                     p.delim_, p.escape_);
    }

    friend basic_istream<CharT, Traits>&
    operator>>(basic_istream<CharT, Traits>& is, const quoted_proxy& p) {
        return detail::quoted_input(is, p.str_, p.delim_, p.escape_);
    }
};

// quoted(const CharT*)
template<class CharT>
inline auto quoted(const CharT* s,
                   CharT delim  = CharT('"'),
                   CharT escape = CharT('\\'))
{
    const CharT* end = s;
    while (*end) ++end;
    return quoted_output_proxy<CharT, void>(s, end, delim, escape);
}

// quoted(const basic_string<>&) — output only
template<class CharT, class Traits, class Allocator>
inline auto quoted(const basic_string<CharT, Traits, Allocator>& s,
                   CharT delim  = CharT('"'),
                   CharT escape = CharT('\\'))
{
    return quoted_output_proxy<CharT, Traits>(
        s.data(), s.data() + s.size(), delim, escape);
}

// quoted(basic_string<>&) — input + output
template<class CharT, class Traits, class Allocator>
inline auto quoted(basic_string<CharT, Traits, Allocator>& s,
                   CharT delim  = CharT('"'),
                   CharT escape = CharT('\\'))
{
    return quoted_proxy<CharT, Traits, Allocator>(s, delim, escape);
}

// quoted(basic_string_view<>) — output only
template<class CharT, class Traits>
inline auto quoted(basic_string_view<CharT, Traits> sv,
                   CharT delim  = CharT('"'),
                   CharT escape = CharT('\\'))
{
    return quoted_output_proxy<CharT, Traits>(
        sv.data(), sv.data() + sv.size(), delim, escape);
}

