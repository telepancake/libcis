template <class CharT>
class iom_get_time;

template <class CharT, class Traits>
basic_istream<CharT, Traits>&
operator>>(basic_istream<CharT, Traits>& is, const iom_get_time<CharT>& x);

template <class CharT>
class iom_get_time {
    tm* tm_;
    const CharT* fmt_;
public:
    iom_get_time(tm* t, const CharT* fmt) : tm_(t), fmt_(fmt) {}

    template <class Cp, class Traits>
    friend basic_istream<Cp, Traits>&
    operator>>(basic_istream<Cp, Traits>& is, const iom_get_time<Cp>& x);
};

template <class CharT, class Traits>
basic_istream<CharT, Traits>&
operator>>(basic_istream<CharT, Traits>& is, const iom_get_time<CharT>& x) {
    typename basic_istream<CharT, Traits>::sentry s(is);
    if (s) {
        typedef istreambuf_iterator<CharT, Traits> Ip;
        typedef time_get<CharT, Ip> Fp;
        ios_base::iostate err = ios_base::goodbit;
        const Fp& tf = std::use_facet<Fp>(is.getloc());
        tf.get(Ip(is), Ip(), is, err, x.tm_, x.fmt_, x.fmt_ + Traits::length(x.fmt_));
        is.setstate(err);
    }
    return is;
}

template <class CharT>
inline iom_get_time<CharT> get_time(tm* t, const CharT* fmt) {
    return iom_get_time<CharT>(t, fmt);
}

