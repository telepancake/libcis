// ---------------------------------------------------------------------------
// C++20 lerp
// ---------------------------------------------------------------------------
namespace detail {

template<class Fp>
constexpr Fp lerp_impl(Fp a, Fp b, Fp t) noexcept {
    if ((a <= 0 && b >= 0) || (a >= 0 && b <= 0))
        return t * b + (1 - t) * a;
    if (t == 1)
        return b;
    const Fp x = a + t * (b - a);
    if ((t > 1) == (b > a))
        return b < x ? x : b;
    else
        return x < b ? x : b;
}

} // namespace detail

inline constexpr float lerp(float a, float b, float t) noexcept {
    return detail::lerp_impl(a, b, t);
}

inline constexpr double lerp(double a, double b, double t) noexcept {
    return detail::lerp_impl(a, b, t);
}

inline constexpr long double lerp(long double a, long double b, long double t) noexcept {
    return detail::lerp_impl(a, b, t);
}

template<class A1, class A2, class A3>
    requires(std::is_arithmetic_v<A1> && std::is_arithmetic_v<A2> && std::is_arithmetic_v<A3>)
inline constexpr promote_t<A1, A2, A3> lerp(A1 a, A2 b, A3 t) noexcept {
    using result_type = promote_t<A1, A2, A3>;
    static_assert(!(std::is_same_v<A1, result_type> &&
                    std::is_same_v<A2, result_type> &&
                    std::is_same_v<A3, result_type>));
    return detail::lerp_impl(static_cast<result_type>(a),
                             static_cast<result_type>(b),
                             static_cast<result_type>(t));
}

// ---------------------------------------------------------------------------
// C++17 hermite (special math)
// ---------------------------------------------------------------------------
namespace detail {

template<class Real>
Real hermite_impl(unsigned n, Real x) {
    if (isnan(x))
        return x;
    Real H_0{1};
    if (n == 0)
        return H_0;
    Real H_n_prev = H_0;
    Real H_n      = 2 * x;
    for (unsigned i = 1; i < n; ++i) {
        Real H_n_next = 2 * (x * H_n - i * H_n_prev);
        H_n_prev = H_n;
        H_n      = H_n_next;
    }
    if (!isfinite(H_n)) {
        Real inf_val = static_cast<Real>(__builtin_huge_val());
        return (n & 1) ? copysign(inf_val, x) : inf_val;
    }
    return H_n;
}

} // namespace detail

inline double     hermite(unsigned n, double x)      { return detail::hermite_impl(n, x); }
inline float      hermite(unsigned n, float x)        {
    return static_cast<float>(hermite(n, static_cast<double>(x)));
}
inline long double hermite(unsigned n, long double x) { return detail::hermite_impl(n, x); }
inline float       hermitef(unsigned n, float x)      { return hermite(n, x); }
inline long double hermitel(unsigned n, long double x){ return hermite(n, x); }

template<class Integer>
    requires std::is_integral_v<Integer>
inline double hermite(unsigned n, Integer x) {
    return hermite(n, static_cast<double>(x));
}

// ---------------------------------------------------------------------------
// C++17 3-argument hypot
// ---------------------------------------------------------------------------
namespace detail {

template<class Real>
Real hypot3_impl(Real x, Real y, Real z) {
    Real ax = x < 0 ? -x : x;
    Real ay = y < 0 ? -y : y;
    Real az = z < 0 ? -z : z;
    Real max_abs = ax > ay ? (ax > az ? ax : az) : (ay > az ? ay : az);
    if (max_abs == 0)
        return Real(0);
    x /= max_abs;
    y /= max_abs;
    z /= max_abs;
    return ::sqrt(static_cast<double>(x * x + y * y + z * z)) * max_abs;
}

template<>
inline float hypot3_impl<float>(float x, float y, float z) {
    float ax = x < 0 ? -x : x;
    float ay = y < 0 ? -y : y;
    float az = z < 0 ? -z : z;
    float max_abs = ax > ay ? (ax > az ? ax : az) : (ay > az ? ay : az);
    if (max_abs == 0.0f)
        return 0.0f;
    x /= max_abs;
    y /= max_abs;
    z /= max_abs;
    return ::sqrtf(x * x + y * y + z * z) * max_abs;
}

template<>
inline long double hypot3_impl<long double>(long double x, long double y, long double z) {
    long double ax = x < 0 ? -x : x;
    long double ay = y < 0 ? -y : y;
    long double az = z < 0 ? -z : z;
    long double max_abs = ax > ay ? (ax > az ? ax : az) : (ay > az ? ay : az);
    if (max_abs == 0.0L)
        return 0.0L;
    x /= max_abs;
    y /= max_abs;
    z /= max_abs;
    return ::sqrtl(x * x + y * y + z * z) * max_abs;
}

} // namespace detail

inline float       hypot(float x, float y, float z)             { return detail::hypot3_impl(x, y, z); }
inline double      hypot(double x, double y, double z)           { return detail::hypot3_impl(x, y, z); }
inline long double hypot(long double x, long double y, long double z) { return detail::hypot3_impl(x, y, z); }

template<class A1, class A2, class A3>
    requires(std::is_arithmetic_v<A1> && std::is_arithmetic_v<A2> && std::is_arithmetic_v<A3>)
inline promote_t<A1, A2, A3> hypot(A1 x, A2 y, A3 z) {
    using result_type = promote_t<A1, A2, A3>;
    static_assert(!(std::is_same_v<A1, result_type> &&
                    std::is_same_v<A2, result_type> &&
                    std::is_same_v<A3, result_type>));
    return detail::hypot3_impl(static_cast<result_type>(x),
                               static_cast<result_type>(y),
                               static_cast<result_type>(z));
}

