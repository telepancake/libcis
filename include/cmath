// <cmath> -- C math functions + C++20 additions in namespace std.
// Mechanically ported from libc++ include/cmath, __math/hypot.h,
// __math/special_functions.h, __type_traits/promote.h.
// Target: gcc-10.2, -std=gnu++20 -fno-exceptions -fno-rtti
#pragma once

// Include stdlib.h first so abs(int), abs(long), abs(long long) are declared
// before math.h adds floating-point abs overloads in C++ mode.
// glibc declarations must keep DEFAULT visibility no matter where this
// wrapper is first included from: io headers wrap their bodies in
// `#pragma GCC visibility push(hidden)` (libstdc++-ABI isolation), and a
// libc prototype first seen inside such a region becomes a hidden symbol
// the linker then cannot resolve against libc (e.g. strtod via <sstream>).
#pragma GCC visibility push(default)
#include <stdlib.h>
#include <math.h>
#pragma GCC visibility pop
#include <bits/fp_abs.h>
#include <type_traits>

// glibc defines signbit, fpclassify, isfinite, isinf, isnan, isnormal,
// isgreater*, isless*, isunordered as macros that expand to __builtin_*.
// Undefine them so we can provide real inline functions in namespace std.
