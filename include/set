// ---- Comparisons ----
template<class Key, class Compare, class Alloc>
bool operator==(const multiset<Key,Compare,Alloc>& x, const multiset<Key,Compare,Alloc>& y) {
    if (x.size() != y.size()) return false;
    auto a = x.begin(), b = y.begin();
    for (; a != x.end(); ++a, ++b)
        if (!(*a == *b)) return false;
    return true;
}

template<class Key, class Compare, class Alloc>
inline detail::synth_three_way_result<Key>
operator<=>(const multiset<Key,Compare,Alloc>& x, const multiset<Key,Compare,Alloc>& y) {
    return lexicographical_compare_three_way(x.begin(), x.end(), y.begin(), y.end(),
                                             detail::synth_three_way);
}

// ---- Non-member swap ----
template<class K, class C, class A>
void swap(multiset<K,C,A>& x, multiset<K,C,A>& y) noexcept(noexcept(x.swap(y))) { x.swap(y); }

// ---- erase_if ----
template<class K, class C, class A, class Pred>
typename multiset<K,C,A>::size_type
erase_if(multiset<K,C,A>& c, Pred pred) {
    auto old = c.size();
    for (auto it = c.begin(); it != c.end(); ) {
        if (pred(*it)) it = c.erase(it);
        else ++it;
    }
    return old - c.size();
}

// ---- Deduction guides for multiset ----
template<class InputIt,
         class Compare = less<typename iterator_traits<InputIt>::value_type>,
         class Alloc   = allocator<typename iterator_traits<InputIt>::value_type>,
         class = enable_if_t<!detail::tree_is_allocator_v<Compare>, void>,
         class = enable_if_t<!is_integral_v<Compare>, void>,
         class = enable_if_t<detail::tree_is_allocator_v<Alloc>, void>>
multiset(InputIt, InputIt, Compare = Compare(), Alloc = Alloc())
    -> multiset<typename iterator_traits<InputIt>::value_type, Compare, Alloc>;

template<class InputIt, class Alloc,
         class = enable_if_t<detail::tree_is_allocator_v<Alloc>, void>>
multiset(InputIt, InputIt, Alloc)
    -> multiset<typename iterator_traits<InputIt>::value_type,
                less<typename iterator_traits<InputIt>::value_type>, Alloc>;

template<class Key, class Compare = less<Key>, class Alloc = allocator<Key>,
         class = enable_if_t<!detail::tree_is_allocator_v<Compare>, void>,
         class = enable_if_t<!is_integral_v<Compare>, void>,
         class = enable_if_t<detail::tree_is_allocator_v<Alloc>, void>>
multiset(initializer_list<Key>, Compare = Compare(), Alloc = Alloc())
    -> multiset<Key, Compare, Alloc>;

template<class Key, class Alloc,
         class = enable_if_t<detail::tree_is_allocator_v<Alloc>, void>>
multiset(initializer_list<Key>, Alloc) -> multiset<Key, less<Key>, Alloc>;

// ---- Cross-container merge implementations ----
template<class Key, class Compare, class Alloc>
template<class C2>
void set<Key,Compare,Alloc>::merge(multiset<Key, C2, Alloc>& source) {
    tree_.merge_unique(source.tree_);
}
template<class Key, class Compare, class Alloc>
template<class C2>
void set<Key,Compare,Alloc>::merge(multiset<Key, C2, Alloc>&& source) {
    tree_.merge_unique(source.tree_);
}


