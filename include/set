    }

    // ---- Observers ----
    key_compare   key_comp()   const { return tree_.value_comp(); }
    value_compare value_comp() const { return tree_.value_comp(); }

    // ---- Lookup ----
    iterator       find(const key_type& k)       { return tree_.find(k); }
