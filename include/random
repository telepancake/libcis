template <class RealType>
template <class URNG>
RealType gamma_distribution<RealType>::operator()(URNG& g, const param_type& p) {
    static_assert(rand_is_valid_urng<URNG>::value, "");
    result_type a = p.alpha();
    uniform_real_distribution<result_type> gen(0, 1);
    exponential_distribution<result_type> egen;
    result_type x;
    if (a == 1) {
        x = egen(g);
    } else if (a > 1) {
        const result_type b = a - 1;
        const result_type c = 3 * a - result_type(0.75);
        while (true) {
            const result_type u = gen(g);
            const result_type v = gen(g);
            const result_type w = u * (1 - u);
            if (w != 0) {
                const result_type y = std::sqrt(c / w) * (u - result_type(0.5));
                x = b + y;
                if (x >= 0) {
                    const result_type z = 64 * w * w * w * v * v;
                    if (z <= 1 - 2 * y * y / x)
                        break;
                    if (std::log(z) <= 2 * (b * std::log(x / b) - y))
                        break;
                }
            }
        }
    } else {
        while (true) {
            const result_type u  = gen(g);
            const result_type es = egen(g);
            if (u <= 1 - a) {
                x = std::pow(u, 1 / a);
                if (x <= es)
                    break;
            } else {
                const result_type e = -std::log((1 - u) / a);
                x = std::pow(1 - a + a * e, 1 / a);
                if (x <= e + es)
                    break;
            }
        }
    }
    return x * p.beta();
}

