//===----------------------------------------------------------------------===//
// discard_block_engine
//===----------------------------------------------------------------------===//

template <class Engine, size_t p, size_t rused>
class discard_block_engine {
    Engine e_;
    int n_;

    static_assert(0 < rused);
    static_assert(rused <= p);
    static_assert(rused <= (size_t)numeric_limits<int>::max());

public:
    typedef typename Engine::result_type result_type;

    static inline constexpr const size_t block_size = p;
    static inline constexpr const size_t used_block = rused;

    static constexpr result_type Min = Engine::min();
    static constexpr result_type Max = Engine::max();
    static constexpr result_type min() { return Engine::min(); }
    static constexpr result_type max() { return Engine::max(); }

    discard_block_engine() : n_(0) {}
    explicit discard_block_engine(const Engine& e) : e_(e), n_(0) {}
    explicit discard_block_engine(Engine&& e) : e_(static_cast<Engine&&>(e)), n_(0) {}
    explicit discard_block_engine(result_type sd) : e_(sd), n_(0) {}
    template <class Sseq>
        requires (is_seed_sequence_v<Sseq, discard_block_engine> &&
                  !is_convertible_v<Sseq, Engine>)
    explicit discard_block_engine(Sseq& q) : e_(q), n_(0) {}

    void seed()               { e_.seed(); n_ = 0; }
    void seed(result_type sd) { e_.seed(sd); n_ = 0; }
    template <class Sseq>
        requires is_seed_sequence_v<Sseq, discard_block_engine>
    void seed(Sseq& q) { e_.seed(q); n_ = 0; }

    result_type operator()() {
        if (n_ >= static_cast<int>(rused)) {
            e_.discard(p - rused);
            n_ = 0;
        }
        ++n_;
        return e_();
    }
    void discard(unsigned long long z) {
        for (; z; --z) operator()();
    }

    const Engine& base() const noexcept { return e_; }

    friend bool operator==(const discard_block_engine& lhs,
                           const discard_block_engine& rhs) {
        return lhs.n_ == rhs.n_ && lhs.e_ == rhs.e_;
    }
    friend bool operator!=(const discard_block_engine& lhs,
                           const discard_block_engine& rhs) {
        return !(lhs == rhs);
    }
};

using ranlux24 = discard_block_engine<ranlux24_base, 223, 23>;
using ranlux48 = discard_block_engine<ranlux48_base, 389, 11>;

//===----------------------------------------------------------------------===//
// independent_bits_engine
//===----------------------------------------------------------------------===//

template <class Engine, size_t w, class UIntType>
class independent_bits_engine {
    template <class UInt, UInt R0, size_t Wp, size_t Mp>
    struct get_n_helper {
        static constexpr const size_t Dt = numeric_limits<UInt>::digits;
        static constexpr const size_t Np = Wp / Mp + (Wp % Mp != 0);
        static constexpr const size_t W0 = Wp / Np;
        static constexpr const UInt   Y0 = W0 >= Dt ? 0 : (R0 >> W0) << W0;
    public:
        static constexpr const size_t value = (R0 - Y0 > Y0 / Np) ? Np + 1 : Np;
    };

public:
    typedef UIntType result_type;

private:
    Engine e_;

    static constexpr const result_type Dt = numeric_limits<result_type>::digits;
    static_assert(0 < w);
    static_assert(w <= Dt);

    typedef typename Engine::result_type engine_result_type;
    using working_result_type = conditional_t<
        sizeof(engine_result_type) <= sizeof(result_type),
        result_type, engine_result_type>;

    static constexpr const working_result_type Rp =
        Engine::max() - Engine::min() + working_result_type(1);
    static constexpr const size_t m_  = rand_log2<working_result_type, Rp>::value;
    static constexpr const size_t n_  = get_n_helper<working_result_type, Rp, w, m_>::value;
    static constexpr const size_t w0_ = w / n_;
    static constexpr const size_t n0_ = n_ - w % n_;
    static constexpr const size_t WDt = numeric_limits<working_result_type>::digits;
    static constexpr const size_t EDt = numeric_limits<engine_result_type>::digits;
    static constexpr const working_result_type y0_ =
        w0_ >= WDt ? 0 : (Rp >> w0_) << w0_;
    static constexpr const working_result_type y1_ =
        w0_ >= WDt - 1 ? 0 : (Rp >> (w0_ + 1)) << (w0_ + 1);
    static constexpr const engine_result_type mask0_ =
        w0_ > 0 ? engine_result_type(~0) >> (EDt - w0_) : engine_result_type(0);
    static constexpr const engine_result_type mask1_ =
        w0_ < EDt - 1 ? engine_result_type(~0) >> (EDt - (w0_ + 1))
                      : engine_result_type(~0);

public:
    static constexpr const result_type Min = 0;
    static constexpr const result_type Max =
        (w == Dt) ? result_type(~0) : (result_type(1) << w) - result_type(1);
    static_assert(Min < Max);

    static constexpr result_type min() { return Min; }
    static constexpr result_type max() { return Max; }

    independent_bits_engine() {}
    explicit independent_bits_engine(const Engine& e) : e_(e) {}
    explicit independent_bits_engine(Engine&& e) : e_(static_cast<Engine&&>(e)) {}
    explicit independent_bits_engine(result_type sd) : e_(sd) {}
    template <class Sseq>
        requires (is_seed_sequence_v<Sseq, independent_bits_engine> &&
                  !is_convertible_v<Sseq, Engine>)
    explicit independent_bits_engine(Sseq& q) : e_(q) {}

    void seed() { e_.seed(); }
    void seed(result_type sd) { e_.seed(sd); }
    template <class Sseq>
        requires is_seed_sequence_v<Sseq, independent_bits_engine>
    void seed(Sseq& q) { e_.seed(q); }

    result_type operator()() {
        if constexpr (Rp != 0) {
            result_type sp = 0;
            for (size_t k = 0; k < n0_; ++k) {
                engine_result_type u;
                do { u = e_() - Engine::min(); } while (u >= y0_);
                sp = static_cast<result_type>(ibe_lshift<w0_>(sp) + (u & mask0_));
            }
            for (size_t k = n0_; k < n_; ++k) {
                engine_result_type u;
                do { u = e_() - Engine::min(); } while (u >= y1_);
                sp = static_cast<result_type>(ibe_lshift<w0_ + 1>(sp) + (u & mask1_));
            }
            return sp;
        } else {
            return static_cast<result_type>(e_() & mask0_);
        }
    }
    void discard(unsigned long long z) {
        for (; z; --z) operator()();
    }

    const Engine& base() const noexcept { return e_; }

    friend bool operator==(const independent_bits_engine& lhs,
                           const independent_bits_engine& rhs) {
        return lhs.e_ == rhs.e_;
    }
    friend bool operator!=(const independent_bits_engine& lhs,
                           const independent_bits_engine& rhs) {
        return !(lhs == rhs);
    }

private:
    template <size_t count>
    static result_type ibe_lshift(result_type x) {
        if constexpr (count < Dt) return x << count;
        else                      return result_type(0);
    }
};

//===----------------------------------------------------------------------===//
// shuffle_order_engine
//===----------------------------------------------------------------------===//

template <uint64_t X, uint64_t Y>
struct ugcd {
    static constexpr const uint64_t value = ugcd<Y, X % Y>::value;
};
template <uint64_t X>
struct ugcd<X, 0> {
    static constexpr const uint64_t value = X;
};

template <uint64_t N, uint64_t D>
struct uratio {
    static_assert(D != 0);
    static constexpr const uint64_t gcd_ = ugcd<N, D>::value;
    static constexpr const uint64_t num  = N / gcd_;
    static constexpr const uint64_t den  = D / gcd_;
};

template <class Engine, size_t k>
class shuffle_order_engine {
    static_assert(0 < k);

public:
    typedef typename Engine::result_type result_type;

private:
    Engine e_;
    result_type v_[k];
    result_type y_;

public:
    static inline constexpr const size_t table_size = k;

    static constexpr const result_type Min = Engine::min();
    static constexpr const result_type Max = Engine::max();
    static_assert(Min < Max);
    static constexpr result_type min() { return Min; }
    static constexpr result_type max() { return Max; }

    static constexpr const unsigned long long Rp = (unsigned long long)(Max - Min) + 1ull;

    shuffle_order_engine()                          { init(); }
    explicit shuffle_order_engine(const Engine& e) : e_(e) { init(); }
    explicit shuffle_order_engine(Engine&& e) : e_(static_cast<Engine&&>(e)) { init(); }
    explicit shuffle_order_engine(result_type sd) : e_(sd) { init(); }
    template <class Sseq>
        requires (is_seed_sequence_v<Sseq, shuffle_order_engine> &&
                  !is_convertible_v<Sseq, Engine>)
    explicit shuffle_order_engine(Sseq& q) : e_(q) { init(); }

    void seed()               { e_.seed(); init(); }
    void seed(result_type sd) { e_.seed(sd); init(); }
    template <class Sseq>
        requires is_seed_sequence_v<Sseq, shuffle_order_engine>
    void seed(Sseq& q) { e_.seed(q); init(); }

    result_type operator()() {
        if constexpr (Rp != 0 || !(k & 1)) {
            using Ratio = uratio<k, Rp != 0 ? Rp : 0x8000000000000000ull>;
            if constexpr (Ratio::num > 0xFFFFFFFFFFFFFFFFull / (Max - Min)) {
                return soe_evalf<Ratio::num, Ratio::den>();
            } else {
                const size_t j = static_cast<size_t>(Ratio::num * (y_ - Min) / Ratio::den);
                y_   = v_[j];
                v_[j] = e_();
                return y_;
            }
        } else {
            return soe_evalf<k, 0>();
        }
    }
    void discard(unsigned long long z) {
        for (; z; --z) operator()();
    }

    const Engine& base() const noexcept { return e_; }

    friend bool operator==(const shuffle_order_engine& lhs,
                           const shuffle_order_engine& rhs) {
        return lhs.y_ == rhs.y_ &&
               std::equal(lhs.v_, lhs.v_ + k, rhs.v_) &&
               lhs.e_ == rhs.e_;
    }
    friend bool operator!=(const shuffle_order_engine& lhs,
                           const shuffle_order_engine& rhs) {
        return !(lhs == rhs);
    }

private:
    void init() {
        for (size_t j = 0; j < k; ++j) v_[j] = e_();
        y_ = e_();
    }
    template <uint64_t num, uint64_t den>
    result_type soe_evalf() {
        const double fp = den == 0 ? num / (2. * 0x8000000000000000ull) : num / (double)den;
        const size_t j  = static_cast<size_t>(fp * (y_ - Min));
        y_   = v_[j];
        v_[j] = e_();
        return y_;
    }
};

using knuth_b = shuffle_order_engine<minstd_rand0, 256>;

