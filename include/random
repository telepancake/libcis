};

//===----------------------------------------------------------------------===//
// seed_seq
//===----------------------------------------------------------------------===//

class seed_seq {
public:
    typedef uint32_t result_type;

    seed_seq() noexcept {}

    template <class T>
        requires is_integral_v<T>
    seed_seq(initializer_list<T> il) {
        init(il.begin(), il.end());
    }

    template <class InputIterator>
    seed_seq(InputIterator first, InputIterator last) {
        static_assert(is_integral_v<typename iterator_traits<InputIterator>::value_type>,
            "seed_seq: value_type must be integral");
        init(first, last);
    }

    template <class RandomAccessIterator>
    void generate(RandomAccessIterator first, RandomAccessIterator last) {
        using value_type = typename iterator_traits<RandomAccessIterator>::value_type;
        static_assert(is_unsigned_v<value_type> && sizeof(value_type) >= sizeof(uint32_t),
            "seed_seq::generate: iterator value_type must be an unsigned integer >= 32 bits");
        if (first == last) return;
        std::fill(first, last, 0x8b8b8b8bu);
        const size_t n  = static_cast<size_t>(last - first);
        const size_t ss = v_.size();
        const size_t t  = (n >= 623) ? 11 : (n >= 68) ? 7 : (n >= 39) ? 5 : (n >= 7) ? 3 : (n - 1) / 2;
        const size_t p  = (n - t) / 2;
        const size_t q  = p + t;
        const size_t m  = std::max(ss + 1, n);
        {
            result_type rr = 1664525 * tp(first[0] ^ first[p] ^ first[n-1]);
            first[p] += rr;
            rr += ss;
            first[q] += rr;
            first[0] = rr;
        }
        size_t kmodn  = 0;
        size_t k1modn = n - 1;
        size_t kpmodn = p % n;
        size_t kqmodn = q % n;
        for (size_t k = 1; k <= ss; ++k) {
            if (++kmodn  == n) kmodn  = 0;
            if (++k1modn == n) k1modn = 0;
            if (++kpmodn == n) kpmodn = 0;
            if (++kqmodn == n) kqmodn = 0;
            result_type rr = 1664525 * tp(first[kmodn] ^ first[kpmodn] ^ first[k1modn]);
            first[kpmodn] += rr;
            rr += kmodn + v_[k-1];
            first[kqmodn] += rr;
            first[kmodn] = rr;
        }
        for (size_t k = ss + 1; k < m; ++k) {
            if (++kmodn  == n) kmodn  = 0;
            if (++k1modn == n) k1modn = 0;
            if (++kpmodn == n) kpmodn = 0;
            if (++kqmodn == n) kqmodn = 0;
            result_type rr = 1664525 * tp(first[kmodn] ^ first[kpmodn] ^ first[k1modn]);
            first[kpmodn] += rr;
            rr += kmodn;
            first[kqmodn] += rr;
            first[kmodn] = rr;
        }
        for (size_t k = m; k < m + n; ++k) {
            if (++kmodn  == n) kmodn  = 0;
            if (++k1modn == n) k1modn = 0;
            if (++kpmodn == n) kpmodn = 0;
            if (++kqmodn == n) kqmodn = 0;
            result_type rr = 1566083941 * tp(first[kmodn] + first[kpmodn] + first[k1modn]);
            first[kpmodn] ^= rr;
            rr -= kmodn;
            first[kqmodn] ^= rr;
            first[kmodn] = rr;
        }
    }

    size_t size() const noexcept { return v_.size(); }
    template <class OutputIterator>
    void param(OutputIterator dest) const {
        std::copy(v_.begin(), v_.end(), dest);
    }

    seed_seq(const seed_seq&)            = delete;
    void operator=(const seed_seq&)      = delete;

private:
    static result_type tp(result_type x) { return x ^ (x >> 27); }

    template <class InputIterator>
    void init(InputIterator first, InputIterator last) {
        for (auto s = first; s != last; ++s)
            v_.push_back(*s & 0xFFFFFFFF);
    }

    vector<result_type> v_;
};

//===----------------------------------------------------------------------===//
// generate_canonical
//===----------------------------------------------------------------------===//

template <class RealType, size_t bits, class URNG>
RealType generate_canonical(URNG& g) {
    const size_t dt    = numeric_limits<RealType>::digits;
    const size_t b     = dt < bits ? dt : bits;
    const size_t log_r = rand_log2<uint64_t, URNG::max() - URNG::min() + uint64_t(1)>::value;
    const size_t k     = b / log_r + (b % log_r != 0) + (b == 0);
    const RealType rp  = static_cast<RealType>(URNG::max() - URNG::min()) + RealType(1);
    RealType base      = rp;
    RealType sp        = static_cast<RealType>(g() - URNG::min());
    for (size_t i = 1; i < k; ++i, base *= rp)
        sp += static_cast<RealType>(g() - URNG::min()) * base;
    return sp / base;
}

//===----------------------------------------------------------------------===//
// Internal: __independent_bits_engine (runtime-width, used by uniform_int)
//===----------------------------------------------------------------------===//

template <class Engine, class UIntType>
class ibe_runtime {
public:
    typedef UIntType result_type;

private:
    typedef typename Engine::result_type engine_result_type;
    using working_result_type = conditional_t<
        sizeof(engine_result_type) <= sizeof(result_type),
        result_type, engine_result_type>;

    Engine& e_;
    size_t w_;
    size_t w0_;
    size_t n_;
    size_t n0_;
    working_result_type y0_;
    working_result_type y1_;
    engine_result_type mask0_;
    engine_result_type mask1_;

    static constexpr const working_result_type Rp =
        Engine::max() - Engine::min() + working_result_type(1);
    static constexpr const size_t m_   = rand_log2<working_result_type, Rp>::value;
    static constexpr const size_t WDt  = numeric_limits<working_result_type>::digits;
    static constexpr const size_t EDt  = numeric_limits<engine_result_type>::digits;

public:
    ibe_runtime(Engine& e, size_t w) : e_(e), w_(w) {
        n_  = w_ / m_ + (w_ % m_ != 0);
        w0_ = w_ / n_;
        if (Rp == 0)
            y0_ = Rp;
        else if (w0_ < WDt)
            y0_ = (Rp >> w0_) << w0_;
        else
            y0_ = 0;
        if (Rp - y0_ > y0_ / n_) {
            ++n_;
            w0_ = w_ / n_;
            if (w0_ < WDt) y0_ = (Rp >> w0_) << w0_;
            else            y0_ = 0;
        }
        n0_ = n_ - w_ % n_;
        if (w0_ < WDt - 1)
            y1_ = (Rp >> (w0_ + 1)) << (w0_ + 1);
        else
            y1_ = 0;
        mask0_ = w0_ > 0 ? engine_result_type(~0) >> (EDt - w0_)     : engine_result_type(0);
        mask1_ = w0_ < EDt - 1 ? engine_result_type(~0) >> (EDt - (w0_ + 1))
                               : engine_result_type(~0);
    }

    result_type operator()() {
        if constexpr (Rp == 0)
            return static_cast<result_type>(e_() & mask0_);
        const size_t w_rt = numeric_limits<result_type>::digits;
        result_type sp = 0;
        for (size_t k = 0; k < n0_; ++k) {
            engine_result_type u;
            do { u = e_() - Engine::min(); } while (u >= y0_);
            if (w0_ < w_rt)
                sp <<= w0_;
            else
                sp = 0;
            sp += u & mask0_;
        }
        for (size_t k = n0_; k < n_; ++k) {
            engine_result_type u;
            do { u = e_() - Engine::min(); } while (u >= y1_);
            if (w0_ < w_rt - 1)
                sp <<= w0_ + 1;
            else
                sp = 0;
            sp += u & mask1_;
        }
        return sp;
    }
};

//===----------------------------------------------------------------------===//
// clamp_to_integral (internal, used by poisson_distribution)
//===----------------------------------------------------------------------===//

template <class IntT, class FloatT,
          bool FloatBigger = (numeric_limits<FloatT>::digits > numeric_limits<IntT>::digits),
          int Bits = (numeric_limits<IntT>::digits - numeric_limits<FloatT>::digits)>
constexpr IntT max_representable_int_for_float() noexcept {
    static_assert(is_floating_point_v<FloatT>);
    static_assert(is_integral_v<IntT>);
    static_assert(numeric_limits<FloatT>::radix == 2);
    return FloatBigger ? numeric_limits<IntT>::max()
                       : (numeric_limits<IntT>::max() >> Bits << Bits);
}

template <class IntT, class RealT>
IntT clamp_to_integral(RealT r) noexcept {
    using Lim = numeric_limits<IntT>;
    const IntT max_val = max_representable_int_for_float<IntT, RealT>();
    if (r >= ::nextafter(static_cast<RealT>(max_val), INFINITY))
        return Lim::max();
    else if (r <= Lim::lowest())
        return Lim::min();
    return static_cast<IntT>(r);
}

//===----------------------------------------------------------------------===//
// uniform_int_distribution
//===----------------------------------------------------------------------===//

template <class IntType = int>
class uniform_int_distribution {
    static_assert(rand_is_valid_inttype<IntType>::value,
        "uniform_int_distribution: IntType must be a supported integer type");

public:
    typedef IntType result_type;

    class param_type {
        result_type a_;
        result_type b_;
    public:
        typedef uniform_int_distribution distribution_type;
        explicit param_type(result_type a = 0,
                            result_type b = numeric_limits<result_type>::max())
            : a_(a), b_(b) {}
        result_type a() const { return a_; }
        result_type b() const { return b_; }
        friend bool operator==(const param_type& x, const param_type& y) {
            return x.a_ == y.a_ && x.b_ == y.b_;
        }
        friend bool operator!=(const param_type& x, const param_type& y) {
            return !(x == y);
        }
    };

private:
    param_type p_;

public:
    uniform_int_distribution() : uniform_int_distribution(0) {}
    explicit uniform_int_distribution(result_type a,
        result_type b = numeric_limits<result_type>::max())
        : p_(param_type(a, b)) {}
    explicit uniform_int_distribution(const param_type& p) : p_(p) {}
    void reset() {}

    template <class URNG>
    result_type operator()(URNG& g) { return (*this)(g, p_); }
    template <class URNG>
    result_type operator()(URNG& g, const param_type& p);

    result_type a() const { return p_.a(); }
    result_type b() const { return p_.b(); }
    param_type param() const { return p_; }
    void param(const param_type& p) { p_ = p; }
    result_type min() const { return a(); }
    result_type max() const { return b(); }

    friend bool operator==(const uniform_int_distribution& x,
                           const uniform_int_distribution& y) { return x.p_ == y.p_; }
    friend bool operator!=(const uniform_int_distribution& x,
                           const uniform_int_distribution& y) { return !(x == y); }
};

template <class IntType>
template <class URNG>
typename uniform_int_distribution<IntType>::result_type
uniform_int_distribution<IntType>::operator()(URNG& g, const param_type& p) {
    static_assert(rand_is_valid_urng<URNG>::value, "");
    using UIntType = conditional_t<sizeof(result_type) <= sizeof(uint32_t),
                                   uint32_t, make_unsigned_t<result_type>>;
    const UIntType rp = UIntType(p.b()) - UIntType(p.a()) + UIntType(1);
    if (rp == 1) return p.a();
    const size_t dt = numeric_limits<UIntType>::digits;
    typedef ibe_runtime<URNG, UIntType> Eng;
    if (rp == 0)
        return static_cast<result_type>(Eng(g, dt)());
    size_t w = dt - static_cast<size_t>(std::countl_zero(rp)) - 1;
    if ((rp & (numeric_limits<UIntType>::max() >> (dt - w))) != 0)
        ++w;
    Eng e(g, w);
    UIntType u;
    do { u = e(); } while (u >= rp);
    return static_cast<result_type>(u + p.a());
}

