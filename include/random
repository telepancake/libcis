        return !(x == y);
    }
};

template <class IntType>
binomial_distribution<IntType>::param_type::param_type(result_type t, double p)
    : t_(t), p_(p) {
    if (0 < p_ && p_ < 1) {
        r0_ = static_cast<result_type>((t_ + 1) * p_);
        pr_ = std::exp(
            std::lgamma(t_ + 1.) - std::lgamma(r0_ + 1.) - std::lgamma(t_ - r0_ + 1.)
            + r0_ * std::log(p_) + (t_ - r0_) * std::log(1 - p_));
        odds_ratio_ = p_ / (1 - p_);
    }
}

template <class IntType>
template <class URNG>
IntType binomial_distribution<IntType>::operator()(URNG& g, const param_type& pr) {
    static_assert(rand_is_valid_urng<URNG>::value, "");
    if (pr.t_ == 0 || pr.p_ == 0) return 0;
    if (pr.p_ == 1) return pr.t_;
    uniform_real_distribution<double> gen;
    double u = gen(g) - pr.pr_;
    if (u < 0) return pr.r0_;
    double pu = pr.pr_;
    double pd = pu;
    result_type ru = pr.r0_;
    result_type rd = ru;
    while (true) {
        bool do_break = true;
        if (rd >= 1) {
            pd *= rd / (pr.odds_ratio_ * (pr.t_ - rd + 1));
            u -= pd;
            do_break = false;
            if (u < 0) return rd - 1;
        }
        if (rd != 0) --rd;
        ++ru;
        if (ru <= pr.t_) {
            pu *= (pr.t_ - ru + 1) * pr.odds_ratio_ / ru;
            u -= pu;
            do_break = false;
            if (u < 0) return ru;
        }
        if (do_break) return 0;
    }
}

