//===----------------------------------------------------------------------===//
// Internal helpers: __log2
//===----------------------------------------------------------------------===//

template <class UIntType, UIntType Xp, size_t Rp>
struct log2_imp;

template <unsigned long long Xp, size_t Rp>
struct log2_imp<unsigned long long, Xp, Rp> {
    static const size_t value =
        Xp & ((unsigned long long)(1) << Rp) ? Rp
            : log2_imp<unsigned long long, Xp, Rp - 1>::value;
};

template <unsigned long long Xp>
struct log2_imp<unsigned long long, Xp, 0> {
    static const size_t value = 0;
};

template <size_t Rp>
struct log2_imp<unsigned long long, 0, Rp> {
    static const size_t value = Rp + 1;
};

template <class UIntType, UIntType Xp>
struct rand_log2 {
    static const size_t value =
        log2_imp<unsigned long long, Xp, sizeof(UIntType) * __CHAR_BIT__ - 1>::value;
};

