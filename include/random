template <class IntType>
template <class URNG>
IntType negative_binomial_distribution<IntType>::operator()(URNG& urng, const param_type& pr) {
    static_assert(rand_is_valid_urng<URNG>::value, "");
    result_type k = pr.k();
    double p = pr.p();
    if (k <= 21 * p && sizeof(IntType) > 1) {
        bernoulli_distribution gen(p);
        result_type f = 0;
        result_type s = 0;
        while (s < k) {
            if (gen(urng)) ++s;
            else            ++f;
        }
        return f;
    }
    return poisson_distribution<result_type>(
        gamma_distribution<double>(k, (1 - p) / p)(urng))(urng);
}

