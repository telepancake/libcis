//===----------------------------------------------------------------------===//
// linear_congruential_engine helpers (lce_ta)
//===----------------------------------------------------------------------===//

enum lce_alg_type { LCE_Full, LCE_Part, LCE_Schrage, LCE_Promote };

template <unsigned long long a,
          unsigned long long c,
          unsigned long long m,
          unsigned long long Mp,
          bool HasOverflow = (a != 0ull && (m & (m - 1ull)) != 0ull),
          bool Full        = (!HasOverflow || m - 1ull <= (Mp - c) / a),
          bool Part        = (!HasOverflow || m - 1ull <= Mp / a),
          bool Schrage     = (HasOverflow && m % a <= m / a)>
struct lce_alg_picker {
    static constexpr lce_alg_type mode =
        Full    ? LCE_Full
        : Part  ? LCE_Part
        : Schrage ? LCE_Schrage
                  : LCE_Promote;
    static_assert(Mp != (unsigned long long)(-1) || Full || Part || Schrage,
        "linear_congruential_engine: unsupported parameters (no __int128)");
};

template <unsigned long long a,
          unsigned long long c,
          unsigned long long m,
          unsigned long long Mp,
          lce_alg_type Mode = lce_alg_picker<a,c,m,Mp>::mode>
struct lce_ta;

// 64-bit specialisations

template <unsigned long long a, unsigned long long c, unsigned long long m>
struct lce_ta<a, c, m, (unsigned long long)(-1), LCE_Promote> {
    typedef unsigned long long result_type;
    static result_type next(result_type xp) {
        // promote: use 128-bit via __extension__
        __extension__ using calc_type = unsigned __int128;
        return static_cast<result_type>(
            (static_cast<calc_type>(a) * xp + c) % m);
    }
};

template <unsigned long long a, unsigned long long c, unsigned long long m>
struct lce_ta<a, c, m, (unsigned long long)(-1), LCE_Schrage> {
    typedef unsigned long long result_type;
    static result_type next(result_type x) {
        const result_type q  = m / a;
        const result_type r  = m % a;
        const result_type t0 = a * (x % q);
        const result_type t1 = r * (x / q);
        x = t0 + (t0 < t1) * m - t1;
        x += c - (x >= m - c) * m;
        return x;
    }
};

template <unsigned long long a, unsigned long long m>
struct lce_ta<a, 0ull, m, (unsigned long long)(-1), LCE_Schrage> {
    typedef unsigned long long result_type;
    static result_type next(result_type x) {
        const result_type q  = m / a;
        const result_type r  = m % a;
        const result_type t0 = a * (x % q);
        const result_type t1 = r * (x / q);
        x = t0 + (t0 < t1) * m - t1;
        return x;
    }
};

template <unsigned long long a, unsigned long long c, unsigned long long m>
struct lce_ta<a, c, m, (unsigned long long)(-1), LCE_Part> {
    typedef unsigned long long result_type;
    static result_type next(result_type x) {
        x = (a * x) % m;
        x += c - (x >= m - c) * m;
        return x;
    }
};

template <unsigned long long a, unsigned long long c, unsigned long long m>
struct lce_ta<a, c, m, (unsigned long long)(-1), LCE_Full> {
    typedef unsigned long long result_type;
    static result_type next(result_type x) { return (a * x + c) % m; }
};

template <unsigned long long a, unsigned long long c>
struct lce_ta<a, c, 0ull, (unsigned long long)(-1), LCE_Full> {
    typedef unsigned long long result_type;
    static result_type next(result_type x) { return a * x + c; }
};

// 32-bit specialisations

template <unsigned long long a, unsigned long long c, unsigned long long m>
struct lce_ta<a, c, m, unsigned(-1), LCE_Promote> {
    typedef unsigned result_type;
    static result_type next(result_type x) {
        return static_cast<result_type>(
            lce_ta<a, c, m, (unsigned long long)(-1)>::next(x));
    }
};

template <unsigned long long Ap, unsigned long long Cp, unsigned long long Mp>
struct lce_ta<Ap, Cp, Mp, unsigned(-1), LCE_Schrage> {
    typedef unsigned result_type;
    static result_type next(result_type x) {
        const result_type a  = static_cast<result_type>(Ap);
        const result_type c  = static_cast<result_type>(Cp);
        const result_type m  = static_cast<result_type>(Mp);
        const result_type q  = m / a;
        const result_type r  = m % a;
        const result_type t0 = a * (x % q);
        const result_type t1 = r * (x / q);
        x = t0 + (t0 < t1) * m - t1;
        x += c - (x >= m - c) * m;
        return x;
    }
};

template <unsigned long long Ap, unsigned long long Mp>
struct lce_ta<Ap, 0ull, Mp, unsigned(-1), LCE_Schrage> {
    typedef unsigned result_type;
    static result_type next(result_type x) {
        const result_type a = static_cast<result_type>(Ap);
        const result_type m = static_cast<result_type>(Mp);
        const result_type q = m / a;
        const result_type r = m % a;
        const result_type t0 = a * (x % q);
        const result_type t1 = r * (x / q);
        x = t0 + (t0 < t1) * m - t1;
        return x;
    }
};

template <unsigned long long Ap, unsigned long long Cp, unsigned long long Mp>
struct lce_ta<Ap, Cp, Mp, unsigned(-1), LCE_Part> {
    typedef unsigned result_type;
    static result_type next(result_type x) {
        const result_type a = static_cast<result_type>(Ap);
        const result_type c = static_cast<result_type>(Cp);
        const result_type m = static_cast<result_type>(Mp);
        x = (a * x) % m;
        x += c - (x >= m - c) * m;
        return x;
    }
};

template <unsigned long long Ap, unsigned long long Cp, unsigned long long Mp>
struct lce_ta<Ap, Cp, Mp, unsigned(-1), LCE_Full> {
    typedef unsigned result_type;
    static result_type next(result_type x) {
        const result_type a = static_cast<result_type>(Ap);
        const result_type c = static_cast<result_type>(Cp);
        const result_type m = static_cast<result_type>(Mp);
        return (a * x + c) % m;
    }
};

template <unsigned long long Ap, unsigned long long Cp>
struct lce_ta<Ap, Cp, 0ull, unsigned(-1), LCE_Full> {
    typedef unsigned result_type;
    static result_type next(result_type x) {
        const result_type a = static_cast<result_type>(Ap);
        const result_type c = static_cast<result_type>(Cp);
        return a * x + c;
    }
};

// 16-bit fallback
template <unsigned long long a, unsigned long long c, unsigned long long m, lce_alg_type mode>
struct lce_ta<a, c, m, (unsigned short)(-1), mode> {
    typedef unsigned short result_type;
    static result_type next(result_type x) {
        return static_cast<result_type>(lce_ta<a, c, m, unsigned(-1)>::next(x));
    }
};

//===----------------------------------------------------------------------===//
// linear_congruential_engine
//===----------------------------------------------------------------------===//

template <class UIntType, UIntType a, UIntType c, UIntType m>
class linear_congruential_engine {
public:
    typedef UIntType result_type;

private:
    result_type x_;

    static constexpr const result_type Mp = result_type(-1);

    static_assert(m == 0 || a < m, "linear_congruential_engine: invalid parameters");
    static_assert(m == 0 || c < m, "linear_congruential_engine: invalid parameters");
    static_assert(is_unsigned_v<UIntType>, "UIntType must be an unsigned type");

public:
    static constexpr const result_type Min = (c == 0u) ? 1u : 0u;
    static constexpr const result_type Max = m - UIntType(1u);
    static_assert(Min < Max, "linear_congruential_engine: invalid parameters");

    static inline constexpr const result_type multiplier   = a;
    static inline constexpr const result_type increment    = c;
    static inline constexpr const result_type modulus      = m;
    static constexpr result_type min() { return Min; }
    static constexpr result_type max() { return Max; }
    static inline constexpr const result_type default_seed = 1u;

    linear_congruential_engine() : linear_congruential_engine(default_seed) {}
    explicit linear_congruential_engine(result_type s) { seed(s); }
    template <class Sseq>
        requires is_seed_sequence_v<Sseq, linear_congruential_engine>
    explicit linear_congruential_engine(Sseq& q) { seed(q); }

    void seed(result_type s = default_seed) {
        if constexpr (m == 0) {
            if constexpr (c == 0)
                x_ = (s == 0) ? 1 : s;
            else
                x_ = s;
        } else {
            if constexpr (c == 0)
                x_ = (s % m == 0) ? 1 : s % m;
            else
                x_ = s % m;
        }
    }

    template <class Sseq>
        requires is_seed_sequence_v<Sseq, linear_congruential_engine>
    void seed(Sseq& q) {
        constexpr unsigned k = 1 + (m == 0 ? (sizeof(result_type) * __CHAR_BIT__ - 1) / 32
                                            : (m > 0x100000000ull));
        static_assert(k <= 2);
        uint32_t ar[k + 3];
        q.generate(ar, ar + k + 3);
        result_type s = static_cast<result_type>(
            (ar[3] + (k == 1 ? 0 : (uint64_t)ar[4] << 32)) % m);
        x_ = (c == 0 && s == 0) ? result_type(1) : s;
    }

    result_type operator()() {
        return x_ = static_cast<result_type>(lce_ta<a, c, m, Mp>::next(x_));
    }
    void discard(unsigned long long z) {
        for (; z; --z) operator()();
    }

    friend bool operator==(const linear_congruential_engine& lhs,
                           const linear_congruential_engine& rhs) {
        return lhs.x_ == rhs.x_;
    }
    friend bool operator!=(const linear_congruential_engine& lhs,
                           const linear_congruential_engine& rhs) {
        return !(lhs == rhs);
    }
};

using minstd_rand0 = linear_congruential_engine<uint_fast32_t, 16807, 0, 2147483647>;
using minstd_rand  = linear_congruential_engine<uint_fast32_t, 48271, 0, 2147483647>;

//===----------------------------------------------------------------------===//
// mersenne_twister_engine
//===----------------------------------------------------------------------===//

template <class UIntType,
          size_t w, size_t n, size_t mshift, size_t r,
          UIntType a,
          size_t u, UIntType d,
          size_t s, UIntType b,
          size_t t, UIntType c,
          size_t l, UIntType f>
class mersenne_twister_engine {
public:
    typedef UIntType result_type;

private:
    result_type x_[n];
    size_t i_;

    static constexpr const result_type Dt = numeric_limits<result_type>::digits;
    static_assert(0 < mshift);
    static_assert(mshift <= n);
    static_assert(w <= Dt);
    static_assert(2 <= w);
    static_assert(r <= w);
    static_assert(u <= w);
    static_assert(s <= w);
    static_assert(t <= w);
    static_assert(l <= w);

public:
    static constexpr const result_type Min = 0;
    static constexpr const result_type Max =
        (w == Dt) ? result_type(~0) : (result_type(1) << w) - result_type(1);
    static_assert(Min < Max);
    static_assert(a <= Max);
    static_assert(b <= Max);
    static_assert(c <= Max);
    static_assert(d <= Max);
    static_assert(f <= Max);

    static inline constexpr const size_t word_size                      = w;
    static inline constexpr const size_t state_size                     = n;
    static inline constexpr const size_t shift_size                     = mshift;
    static inline constexpr const size_t mask_bits                      = r;
    static inline constexpr const result_type xor_mask                  = a;
    static inline constexpr const size_t tempering_u                    = u;
    static inline constexpr const result_type tempering_d               = d;
    static inline constexpr const size_t tempering_s                    = s;
    static inline constexpr const result_type tempering_b               = b;
    static inline constexpr const size_t tempering_t                    = t;
    static inline constexpr const result_type tempering_c               = c;
    static inline constexpr const size_t tempering_l                    = l;
    static inline constexpr const result_type initialization_multiplier = f;
    static constexpr result_type min() { return Min; }
    static constexpr result_type max() { return Max; }
    static inline constexpr const result_type default_seed = 5489u;

    mersenne_twister_engine() : mersenne_twister_engine(default_seed) {}
    explicit mersenne_twister_engine(result_type sd) { seed(sd); }
    template <class Sseq>
        requires is_seed_sequence_v<Sseq, mersenne_twister_engine>
    explicit mersenne_twister_engine(Sseq& q) { seed(q); }

    void seed(result_type sd = default_seed) {
        x_[0] = sd & Max;
        for (size_t k = 1; k < n; ++k)
            x_[k] = (f * (x_[k-1] ^ mt_rshift<w-2>(x_[k-1])) + k) & Max;
        i_ = 0;
    }

    template <class Sseq>
        requires is_seed_sequence_v<Sseq, mersenne_twister_engine>
    void seed(Sseq& q) {
        const unsigned k = 1 + (w - 1) / 32;
        static_assert(k <= 2);
        uint32_t ar[n * k];
        q.generate(ar, ar + n * k);
        for (size_t j = 0; j < n; ++j) {
            if constexpr (k == 1)
                x_[j] = static_cast<result_type>(ar[j] & Max);
            else
                x_[j] = static_cast<result_type>(
                    (ar[2*j] + ((uint64_t)ar[2*j+1] << 32)) & Max);
        }
        const result_type mask = (r == Dt) ? result_type(~0) : (result_type(1) << r) - result_type(1);
        i_ = 0;
        if ((x_[0] & ~mask) == 0) {
            for (size_t j = 1; j < n; ++j)
                if (x_[j] != 0) return;
            x_[0] = result_type(1) << (w - 1);
        }
    }

    result_type operator()() {
        const size_t j        = (i_ + 1) % n;
        const result_type mask = (r == Dt) ? result_type(~0) : (result_type(1) << r) - result_type(1);
        const result_type yp   = (x_[i_] & ~mask) | (x_[j] & mask);
        const size_t k         = (i_ + mshift) % n;
        x_[i_]                 = x_[k] ^ mt_rshift<1>(yp) ^ (a * (yp & 1));
        result_type z          = x_[i_] ^ (mt_rshift<u>(x_[i_]) & d);
        i_                     = j;
        z ^= mt_lshift<s>(z) & b;
        z ^= mt_lshift<t>(z) & c;
        return z ^ mt_rshift<l>(z);
    }

    void discard(unsigned long long z) {
        for (; z; --z) operator()();
    }

    friend bool operator==(const mersenne_twister_engine& lhs,
                           const mersenne_twister_engine& rhs) {
        if (lhs.i_ == rhs.i_)
            return std::equal(lhs.x_, lhs.x_ + n, rhs.x_);
        if (lhs.i_ == 0 || rhs.i_ == 0) {
            size_t j = std::min(n - lhs.i_, n - rhs.i_);
            if (!std::equal(lhs.x_ + lhs.i_, lhs.x_ + lhs.i_ + j, rhs.x_ + rhs.i_))
                return false;
            if (lhs.i_ == 0)
                return std::equal(lhs.x_ + j, lhs.x_ + n, rhs.x_);
            return std::equal(lhs.x_, lhs.x_ + (n - j), rhs.x_ + j);
        }
        if (lhs.i_ < rhs.i_) {
            size_t j = n - rhs.i_;
            if (!std::equal(lhs.x_ + lhs.i_, lhs.x_ + lhs.i_ + j, rhs.x_ + rhs.i_))
                return false;
            if (!std::equal(lhs.x_ + lhs.i_ + j, lhs.x_ + n, rhs.x_))
                return false;
            return std::equal(lhs.x_, lhs.x_ + lhs.i_, rhs.x_ + (n - (lhs.i_ + j)));
        }
        size_t j = n - lhs.i_;
        if (!std::equal(rhs.x_ + rhs.i_, rhs.x_ + rhs.i_ + j, lhs.x_ + lhs.i_))
            return false;
        if (!std::equal(rhs.x_ + rhs.i_ + j, rhs.x_ + n, lhs.x_))
            return false;
        return std::equal(rhs.x_, rhs.x_ + rhs.i_, lhs.x_ + (n - (rhs.i_ + j)));
    }
    friend bool operator!=(const mersenne_twister_engine& lhs,
                           const mersenne_twister_engine& rhs) {
        return !(lhs == rhs);
    }

private:
    template <size_t count>
    static result_type mt_lshift(result_type x) {
        if constexpr (count < w) return (x << count) & Max;
        else                     return result_type(0);
    }
    template <size_t count>
    static result_type mt_rshift(result_type x) {
        if constexpr (count < Dt) return x >> count;
        else                      return result_type(0);
    }
};

using mt19937 = mersenne_twister_engine<
    uint_fast32_t, 32, 624, 397, 31,
    0x9908b0df, 11, 0xffffffff, 7, 0x9d2c5680, 15, 0xefc60000, 18, 1812433253>;

using mt19937_64 = mersenne_twister_engine<
    uint_fast64_t, 64, 312, 156, 31,
    0xb5026f5aa96619e9ULL, 29, 0x5555555555555555ULL, 17,
    0x71d67fffeda60000ULL, 37, 0xfff7eee000000000ULL, 43,
    6364136223846793005ULL>;

//===----------------------------------------------------------------------===//
// subtract_with_carry_engine
//===----------------------------------------------------------------------===//

template <class UIntType, size_t w, size_t s, size_t r>
class subtract_with_carry_engine {
public:
    typedef UIntType result_type;

private:
    result_type x_[r];
    result_type c_;
    size_t i_;

    static constexpr const result_type Dt = numeric_limits<result_type>::digits;
    static_assert(0 < w);
    static_assert(w <= Dt);
    static_assert(0 < s);
    static_assert(s < r);

public:
    static constexpr const result_type Min = 0;
    static constexpr const result_type Max =
        (w == Dt) ? result_type(~0) : (result_type(1) << w) - result_type(1);
    static_assert(Min < Max);

    static inline constexpr const size_t word_size = w;
    static inline constexpr const size_t short_lag = s;
    static inline constexpr const size_t long_lag   = r;
    static constexpr result_type min() { return Min; }
    static constexpr result_type max() { return Max; }
    static inline constexpr const result_type default_seed = 19780503u;

    subtract_with_carry_engine() : subtract_with_carry_engine(default_seed) {}
    explicit subtract_with_carry_engine(result_type sd) { seed(sd); }
    template <class Sseq>
        requires is_seed_sequence_v<Sseq, subtract_with_carry_engine>
    explicit subtract_with_carry_engine(Sseq& q) { seed(q); }

    void seed(result_type sd = default_seed) {
        linear_congruential_engine<result_type, 40014u, 0u, 2147483563u>
            e(sd == 0u ? default_seed : sd);
        for (size_t k = 0; k < r; ++k) {
            if constexpr ((1 + (w - 1) / 32) == 1)
                x_[k] = static_cast<result_type>(e() & Max);
            else {
                result_type e0 = e();
                x_[k] = static_cast<result_type>((e0 + ((uint64_t)e() << 32)) & Max);
            }
        }
        c_ = (x_[r-1] == 0);
        i_ = 0;
    }

    template <class Sseq>
        requires is_seed_sequence_v<Sseq, subtract_with_carry_engine>
    void seed(Sseq& q) {
        const unsigned k = 1 + (w - 1) / 32;
        static_assert(k <= 2);
        uint32_t ar[r * k];
        q.generate(ar, ar + r * k);
        for (size_t j = 0; j < r; ++j) {
            if constexpr (k == 1)
                x_[j] = static_cast<result_type>(ar[j] & Max);
            else
                x_[j] = static_cast<result_type>(
                    (ar[2*j] + ((uint64_t)ar[2*j+1] << 32)) & Max);
        }
        c_ = (x_[r-1] == 0);
        i_ = 0;
    }

    result_type operator()() {
        const result_type& xs = x_[(i_ + (r - s)) % r];
        result_type& xr       = x_[i_];
        result_type new_c     = (c_ == 0) ? (xs < xr) : (xs != 0 ? xs <= xr : 1);
        xr                    = (xs - xr - c_) & Max;
        c_                    = new_c;
        i_                    = (i_ + 1) % r;
        return xr;
    }
    void discard(unsigned long long z) {
        for (; z; --z) operator()();
    }

    friend bool operator==(const subtract_with_carry_engine& lhs,
                           const subtract_with_carry_engine& rhs) {
        if (lhs.c_ != rhs.c_) return false;
        if (lhs.i_ == rhs.i_)
            return std::equal(lhs.x_, lhs.x_ + r, rhs.x_);
        if (lhs.i_ == 0 || rhs.i_ == 0) {
            size_t j = std::min(r - lhs.i_, r - rhs.i_);
            if (!std::equal(lhs.x_ + lhs.i_, lhs.x_ + lhs.i_ + j, rhs.x_ + rhs.i_))
                return false;
            if (lhs.i_ == 0)
                return std::equal(lhs.x_ + j, lhs.x_ + r, rhs.x_);
            return std::equal(lhs.x_, lhs.x_ + (r - j), rhs.x_ + j);
        }
        if (lhs.i_ < rhs.i_) {
            size_t j = r - rhs.i_;
            if (!std::equal(lhs.x_ + lhs.i_, lhs.x_ + lhs.i_ + j, rhs.x_ + rhs.i_))
                return false;
            if (!std::equal(lhs.x_ + lhs.i_ + j, lhs.x_ + r, rhs.x_))
                return false;
            return std::equal(lhs.x_, lhs.x_ + lhs.i_, rhs.x_ + (r - (lhs.i_ + j)));
        }
        size_t j = r - lhs.i_;
        if (!std::equal(rhs.x_ + rhs.i_, rhs.x_ + rhs.i_ + j, lhs.x_ + lhs.i_))
            return false;
        if (!std::equal(rhs.x_ + rhs.i_ + j, rhs.x_ + r, lhs.x_))
            return false;
        return std::equal(rhs.x_, rhs.x_ + rhs.i_, lhs.x_ + (r - (rhs.i_ + j)));
    }
    friend bool operator!=(const subtract_with_carry_engine& lhs,
                           const subtract_with_carry_engine& rhs) {
        return !(lhs == rhs);
    }
};

