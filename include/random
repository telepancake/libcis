class random_device {
    int fd_;

public:
    typedef unsigned result_type;

    static constexpr result_type min() { return 0; }
    static constexpr result_type max() { return 0xFFFFFFFFu; }

    random_device() {
        fd_ = ::open("/dev/urandom", O_RDONLY);
        if (fd_ < 0) __builtin_trap();
    }
    explicit random_device(const char* /*token*/) : random_device() {}
    ~random_device() { if (fd_ >= 0) ::close(fd_); }

